'''
Test whether the website can be accessed through local port 5000.
Specifically, test if the first page of the website ("/") is accessible and returns HTTP 302 redirect to "/dashboard".
'''
import unittest
from main import app
class TestWebsiteAccess(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_index_redirects_to_dashboard(self):
        # Access the root URL
        response = self.client.get('/')
        # The root URL should redirect to /dashboard
        self.assertEqual(response.status_code, 302)
        self.assertIn('/dashboard', response.headers['Location'])
    def test_dashboard_accessible(self):
        # Access the dashboard page directly
        response = self.client.get('/dashboard')
        # The dashboard page should be accessible with status code 200
        self.assertEqual(response.status_code, 200)
        # The response data should contain the welcome message for user 'john'
        self.assertIn(b'Welcome, john!', response.data)
if __name__ == '__main__':
    unittest.main()

test_requirement_1.py:
'''
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Specifically:
- Test that the root URL '/' redirects to '/dashboard'.
- Test that the '/dashboard' page loads successfully (status code 200).
- Test that the dashboard page contains expected elements such as welcome message with username, quick stats, create article button, and recent activity section.
- Test that the "Create Article" button link navigates to '/article/create'.
'''
import unittest
from main import app
class ContentPublishingHubBasicNavigationTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_root_redirects_to_dashboard(self):
        response = self.client.get('/')
        self.assertEqual(response.status_code, 302)
        self.assertIn('/dashboard', response.headers['Location'])
    def test_dashboard_page_loads(self):
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        html = response.get_data(as_text=True)
        # Check welcome message with username 'john'
        self.assertIn('Welcome, john!', html)
        # Check quick stats section id
        self.assertIn('id="quick-stats"', html)
        # Check create article button id and link
        self.assertIn('id="create-article-button"', html)
        self.assertIn('href="/article/create"', html)
        # Check recent activity section id
        self.assertIn('id="recent-activity"', html)
    def test_create_article_navigation_link(self):
        # Get dashboard page
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        html = response.get_data(as_text=True)
        # Extract the create article button href and test navigation
        # Since href is static, just test that /article/create loads
        create_article_response = self.client.get('/article/create')
        self.assertEqual(create_article_response.status_code, 200)
        create_article_html = create_article_response.get_data(as_text=True)
        # Check that create article page container is present
        self.assertIn('id="create-article-page"', create_article_html)
if __name__ == '__main__':
    unittest.main()

