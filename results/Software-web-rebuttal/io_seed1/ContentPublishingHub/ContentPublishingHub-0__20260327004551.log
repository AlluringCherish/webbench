'''
Main Flask application for ContentPublishingHub.
Implements all backend routes, data handling, version control,
content scheduling, analytics, and collaborative content creation.
Data is stored in plain text files under the 'data' directory.
'''
import os
import datetime
from flask import Flask, render_template, request, redirect, url_for, flash, session, abort
from werkzeug.utils import secure_filename
from collections import defaultdict
app = Flask(__name__)
app.secret_key = 'supersecretkey'  # For session management and flash messages
DATA_DIR = 'data'
# Helper functions for reading and writing data files
def read_users():
    users = {}
    path = os.path.join(DATA_DIR, 'users.txt')
    if not os.path.exists(path):
        return users
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            username, email, fullname, created_date = line.split('|')
            users[username] = {
                'username': username,
                'email': email,
                'fullname': fullname,
                'created_date': created_date
            }
    return users
def read_articles():
    articles = {}
    path = os.path.join(DATA_DIR, 'articles.txt')
    if not os.path.exists(path):
        return articles
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 10:
                continue
            article_id, title, author, category, status, tags, featured_image, meta_description, created_date, publish_date = parts
            articles[int(article_id)] = {
                'article_id': int(article_id),
                'title': title,
                'author': author,
                'category': category,
                'status': status,
                'tags': tags.split(',') if tags else [],
                'featured_image': featured_image,
                'meta_description': meta_description,
                'created_date': created_date,
                'publish_date': publish_date if publish_date else None
            }
    return articles
def write_articles(articles):
    path = os.path.join(DATA_DIR, 'articles.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for article_id in sorted(articles.keys()):
            a = articles[article_id]
            tags_str = ','.join(a['tags']) if a['tags'] else ''
            publish_date = a['publish_date'] if a['publish_date'] else ''
            line = f"{a['article_id']}|{a['title']}|{a['author']}|{a['category']}|{a['status']}|{tags_str}|{a['featured_image']}|{a['meta_description']}|{a['created_date']}|{publish_date}\n"
            f.write(line)
def read_article_versions():
    versions = defaultdict(list)  # article_id -> list of versions sorted by version_number
    path = os.path.join(DATA_DIR, 'article_versions.txt')
    if not os.path.exists(path):
        return versions
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|', 6)
            if len(parts) != 7:
                continue
            version_id, article_id, version_number, content, author, created_date, change_summary = parts
            version = {
                'version_id': int(version_id),
                'article_id': int(article_id),
                'version_number': int(version_number),
                'content': content,
                'author': author,
                'created_date': created_date,
                'change_summary': change_summary
            }
            versions[int(article_id)].append(version)
    # Sort versions by version_number ascending
    for article_id in versions:
        versions[article_id].sort(key=lambda v: v['version_number'])
    return versions
def write_article_versions(versions):
    path = os.path.join(DATA_DIR, 'article_versions.txt')
    all_versions = []
    for article_id in versions:
        all_versions.extend(versions[article_id])
    all_versions.sort(key=lambda v: v['version_id'])
    with open(path, 'w', encoding='utf-8') as f:
        for v in all_versions:
            line = f"{v['version_id']}|{v['article_id']}|{v['version_number']}|{v['content']}|{v['author']}|{v['created_date']}|{v['change_summary']}\n"
            f.write(line)
def read_approvals():
    approvals = []
    path = os.path.join(DATA_DIR, 'approvals.txt')
    if not os.path.exists(path):
        return approvals
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|', 6)
            if len(parts) != 7:
                continue
            approval_id, article_id, version_id, approver, status, comments, timestamp = parts
            approvals.append({
                'approval_id': int(approval_id),
                'article_id': int(article_id),
                'version_id': int(version_id),
                'approver': approver,
                'status': status,
                'comments': comments,
                'timestamp': timestamp
            })
    return approvals
def write_approvals(approvals):
    path = os.path.join(DATA_DIR, 'approvals.txt')
    approvals.sort(key=lambda a: a['approval_id'])
    with open(path, 'w', encoding='utf-8') as f:
        for a in approvals:
            line = f"{a['approval_id']}|{a['article_id']}|{a['version_id']}|{a['approver']}|{a['status']}|{a['comments']}|{a['timestamp']}\n"
            f.write(line)
def read_workflow_stages():
    stages = []
    path = os.path.join(DATA_DIR, 'workflow_stages.txt')
    if not os.path.exists(path):
        return stages
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 5:
                continue
            stage_id, category, stage_name, stage_order, is_required = parts
            stages.append({
                'stage_id': int(stage_id),
                'category': category,
                'stage_name': stage_name,
                'stage_order': int(stage_order),
                'is_required': is_required.lower() == 'yes'
            })
    return stages
def read_comments():
    comments = []
    path = os.path.join(DATA_DIR, 'comments.txt')
    if not os.path.exists(path):
        return comments
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|', 5)
            if len(parts) != 6:
                continue
            comment_id, article_id, version_id, user, comment_text, timestamp = parts
            comments.append({
                'comment_id': int(comment_id),
                'article_id': int(article_id),
                'version_id': int(version_id),
                'user': user,
                'comment_text': comment_text,
                'timestamp': timestamp
            })
    return comments
def write_comments(comments):
    path = os.path.join(DATA_DIR, 'comments.txt')
    comments.sort(key=lambda c: c['comment_id'])
    with open(path, 'w', encoding='utf-8') as f:
        for c in comments:
            line = f"{c['comment_id']}|{c['article_id']}|{c['version_id']}|{c['user']}|{c['comment_text']}|{c['timestamp']}\n"
            f.write(line)
def read_analytics():
    analytics = []
    path = os.path.join(DATA_DIR, 'analytics.txt')
    if not os.path.exists(path):
        return analytics
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 7:
                continue
            analytics_id, article_id, date, views, unique_visitors, avg_time_seconds, shares = parts
            analytics.append({
                'analytics_id': int(analytics_id),
                'article_id': int(article_id),
                'date': date,
                'views': int(views),
                'unique_visitors': int(unique_visitors),
                'avg_time_seconds': int(avg_time_seconds),
                'shares': int(shares)
            })
    return analytics
def write_analytics(analytics):
    path = os.path.join(DATA_DIR, 'analytics.txt')
    analytics.sort(key=lambda a: a['analytics_id'])
    with open(path, 'w', encoding='utf-8') as f:
        for a in analytics:
            line = f"{a['analytics_id']}|{a['article_id']}|{a['date']}|{a['views']}|{a['unique_visitors']}|{a['avg_time_seconds']}|{a['shares']}\n"
            f.write(line)
# Utility functions
def get_next_article_id(articles):
    if not articles:
        return 1
    return max(articles.keys()) + 1
def get_next_version_id(versions):
    max_id = 0
    for vlist in versions.values():
        for v in vlist:
            if v['version_id'] > max_id:
                max_id = v['version_id']
    return max_id + 1
def get_next_approval_id(approvals):
    if not approvals:
        return 1
    return max(a['approval_id'] for a in approvals) + 1
def get_next_comment_id(comments):
    if not comments:
        return 1
    return max(c['comment_id'] for c in comments) + 1
def get_next_analytics_id(analytics):
    if not analytics:
        return 1
    return max(a['analytics_id'] for a in analytics) + 1
def current_datetime_str():
    return datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
def current_date_str():
    return datetime.datetime.now().strftime('%Y-%m-%d')
# For simplicity, simulate a logged-in user (in real app, implement auth)
def get_logged_in_username():
    # For testing, default to 'john'
    # In real app, use session or login manager
    return session.get('username', 'john')
# Routes
@app.route('/')
def index():
    return redirect(url_for('dashboard'))
@app.route('/dashboard')
def dashboard():
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    articles = read_articles()
    versions = read_article_versions()
    approvals = read_approvals()
    comments = read_comments()
    analytics = read_analytics()
    # Quick stats: total articles, published articles, drafts, total views (all articles by user)
    user_articles = [a for a in articles.values() if a['author'] == username]
    total_articles = len(user_articles)
    published_articles = len([a for a in user_articles if a['status'] == 'published'])
    draft_articles = len([a for a in user_articles if a['status'] == 'draft'])
    # Total views for user's published articles (sum of views in analytics)
    user_article_ids = [a['article_id'] for a in user_articles if a['status'] == 'published']
    total_views = sum(a['views'] for a in analytics if a['article_id'] in user_article_ids)
    # Recent activity feed: last 5 comments or approvals on user's articles, sorted by timestamp desc
    recent_activities = []
    for c in comments:
        if c['article_id'] in user_article_ids:
            recent_activities.append({
                'type': 'comment',
                'user': c['user'],
                'article_id': c['article_id'],
                'version_id': c['version_id'],
                'text': c['comment_text'],
                'timestamp': c['timestamp']
            })
    for a in approvals:
        if a['article_id'] in user_article_ids:
            recent_activities.append({
                'type': 'approval',
                'user': a['approver'],
                'article_id': a['article_id'],
                'version_id': a['version_id'],
                'status': a['status'],
                'comments': a['comments'],
                'timestamp': a['timestamp']
            })
    recent_activities.sort(key=lambda x: x['timestamp'], reverse=True)
    recent_activities = recent_activities[:5]
    return render_template('dashboard.html',
                           username=username,
                           quick_stats={
                               'total_articles': total_articles,
                               'published_articles': published_articles,
                               'draft_articles': draft_articles,
                               'total_views': total_views
                           },
                           recent_activity=recent_activities)
@app.route('/article/create', methods=['GET', 'POST'])
def create_article():
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    if request.method == 'POST':
        title = request.form.get('article-title', '').strip()
        content = request.form.get('article-content', '').strip()
        if not title:
            flash('Article title is required.', 'error')
            return render_template('create_article.html')
        if not content:
            flash('Article content is required.', 'error')
            return render_template('create_article.html')
        articles = read_articles()
        article_versions = read_article_versions()
        new_article_id = get_next_article_id(articles)
        created_date = current_date_str()
        # Default category, tags, featured_image, meta_description can be empty or set later
        new_article = {
            'article_id': new_article_id,
            'title': title,
            'author': username,
            'category': '',
            'status': 'draft',
            'tags': [],
            'featured_image': '',
            'meta_description': '',
            'created_date': created_date,
            'publish_date': None
        }
        articles[new_article_id] = new_article
        write_articles(articles)
        # Create initial version
        new_version_id = get_next_version_id(article_versions)
        version = {
            'version_id': new_version_id,
            'article_id': new_article_id,
            'version_number': 1,
            'content': content,
            'author': username,
            'created_date': current_datetime_str(),
            'change_summary': 'Initial draft'
        }
        article_versions[new_article_id].append(version)
        write_article_versions(article_versions)
        flash('Article draft created successfully.', 'success')
        return redirect(url_for('edit_article', article_id=new_article_id))
    return render_template('create_article.html')
@app.route('/article/<int:article_id>/edit', methods=['GET', 'POST'])
def edit_article(article_id):
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    articles = read_articles()
    if article_id not in articles:
        abort(404)
    article = articles[article_id]
    if article['author'] != username:
        abort(403)
    article_versions = read_article_versions()
    versions = article_versions.get(article_id, [])
    if not versions:
        # No versions exist, create initial version with empty content
        versions = []
    latest_version = versions[-1] if versions else None
    if request.method == 'POST':
        title = request.form.get('edit-article-title', '').strip()
        content = request.form.get('edit-article-content', '').strip()
        change_summary = request.form.get('change-summary', '').strip()
        if not title:
            flash('Article title is required.', 'error')
            return render_template('edit_article.html', article=article, content=latest_version['content'] if latest_version else '', versions=versions)
        if not content:
            flash('Article content is required.', 'error')
            return render_template('edit_article.html', article=article, content=latest_version['content'] if latest_version else '', versions=versions)
        if not change_summary:
            change_summary = 'Updated content'
        # Update article title
        article['title'] = title
        articles[article_id] = article
        write_articles(articles)
        # Add new version
        new_version_id = get_next_version_id(article_versions)
        new_version_number = (versions[-1]['version_number'] + 1) if versions else 1
        new_version = {
            'version_id': new_version_id,
            'article_id': article_id,
            'version_number': new_version_number,
            'content': content,
            'author': username,
            'created_date': current_datetime_str(),
            'change_summary': change_summary
        }
        article_versions[article_id].append(new_version)
        write_article_versions(article_versions)
        flash('New version saved successfully.', 'success')
        return redirect(url_for('edit_article', article_id=article_id))
    # GET request
    content = latest_version['content'] if latest_version else ''
    return render_template('edit_article.html', article=article, content=content, versions=versions)
@app.route('/article/<int:article_id>/versions', methods=['GET', 'POST'])
def version_history(article_id):
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    articles = read_articles()
    if article_id not in articles:
        abort(404)
    article = articles[article_id]
    if article['author'] != username:
        abort(403)
    article_versions = read_article_versions()
    versions = article_versions.get(article_id, [])
    if not versions:
        flash('No versions found for this article.', 'info')
        return redirect(url_for('edit_article', article_id=article_id))
    # Handle restore version POST
    if request.method == 'POST':
        restore_version_id = request.form.get('restore_version_id')
        if not restore_version_id:
            flash('No version selected to restore.', 'error')
            return redirect(url_for('version_history', article_id=article_id))
        try:
            restore_version_id = int(restore_version_id)
        except ValueError:
            flash('Invalid version ID.', 'error')
            return redirect(url_for('version_history', article_id=article_id))
        # Find version to restore
        restore_version = None
        for v in versions:
            if v['version_id'] == restore_version_id:
                restore_version = v
                break
        if not restore_version:
            flash('Version not found.', 'error')
            return redirect(url_for('version_history', article_id=article_id))
        # Create a new version identical to the restored version but with new version number and id
        new_version_id = get_next_version_id(article_versions)
        new_version_number = versions[-1]['version_number'] + 1
        new_version = {
            'version_id': new_version_id,
            'article_id': article_id,
            'version_number': new_version_number,
            'content': restore_version['content'],
            'author': username,
            'created_date': current_datetime_str(),
            'change_summary': f"Restored version {restore_version['version_number']}"
        }
        article_versions[article_id].append(new_version)
        write_article_versions(article_versions)
        flash(f'Version {restore_version["version_number"]} restored as new version.', 'success')
        return redirect(url_for('edit_article', article_id=article_id))
    # GET request: show versions list and comparison
    # Optional: allow selecting two versions to compare via query params
    v1_id = request.args.get('v1', type=int)
    v2_id = request.args.get('v2', type=int)
    version_comparison = None
    if v1_id and v2_id:
        v1 = next((v for v in versions if v['version_id'] == v1_id), None)
        v2 = next((v for v in versions if v['version_id'] == v2_id), None)
        if v1 and v2:
            # Simple text diff for content (line by line)
            import difflib
            diff = difflib.unified_diff(
                v1['content'].splitlines(),
                v2['content'].splitlines(),
                fromfile=f'Version {v1["version_number"]}',
                tofile=f'Version {v2["version_number"]}',
                lineterm=''
            )
            version_comparison = '\n'.join(diff)
    return render_template('version_history.html',
                           article=article,
                           versions=versions,
                           version_comparison=version_comparison,
                           v1_id=v1_id,
                           v2_id=v2_id)
@app.route('/articles/mine', methods=['GET'])
def my_articles():
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    status_filter = request.args.get('status', '').strip().lower()
    articles = read_articles()
    user_articles = [a for a in articles.values() if a['author'] == username]
    if status_filter:
        user_articles = [a for a in user_articles if a['status'].lower() == status_filter]
    return render_template('my_articles.html',
                           articles=user_articles,
                           filter_status=status_filter)
@app.route('/articles/published', methods=['GET'])
def published_articles():
    category_filter = request.args.get('category', '').strip().lower()
    sort_by = request.args.get('sort', 'publish_date').strip().lower()
    articles = read_articles()
    published = [a for a in articles.values() if a['status'] == 'published']
    if category_filter:
        published = [a for a in published if a['category'].lower() == category_filter]
    # Sorting options: publish_date (default), title, author
    if sort_by == 'title':
        published.sort(key=lambda a: a['title'].lower())
    elif sort_by == 'author':
        published.sort(key=lambda a: a['author'].lower())
    else:
        # Default sort by publish_date descending
        published.sort(key=lambda a: a['publish_date'] or '', reverse=True)
    return render_template('published_articles.html',
                           articles=published,
                           filter_category=category_filter,
                           sort_by=sort_by)
@app.route('/calendar', methods=['GET', 'POST'])
def content_calendar():
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    articles = read_articles()
    # For calendar view selector, support 'month' or 'week' (default month)
    calendar_view = request.args.get('view', 'month')
    # Scheduled articles: those with publish_date set
    scheduled_articles = [a for a in articles.values() if a['publish_date']]
    if request.method == 'POST':
        # Schedule an article publication
        article_id = request.form.get('article_id')
        publish_date = request.form.get('publish_date')
        if not article_id or not publish_date:
            flash('Article and publish date are required to schedule.', 'error')
            return redirect(url_for('content_calendar', view=calendar_view))
        try:
            article_id = int(article_id)
        except ValueError:
            flash('Invalid article ID.', 'error')
            return redirect(url_for('content_calendar', view=calendar_view))
        if article_id not in articles:
            flash('Article not found.', 'error')
            return redirect(url_for('content_calendar', view=calendar_view))
        # Validate date format YYYY-MM-DD or YYYY-MM-DD HH:MM:SS
        try:
            if len(publish_date) == 10:
                datetime.datetime.strptime(publish_date, '%Y-%m-%d')
            else:
                datetime.datetime.strptime(publish_date, '%Y-%m-%d %H:%M:%S')
        except ValueError:
            flash('Invalid date format. Use YYYY-MM-DD or YYYY-MM-DD HH:MM:SS.', 'error')
            return redirect(url_for('content_calendar', view=calendar_view))
        # Update article publish_date and status if needed
        article = articles[article_id]
        article['publish_date'] = publish_date
        if article['status'] == 'draft':
            article['status'] = 'pending_review'
        articles[article_id] = article
        write_articles(articles)
        flash(f'Article "{article["title"]}" scheduled for publication on {publish_date}.', 'success')
        return redirect(url_for('content_calendar', view=calendar_view))
    return render_template('content_calendar.html',
                           calendar_view=calendar_view,
                           scheduled_articles=scheduled_articles,
                           user=username)
@app.route('/article/<int:article_id>/analytics')
def article_analytics(article_id):
    username = get_logged_in_username()
    users = read_users()
    if username not in users:
        abort(403)
    articles = read_articles()
    if article_id not in articles:
        abort(404)
    article = articles[article_id]
    # Only author or admin can view analytics
    if article['author'] != username and username != 'admin':
        abort(403)
    analytics = read_analytics()
    article_analytics = [a for a in analytics if a['article_id'] == article_id]
    # Aggregate overview
    total_views = sum(a['views'] for a in article_analytics)
    unique_visitors = sum(a['unique_visitors'] for a in article_analytics)
    avg_time_seconds = 0
    shares = sum(a['shares'] for a in article_analytics)
    if article_analytics:
        avg_time_seconds = int(sum(a['avg_time_seconds'] for a in article_analytics) / len(article_analytics))
    return render_template('article_analytics.html',
                           article=article,
                           analytics_overview=article_analytics,
                           total_views=total_views,
                           unique_visitors=unique_visitors,
                           avg_time_seconds=avg_time_seconds,
                           shares=shares)
# Additional routes for navigation buttons
