'''
Test the elements and integrity of all pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class ContentPublishingHubPageElementsTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_page_elements(self):
        """Test /dashboard page elements presence and correctness"""
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check page container
        container = soup.find(id='dashboard-page')
        self.assertIsNotNone(container, "Dashboard page container not found")

        # Check welcome message with username
        welcome = soup.find(id='welcome-message')
        self.assertIsNotNone(welcome, "Welcome message not found")
        self.assertIn("Welcome,", welcome.text)

        # Check quick stats section
        quick_stats = soup.find(id='quick-stats')
        self.assertIsNotNone(quick_stats, "Quick stats section not found")
        # Check that quick stats contains required list items
        stats_items = quick_stats.find_all('li')
        stats_texts = [li.text for li in stats_items]
        self.assertTrue(any("Total Articles:" in text for text in stats_texts), "Total Articles stat missing")
        self.assertTrue(any("Published Articles:" in text for text in stats_texts), "Published Articles stat missing")
        self.assertTrue(any("Draft Articles:" in text for text in stats_texts), "Draft Articles stat missing")
        self.assertTrue(any("Total Views:" in text for text in stats_texts), "Total Views stat missing")

        # Check Create Article button
        create_button = soup.find(id='create-article-button')
        self.assertIsNotNone(create_button, "Create Article button not found")
        self.assertEqual(create_button.name, 'a')
        self.assertIn('href', create_button.attrs)
        self.assertTrue(create_button['href'].endswith('/article/create'))

        # Check recent activity feed
        recent_activity = soup.find(id='recent-activity')
        self.assertIsNotNone(recent_activity, "Recent activity feed not found")
        # It should contain either a list or a paragraph "No recent activity."
        ul = recent_activity.find('ul')
        p = recent_activity.find('p')
        self.assertTrue(ul is not None or (p is not None and "No recent activity" in p.text),
                        "Recent activity feed should have a list or no activity message")

    def test_create_article_page_elements(self):
        """Test /article/create page elements presence and correctness"""
        response = self.client.get('/article/create')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        container = soup.find(id='create-article-page')
