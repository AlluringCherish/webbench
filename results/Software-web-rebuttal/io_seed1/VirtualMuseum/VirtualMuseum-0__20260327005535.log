visitor_tickets.html
```html
'''
Visitor Tickets page template.
Allows visitors to purchase tickets and view their purchased tickets.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Visitor Tickets</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="visitor-tickets-page">
        <h1>Visitor Tickets</h1>
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <ul class="flashes">
              {% for category, message in messages %}
                <li class="{{ category }}">{{ message }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endwith %}
        <form method="post" action="{{ url_for('visitor_tickets') }}">
            <label for="ticket-type">Ticket Type:</label>
            <select id="ticket-type" name="ticket-type" required>
                <option value="">Select Ticket Type</option>
                <option value="Standard">Standard</option>
                <option value="Student">Student</option>
                <option value="Senior">Senior</option>
                <option value="Family">Family</option>
                <option value="VIP">VIP</option>
            </select><br><br>
            <label for="number-of-tickets">Number of Tickets:</label>
            <input type="number" id="number-of-tickets" name="number-of-tickets" min="1" required><br><br>
            <label for="visitor-name">Visitor Name:</label>
            <input type="text" id="visitor-name" name="visitor-name" required><br><br>
            <label for="visitor-email">Visitor Email:</label>
            <input type="email" id="visitor-email" name="visitor-email" required><br><br>
            <label for="visit-date">Visit Date:</label>
            <input type="date" id="visit-date" name="visit-date" required><br><br>
            <label for="visit-time">Visit Time:</label>
            <input type="time" id="visit-time" name="visit-time" required><br><br>
            <button type="submit" id="purchase-ticket-button">Purchase Ticket</button>
        </form>
        <h2>My Tickets</h2>
        <table id="my-tickets-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Ticket Type</th>
                    <th>Visit Date</th>
                    <th>Visit Time</th>
                    <th>Number of Tickets</th>
                    <th>Price</th>
                    <th>Visitor Name</th>
                    <th>Visitor Email</th>
                    <th>Purchase Date</th>
                </tr>
            </thead>
            <tbody>
                {% for ticket in tickets %}
                <tr>
                    <td>{{ ticket.ticket_id }}</td>
                    <td>{{ ticket.ticket_type }}</td>
                    <td>{{ ticket.visit_date }}</td>
                    <td>{{ ticket.visit_time }}</td>
                    <td>{{ ticket.number_of_tickets }}</td>
                    <td>{{ "%.2f"|format(ticket.price) }}</td>
                    <td>{{ ticket.visitor_name }}</td>
                    <td>{{ ticket.visitor_email }}</td>
                    <td>{{ ticket.purchase_date }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9">No tickets purchased yet.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

