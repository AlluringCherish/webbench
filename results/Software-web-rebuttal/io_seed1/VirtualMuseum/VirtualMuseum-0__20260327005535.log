<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Virtual Events</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="virtual-events-page">
        <h1>Virtual Events</h1>
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <ul class="flashes">
              {% for category, message in messages %}
                <li class="{{ category }}">{{ message }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endwith %}
        <table id="event-list" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Type</th>
                    <th>Registration Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for event in events %}
                <tr>
                    <td>{{ event.title }}</td>
                    <td>{{ event.date }}</td>
                    <td>{{ event.time }}</td>
                    <td>{{ event.event_type }}</td>
                    <td>{{ event.registration_status }}</td>
                    <td>
                        {% if event.registration_status == 'Not Registered' %}
                        <form method="post" action="{{ url_for('virtual_events') }}" style="display:inline;">
                            <input type="hidden" name="action" value="register">
                            <input type="hidden" name="event_id" value="{{ event.event_id }}">
                            <button type="submit" id="register-event-button-{{ event.event_id }}">Register</button>
                        </form>
                        {% else %}
                        <form method="post" action="{{ url_for('virtual_events') }}" style="display:inline;">
                            <input type="hidden" name="action" value="cancel">
                            <input type="hidden" name="registration_id" value="{{ event.registration_id }}">
                            <button type="submit" id="cancel-registration-button-{{ event.registration_id }}">Cancel Registration</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6">No events found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
