                <option value="All" {% if filter_language == 'All' or filter_language == '' %}selected{% endif %}>All</option>
                <option value="English" {% if filter_language == 'English' %}selected{% endif %}>English</option>
                <option value="Spanish" {% if filter_language == 'Spanish' %}selected{% endif %}>Spanish</option>
                <option value="French" {% if filter_language == 'French' %}selected{% endif %}>French</option>
            </select>
            <button type="submit" id="apply-language-filter">Apply Filter</button>
        </form>
        <table id="audio-guide-list" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Exhibit Number</th>
                    <th>Title</th>
                    <th>Language</th>
                    <th>Duration (min)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for guide in audio_guides %}
                <tr>
                    <td>{{ guide.exhibit_number }}</td>
                    <td>{{ guide.title }}</td>
                    <td>{{ guide.language }}</td>
                    <td>{{ guide.duration }}</td>
                    <td>
                        <!-- For demonstration, play button could trigger audio playback or show script -->
                        <button id="play-guide-button-{{ guide.guide_id }}" onclick="alert('Playing audio guide: {{ guide.title }}')">Play Guide</button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5">No audio guides found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
