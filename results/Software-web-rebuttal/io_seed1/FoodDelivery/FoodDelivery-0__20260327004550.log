        <input type="text" id="search-input" name="search" placeholder="Search by name or cuisine" value="{{ search_query }}">
        <select id="cuisine-filter" name="cuisine">
            <option value="All" {% if selected_cuisine == 'All' or selected_cuisine == '' %}selected{% endif %}>All Cuisines</option>
            {% for cuisine in cuisines %}
                <option value="{{ cuisine }}" {% if selected_cuisine == cuisine %}selected{% endif %}>{{ cuisine }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="restaurants-grid">
        {% if restaurants %}
            <ul>
                {% for restaurant in restaurants %}
                    <li>
                        <div class="restaurant-card">
                            <!-- Placeholder for logo image if available -->
                            <div class="restaurant-logo">
                                <img src="{{ url_for('static', filename='images/restaurants/' + restaurant.restaurant_id + '.png') }}" alt="{{ restaurant.name }} Logo" onerror="this.style.display='none'">
                            </div>
