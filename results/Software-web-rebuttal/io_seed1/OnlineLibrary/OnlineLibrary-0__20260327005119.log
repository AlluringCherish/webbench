}
a:hover {
    text-decoration: underline;
}
/* Container for pages */
div[id$='-page'] {
    max-width: 960px;
    margin: 2rem auto;
    padding: 1rem 2rem;
    background-color: #fff;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
