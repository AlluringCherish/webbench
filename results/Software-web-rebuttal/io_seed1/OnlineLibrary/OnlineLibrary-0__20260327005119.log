    transition: background-color 0.3s ease;
}
button:hover, button:focus {
    background-color: #0056b3;
    outline: none;
}
button:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
}
/* Forms */
form {
    margin-top: 1rem;
}
input[type="text"],
input[type="email"],
input[type="search"],
select,
textarea {
    width: 100%;
