    ensure_data_file('reservations.txt', EXAMPLE_RESERVATIONS)
    ensure_data_file('reviews.txt', EXAMPLE_REVIEWS)
    ensure_data_file('fines.txt', EXAMPLE_FINES)
    app.run(port=5000, debug=True)
