}
.book-status {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #444;
}
.book-rating {
    font-size: 0.9rem;
    color: #666;
}
/* Featured Books Grid */
#featured-books-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}
/* Book Grid on Catalog Page */
#book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
}
/* Reviews Section */
#reviews-section {
    margin-top: 1.5rem;
