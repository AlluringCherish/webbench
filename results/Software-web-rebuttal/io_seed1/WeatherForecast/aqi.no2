<!DOCTYPE html>
lang="en">
<head>
rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
<body>
<h1>Saved Locations</h1>
{% if saved_locations %}
<thead>
<th>Weather
{% for sl in saved_locations %}
<td>
{% if sl.temperature is not none %}
{{ sl.temperature }}
{% else %}
{% endif %}
</td>
<td>{{ sl.condition if sl.condition else 'N/A' }}</td>
id="view-location-weather-{{ sl.location_id }}"
<form action="{{ url_for('remove_location', saved_id=sl.saved_id) }}"
</form>
{% endfor %}
{% else %}
<p>No
{% endif %}
<button id="add-new-location-button"