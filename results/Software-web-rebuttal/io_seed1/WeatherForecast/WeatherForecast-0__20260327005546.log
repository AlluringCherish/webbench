'''
Weekly Forecast Page Template for WeatherForecast Web Application.
Displays 7-day weather forecast with location filter dropdown.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weekly Forecast</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="forecast-page">
        <h1>Weekly Forecast</h1>
        <form method="post" id="forecast-filter-form">
            <label for="location-filter">Select Location:</label>
            <select id="location-filter" name="location-filter" onchange="this.form.submit()">
                <option value="">-- Select Location --</option>
                {% for loc in locations %}
                    <option value="{{ loc.location_id }}" {% if loc.location_id == selected_location_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>
        {% if forecasts %}
            <table id="forecast-table" cellpadding="5" cellspacing="0" border="1">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>High Temp (°{{ temperature_unit[0] }})</th>
                        <th>Low Temp (°{{ temperature_unit[0] }})</th>
                        <th>Condition</th>
                        <th>Precipitation (%)</th>
                        <th>Humidity (%)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for f in forecasts %}
                    <tr class="forecast-card">
                        <td>{{ f.date }}</td>
                        <td>{{ f.high_temp_converted }}</td>
                        <td>{{ f.low_temp_converted }}</td>
                        <td>{{ f.condition }}</td>
                        <td>{{ f.precipitation }}</td>
                        <td>{{ f.humidity }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>No forecast data available for selected location.</p>
        {% endif %}
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button id="back-to-dashboard" type="submit">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/location_search.html
```html
'''
Location Search Page Template for WeatherForecast Web Application.
Allows users to search locations by city name or coordinates and select locations to save.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Locations</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="search-page">
        <h1>Search Locations</h1>
        <form method="post" action="{{ url_for('location_search') }}">
            <input type="text" id="location-search-input" name="location-search-input" placeholder="Enter city name or coordinates (lat,lon)" value="{{ query }}">
            <button type="submit">Search</button>
        </form>
        {% if search_results %}
            <h2>Search Results</h2>
            <ul id="search-results">
                {% for loc in search_results %}
                <li>
                    {{ loc.location_name }} ({{ loc.latitude }}, {{ loc.longitude }})
                    <form method="post" action="{{ url_for('select_location', location_id=loc.location_id) }}" style="display:inline;">
                        <button id="select-location-button-{{ loc.location_id }}" type="submit">Select Location</button>
                    </form>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            {% if query %}
                <p>No locations found matching "{{ query }}".</p>
            {% endif %}
        {% endif %}
        {% if saved_locations %}
            <h2>Saved Locations</h2>
            <ul id="saved-locations-list">
                {% for sl in saved_locations %}
                <li>{{ sl.location_name }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No saved locations.</p>
        {% endif %}
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button type="submit">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/weather_alerts.html
```html
'''
Weather Alerts Page Template for WeatherForecast Web Application.
Displays active weather alerts with filters and acknowledge buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Alerts</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="alerts-page">
        <h1>Weather Alerts</h1>
        <form method="post" action="{{ url_for('weather_alerts') }}">
            <label for="severity-filter">Filter by Severity:</label>
            <select id="severity-filter" name="severity-filter" onchange="this.form.submit()">
                <option value="All" {% if severity_filter == 'All' %}selected{% endif %}>All</option>
                <option value="Critical" {% if severity_filter == 'Critical' %}selected{% endif %}>Critical</option>
                <option value="High" {% if severity_filter == 'High' %}selected{% endif %}>High</option>
                <option value="Medium" {% if severity_filter == 'Medium' %}selected{% endif %}>Medium</option>
                <option value="Low" {% if severity_filter == 'Low' %}selected{% endif %}>Low</option>
            </select>
            <label for="location-filter-alerts">Filter by Location:</label>
            <select id="location-filter-alerts" name="location-filter-alerts" onchange="this.form.submit()">
                <option value="All" {% if location_filter == 'All' %}selected{% endif %}>All</option>
                {% for loc in locations %}
                    <option value="{{ loc.location_id }}" {% if location_filter|int == loc.location_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>
        {% if alerts %}
            <div id="alerts-list">
                {% for alert in alerts %}
                    <div class="alert-item">
                        <strong>Severity:</strong> {{ alert.severity }}<br>
                        <strong>Location:</strong> {{ alert.location_name }}<br>
                        <strong>Type:</strong> {{ alert.alert_type }}<br>
                        <strong>Description:</strong> {{ alert.description }}<br>
                        <strong>Start Time:</strong> {{ alert.start_time }}<br>
                        <strong>End Time:</strong> {{ alert.end_time }}<br>
                        <form method="post" action="{{ url_for('acknowledge_alert', alert_id=alert.alert_id) }}">
                            <button id="acknowledge-alert-button-{{ alert.alert_id }}" type="submit">Acknowledge Alert</button>
                        </form>
                    </div>
                    <hr>
                {% endfor %}
            </div>
        {% else %}
            <p>No active weather alerts.</p>
        {% endif %}
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button type="submit">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/air_quality.html
```html
'''
Air Quality Page Template for WeatherForecast Web Application.
Displays air quality index and pollution details for selected location.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Air Quality Index</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="air-quality-page">
        <h1>Air Quality Index</h1>
        <form method="post" action="{{ url_for('air_quality') }}">
            <label for="location-aqi-filter">Select Location:</label>
            <select id="location-aqi-filter" name="location-aqi-filter" onchange="this.form.submit()">
                <option value="">-- Select Location --</option>
                {% for loc in locations %}
                    <option value="{{ loc.location_id }}" {% if loc.location_id == selected_location_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>
        {% if aqi %}
            <div id="aqi-display">
                <strong>AQI Index:</strong> {{ aqi.aqi_index }}
            </div>
            <div id="aqi-description">
                <strong>Description:</strong> {{ aqi_description }}
            </div>
            <table id="pollution-details" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>Pollutant</th>
                        <th>Value (µg/m³)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>PM2.5</td><td>{{ aqi.pm25 }}</td></tr>
                    <tr><td>PM10</td><td>{{ aqi.pm10 }}</td></tr>
                    <tr><td>NO2</td><td>{{ aqi.no2 }}</td></tr>
                    <tr><td>O3</td><td>{{ aqi.o3 }}</td></tr>
                </tbody>
            </table>
            <div id="health-recommendation">
                <strong>Health Recommendation:</strong> {{ health_recommendation }}
            </div>
            <div id="last-updated">
                Last Updated: {{ aqi.last_updated }}
            </div>
        {% else %}
            <p>No air quality data available for selected location.</p>
        {% endif %}
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button type="submit">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/saved_locations.html
```html
'''
Saved Locations Page Template for WeatherForecast Web Application.
Displays all saved locations with current temperature and weather condition.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Saved Locations</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="saved-locations-page">
        <h1>Saved Locations</h1>
        {% if saved_locations %}
            <table id="locations-table" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>Location Name</th>
                        <th>Temperature (°{{ temperature_unit[0] }})</th>
                        <th>Condition</th>
                        <th>Default</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for sl in saved_locations %}
                    <tr>
                        <td>{{ sl.location_name }}</td>
                        <td>
                            {% if sl.temperature is not none %}
                                {{ sl.temperature }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>{{ sl.condition if sl.condition else 'N/A' }}</td>
                        <td>{% if sl.is_default %}Yes{% else %}No{% endif %}</td>
                        <td>
                            <button id="view-location-weather-{{ sl.location_id }}" data-location-id="{{ sl.location_id }}" type="button">View Weather</button>
                            <form method="post" action="{{ url_for('remove_location', saved_id=sl.saved_id) }}" style="display:inline;">
                                <button id="remove-location-button-{{ sl.saved_id }}" data-saved-id="{{ sl.saved_id }}" type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>No saved locations.</p>
        {% endif %}
        <button id="add-new-location-button" type="button">Add New Location</button>
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button type="submit">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/settings.html
```html
'''
Settings Page Template for WeatherForecast Web Application.
Allows users to configure temperature units, notification preferences, and default location.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Settings</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="settings-page">
        <h1>Settings</h1>
        <form method="post" action="{{ url_for('settings') }}">
            <label for="temperature-unit-select">Temperature Unit:</label>
            <select id="temperature-unit-select" name="temperature-unit-select">
                <option value="Celsius" {% if settings.temperature_unit == 'Celsius' %}selected{% endif %}>Celsius</option>
                <option value="Fahrenheit" {% if settings.temperature_unit == 'Fahrenheit' %}selected{% endif %}>Fahrenheit</option>
                <option value="Kelvin" {% if settings.temperature_unit == 'Kelvin' %}selected{% endif %}>Kelvin</option>
            </select>
            <br><br>
            <label for="default-location-select">Default Location:</label>
            <select id="default-location-select" name="default-location-select">
                <option value="">-- Select Default Location --</option>
                {% for loc in locations %}
                    <option value="{{ loc.location_id }}" {% if settings.default_location_id == loc.location_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
            <br><br>
            <label for="alert-notifications-toggle">Enable Alert Notifications:</label>
            <input type="checkbox" id="alert-notifications-toggle" name="alert-notifications-toggle" {% if settings.alert_notifications_enabled %}checked{% endif %}>
            <br><br>
            <button id="save-settings-button" type="submit">Save Settings</button>
        </form>
        <form method="post" action="{{ url_for('back_to_dashboard') }}">
            <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
