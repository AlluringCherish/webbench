Displays current weather summary for default location and navigation buttons to other pages.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="dashboard-page">
        <h1>Weather Dashboard</h1>
        <div id="current-weather-summary">
            {% if current_weather %}
                <h2>{{ current_weather.location_name }}</h2>
                <div id="temperature-display">
                    Temperature: {{ current_weather.temperature_converted }} °{{ temperature_unit[0] }}
                </div>
