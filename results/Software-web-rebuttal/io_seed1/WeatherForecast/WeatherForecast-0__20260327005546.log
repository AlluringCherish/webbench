'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of ALL pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''
import unittest
from main import app
from bs4 import BeautifulSoup

class WeatherForecastTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_01_dashboard_accessible(self):
        # Test Task 1: Access dashboard page at root '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Weather Dashboard', response.data)

    def test_02_dashboard_elements(self):
        # Test Task 2 & 3: Dashboard page elements presence and correctness
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div missing")
        # Check current weather summary container
        current_weather_summary = dashboard_div.find('div', id='current-weather-summary')
        self.assertIsNotNone(current_weather_summary, "Current weather summary div missing")
        # Check buttons by id
        self.assertIsNotNone(dashboard_div.find('button', id='search-location-button'), "Search Locations button missing")
        self.assertIsNotNone(dashboard_div.find('button', id='view-forecast-button'), "View Weekly Forecast button missing")
        self.assertIsNotNone(dashboard_div.find('button', id='view-alerts-button'), "View Weather Alerts button missing")
        self.assertIsNotNone(dashboard_div.find('button', id='view-air-quality-button'), "View Air Quality button missing")
        self.assertIsNotNone(dashboard_div.find('button', id='saved-locations-button'), "Saved Locations button missing")
        self.assertIsNotNone(dashboard_div.find('button', id='settings-button'), "Settings button missing")

    def test_03_current_weather_page_elements(self):
        # Test Current Weather page for a valid location (use location_id=1 from example data)
        response = self.client.get('/current_weather/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='current-weather-page')
        self.assertIsNotNone(container, "Current weather page container missing")
        self.assertIsNotNone(container.find('h1', id='location-name'), "Location name h1 missing")
        self.assertIsNotNone(container.find('div', id='temperature-display'), "Temperature display div missing")
        self.assertIsNotNone(container.find('div', id='weather-condition'), "Weather condition div missing")
        self.assertIsNotNone(container.find('div', id='humidity-info'), "Humidity info div missing")
        self.assertIsNotNone(container.find('div', id='wind-speed-info'), "Wind speed info div missing")
        self.assertIsNotNone(container.find('button', id='back-to-dashboard'), "Back to Dashboard button missing")

    def test_04_weekly_forecast_page_elements(self):
        # Test Weekly Forecast page GET and POST with location filter
        response = self.client.get('/weekly_forecast')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='forecast-page')
        self.assertIsNotNone(container, "Forecast page container missing")
        self.assertIsNotNone(container.find('form', id='forecast-filter-form'), "Forecast filter form missing")
        self.assertIsNotNone(container.find('select', id='location-filter'), "Location filter dropdown missing")
        self.assertIsNotNone(container.find('table', id='forecast-table'), "Forecast table missing")
        self.assertIsNotNone(container.find('button', id='back-to-dashboard'), "Back to Dashboard button missing")

        # POST with location filter
        response_post = self.client.post('/weekly_forecast', data={'location-filter': '1'})
        self.assertEqual(response_post.status_code, 200)
        soup_post = BeautifulSoup(response_post.data, 'html.parser')
        self.assertIsNotNone(soup_post.find('table', id='forecast-table'), "Forecast table missing after POST")

    def test_05_location_search_page_elements(self):
        # Test Location Search page GET and POST
        response = self.client.get('/location_search')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='search-page')
        self.assertIsNotNone(container, "Search page container missing")
        self.assertIsNotNone(container.find('input', id='location-search-input'), "Location search input missing")
        self.assertIsNotNone(container.find('form'), "Search form missing")
        self.assertIsNotNone(container.find('button', type='submit'), "Search button missing")

        # POST search with a city name that exists (e.g. 'New York')
        response_post = self.client.post('/location_search', data={'location-search-input': 'New York'})
        self.assertEqual(response_post.status_code, 200)
        soup_post = BeautifulSoup(response_post.data, 'html.parser')
        search_results = soup_post.find('ul', id='search-results')
        self.assertIsNotNone(search_results, "Search results list missing after POST")
        self.assertTrue(any('New York' in li.text for li in search_results.find_all('li')), "Expected location 'New York' not found in search results")

    def test_06_weather_alerts_page_elements(self):
        # Test Weather Alerts page GET and POST filtering
        response = self.client.get('/weather_alerts')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='alerts-page')
        self.assertIsNotNone(container, "Alerts page container missing")
        self.assertIsNotNone(container.find('form'), "Alerts filter form missing")
        self.assertIsNotNone(container.find('select', id='severity-filter'), "Severity filter dropdown missing")
        self.assertIsNotNone(container.find('select', id='location-filter-alerts'), "Location filter dropdown missing")
        self.assertIsNotNone(container.find('div', id='alerts-list') or container.find('p'), "Alerts list or no alerts message missing")
        self.assertIsNotNone(container.find('button', type='submit'), "Back to Dashboard button missing")

        # POST filter by severity and location
        response_post = self.client.post('/weather_alerts', data={'severity-filter': 'High', 'location-filter-alerts': '1'})
        self.assertEqual(response_post.status_code, 200)
        soup_post = BeautifulSoup(response_post.data, 'html.parser')
        self.assertIsNotNone(soup_post.find('div', id='alerts-list') or soup_post.find('p'), "Alerts list or no alerts message missing after POST")

    def test_07_air_quality_page_elements(self):
        # Test Air Quality page GET and POST
        response = self.client.get('/air_quality')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='air-quality-page')
        self.assertIsNotNone(container, "Air quality page container missing")
        self.assertIsNotNone(container.find('form'), "Air quality filter form missing")
        self.assertIsNotNone(container.find('select', id='location-aqi-filter'), "Location AQI filter dropdown missing")
        # AQI display elements may or may not be present depending on data
        # Check for either AQI display or no data message
        self.assertTrue(container.find('div', id='aqi-display') or container.find('p'), "AQI display or no data message missing")
        self.assertIsNotNone(container.find('button', type='submit'), "Back to Dashboard button missing")

        # POST with location filter
        response_post = self.client.post('/air_quality', data={'location-aqi-filter': '1'})
        self.assertEqual(response_post.status_code, 200)
        soup_post = BeautifulSoup(response_post.data, 'html.parser')
        self.assertTrue(soup_post.find('div', id='aqi-display') or soup_post.find('p'), "AQI display or no data message missing after POST")

    def test_08_saved_locations_page_elements(self):
        # Test Saved Locations page GET
        response = self.client.get('/saved_locations')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='saved-locations-page')
        self.assertIsNotNone(container, "Saved locations page container missing")
        # Table or no saved locations message
        self.assertTrue(container.find('table', id='locations-table') or container.find('p'), "Locations table or no saved locations message missing")
        self.assertIsNotNone(container.find('button', id='add-new-location-button'), "Add New Location button missing")
        self.assertIsNotNone(container.find('button', id='back-to-dashboard'), "Back to Dashboard button missing")

    def test_09_settings_page_elements(self):
        # Test Settings page GET and POST
        response = self.client.get('/settings')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='settings-page')
        self.assertIsNotNone(container, "Settings page container missing")
        self.assertIsNotNone(container.find('form'), "Settings form missing")
        self.assertIsNotNone(container.find('select', id='temperature-unit-select'), "Temperature unit select missing")
        self.assertIsNotNone(container.find('select', id='default-location-select'), "Default location select missing")
        self.assertIsNotNone(container.find('input', id='alert-notifications-toggle'), "Alert notifications toggle missing")
        self.assertIsNotNone(container.find('button', id='save-settings-button'), "Save Settings button missing")
        self.assertIsNotNone(container.find('button', id='back-to-dashboard'), "Back to Dashboard button missing")

        # POST to update settings
        response_post = self.client.post('/settings', data={
            'temperature-unit-select': 'Fahrenheit',
            'default-location-select': '1',
            'alert-notifications-toggle': 'on'
        }, follow_redirects=True)
        self.assertEqual(response_post.status_code, 200)
        self.assertIn(b'Weather Dashboard', response_post.data)

if __name__ == '__main__':
    unittest.main()
