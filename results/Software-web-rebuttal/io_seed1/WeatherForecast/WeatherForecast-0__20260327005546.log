'''
Dashboard Page Template for WeatherForecast Web Application.
Displays current weather summary for default location and navigation buttons to other pages.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="dashboard-page">
        <h1>Weather Dashboard</h1>
        <div id="current-weather-summary">
            {% if current_weather %}
                <h2>{{ current_weather.location_name }}</h2>
                <div id="temperature-display">
                    Temperature: {{ current_weather.temperature_converted }} °{{ temperature_unit[0] }}
                </div>
                <div id="weather-condition">
                    Condition: {{ current_weather.condition }}
                </div>
                <div id="humidity-info">
                    Humidity: {{ current_weather.humidity }}%
                </div>
                <div id="wind-speed-info">
                    Wind Speed: {{ current_weather.wind_speed }} mph
                </div>
                <div id="last-updated">
                    Last Updated: {{ current_weather.last_updated }}
                </div>
            {% else %}
                <p>No current weather data available.</p>
            {% endif %}
        </div>
        <button id="search-location-button" type="button">Search Locations</button>
        <button id="view-forecast-button" type="button">View Weekly Forecast</button>
        <button id="view-alerts-button" type="button">View Weather Alerts</button>
        <button id="view-air-quality-button" type="button" onclick="window.location.href='{{ url_for('air_quality') }}'">View Air Quality</button>
        <button id="saved-locations-button" type="button" onclick="window.location.href='{{ url_for('saved_locations') }}'">Saved Locations</button>
        <button id="settings-button" type="button" onclick="window.location.href='{{ url_for('settings') }}'">Settings</button>
    </div>
</body>
</html>
