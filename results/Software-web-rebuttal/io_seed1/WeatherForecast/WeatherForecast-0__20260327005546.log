document.addEventListener('DOMContentLoaded', function () {
    // Dashboard page buttons
    const searchLocationButton = document.getElementById('search-location-button');
    if (searchLocationButton) {
        searchLocationButton.addEventListener('click', function () {
            window.location.href = '/location_search';
        });
    }

    const viewForecastButton = document.getElementById('view-forecast-button');
    if (viewForecastButton) {
        viewForecastButton.addEventListener('click', function () {
            window.location.href = '/weekly_forecast';
        });
    }

    const viewAlertsButton = document.getElementById('view-alerts-button');
    if (viewAlertsButton) {
        viewAlertsButton.addEventListener('click', function () {
            window.location.href = '/weather_alerts';
        });
    }

    // Weekly Forecast page: location filter dropdown
    const forecastLocationFilter = document.getElementById('location-filter');
    if (forecastLocationFilter) {
        forecastLocationFilter.addEventListener('change', function () {
            // Submit the form to filter forecasts by location
            const form = forecastLocationFilter.closest('form');
            if (form) {
                form.submit();
            }
        });
    }

    // Weather Alerts page: severity and location filters
    const severityFilter = document.getElementById('severity-filter');
    if (severityFilter) {
        severityFilter.addEventListener('change', function () {
            const form = severityFilter.closest('form');
            if (form) {
                form.submit();
            }
        });
    }

    const locationFilterAlerts = document.getElementById('location-filter-alerts');
    if (locationFilterAlerts) {
        locationFilterAlerts.addEventListener('change', function () {
            const form = locationFilterAlerts.closest('form');
            if (form) {
                form.submit();
            }
        });
    }

    // Air Quality page: location filter dropdown
    const aqiLocationFilter = document.getElementById('location-aqi-filter');
    if (aqiLocationFilter) {
        aqiLocationFilter.addEventListener('change', function () {
            const form = aqiLocationFilter.closest('form');
            if (form) {
                form.submit();
            }
        });
    }

    // Saved Locations page: add new location button
    const addNewLocationButton = document.getElementById('add-new-location-button');
    if (addNewLocationButton) {
        addNewLocationButton.addEventListener('click', function () {
            window.location.href = '/add_new_location';
        });
    }

    // Saved Locations page: view location weather buttons
    const viewLocationButtons = document.querySelectorAll('[id^="view-location-weather-"]');
    viewLocationButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            const locationId = this.getAttribute('data-location-id');
            if (locationId) {
                window.location.href = '/current_weather/' + locationId;
            }
        });
    });

    // Saved Locations page: remove location buttons
    const removeLocationButtons = document.querySelectorAll('[id^="remove-location-button-"]');
    removeLocationButtons.forEach(function (button) {
        button.addEventListener('click', function (event) {
            event.preventDefault();
            const savedId = this.getAttribute('data-saved-id');
            if (savedId) {
                // Submit a form to remove location
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/remove_location/' + savedId;
                document.body.appendChild(form);
                form.submit();
            }
        });
    });

    // Settings page: back to dashboard button
    const backToDashboardButtons = document.querySelectorAll('#back-to-dashboard');
    backToDashboardButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            // Submit a POST request to back_to_dashboard route
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/back_to_dashboard';
            document.body.appendChild(form);
            form.submit();
        });
    });
});
