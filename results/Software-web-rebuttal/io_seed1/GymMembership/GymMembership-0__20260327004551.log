templates/trainer_detail.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trainer Profile</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="trainer-detail-page">
    <h1 id="trainer-name">{{ trainer.name }}</h1>
    <div id="trainer-bio">
        <strong>Biography:</strong>
        <p>{{ trainer.bio }}</p>
    </div>
    <div id="trainer-certifications">
        <strong>Certifications:</strong>
        <p>{{ trainer.certifications }}</p>
    </div>
    <div id="trainer-experience">
        <strong>Experience:</strong> {{ trainer.experience_years }} years
    </div>

    <form method="post" action="{{ url_for('trainer_detail', trainer_id=trainer.trainer_id) }}">
        <button id="book-session-button" type="submit">Book a Session</button>
    </form>

    <div id="trainer-reviews">
        <h3>Client Reviews</h3>
        {% if trainer_reviews %}
            <ul>
                {% for review in trainer_reviews %}
                <li>{{ review }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No reviews available.</p>
        {% endif %}
    </div>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/pt_booking.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Personal Training</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="booking-page">
    <h1>Book Personal Training</h1>

    {% if error %}
    <div class="error-message" style="color:red;">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ url_for('pt_booking') }}">
        <label for="member_name">Your Name:</label><br>
        <input type="text" id="member_name" name="member_name" value="{{ form_data.member_name if form_data else '' }}" required><br><br>

        <label for="select-trainer">Select Trainer:</label><br>
        <select id="select-trainer" name="select_trainer" required>
            <option value="">-- Select Trainer --</option>
            {% for trainer in trainers %}
            <option value="{{ trainer.trainer_id }}" {% if selected_trainer == trainer.trainer_id or (form_data and form_data.select_trainer == trainer.trainer_id) %}selected{% endif %}>{{ trainer.name }} ({{ trainer.specialty }})</option>
            {% endfor %}
        </select><br><br>

        <label for="session-date">Session Date:</label><br>
        <input type="date" id="session-date" name="session_date" value="{{ form_data.session_date if form_data else '' }}" required><br><br>

        <label for="session-time">Session Time:</label><br>
        <select id="session-time" name="session_time" required>
            <option value="">-- Select Time Slot --</option>
            {% for time in time_slots %}
            <option value="{{ time }}" {% if form_data and form_data.session_time == time %}selected{% endif %}>{{ time }}</option>
            {% endfor %}
        </select><br><br>

        <label for="session-duration">Session Duration (minutes):</label><br>
        <select id="session-duration" name="session_duration" required>
            <option value="">-- Select Duration --</option>
            <option value="30" {% if form_data and form_data.session_duration == '30' %}selected{% endif %}>30</option>
            <option value="60" {% if form_data and form_data.session_duration == '60' %}selected{% endif %}>60</option>
            <option value="90" {% if form_data and form_data.session_duration == '90' %}selected{% endif %}>90</option>
        </select><br><br>

        <button id="confirm-booking-button" type="submit">Confirm Booking</button>
    </form>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/workout_records.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Workout Records</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="workouts-page">
    <h1>My Workout Records</h1>

    <form method="get" action="{{ url_for('workout_records') }}">
        <label for="filter-by-type">Filter by Workout Type:</label>
        <select id="filter-by-type" name="filter" onchange="this.form.submit()">
            <option value="" {% if not filter_type %}selected{% endif %}>All</option>
            <option value="Class" {% if filter_type == 'class' %}selected{% endif %}>Class</option>
            <option value="PT Session" {% if filter_type == 'pt session' %}selected{% endif %}>PT Session</option>
            <option value="Personal" {% if filter_type == 'personal' %}selected{% endif %}>Personal</option>
            <option value="Cardio" {% if filter_type == 'cardio' %}selected{% endif %}>Cardio</option>
            <option value="Strength" {% if filter_type == 'strength' %}selected{% endif %}>Strength</option>
            <option value="Flexibility" {% if filter_type == 'flexibility' %}selected{% endif %}>Flexibility</option>
            <option value="Sports" {% if filter_type == 'sports' %}selected{% endif %}>Sports</option>
        </select>
    </form>

    <table id="workouts-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Duration (minutes)</th>
                <th>Calories Burned</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            {% for workout in workouts %}
            <tr>
                <td>{{ workout.workout_date }}</td>
                <td>{{ workout.workout_type }}</td>
                <td>{{ workout.duration_minutes }}</td>
                <td>{{ workout.calories_burned }}</td>
                <td>{{ workout.notes }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5">No workout records found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <button id="log-workout-button" onclick="location.href='{{ url_for('log_workout') }}'">Log a New Workout</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/log_workout.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Log Workout</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="log-workout-page">
    <h1>Log Workout</h1>

    {% if error %}
    <div class="error-message" style="color:red;">{{ error }}</div>
    {% endif %}

    <form method="post" action="{{ url_for('log_workout') }}">
        <label for="member_name">Your Name:</label><br>
        <input type="text" id="member_name" name="member_name" value="{{ form_data.member_name if form_data else '' }}" required><br><br>

        <label for="workout-type">Workout Type:</label><br>
        <select id="workout-type" name="workout_type" required>
            <option value="">-- Select Workout Type --</option>
            {% for wt in workout_types %}
            <option value="{{ wt }}" {% if form_data and form_data.workout_type == wt %}selected{% endif %}>{{ wt }}</option>
            {% endfor %}
        </select><br><br>

        <label for="workout-duration">Duration (minutes):</label><br>
        <input type="number" id="workout-duration" name="workout_duration" min="1" value="{{ form_data.workout_duration if form_data else '' }}" required><br><br>

        <label for="calories-burned">Calories Burned:</label><br>
        <input type="number" id="calories-burned" name="calories_burned" min="0" value="{{ form_data.calories_burned if form_data else '' }}" required><br><br>

        <label for="workout-notes">Notes:</label><br>
        <textarea id="workout-notes" name="workout_notes" rows="4" cols="50">{{ form_data.workout_notes if form_data else '' }}</textarea><br><br>

        <button id="submit-workout-button" type="submit">Submit Workout Record</button>
    </form>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
