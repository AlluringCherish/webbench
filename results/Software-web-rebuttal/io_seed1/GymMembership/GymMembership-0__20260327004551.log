        <button id="book-trainer-button" onclick="location.href='{{ url_for('pt_booking') }}'">Book Personal Training</button>
        <button id="workout-records-button" onclick="location.href='{{ url_for('workout_records') }}'">My Workout Records</button>
    </div>
</div>
</body>
</html>
