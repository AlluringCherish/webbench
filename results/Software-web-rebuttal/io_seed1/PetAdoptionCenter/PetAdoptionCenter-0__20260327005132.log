<body>
    <div id="dashboard-page">
        <h1>Pet Adoption Dashboard</h1>
        {% if user %}
            <p>Welcome, {{ user.username }}!</p>
        {% else %}
            <p>Welcome, Guest! Please <a href="{{ url_for('login') }}">log in</a> to access more features.</p>
        {% endif %}
        <section id="featured-pets">
