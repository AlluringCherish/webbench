def load_adoption_history():
    history = {}
    lines = read_file_lines('adoption_history.txt')
    for line in lines:
        parts = line.split('|')
        if len(parts) == 6:
            history_id = parts[0]
            history[history_id] = {
                'history_id': history_id,
