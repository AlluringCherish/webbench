'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) can be accessed and loads correctly.
Test basic navigation buttons on the Dashboard page.
'''
import unittest
from main import app

class PetAdoptionCenterBasicAccessTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page loads successfully (HTTP 200)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check that the page title is correct
        self.assertIn(b'<title>Pet Adoption Dashboard</title>', response.data)
        # Check that the dashboard container div is present
        self.assertIn(b'id="dashboard-page"', response.data)
        # Check that featured pets section is present
        self.assertIn(b'id="featured-pets"', response.data)
        # Check that navigation buttons exist
        self.assertIn(b'id="browse-pets-button"', response.data)
        self.assertIn(b'id="back-to-dashboard"', response.data)

    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons have correct links or actions
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        # Browse Pets button should link to /pet_listings
        self.assertIn('onclick="location.href=\'/pet_listings\'"', html)
        # Back to Dashboard button should reload the page (JS reload)
        self.assertIn('id="back-to-dashboard"', html)
        # Login button should be present if not logged in
        self.assertIn('onclick="location.href=\'/login\'"', html)

if __name__ == '__main__':
    unittest.main()
