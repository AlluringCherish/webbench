    return str(max_id + 1)
# --- SHELTERS ---
def load_shelters():
    shelters = {}
    lines = read_file_lines('shelters.txt')
    for line in lines:
        parts = line.split('|')
        if len(parts) == 5:
            shelter_id = parts[0]
            shelters[shelter_id] = {
