# --- MESSAGES ---
def load_messages():
    messages = {}
    lines = read_file_lines('messages.txt')
    for line in lines:
        parts = line.split('|')
        if len(parts) == 7:
            message_id = parts[0]
            messages[message_id] = {
                'message_id': message_id,
                'sender_username': parts[1],
