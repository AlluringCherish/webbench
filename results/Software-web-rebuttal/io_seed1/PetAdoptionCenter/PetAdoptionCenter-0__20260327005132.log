    pets = load_pets()
    user_favorites = [f for f in favorites if f['username'] == user['username']]
    if request.method == 'POST':
        # Handle add or remove favorite
        action = request.form.get('action')
        pet_id = request.form.get('pet_id')
        if action == 'add':
            # Check if already favorite
