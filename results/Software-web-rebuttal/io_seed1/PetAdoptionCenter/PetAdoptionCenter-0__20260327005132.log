// Wait for the DOM to be fully loaded
document.addEventListener('DOMContentLoaded', function () {
    // Dashboard page buttons
    const browsePetsButton = document.getElementById('browse-pets-button');
    if (browsePetsButton) {
        browsePetsButton.addEventListener('click', function () {
            window.location.href = '/pet_listings';
        });
    }

    const backToDashboardButtons = document.querySelectorAll('#back-to-dashboard');
    backToDashboardButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            location.reload();
        });
    });

    // Pet Listings Page: filtering and search
    const petListingsPage = document.getElementById('pet-listings-page');
    if (petListingsPage) {
        const speciesFilter = document.getElementById('filter-species');
        const searchInput = document.getElementById('search-input');

        function updatePetListings() {
            const species = speciesFilter.value;
            const search = searchInput.value.trim();

            // Build query parameters and reload page
            const params = new URLSearchParams();
            if (species && species !== 'All') {
                params.append('filter-species', species);
            }
            if (search) {
                params.append('search-input', search);
            }
            window.location.href = '/pet_listings?' + params.toString();
        }

        if (speciesFilter) {
            speciesFilter.addEventListener('change', updatePetListings);
        }
        if (searchInput) {
            searchInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    updatePetListings();
                }
            });
        }
    }

    // Pet Details Page: adopt button and back button
    const petDetailsPage = document.getElementById('pet-details-page');
    if (petDetailsPage) {
        const adoptButton = document.getElementById('adopt-button');
        if (adoptButton) {
            adoptButton.addEventListener('click', function () {
                const petId = adoptButton.getAttribute('data-pet-id');
