                'date_submitted': parts[12]
            }
    return applications
def save_applications(applications):
    lines = []
    for a in applications.values():
        line = '|'.join([
            a['application_id'], a['username'], a['pet_id'], a['applicant_name'],
            a['phone'], a['address'], a['housing_type'], a['has_yard'],
