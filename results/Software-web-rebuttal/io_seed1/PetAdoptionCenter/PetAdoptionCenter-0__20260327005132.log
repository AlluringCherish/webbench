```javascript
/*
JavaScript for PetAdoptionCenter web application.
Handles client-side interactivity such as button actions, filtering, and navigation.
*/

// Add event listener for all back-to-dashboard buttons to navigate to dashboard page
document.querySelectorAll('#back-to-dashboard').forEach(button => {
    button.addEventListener('click', () => {
        window.location.href = '/';
    });
});

// Pet Listings Page: handle species filter and search input to reload page with query parameters
const speciesFilter = document.getElementById('filter-species');
const searchInput = document.getElementById('search-input');
if (speciesFilter && searchInput) {
    function updatePetListings() {
        const species = speciesFilter.value;
        const search = searchInput.value.trim();
        const params = new URLSearchParams();
        if (species && species !== 'All') {
            params.append('filter-species', species);
        }
        if (search) {
            params.append('search-input', search);
        }
        const queryString = params.toString();
        window.location.href = '/pet_listings' + (queryString ? '?' + queryString : '');
    }
    speciesFilter.addEventListener('change', updatePetListings);
    searchInput.addEventListener('keyup', function(event) {
        if (event.key === 'Enter') {
            updatePetListings();
        }
    });
}

// My Applications Page: back to dashboard button handled above

