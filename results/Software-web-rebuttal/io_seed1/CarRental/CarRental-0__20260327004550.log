// Wait for DOM content to be loaded
document.addEventListener('DOMContentLoaded', function () {

    // Vehicle Search Page: handle filters and search
    const locationFilter = document.getElementById('location-filter');
    const vehicleTypeFilter = document.getElementById('vehicle-type-filter');
    const dateRangeInput = document.getElementById('date-range-input');

    if (locationFilter || vehicleTypeFilter || dateRangeInput) {
        // Attach event listeners to filters to trigger search on change
        if (locationFilter) {
            locationFilter.addEventListener('change', applyVehicleSearchFilters);
        }
        if (vehicleTypeFilter) {
            vehicleTypeFilter.addEventListener('change', applyVehicleSearchFilters);
        }
        if (dateRangeInput) {
            dateRangeInput.addEventListener('change', applyVehicleSearchFilters);
        }
    }

    // Locations Page: handle hours filter and search input
    const hoursFilter = document.getElementById('hours-filter');
    const searchLocationInput = document.getElementById('search-location-input');

    if (hoursFilter) {
        hoursFilter.addEventListener('change', applyLocationsFilters);
    }
    if (searchLocationInput) {
        searchLocationInput.addEventListener('input', debounce(applyLocationsFilters, 300));
    }

    // Reservations Page: handle sort by date button
    const sortByDateButton = document.getElementById('sort-by-date-button');
    if (sortByDateButton) {
        sortByDateButton.addEventListener('click', function () {
            // Submit form with sort_by_date
            const form = document.getElementById('reservations-form');
            if (form) {
                // Add hidden input to indicate sort by date
                let input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'sort_by_date';
                input.value = '1';
                form.appendChild(input);
                form.submit();
            }
        });
    }

    // Special Requests Page: handle reservation selection change to update form fields
    const selectReservationDropdown = document.getElementById('select-reservation');
    if (selectReservationDropdown) {
        selectReservationDropdown.addEventListener('change', function () {
            // On selection change, reload page with selected reservation_id as query param
            const selectedId = this.value;
            if (selectedId) {
                const url = new URL(window.location.href);
                url.searchParams.set('reservation_id', selectedId);
                window.location.href = url.toString();
            }
        });
    }

    // Dashboard Page buttons handled inline with onclick, no extra JS needed

    // Booking Page: handle calculate price and proceed to insurance buttons
    const calculatePriceButton = document.getElementById('calculate-price-button');
    const proceedToInsuranceButton = document.getElementById('proceed-to-insurance-button');
    if (calculatePriceButton) {
        calculatePriceButton.addEventListener('click', function () {
            // Set hidden input action to calculate_price and submit form
            const form = document.getElementById('booking-form');
            if (form) {
                let actionInput = form.querySelector('input[name="action"]');
                if (!actionInput) {
                    actionInput = document.createElement('input');
                    actionInput.type = 'hidden';
                    actionInput.name = 'action';
                    form.appendChild(actionInput);
                }
                actionInput.value = 'calculate_price';
                form.submit();
            }
        });
    }
    if (proceedToInsuranceButton) {
        proceedToInsuranceButton.addEventListener('click', function () {
            // Set hidden input action to proceed_to_insurance and submit form
            const form = document.getElementById('booking-form');
            if (form) {
                let actionInput = form.querySelector('input[name="action"]');
                if (!actionInput) {
                    actionInput = document.createElement('input');
                    actionInput.type = 'hidden';
                    actionInput.name = 'action';
                    form.appendChild(actionInput);
                }
                actionInput.value = 'proceed_to_insurance';
                form.submit();
            }
        });
    }

    // Insurance Options Page: update insurance description and price on selection
    const insuranceOptionsDiv = document.getElementById('insurance-options');
    if (insuranceOptionsDiv) {
        const radios = insuranceOptionsDiv.querySelectorAll('input[type=radio]');
        radios.forEach(function (radio) {
            radio.addEventListener('change', function () {
                updateInsuranceDetails(this.value);
            });
        });
        // On page load, update details for selected insurance if any
        const selectedRadio = insuranceOptionsDiv.querySelector('input[type=radio]:checked');
        if (selectedRadio) {
            updateInsuranceDetails(selectedRadio.value);
        }
    }

    // Helper function to update insurance description and price dynamically
    function updateInsuranceDetails(insuranceId) {
        // The insurance description and price are rendered server-side,
        // so here we can just submit the form to update or do nothing.
        // For better UX, we could implement AJAX, but per requirements, keep simple.
        // So no dynamic update here.
    }

    // Utility: debounce function to limit frequency of function calls
    function debounce(func, wait) {
        let timeout;
        return function () {
            const context = this, args = arguments;
            clearTimeout(timeout);
            timeout = setTimeout(() => func.apply(context, args), wait);
        };
    }

    // Rental History Page: handle status filter change to reload page with filter
    const statusFilter = document.getElementById('status-filter');
    if (statusFilter) {
        statusFilter.addEventListener('change', function () {
            const selectedStatus = this.value;
            const url = new URL(window.location.href);
            url.searchParams.set('status_filter', selectedStatus);
            window.location.href = url.toString();
        });
    }

    // Locations Page: handle back to dashboard button
    const backToDashboardButtons = document.querySelectorAll('#back-to-dashboard');
    backToDashboardButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            window.location.href = '/';
        });
    });

    // Reservations Page: handle back to dashboard button
    const reservationsBackButtons = document.querySelectorAll('#back-to-dashboard');
    reservationsBackButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            window.location.href = '/';
        });
    });

    // Rental History Page: handle back to dashboard button
    const historyBackButtons = document.querySelectorAll('#back-to-dashboard');
    historyBackButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
            window.location.href = '/';
        });
    });

    // General: handle buttons with IDs starting with view-details-button- to navigate
    document.querySelectorAll('button[id^="view-details-button-"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const vehicleId = this.id.replace('view-details-button-', '');
            window.location.href = '/vehicle_details/' + vehicleId;
        });
    });

    // General: handle buttons with IDs starting with modify-reservation-button- to navigate
    document.querySelectorAll('button[id^="modify-reservation-button-"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const reservationId = this.id.replace('modify-reservation-button-', '');
            window.location.href = '/special_requests?reservation_id=' + reservationId;
        });
    });

    // General: handle buttons with IDs starting with cancel-reservation-button- to submit cancellation
    document.querySelectorAll('button[id^="cancel-reservation-button-"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const reservationId = this.id.replace('cancel-reservation-button-', '');
            if (confirm('Are you sure you want to cancel reservation ' + reservationId + '?')) {
                // Create a form and submit POST to /reservations with cancel_reservation_id
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/reservations';
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'cancel_reservation_id';
                input.value = reservationId;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        });
    });

    // General: handle buttons with IDs starting with view-rental-details- to navigate
    document.querySelectorAll('button[id^="view-rental-details-"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const rentalId = this.id.replace('view-rental-details-', '');
            window.location.href = '/rental_history/' + rentalId;
        });
    });

    // General: handle buttons with IDs starting with location-detail-button- to navigate
    document.querySelectorAll('button[id^="location-detail-button-"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const locationId = this.id.replace('location-detail-button-', '');
            window.location.href = '/locations/' + locationId;
        });
    });

});
