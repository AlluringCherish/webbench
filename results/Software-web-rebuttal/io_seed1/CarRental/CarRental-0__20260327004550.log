@app.route('/reservations', methods=['GET', 'POST'])
def reservations():
    reservations = read_reservations()
    vehicles = read_vehicles()
    vehicle_dict = {v['vehicle_id']: v for v in vehicles}
    sort_by_date = False
    if request.method == 'POST':
        if 'sort_by_date' in request.form:
            sort_by_date = True
        elif 'modify_reservation_id' in request.form:
            reservation_id = request.form.get('modify_reservation_id')
            # For simplicity, redirect to special requests page to modify special requests
            return redirect(url_for('special_requests', reservation_id=reservation_id))
        elif 'cancel_reservation_id' in request.form:
            reservation_id = request.form.get('cancel_reservation_id')
            # Cancel reservation by setting status to Cancelled
            for r in reservations:
                if r['reservation_id'] == reservation_id:
                    r['status'] = 'Cancelled'
                    flash(f"Reservation {reservation_id} cancelled.", "info")
                    break
            write_reservations(reservations)
    if sort_by_date:
        # Sort reservations by rental pickup date ascending
        rentals = read_rentals()
        rental_dict = {r['rental_id']: r for r in rentals}
        reservations.sort(key=lambda r: parse_date(rental_dict.get(r['rental_id'], {}).get('pickup_date', '9999-12-31')) or datetime.max)
    # Prepare reservations list with vehicle info
    reservations_display = []
    for r in reservations:
        vehicle = vehicle_dict.get(r['vehicle_id'])
        reservations_display.append({
            'reservation_id': r['reservation_id'],
            'vehicle_make_model': f"{vehicle['make']} {vehicle['model']}" if vehicle else 'Unknown',
            'status': r['status'],
            'special_requests': r['special_requests']
        })
    return render_template('reservations.html',
                           reservations=reservations_display)
@app.route('/special_requests', methods=['GET', 'POST'])
def special_requests():
    reservations = read_reservations()
    reservation_id = request.args.get('reservation_id', '')
    if request.method == 'POST':
        reservation_id = request.form.get('select_reservation')
        driver_assistance = request.form.get('driver_assistance_checkbox')
        gps_option = request.form.get('gps_option_checkbox')
        child_seat_quantity = request.form.get('child_seat_quantity', '0')
        special_notes = request.form.get('special_notes', '').strip()
        # Compose special requests string
        requests_list = []
        if driver_assistance == 'on':
            requests_list.append('Driver assistance requested')
        if gps_option == 'on':
            requests_list.append('GPS option requested')
        try:
            child_seats = int(child_seat_quantity)
            if child_seats > 0:
                requests_list.append(f'{child_seats} child seat(s) needed')
        except:
            pass
        if special_notes:
            requests_list.append(special_notes)
        special_requests_str = '; '.join(requests_list)
        # Update reservation special_requests field
        updated = False
        for r in reservations:
            if r['reservation_id'] == reservation_id:
                r['special_requests'] = special_requests_str
                updated = True
                break
        if updated:
            write_reservations(reservations)
            flash("Special requests updated successfully.", "success")
            return redirect(url_for('reservations'))
        else:
            flash("Reservation not found.", "error")
    # For GET or if no reservation_id specified, show form with dropdown
    reservations_options = []
    for r in reservations:
        reservations_options.append({
            'reservation_id': r['reservation_id'],
            'display': f"Reservation {r['reservation_id']} (Status: {r['status']})"
        })
    # If reservation_id specified, prefill form with existing special requests
    prefill = {
        'driver_assistance': False,
        'gps_option': False,
        'child_seat_quantity': '',
        'special_notes': ''
    }
    if reservation_id:
        res = get_reservation_by_id(reservation_id)
        if res:
            sr = res['special_requests'].lower()
            prefill['driver_assistance'] = 'driver assistance' in sr
            prefill['gps_option'] = 'gps' in sr
            # Try to extract child seat quantity from string
            import re
            m = re.search(r'(\d+)\s*child seat', sr)
            if m:
                prefill['child_seat_quantity'] = m.group(1)
            else:
                prefill['child_seat_quantity'] = ''
            # Remove known requests from notes
            notes = sr
            for phrase in ['driver assistance requested', 'gps option requested', f"{prefill['child_seat_quantity']} child seat(s) needed"]:
                notes = notes.replace(phrase, '')
            prefill['special_notes'] = notes.strip('; ').strip()
    return render_template('special_requests.html',
                           reservations=reservations_options,
                           selected_reservation=reservation_id,
                           prefill=prefill)
@app.route('/locations', methods=['GET'])
def locations():
    locations = read_locations()
    hours_filter = request.args.get('hours_filter', 'All')
    search_input = request.args.get('search_location_input', '').strip().lower()
    filtered_locations = []
    for loc in locations:
        # Filter by hours
        if hours_filter != 'All':
            if hours_filter == '24/7' and loc['hours'] != '24/7':
                continue
            elif hours_filter == 'Business Hours' and loc['hours'] == '24/7':
                continue
            elif hours_filter == 'Weekend' and loc['hours'] == '24/7':
                continue
            # For simplicity, treat Business Hours as 09:00-18:00 and Weekend as others
            if hours_filter == 'Business Hours' and loc['hours'] != '09:00-18:00':
                continue
            if hours_filter == 'Weekend' and loc['hours'] == '09:00-18:00':
                continue
        # Filter by search input (city or name)
        if search_input:
            if search_input not in loc['city'].lower() and search_input not in loc['address'].lower():
                continue
        filtered_locations.append(loc)
    return render_template('locations.html',
                           locations=filtered_locations,
                           hours_filter=hours_filter,
                           search_location_input=search_input)
