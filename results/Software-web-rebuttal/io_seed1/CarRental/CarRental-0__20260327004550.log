@app.route('/booking/<vehicle_id>', methods=['GET', 'POST'])
def booking(vehicle_id):
    vehicle = get_vehicle_by_id(vehicle_id)
    if not vehicle:
        flash("Vehicle not found.", "error")
        return redirect(url_for('vehicle_search'))
    locations = read_locations()
    total_price = None
    pickup_location = ''
    dropoff_location = ''
    pickup_date = ''
    dropoff_date = ''
    if request.method == 'POST':
        pickup_location = request.form.get('pickup_location', '')
        dropoff_location = request.form.get('dropoff_location', '')
        pickup_date = request.form.get('pickup_date', '')
        dropoff_date = request.form.get('dropoff_date', '')
        action = request.form.get('action', '')
        # Validate dates
        start = parse_date(pickup_date)
        end = parse_date(dropoff_date)
        if not start or not end or end < start:
            flash("Invalid pickup or dropoff dates.", "error")
            return render_template('booking.html',
                                   vehicle=vehicle,
                                   locations=locations,
                                   total_price=total_price,
                                   pickup_location=pickup_location,
                                   dropoff_location=dropoff_location,
                                   pickup_date=pickup_date,
                                   dropoff_date=dropoff_date)
        days = (end - start).days + 1
        total_price = days * vehicle['daily_rate']
        if action == 'calculate_price':
            # Just calculate price and show
            flash(f"Total price for {days} day(s): ${total_price:.2f}", "info")
        elif action == 'proceed_to_insurance':
            # Save booking info temporarily in session or pass via query parameters
            # Since no authentication, we pass via query parameters (not secure but per requirements)
            # Redirect to insurance options page with booking info
            return redirect(url_for('insurance_options',
                                    vehicle_id=vehicle_id,
                                    pickup_location=pickup_location,
                                    dropoff_location=dropoff_location,
                                    pickup_date=pickup_date,
                                    dropoff_date=dropoff_date,
                                    total_price=total_price))
    return render_template('booking.html',
                           vehicle=vehicle,
                           locations=locations,
                           total_price=total_price,
                           pickup_location=pickup_location,
                           dropoff_location=dropoff_location,
                           pickup_date=pickup_date,
                           dropoff_date=dropoff_date)
@app.route('/insurance_options', methods=['GET', 'POST'])
def insurance_options():
    insurance_plans = read_insurance()
    # Retrieve booking info from query parameters or form
    vehicle_id = request.args.get('vehicle_id') or request.form.get('vehicle_id')
    pickup_location = request.args.get('pickup_location') or request.form.get('pickup_location')
    dropoff_location = request.args.get('dropoff_location') or request.form.get('dropoff_location')
    pickup_date = request.args.get('pickup_date') or request.form.get('pickup_date')
    dropoff_date = request.args.get('dropoff_date') or request.form.get('dropoff_date')
    total_price = request.args.get('total_price') or request.form.get('total_price')
    selected_insurance_id = None
    insurance_description = ''
    insurance_price = 0.0
    if request.method == 'POST':
        selected_insurance_id = request.form.get('insurance_plan')
        if selected_insurance_id:
            plan = get_insurance_by_id(selected_insurance_id)
            if plan:
                insurance_description = plan['description']
                # Calculate insurance price based on rental days
                days = date_range_days(pickup_date, dropoff_date)
                insurance_price = days * plan['daily_cost']
        confirm = request.form.get('confirm_booking')
        if confirm == 'Confirm Booking':
            # Create new rental, reservation, and save data
            # Since no customer info, create a dummy customer with id=0
            customers = read_customers()
            if not customers:
                # Create a default customer
                customer_id = '1'
                customers.append({
                    'customer_id': customer_id,
                    'name': 'Guest User',
                    'email': '',
                    'phone': '',
                    'driver_license': '',
                    'license_expiry': ''
                })
                write_customers(customers)
            else:
                customer_id = customers[0]['customer_id']  # Use first customer as guest
            rentals = read_rentals()
            reservations = read_reservations()
            rental_id = get_next_id(rentals, 'rental_id')
            reservation_id = get_next_id(reservations, 'reservation_id')
            days = date_range_days(pickup_date, dropoff_date)
            total_price_float = float(total_price) if total_price else 0.0
            insurance_cost = insurance_price
            grand_total = total_price_float + insurance_cost
            # Create rental entry
            rental = {
                'rental_id': rental_id,
                'vehicle_id': vehicle_id,
                'customer_id': customer_id,
                'pickup_date': pickup_date,
                'dropoff_date': dropoff_date,
                'pickup_location': pickup_location,
                'dropoff_location': dropoff_location,
                'total_price': grand_total,
                'status': 'Active'
            }
            rentals.append(rental)
            write_rentals(rentals)
            # Create reservation entry
            reservation = {
                'reservation_id': reservation_id,
                'rental_id': rental_id,
                'vehicle_id': vehicle_id,
                'customer_id': customer_id,
                'status': 'Confirmed',
                'insurance_id': selected_insurance_id if selected_insurance_id else '',
                'special_requests': ''
            }
            reservations.append(reservation)
            write_reservations(reservations)
            flash("Booking confirmed successfully!", "success")
            return redirect(url_for('dashboard'))
    return render_template('insurance_options.html',
                           insurance_plans=insurance_plans,
                           selected_insurance_id=selected_insurance_id,
                           insurance_description=insurance_description,
                           insurance_price=insurance_price,
                           vehicle_id=vehicle_id,
                           pickup_location=pickup_location,
                           dropoff_location=dropoff_location,
                           pickup_date=pickup_date,
                           dropoff_date=dropoff_date,
                           total_price=total_price)
@app.route('/rental_history', methods=['GET'])
def rental_history():
    rentals = read_rentals()
    vehicles = read_vehicles()
    # Join vehicle info to rentals for display
    vehicle_dict = {v['vehicle_id']: v for v in vehicles}
    status_filter = request.args.get('status_filter', 'All')
    filtered_rentals = []
    for r in rentals:
        if status_filter != 'All' and r['status'] != status_filter:
            continue
        rental_info = r.copy()
        vehicle = vehicle_dict.get(r['vehicle_id'])
        if vehicle:
            rental_info['vehicle_make_model'] = f"{vehicle['make']} {vehicle['model']}"
        else:
            rental_info['vehicle_make_model'] = 'Unknown'
        filtered_rentals.append(rental_info)
    statuses = ['All', 'Active', 'Completed', 'Cancelled']
    return render_template('rental_history.html',
                           rentals=filtered_rentals,
                           status_filter=status_filter,
                           statuses=statuses)
