'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of the Dashboard page, verifying the presence and correctness of all specified elements as per the requirements.
'''
import unittest
from app import app
from bs4 import BeautifulSoup

class CarRentalDashboardTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test that the page title is "Car Rental Dashboard"
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string.strip()
        self.assertEqual(title, "Car Rental Dashboard", "Dashboard page title should be 'Car Rental Dashboard'")

    def test_dashboard_main_div_present(self):
        # Test presence of main container div with id 'dashboard-page'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard main container div with id 'dashboard-page' should be present")

    def test_featured_vehicles_section(self):
        # Test presence of featured vehicles section with id 'featured-vehicles'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_section = soup.find('section', id='featured-vehicles')
        self.assertIsNotNone(featured_section, "Featured vehicles section with id 'featured-vehicles' should be present")
        # Check that featured vehicles container exists if vehicles available
        container = featured_section.find('div', class_='featured-vehicles-container')
        # It can be None if no featured vehicles, so no assert here, but if present check vehicle cards
        if container:
            vehicle_cards = container.find_all('div', class_='vehicle-card')
            self.assertTrue(len(vehicle_cards) > 0, "There should be at least one vehicle card in featured vehicles")

    def test_promotions_section(self):
        # Test presence of promotions section with id 'promotions-section'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        promotions_section = soup.find('section', id='promotions-section')
        self.assertIsNotNone(promotions_section, "Promotions section with id 'promotions-section' should be present")
        # Check that promotions are listed as <li> items inside a <ul>
        ul = promotions_section.find('ul')
        self.assertIsNotNone(ul, "Promotions section should contain a <ul> element")
        li_items = ul.find_all('li')
        self.assertTrue(len(li_items) >= 1, "Promotions section should contain at least one promotion item")

    def test_navigation_buttons(self):
        # Test presence and correctness of navigation buttons with specified ids
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # search-vehicles-button
        search_btn = soup.find('button', id='search-vehicles-button')
        self.assertIsNotNone(search_btn, "Button with id 'search-vehicles-button' should be present")
        self.assertIn('/vehicle_search', search_btn.get('onclick', ''), "Search Vehicles button should navigate to /vehicle_search")
        # my-reservations-button
        reservations_btn = soup.find('button', id='my-reservations-button')
        self.assertIsNotNone(reservations_btn, "Button with id 'my-reservations-button' should be present")
        self.assertIn('/reservations', reservations_btn.get('onclick', ''), "My Reservations button should navigate to /reservations")
        # Rental History button (no id, but text present)
        rental_history_btn = None
        for btn in soup.find_all('button'):
            if btn.text.strip() == 'Rental History':
                rental_history_btn = btn
                break
        self.assertIsNotNone(rental_history_btn, "Button with text 'Rental History' should be present")
        self.assertIn('/rental_history', rental_history_btn.get('onclick', ''), "Rental History button should navigate to /rental_history")
        # Locations button
        locations_btn = None
        for btn in soup.find_all('button'):
            if btn.text.strip() == 'Locations':
                locations_btn = btn
                break
        self.assertIsNotNone(locations_btn, "Button with text 'Locations' should be present")
        self.assertIn('/locations', locations_btn.get('onclick', ''), "Locations button should navigate to /locations")
        # Special Requests button
        special_requests_btn = None
        for btn in soup.find_all('button'):
            if btn.text.strip() == 'Special Requests':
                special_requests_btn = btn
                break
        self.assertIsNotNone(special_requests_btn, "Button with text 'Special Requests' should be present")
        self.assertIn('/special_requests', special_requests_btn.get('onclick', ''), "Special Requests button should navigate to /special_requests")

if __name__ == '__main__':
    unittest.main()
