<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Car Rental Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="dashboard-page">
        <h1>Car Rental Dashboard</h1>
        <section id="featured-vehicles">
            <h2>Featured Vehicles</h2>
            {% if featured_vehicles %}
                <div class="featured-vehicles-container">
                    {% for vehicle in featured_vehicles %}
                        <div class="vehicle-card">
                            <img src="{{ url_for('static', filename='images/vehicles/' + vehicle.vehicle_id + '.jpg') }}" alt="{{ vehicle.make }} {{ vehicle.model }}" onerror="this.onerror=null;this.src='{{ url_for('static', filename='images/vehicles/default.jpg') }}';">
                            <h3>{{ vehicle.make }} {{ vehicle.model }}</h3>
                            <p>Type: {{ vehicle.vehicle_type }}</p>
                            <p>Daily Rate: ${{ "%.2f"|format(vehicle.daily_rate) }}</p>
                            <a href="{{ url_for('vehicle_details', vehicle_id=vehicle.vehicle_id) }}">
                                <button id="view-details-button-{{ vehicle.vehicle_id }}">View Details</button>
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No featured vehicles available at the moment.</p>
            {% endif %}
        </section>
        <section id="promotions-section">
            <h2>Current Promotions</h2>
            <ul>
                {% for promo in promotions %}
                    <li>{{ promo }}</li>
                {% endfor %}
            </ul>
        </section>
        <nav class="dashboard-navigation">
            <button id="search-vehicles-button" onclick="location.href='{{ url_for('vehicle_search') }}'">Search Vehicles</button>
            <button id="my-reservations-button" onclick="location.href='{{ url_for('reservations') }}'">My Reservations</button>
