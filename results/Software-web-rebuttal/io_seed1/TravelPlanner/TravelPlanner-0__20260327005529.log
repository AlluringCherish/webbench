'''
Testing Task 1: Test whether the website can be accessed through local port 5000.
Testing Task 2: Test whether the first page of the website (Dashboard) loads correctly and basic navigation buttons work.
'''

import unittest
from app import app

class TravelPlannerBasicAccessTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Travel Planner Dashboard', response.data)

    def test_dashboard_navigation_buttons_present(self):
        # Test that navigation buttons exist on the dashboard page
        response = self.client.get('/')
        self.assertIn(b'id="browse-destinations-button"', response.data)
        self.assertIn(b'id="plan-itinerary-button"', response.data)
        self.assertIn(b'onclick="location.href=\'/destinations\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/itinerary_planning\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/accommodations\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/transportation\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/travel_packages\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/trip_management\'"', response.data)
        self.assertIn(b'onclick="location.href=\'/travel_recommendations\'"', response.data)

if __name__ == '__main__':
    unittest.main()
