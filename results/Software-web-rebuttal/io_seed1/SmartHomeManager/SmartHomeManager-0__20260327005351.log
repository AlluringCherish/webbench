<body>
<div id="energy-page">
    <h1>Energy Report</h1>
    <div id="energy-summary">
        <p>Total Energy Consumption: {{ total_consumption }} kWh</p>
        <p>Estimated Cost: ${{ "%.2f"|format(cost_estimate) }}</p>
    </div>

    <form method="post">
        <label for="date-filter">Filter by Date:</label>
        <input type="date" id="date-filter" name="date-filter" value="{{ filter_date }}">
        <button id="apply-filter-button" type="submit">Apply Filter</button>
    </form>

    <table id="energy-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ log.device_name }}</td>
                <td>{{ log.date }}</td>
                <td>{{ log.consumption_kwh }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <button id="back-to-dashboard" onclick="location.href='/'">Back to Dashboard</button>
</div>
</body>
</html>
```

