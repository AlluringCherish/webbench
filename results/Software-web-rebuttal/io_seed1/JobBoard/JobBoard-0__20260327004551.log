'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence and correctness of all specified elements as per the requirements.
'''
import unittest
from main import app
from bs4 import BeautifulSoup

class JobBoardDashboardTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible at root '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test that the page title is correct
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string.strip()
        self.assertEqual(title, "Job Board Dashboard", "Dashboard page title should be 'Job Board Dashboard'")

    def test_dashboard_main_container(self):
        # Test presence of main container div with id 'dashboard-page'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page should contain div with id 'dashboard-page'")

    def test_featured_jobs_section(self):
        # Test presence of featured jobs div and list
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_div = soup.find('div', id='featured-jobs')
        self.assertIsNotNone(featured_div, "Dashboard should contain div with id 'featured-jobs'")
        featured_list = featured_div.find('div', id='featured-jobs-list')
        self.assertIsNotNone(featured_list, "Featured jobs section should contain div with id 'featured-jobs-list'")
        # If featured jobs exist, check for list and buttons
        ul = featured_list.find('ul')
        if ul:
            items = ul.find_all('li')
            self.assertGreaterEqual(len(items), 0, "Featured jobs list should have zero or more job items")
            for li in items:
                # Check for job title strong tag
                strong = li.find('strong')
                self.assertIsNotNone(strong, "Each featured job item should have a strong tag for job title")
                # Check for company name text presence
                self.assertIn('at', li.text, "Featured job item should contain company name text")
                # Check for location and salary text presence
                self.assertRegex(li.text, r'\$\d+', "Featured job item should contain salary range with dollar sign")
                # Check for view details button with correct id pattern
                button = li.find('button')
                self.assertIsNotNone(button, "Featured job item should have a 'View Details' button")
                self.assertTrue(button['id'].startswith('view-job-button-'), "View Details button id should start with 'view-job-button-'")

    def test_dashboard_navigation_buttons(self):
        # Test presence and correctness of navigation buttons with specified ids
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        browse_btn = soup.find('button', id='browse-jobs-button')
        self.assertIsNotNone(browse_btn, "Dashboard should have a button with id 'browse-jobs-button'")
        my_apps_btn = soup.find('button', id='my-applications-button')
        self.assertIsNotNone(my_apps_btn, "Dashboard should have a button with id 'my-applications-button'")
        companies_btn = soup.find('button', id='companies-button')
        self.assertIsNotNone(companies_btn, "Dashboard should have a button with id 'companies-button'")

    def test_featured_job_view_buttons_navigation(self):
        # Test that clicking a featured job's view button would navigate to the correct job details URL
        # Since this is server-side test, we check the button data-job-id attribute and URL pattern in JS
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        buttons = soup.select('.view-job-button')
        for button in buttons:
            job_id = button.get('data-job-id')
            self.assertIsNotNone(job_id, "View job button should have a data-job-id attribute")
            # The URL for job details should be /job/<job_id>
            expected_url = f"/job/{job_id}"
            # We cannot click buttons here, but we can check the JS snippet in the page contains the url_for with empty job_id
            # So we check the JS code contains url_for('job_details', job_id='')
            self.assertIn("url_for('job_details', job_id='')", response.get_data(as_text=True), "Dashboard JS should contain url_for for job_details route")

if __name__ == '__main__':
    unittest.main()
