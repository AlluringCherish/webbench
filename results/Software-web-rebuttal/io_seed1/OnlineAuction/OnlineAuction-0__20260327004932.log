<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
<div id="dashboard-page">
    <h1>Auction Dashboard</h1>
    <section id="featured-auctions">
        <h2>Featured Auctions</h2>
        {% if featured_auctions %}
            <div class="featured-auctions-list">
                {% for auction in featured_auctions %}
                    <div class="auction-card" id="auction-card-{{ auction.auction_id }}">
                        <img src="{{ url_for('static', filename='images/' + auction.image_url) }}" alt="{{ auction.item_name }}">
                        <h3>{{ auction.item_name }}</h3>
                        <p>Current Bid: ${{ '%.2f'|format(auction.current_bid) }}</p>
                        <p>Time Remaining: {{ auction.time_remaining }}</p>
                        <button id="view-auction-button-{{ auction.auction_id }}">View Details</button>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p>No featured auctions available.</p>
        {% endif %}
    </section>
    <section id="trending-auctions-section">
        <h2>Trending Auctions</h2>
        {% if trending_auctions %}
            <div id="trending-list">
                {% for trend in trending_auctions %}
                    <div class="trending-auction-card" id="trending-auction-{{ trend.auction_id }}">
                        <span class="trending-rank">#{{ trend.trending_rank }}</span>
                        <h3>{{ trend.item_name }}</h3>
                        <p>Current Bid: ${{ '%.2f'|format(trend.current_bid) }}</p>
                        <p>Bid Count: {{ trend.bid_count }}</p>
                        <button id="view-auction-button-{{ trend.auction_id }}">View Details</button>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p>No trending auctions available.</p>
        {% endif %}
    </section>
    <div class="dashboard-buttons">
        <button id="browse-auctions-button">Browse Auctions</button>
        <button id="view-bids-button">View Bid History</button>
        <button id="trending-auctions-button">Trending Auctions</button>
    </div>
</div>
</body>
</html>
```

auction_catalog.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Catalog</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
<div id="catalog-page">
    <h1>Auction Catalog</h1>
    <div class="catalog-filters">
        <input type="text" id="search-input" placeholder="Search auctions..." value="{{ search_query }}">
        <select id="category-filter">
            <option value="All" {% if selected_category|lower == 'all' or not selected_category %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category|lower == category.category_name|lower %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
            <option value="Art" {% if selected_category|lower == 'art' %}selected{% endif %}>Art</option>
            <option value="Other" {% if selected_category|lower == 'other' %}selected{% endif %}>Other</option>
        </select>
    </div>
    <div id="auctions-grid">
        {% if auctions %}
            {% for auction in auctions %}
                <div class="auction-card" id="auction-card-{{ auction.auction_id }}">
                    <img src="{{ url_for('static', filename='images/' + auction.image_url) }}" alt="{{ auction.item_name }}">
                    <h3>{{ auction.item_name }}</h3>
                    <p>Current Bid: ${{ '%.2f'|format(auction.current_bid) }}</p>
                    <p>Time Remaining: {{ auction.time_remaining }}</p>
                    <button id="view-auction-button-{{ auction.auction_id }}">View Details</button>
                </div>
            {% endfor %}
        {% else %}
            <p>No auctions found.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard">Back to Dashboard</button>
</div>
</body>
</html>
```

auction_details.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
<div id="auction-details-page">
    <h1 id="auction-title">{{ auction.item_name }}</h1>
    <div id="auction-description">
        <p>{{ auction.description }}</p>
    </div>
    <div id="current-bid">
        <strong>Current Highest Bid:</strong> ${{ '%.2f'|format(auction.current_bid) }}
    </div>
    <div id="time-remaining">
        <strong>Time Remaining:</strong> {{ auction.time_remaining }}
    </div>
    <button id="place-bid-button" onclick="window.location.href='{{ url_for('place_bid', auction_id=auction.auction_id) }}'">Place Bid</button>
    <div id="bid-history">
        <h2>Bid History</h2>
        {% if bid_history %}
            <ul>
                {% for bid in bid_history %}
                    <li>{{ bid.bidder_name }} bid ${{ '%.2f'|format(bid.bid_amount) }} on {{ bid.bid_timestamp }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No bids placed yet.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard">Back to Dashboard</button>
</div>
</body>
</html>
