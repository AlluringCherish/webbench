Displays detailed information about a specific auction item and its bid history.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}" defer></script>
</head>
<body>
<div id="auction-details-page">
    <h1 id="auction-title">{{ auction.item_name }}</h1>
    <div id="auction-description">{{ auction.description }}</div>
    <div id="current-bid">Current Bid: ${{ '%.2f'|format(auction.current_bid) }}</div>
    <div>Time Remaining: {{ auction.time_remaining }}</div>
    <button id="place-bid-button" onclick="window.location.href='{{ url_for('place_bid', auction_id=auction.auction_id) }}'">Place Bid</button>

    <section id="bid-history">
        <h2>Bid History</h2>
        {% if bid_history %}
            <table>
                <thead>
                    <tr>
                        <th>Bidder Name</th>
                        <th>Bid Amount</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    {% for bid in bid_history %}
                        <tr>
                            <td>{{ bid.bidder_name }}</td>
                            <td>${{ '%.2f'|format(bid.bid_amount) }}</td>
                            <td>{{ bid.bid_timestamp }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>No bids placed yet.</p>
        {% endif %}
    </section>

    <button id="back-to-dashboard">Back to Dashboard</button>
</div>
</body>
</html>
