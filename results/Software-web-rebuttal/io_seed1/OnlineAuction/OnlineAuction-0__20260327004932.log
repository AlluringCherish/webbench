        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check page container div id
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' should exist")

        # Check featured auctions section
        featured_section = soup.find('section', id='featured-auctions')
        self.assertIsNotNone(featured_section, "Featured auctions section with id 'featured-auctions' should exist")

        # Check trending auctions section
        trending_section = soup.find('section', id='trending-auctions-section')
        self.assertIsNotNone(trending_section, "Trending auctions section with id 'trending-auctions-section' should exist")

        # Check navigation buttons
        browse_btn = soup.find('button', id='browse-auctions-button')
        self.assertIsNotNone(browse_btn, "Browse Auctions button with id 'browse-auctions-button' should exist")

        view_bids_btn = soup.find('button', id='view-bids-button')
        self.assertIsNotNone(view_bids_btn, "View Bid History button with id 'view-bids-button' should exist")

        trending_btn = soup.find('button', id='trending-auctions-button')
        self.assertIsNotNone(trending_btn, "Trending Auctions button with id 'trending-auctions-button' should exist")

    def test_dashboard_featured_auctions_elements(self):
        # Test Task 3: Verify featured auctions elements on dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        featured_auctions = soup.select('#featured-auctions .auction-card')
        # If there are featured auctions, check each auction card elements
        for card in featured_auctions:
            # Image with src attribute
            img = card.find('img')
            self.assertIsNotNone(img, "Auction card should have an image element")
            self.assertTrue(img.has_attr('src'), "Auction image should have 'src' attribute")

            # Title h3
            title = card.find('h3')
            self.assertIsNotNone(title, "Auction card should have a title h3 element")
            self.assertTrue(title.text.strip() != '', "Auction title should not be empty")

            # Current bid paragraph
            current_bid_p = card.find('p', string=lambda text: text and 'Current Bid' in text)
            self.assertIsNotNone(current_bid_p, "Auction card should display current bid")

            # Time remaining paragraph
            time_remaining_p = card.find('p', string=lambda text: text and 'Time Remaining' in text)
            self.assertIsNotNone(time_remaining_p, "Auction card should display time remaining")

            # View Details button with correct id
            btn = card.find('button', id=lambda x: x and x.startswith('view-auction-button-'))
            self.assertIsNotNone(btn, "Auction card should have a 'View Details' button with correct id")

    def test_dashboard_trending_auctions_elements(self):
        # Test Task 3: Verify trending auctions elements on dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        trending_auctions = soup.select('#trending-auctions-section .trending-auction-card')
        for card in trending_auctions:
            # Trending rank span
            rank_span = card.find('span', class_='trending-rank')
            self.assertIsNotNone(rank_span, "Trending auction card should have a trending rank span")

            # Title h3
            title = card.find('h3')
            self.assertIsNotNone(title, "Trending auction card should have a title h3 element")
            self.assertTrue(title.text.strip() != '', "Trending auction title should not be empty")

            # Current bid paragraph
            current_bid_p = card.find('p', string=lambda text: text and 'Current Bid' in text)
            self.assertIsNotNone(current_bid_p, "Trending auction card should display current bid")

            # Bid count paragraph
            bid_count_p = card.find('p', string=lambda text: text and 'Bid Count' in text)
            self.assertIsNotNone(bid_count_p, "Trending auction card should display bid count")

            # View Details button with correct id
            btn = card.find('button', id=lambda x: x and x.startswith('view-auction-button-'))
            self.assertIsNotNone(btn, "Trending auction card should have a 'View Details' button with correct id")

    def test_dashboard_navigation_buttons_functionality(self):
        # Test Task 2: Navigation buttons redirect to correct pages (simulate GET requests)
        # Browse Auctions button should lead to /catalog
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200, "Browse Auctions page '/catalog' should be accessible")

        # View Bid History button should lead to /bid_history
        response = self.client.get('/bid_history')
        self.assertEqual(response.status_code, 200, "Bid History page '/bid_history' should be accessible")

        # Trending Auctions button should lead to /trending
        response = self.client.get('/trending')
        self.assertEqual(response.status_code, 200, "Trending Auctions page '/trending' should be accessible")

if __name__ == '__main__':
    unittest.main()
