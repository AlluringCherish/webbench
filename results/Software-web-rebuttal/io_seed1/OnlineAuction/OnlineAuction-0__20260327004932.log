'''
HTML template for the Place Bid page of OnlineAuction web application.
Allows users to enter bid information for an auction item.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Place Bid</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}" defer></script>
</head>
<body>
<div id="place-bid-page">
    <h1>Place Bid</h1>
    <div id="auction-name">{{ auction.item_name }}</div>
    <div id="minimum-bid">Minimum Acceptable Bid: ${{ '%.2f'|format(minimum_bid) }}</div>

    {% if error %}
        <p class="error-message">{{ error }}</p>
    {% endif %}

    <form method="post" action="{{ url_for('place_bid', auction_id=auction.auction_id) }}">
        <label for="bidder-name">Bidder Name:</label><br>
        <input type="text" id="bidder-name" name="bidder-name" required><br><br>

        <label for="bid-amount">Bid Amount:</label><br>
        <input type="number" id="bid-amount" name="bid-amount" step="0.01" min="{{ minimum_bid }}" required><br><br>

        <button type="submit" id="submit-bid-button">Submit Bid</button>
    </form>

    <button id="back-to-dashboard">Back to Dashboard</button>
</div>
</body>
</html>
