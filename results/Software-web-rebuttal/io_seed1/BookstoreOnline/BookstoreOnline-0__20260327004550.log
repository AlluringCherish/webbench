    <form action="{{ url_for('write_review') }}" method="post">
        <label for="select-book">Select Book:</label><br>
        <select id="select-book" name="select-book" required>
            <option value="" disabled {% if not selected_book %}selected{% endif %}>Select a book</option>
            {% for book in books %}
