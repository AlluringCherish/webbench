dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bookstore Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="dashboard-page">
    <h1>Bookstore Dashboard</h1>
    <section id="featured-books">
        <h2>Featured Books</h2>
        <div class="books-list">
            {% for book in featured_books %}
            <div class="book-card">
                <h3>{{ book.title }}</h3>
                <p><strong>Author:</strong> {{ book.author }}</p>
                <p><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</p>
                <form action="{{ url_for('book_details', book_id=book.book_id) }}" method="get">
                    <button type="submit" id="view-book-button-{{ book.book_id }}">View Details</button>
                </form>
            </div>
            {% else %}
            <p>No featured books available.</p>
            {% endfor %}
        </div>
    </section>
    <section id="bestsellers-section">
        <h2>Bestsellers</h2>
        <div class="bestsellers-list">
            {% for bestseller in bestsellers %}
            <div class="bestseller-item">
                <span class="rank">{{ bestseller.rank }}.</span>
                <span class="title">{{ bestseller.title }}</span> by
                <span class="author">{{ bestseller.author }}</span>
                <span class="sales-count">({{ bestseller.sales_count }} sold)</span>
                <form action="{{ url_for('book_details', book_id=bestseller.book_id) }}" method="get" style="display:inline;">
                    <button type="submit" id="view-book-button-{{ bestseller.book_id }}">View Details</button>
                </form>
            </div>
            {% else %}
            <p>No bestsellers available.</p>
            {% endfor %}
        </div>
    </section>
    <section id="navigation-buttons">
        <form action="{{ url_for('go_to_catalog') }}" method="post" style="display:inline;">
            <button type="submit" id="browse-catalog-button">Browse Catalog</button>
        </form>
        <form action="{{ url_for('go_to_cart') }}" method="post" style="display:inline;">
            <button type="submit" id="view-cart-button">View Cart</button>
        </form>
        <form action="{{ url_for('go_to_bestsellers') }}" method="post" style="display:inline;">
            <button type="submit" id="bestsellers-button">Bestsellers</button>
        </form>
    </section>
</div>
</body>
</html>
