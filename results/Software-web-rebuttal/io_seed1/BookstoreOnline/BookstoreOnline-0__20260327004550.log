        </form>
        <form action="{{ url_for('go_to_cart') }}" method="post" style="display:inline;">
            <button type="submit" id="view-cart-button">View Cart</button>
        </form>
        <form action="{{ url_for('go_to_bestsellers') }}" method="post" style="display:inline;">
            <button type="submit" id="bestsellers-button">Bestsellers</button>
        </form>
    </section>
</div>
</body>
</html>
