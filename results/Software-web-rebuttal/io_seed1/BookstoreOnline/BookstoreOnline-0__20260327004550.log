write_review.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write a Review</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="write-review-page">
    <h1>Write a Review</h1>
    <form action="{{ url_for('write_review') }}" method="post">
        <label for="select-book">Select Book:</label><br>
        <select id="select-book" name="select-book" required>
            <option value="" disabled {% if not selected_book %}selected{% endif %}>Select a book</option>
            {% for book in books %}
            <option value="{{ book.book_id }}" {% if book.book_id == selected_book %}selected{% endif %}>{{ book.title }}</option>
            {% endfor %}
        </select><br><br>
        <label for="customer-name">Your Name:</label><br>
        <input type="text" id="customer-name" name="customer-name" value="{{ customer_name|default('') }}" required><br><br>
        <label for="rating-select">Rating:</label><br>
        <select id="rating-select" name="rating-select" required>
            <option value="" disabled {% if not selected_rating %}selected{% endif %}>Select rating</option>
            {% for i in range(1,6) %}
            <option value="{{ i }}" {% if selected_rating and selected_rating|int == i %}selected{% endif %}>{{ i }} star{% if i > 1 %}s{% endif %}</option>
            {% endfor %}
        </select><br><br>
        <label for="review-text">Review:</label><br>
        <textarea id="review-text" name="review-text" rows="5" cols="50" required>{{ review_text|default('') }}</textarea><br><br>
        <button type="submit" id="submit-review-button">Submit Review</button>
    </form>
    <form action="{{ url_for('reviews') }}" method="get">
        <button type="submit">Back to Reviews</button>
    </form>
</div>
</body>
</html>
```

bestsellers.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bestsellers</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="bestsellers-page">
    <h1>Bestsellers</h1>
    <form method="get" action="{{ url_for('bestsellers') }}">
        <label for="time-period-filter">Filter by Time Period:</label>
        <select id="time-period-filter" name="period" onchange="this.form.submit()">
            {% for period in time_periods %}
            <option value="{{ period }}" {% if period == selected_period %}selected{% endif %}>{{ period }}</option>
            {% endfor %}
        </select>
    </form>
    <div id="bestsellers-list">
        {% if bestsellers %}
        <ol>
            {% for bestseller in bestsellers %}
            <li>
                <span class="rank">{{ bestseller.rank }}.</span>
                <span class="title">{{ bestseller.title }}</span> by
                <span class="author">{{ bestseller.author }}</span>
                <span class="sales-count">({{ bestseller.sales_count }} sold)</span>
                <form action="{{ url_for('book_details', book_id=bestseller.book_id) }}" method="get" style="display:inline;">
                    <button type="submit" id="view-book-button-{{ bestseller.book_id }}">View Details</button>
                </form>
            </li>
            {% endfor %}
        </ol>
        {% else %}
        <p>No bestsellers available for this period.</p>
        {% endif %}
    </div>
    <form action="{{ url_for('back_to_dashboard') }}" method="post">
        <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
    </form>
</div>
</body>
</html>
