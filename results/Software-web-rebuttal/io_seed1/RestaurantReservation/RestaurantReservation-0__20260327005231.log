                <tr>
                    <td>{{ res.date }}</td>
                    <td>{{ res.time }}</td>
                    <td>{{ res.party_size }}</td>
                    <td>{{ res.special_requests if res.special_requests else '-' }}</td>
                    <td>{{ res.status }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p>No upcoming reservations.</p>
        {% endif %}
    </section>
    <section id="navigation-buttons" style="margin-top:30px;">
