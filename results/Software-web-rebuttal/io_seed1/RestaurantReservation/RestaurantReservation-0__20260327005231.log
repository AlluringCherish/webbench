}
#dashboard-page, #menu-page, #dish-details-page, #reservation-page, #my-reservations-page,
#waitlist-page, #reviews-page, #write-review-page, #profile-page {
    max-width: 900px;
    margin: 0 auto;
    background-color: #fff;
    padding: 25px 30px;
    border-radius: 8px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}
/* Headings */
h1 {
    font-size: 2.2rem;
    margin-bottom: 20px;
