        </form>
        <form action="{{ url_for('my_reservations') }}" method="get" style="display:inline;">
            <button type="submit" id="my-reservations-button">My Reservations</button>
        </form>
        <form action="{{ url_for('my_reviews') }}" method="get" style="display:inline;">
            <button type="submit" id="my-reviews-button">My Reviews</button>
        </form>
        <form action="{{ url_for('waitlist') }}" method="get" style="display:inline;">
            <button type="submit" id="waitlist-button">Waitlist</button>
        </form>
        <form action="{{ url_for('profile') }}" method="get" style="display:inline;">
            <button type="submit" id="profile-button">My Profile</button>
        </form>
    </section>
</div>
</body>
</html>
