            <button type="submit" id="view-menu-button">View Menu</button>
        </form>
        <form action="{{ url_for('back_to_dashboard') }}" method="get" style="display:inline;">
            <button type="submit" id="back-to-dashboard">Refresh Dashboard</button>
        </form>
        <form action="{{ url_for('my_reservations') }}" method="get" style="display:inline;">
            <button type="submit" id="my-reservations-button">My Reservations</button>
