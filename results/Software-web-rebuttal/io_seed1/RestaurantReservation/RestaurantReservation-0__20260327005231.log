                    <th>Date</th>
                    <th>Time</th>
                    <th>Party Size</th>
                    <th>Special Requests</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for res in upcoming_reservations %}
                <tr>
                    <td>{{ res.date }}</td>
                    <td>{{ res.time }}</td>
                    <td>{{ res.party_size }}</td>
                    <td>{{ res.special_requests if res.special_requests else '-' }}</td>
                    <td>{{ res.status }}</td>
