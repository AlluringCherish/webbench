/* Reset some default styles */
body, h1, h2, h3, p, ul, li, table, th, td, input, select, textarea, button, form {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}
/* Body and container */
body {
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.5;
