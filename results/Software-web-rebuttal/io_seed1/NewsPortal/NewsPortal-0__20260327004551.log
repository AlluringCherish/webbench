            </ul>
        {% else %}
            <p>No featured articles available.</p>
        {% endif %}
    </section>
    <section id="trending-articles">
        <h2>Trending News</h2>
        {% if trending_articles %}
            <ul>
                {% for t in trending_articles %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=t.article_id) }}">{{ t.article_title }}</a>
                        <div>Category: {{ t.category }} | Views: {{ t.view_count }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No trending articles available.</p>
        {% endif %}
    </section>
    <div>
        <button id="browse-articles-button" onclick="location.href='{{ url_for('article_catalog') }}'">Browse Articles</button>
        <button id="view-bookmarks-button" onclick="location.href='{{ url_for('bookmarks') }}'">View Bookmarks</button>
        <button id="trending-articles-button" onclick="location.href='{{ url_for('trending_articles') }}'">Trending Articles</button>
    </div>
</div>
</body>
</html>
```

article_catalog.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Article Catalog</title>
</head>
<body>
<div id="catalog-page">
    <h1>Article Catalog</h1>
    <form method="get" action="{{ url_for('article_catalog') }}">
        <input type="text" id="search-input" name="search" placeholder="Search articles..." value="{{ search_query }}">
        <select id="category-filter" name="category">
            <option value="">All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category|lower == category.category_name|lower %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="articles-grid">
        {% if articles %}
            <ul>
                {% for article in articles %}
                    <li>
                        <!-- Thumbnail placeholder: no image data provided -->
                        <div><strong>{{ article.title }}</strong></div>
                        <div>By {{ article.author }} | {{ article.date }}</div>
                        <button id="view-article-button-{{ article.article_id }}" onclick="location.href='{{ url_for('article_details', article_id=article.article_id) }}'">View Article</button>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No articles found.</p>
        {% endif %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

