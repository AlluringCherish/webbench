<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>News Portal</title>
</head>
<body>
<div id="dashboard-page">
    <h1>News Portal</h1>
    <section id="featured-articles">
        <h2>Featured Articles</h2>
        {% if featured_articles %}
            <ul>
                {% for article in featured_articles %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.title }}</a>
                        <div>By {{ article.author }} | {{ article.date }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No featured articles available.</p>
        {% endif %}
    </section>

    <section id="trending-articles">
        <h2>Trending News</h2>
        {% if trending_articles %}
            <ul>
                {% for t in trending_articles %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=t.article_id) }}">{{ t.article_title }}</a>
                        <div>Category: {{ t.category }} | Views: {{ t.view_count }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No trending articles available.</p>
        {% endif %}
    </section>

    <div>
        <button id="browse-articles-button" onclick="location.href='{{ url_for('article_catalog') }}'">Browse Articles</button>
        <button id="view-bookmarks-button" onclick="location.href='{{ url_for('bookmarks') }}'">View Bookmarks</button>
        <button id="trending-articles-button" onclick="location.href='{{ url_for('trending_articles') }}'">Trending Articles</button>
    </div>
</div>
</body>
</html>
