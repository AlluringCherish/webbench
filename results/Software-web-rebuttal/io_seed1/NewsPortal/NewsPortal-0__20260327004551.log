styles.css
```css
/*
styles.css
Consistent and clean styling for NewsPortal web application pages.
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    padding: 20px;
}
/* Container divs for pages */
#dashboard-page,
#catalog-page,
#article-details-page,
#bookmarks-page,
#comments-page,
#write-comment-page,
#trending-page,
#category-page,
#search-results-page {
    max-width: 900px;
    margin: 0 auto;
    background-color: #fff;
    padding: 25px 30px;
    border-radius: 6px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}
/* Headings */
h1 {
    font-size: 2.2em;
    margin-bottom: 20px;
    color: #222;
}
h2 {
    font-size: 1.6em;
    margin-bottom: 15px;
    color: #444;
}
/* Lists */
ul, ol {
    list-style: none;
    margin-bottom: 20px;
}
ul li, ol li {
    background-color: #f0f0f0;
    margin-bottom: 12px;
    padding: 12px 15px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
}
ul li:hover, ol li:hover {
    background-color: #e0e0e0;
}
/* Links */
a {
    color: #007BFF;
    text-decoration: none;
}
a:hover {
    text-decoration: underline;
}
/* Buttons */
button {
    background-color: #007BFF;
    color: white;
    border: none;
    padding: 8px 16px;
    margin: 5px 3px 5px 0;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1em;
    transition: background-color 0.3s ease;
}
button:disabled,
button[disabled] {
    background-color: #999;
    cursor: not-allowed;
}
button:hover:not(:disabled) {
    background-color: #0056b3;
}
/* Forms */
form {
    margin-bottom: 20px;
}
input[type="text"],
select,
textarea {
    width: 100%;
    padding: 8px 10px;
    margin-top: 6px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1em;
    resize: vertical;
}
label {
    font-weight: bold;
    display: block;
    margin-top: 10px;
}
/* Sections */
section {
    margin-bottom: 30px;
}
/* Featured Articles and Trending News on Dashboard */
#featured-articles ul,
#trending-articles ul {
    padding-left: 15px;
}
#featured-articles li,
#trending-articles li {
    padding: 10px 0;
    border-bottom: 1px solid #ddd;
}
#featured-articles li:last-child,
#trending-articles li:last-child {
    border-bottom: none;
}
/* Article Cards in Article Catalog */
#articles-grid ul li {
    display: flex;
    flex-direction: column;
    border: 1px solid #ddd;
    padding: 15px;
    border-radius: 5px;
    background-color: #fff;
}
#articles-grid ul li > div:first-child {
    font-weight: bold;
    font-size: 1.1em;
    margin-bottom: 6px;
}
/* Article Details */
#article-content p {
    white-space: pre-wrap;
    margin-top: 15px;
    font-size: 1.1em;
}
/* Bookmarks List */
#bookmarks-list ul li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-bottom: 1px solid #ddd;
}
#bookmarks-list ul li div {
    flex-grow: 1;
}
/* Comments List */
#comments-list ul li {
    border-bottom: 1px solid #ddd;
    padding: 12px 10px;
    margin-bottom: 10px;
    background-color: #fafafa;
    border-radius: 4px;
}
#comments-list ul li div:first-child {
