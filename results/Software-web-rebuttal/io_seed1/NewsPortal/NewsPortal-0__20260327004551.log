                        <div><em>{{ comment.commenter_name }}</em> on {{ comment.comment_date }}</div>
                        <div>{{ comment.comment_text }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No comments found.</p>
        {% endif %}
    </div>
    <button id="write-comment-button" onclick="location.href='{{ url_for('write_comment') }}'">Write a Comment</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

write_comment.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write a Comment</title>
</head>
<body>
<div id="write-comment-page">
    <h1>Write a Comment</h1>
    {% if error %}
        <p style="color:red;">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ url_for('write_comment') }}">
        <label for="select-article">Select Article:</label>
        <select id="select-article" name="select-article" required>
            <option value="">-- Select an article --</option>
            {% for article in articles %}
                <option value="{{ article.article_id }}" {% if selected_article_id == article.article_id %}selected{% endif %}>{{ article.title }}</option>
            {% endfor %}
        </select><br><br>
        <label for="commenter-name">Your Name:</label>
        <input type="text" id="commenter-name" name="commenter-name" value="{{ commenter_name|default('') }}" required><br><br>
        <label for="comment-text">Comment:</label><br>
        <textarea id="comment-text" name="comment-text" rows="5" cols="50" required>{{ comment_text|default('') }}</textarea><br><br>
        <button id="submit-comment-button" type="submit">Submit Comment</button>
    </form>
    <button onclick="location.href='{{ url_for('comments') }}'">Back to Comments</button>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

trending_articles.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trending Articles</title>
</head>
<body>
<div id="trending-page">
    <h1>Trending Articles</h1>
    <form method="get" action="{{ url_for('trending_articles') }}">
        <label for="time-period-filter">Filter by Time Period:</label>
        <select id="time-period-filter" name="period" onchange="this.form.submit()">
            <option value="" {% if not selected_period %}selected{% endif %}>All</option>
            <option value="Today" {% if selected_period == 'Today' %}selected{% endif %}>Today</option>
            <option value="This Week" {% if selected_period == 'This Week' %}selected{% endif %}>This Week</option>
            <option value="This Month" {% if selected_period == 'This Month' %}selected{% endif %}>This Month</option>
        </select>
    </form>
    <div id="trending-list">
        {% if trending_articles %}
            <ol>
                {% for article in trending_articles %}
                    <li>
                        <div>Rank {{ loop.index }}: <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.article_title }}</a></div>
                        <div>Category: {{ article.category }} | Views: {{ article.view_count }}</div>
                        <button id="view-article-button-{{ article.article_id }}" onclick="location.href='{{ url_for('article_details', article_id=article.article_id) }}'">View Article</button>
                    </li>
                {% endfor %}
            </ol>
        {% else %}
            <p>No trending articles found.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

category.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Category Articles</title>
</head>
<body>
<div id="category-page">
    <h1 id="category-title">{{ category.category_name }}</h1>
    <div>
        <button id="sort-by-date" onclick="location.href='{{ url_for('category_page', category_name=category.category_name, sort='date') }}'">Sort by Date</button>
        <button id="sort-by-popularity" onclick="location.href='{{ url_for('category_page', category_name=category.category_name, sort='popularity') }}'">Sort by Popularity</button>
    </div>
    <div id="category-articles">
        {% if articles %}
            <ul>
                {% for article in articles %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.title }}</a>
                        <div>By {{ article.author }} | {{ article.date }} | Views: {{ article.views }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No articles found in this category.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
