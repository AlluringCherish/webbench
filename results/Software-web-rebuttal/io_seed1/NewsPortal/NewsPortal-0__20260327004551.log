<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trending Articles</title>
</head>
<body>
<div id="trending-page">
    <h1>Trending Articles</h1>
    <form method="get" action="{{ url_for('trending_articles') }}">
        <label for="time-period-filter">Filter by Time Period:</label>
        <select id="time-period-filter" name="period" onchange="this.form.submit()">
            <option value="" {% if not selected_period %}selected{% endif %}>All</option>
            <option value="Today" {% if selected_period == 'Today' %}selected{% endif %}>Today</option>
            <option value="This Week" {% if selected_period == 'This Week' %}selected{% endif %}>This Week</option>
            <option value="This Month" {% if selected_period == 'This Month' %}selected{% endif %}>This Month</option>
        </select>
    </form>
    <div id="trending-list">
        {% if trending_articles %}
            <ol>
                {% for article in trending_articles %}
                    <li>
                        <div>Rank {{ loop.index }}: <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.article_title }}</a></div>
                        <div>Category: {{ article.category }} | Views: {{ article.view_count }}</div>
                        <button id="view-article-button-{{ article.article_id }}" onclick="location.href='{{ url_for('article_details', article_id=article.article_id) }}'">View Article</button>
                    </li>
                {% endfor %}
            </ol>
        {% else %}
            <p>No trending articles found.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

category.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Category Articles</title>
</head>
<body>
<div id="category-page">
    <h1 id="category-title">{{ category.category_name }}</h1>
    <div>
        <button id="sort-by-date" onclick="location.href='{{ url_for('category_page', category_name=category.category_name, sort='date') }}'">Sort by Date</button>
        <button id="sort-by-popularity" onclick="location.href='{{ url_for('category_page', category_name=category.category_name, sort='popularity') }}'">Sort by Popularity</button>
    </div>
    <div id="category-articles">
        {% if articles %}
            <ul>
                {% for article in articles %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.title }}</a>
                        <div>By {{ article.author }} | {{ article.date }} | Views: {{ article.views }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No articles found in this category.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

search_results.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Results</title>
</head>
<body>
<div id="search-results-page">
    <h1>Search Results</h1>
    <div id="search-query-display">
        {% if query %}
            <p>Search query: "{{ query }}"</p>
        {% else %}
            <p>No search query provided.</p>
        {% endif %}
    </div>
    <div id="results-list">
        {% if results %}
            <ul>
                {% for article in results %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.title }}</a>
                        <p>{{ article.content[:150] }}{% if article.content|length > 150 %}...{% endif %}</p>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <div id="no-results-message">
                <p>No results found.</p>
            </div>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

styles.css
```css
/*
styles.css
Consistent and clean styling for NewsPortal web application pages.
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    padding: 20px;
}
/* Container divs for pages */
#dashboard-page,
#catalog-page,
#article-details-page,
#bookmarks-page,
#comments-page,
#write-comment-page,
#trending-page,
#category-page,
#search-results-page {
    max-width: 900px;
    margin: 0 auto;
    background-color: #fff;
    padding: 25px 30px;
    border-radius: 6px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}
/* Headings */
h1 {
    font-size: 2.2em;
    margin-bottom: 20px;
    color: #222;
}
h2 {
    font-size: 1.6em;
    margin-bottom: 15px;
    color: #444;
}
/* Lists */
ul, ol {
    list-style: none;
    margin-bottom: 20px;
}
ul li, ol li {
    background-color: #f0f0f0;
    margin-bottom: 12px;
    padding: 12px 15px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
}
ul li:hover, ol li:hover {
    background-color: #e0e0e0;
}
/* Links */
a {
    color: #007BFF;
    text-decoration: none;
}
a:hover {
    text-decoration: underline;
}
/* Buttons */
button {
    background-color: #007BFF;
    color: white;
    border: none;
    padding: 8px 16px;
    margin: 5px 3px 5px 0;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1em;
    transition: background-color 0.3s ease;
}
button:disabled,
button[disabled] {
    background-color: #999;
    cursor: not-allowed;
}
button:hover:not(:disabled) {
    background-color: #0056b3;
}
/* Forms */
form {
    margin-bottom: 20px;
}
input[type="text"],
select,
textarea {
    width: 100%;
    padding: 8px 10px;
    margin-top: 6px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1em;
    resize: vertical;
}
label {
    font-weight: bold;
    display: block;
    margin-top: 10px;
}
/* Sections */
section {
    margin-bottom: 30px;
}
/* Featured Articles and Trending News on Dashboard */
#featured-articles ul,
#trending-articles ul {
    padding-left: 15px;
}
#featured-articles li,
#trending-articles li {
    padding: 10px 0;
    border-bottom: 1px solid #ddd;
}
#featured-articles li:last-child,
#trending-articles li:last-child {
    border-bottom: none;
}
/* Article Cards in Article Catalog */
#articles-grid ul li {
    display: flex;
    flex-direction: column;
    border: 1px solid #ddd;
    padding: 15px;
    border-radius: 5px;
    background-color: #fff;
}
#articles-grid ul li > div:first-child {
    font-weight: bold;
    font-size: 1.1em;
    margin-bottom: 6px;
}
/* Article Details */
#article-content p {
    white-space: pre-wrap;
    margin-top: 15px;
    font-size: 1.1em;
}
/* Bookmarks List */
#bookmarks-list ul li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-bottom: 1px solid #ddd;
}
#bookmarks-list ul li div {
    flex-grow: 1;
}
/* Comments List */
#comments-list ul li {
    border-bottom: 1px solid #ddd;
    padding: 12px 10px;
    margin-bottom: 10px;
    background-color: #fafafa;
    border-radius: 4px;
}
#comments-list ul li div:first-child {
    font-weight: bold;
    margin-bottom: 4px;
}
#comments-list ul li div:nth-child(2) {
    font-style: italic;
    font-size: 0.9em;
    margin-bottom: 6px;
}
/* Trending Articles List */
#trending-list ol li {
    padding: 12px 10px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 10px;
    background-color: #fff;
    border-radius: 4px;
}
#trending-list ol li div:first-child {
    font-weight: bold;
    margin-bottom: 6px;
}
/* Category Articles */
#category-articles ul li {
    padding: 10px 12px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 8px;
    background-color: #fff;
    border-radius: 4px;
}
#category-articles ul li div {
    font-size: 0.9em;
    color: #555;
}
/* Search Results */
#results-list ul li {
    padding: 12px 10px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 10px;
    background-color: #fff;
    border-radius: 4px;
}
#results-list ul li p {
    margin-top: 6px;
    color: #555;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    body {
        padding: 10px;
    }
    #dashboard-page,
    #catalog-page,
    #article-details-page,
    #bookmarks-page,
    #comments-page,
    #write-comment-page,
    #trending-page,
    #category-page,
    #search-results-page {
        padding: 15px 20px;
    }
    button {
        width: 100%;
        margin: 8px 0;
    }
}
