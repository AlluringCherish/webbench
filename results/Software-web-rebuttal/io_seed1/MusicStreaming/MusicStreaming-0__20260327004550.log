        return songs
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            song = {
                'song_id': parts[0],
                'title': parts[1],
                'artist_id': parts[2],
                'album_id': parts[3],
                'genre': parts[4],
                'duration': int(parts[5]),
                'release_date': parts[6],
                'play_count': int(parts[7])
            }
            songs.append(song)
    return songs
