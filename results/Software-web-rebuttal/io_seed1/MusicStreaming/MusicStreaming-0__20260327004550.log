        {% if albums %}
            <ul>
                {% for album in albums %}
                    <li>
                        <div class="album-card">
                            <div class="album-info">
                                <strong>{{ album.title }}</strong><br>
                                Artist: <a href="{{ url_for('artist_profile', artist_id=album.artist_id) }}">{{ album.artist_name }}</a><br>
                                Year: {{ album.release_year }}
                            </div>
                            <button id="view-album-button-{{ album.album_id }}" onclick="location.href='{{ url_for('album_details', album_id=album.album_id) }}'">View</button>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No albums found.</p>
        {% endif %}
    </div>
    <nav>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
