                continue
            artist = {
                'artist_id': parts[0],
                'name': parts[1],
                'genre': parts[2],
                'country': parts[3],
                'formation_year': parts[4]
            }
            artists.append(artist)
    return artists
def write_artists(artists):
    path = os.path.join(DATA_DIR, 'artists.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for a in artists:
            line = '|'.join([
                a['artist_id'],
                a['name'],
                a['genre'],
                a['country'],
                a['formation_year']
            ])
            f.write(line + '\n')
def read_albums():
    albums = []
    path = os.path.join(DATA_DIR, 'albums.txt')
