                        <button id="continue-learning-button-{{ course.course_id }}" onclick="location.href='{{ url_for('course_learning', course_id=course.course_id) }}'">Continue Learning</button>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You are not enrolled in any courses.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

course_learning.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Course Learning</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="learning-page">
    <h1>{{ course.title }}</h1>
    <p>Progress: {{ progress }}%</p>
    <div id="lessons-list">
        <h2>Lessons</h2>
        <ul>
            {% for lesson in lessons %}
                <li>
                    {% if lesson.lesson_id in completed_lessons %}
                        <strong>{{ lesson.title }} (Completed)</strong>
                    {% elif lesson.lesson_id == current_lesson.lesson_id %}
                        <strong>{{ lesson.title }} (Current)</strong>
                    {% else %}
                        {{ lesson.title }}
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
    <div id="lesson-content">
        <h3>{{ current_lesson.title }}</h3>
        <p>{{ current_lesson.content }}</p>
    </div>
    <form method="post" action="{{ url_for('course_learning', course_id=course.course_id) }}">
        <button id="mark-complete-button" type="submit">Mark Complete</button>
    </form>
    <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
</div>
</body>
</html>
```

my_assignments.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Assignments</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="assignments-page">
    <h1>My Assignments</h1>
    <table id="assignments-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Due Date</th>
                <th>Max Points</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% if assignments %}
                {% for assignment in assignments %}
                    <tr>
                        <td>{{ assignment.title }}</td>
                        <td>{{ assignment.description }}</td>
                        <td>{{ assignment.due_date }}</td>
                        <td>{{ assignment.max_points }}</td>
                        <td>{{ assignment.status }}</td>
                        <td>
                            {% if assignment.status == 'Pending' %}
                                <button id="submit-assignment-button-{{ assignment.assignment_id }}" onclick="location.href='{{ url_for('submit_assignment', assignment_id=assignment.assignment_id) }}'">Submit</button>
                            {% else %}
                                Submitted
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="6">No assignments found.</td>
                </tr>
            {% endif %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

