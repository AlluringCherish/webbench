        {% if enrolled_courses %}
            <ul>
                {% for course in enrolled_courses %}
                    <li>
                        <strong>{{ course.title }}</strong> - Progress: {{ course.progress }}% - Status: {{ course.status }}
                        <button id="continue-learning-button-{{ course.course_id }}" onclick="location.href='{{ url_for('course_learning', course_id=course.course_id) }}'">Continue Learning</button>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You are not enrolled in any courses.</p>
        {% endif %}
    </div>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
