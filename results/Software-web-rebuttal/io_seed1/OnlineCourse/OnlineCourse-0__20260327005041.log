templates/course_learning.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Course Learning</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="learning-page">
    <h1>{{ course.title }}</h1>
    <p>Progress: {{ progress }}%</p>

    <div id="lessons-list">
        <h2>Lessons</h2>
        <ul>
            {% for lesson in lessons %}
                <li>
                    {% if lesson.lesson_id in completed_lessons %}
                        <strong>{{ lesson.title }} (Completed)</strong>
                    {% elif lesson.lesson_id == current_lesson.lesson_id %}
                        <strong>{{ lesson.title }} (Current)</strong>
                    {% else %}
                        {{ lesson.title }}
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>

    <div id="lesson-content">
        <h3>{{ current_lesson.title }}</h3>
        <p>{{ current_lesson.content }}</p>
    </div>

    <form method="post" action="{{ url_for('course_learning', course_id=course.course_id) }}">
        <button id="mark-complete-button" type="submit">Mark Complete</button>
    </form>

    <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
</div>
</body>
</html>
```

