                        'status': parts[6]
                    }
    return courses
def read_enrollments():
    enrollments = {}
    path = os.path.join(DATA_DIR, 'enrollments.txt')
    if not os.path.exists(path):
        return enrollments
    with open(path, 'r', encoding='utf-8') as f:
