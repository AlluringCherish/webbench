'''
Testing Task 1, 2 and 3:
- Test whether the website can be accessed through local port 5000 (Dashboard page).
- Test whether the first page (Dashboard) loads correctly with example data.
- Test basic navigation from Dashboard to Course Catalog and My Courses pages.
- Test presence and correctness of all specified elements on Dashboard page as per requirements.
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class OnlineCourseTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
        self.ctx = app.app_context()
        self.ctx.push()
        # Log in as example user 'john' to access dashboard
        with self.client:
            self.client.post('/login', data={'username': 'john'}, follow_redirects=True)
    def tearDown(self):
        self.ctx.pop()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible at '/' and returns 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
    def test_dashboard_page_elements(self):
        # Test that dashboard page contains required elements with correct IDs and content
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' not found")
        # Check welcome message h1 with id 'welcome-message' contains user's full name
        welcome_h1 = dashboard_div.find('h1', id='welcome-message')
        self.assertIsNotNone(welcome_h1, "Welcome message h1 with id 'welcome-message' not found")
        self.assertIn('John Student', welcome_h1.text, "Welcome message does not contain user's full name")
        # Check enrolled courses div with id 'enrolled-courses'
        enrolled_div = dashboard_div.find('div', id='enrolled-courses')
        self.assertIsNotNone(enrolled_div, "Enrolled courses div with id 'enrolled-courses' not found")
        # Since user 'john' is enrolled in courses per example data, check that enrolled courses list exists
        ul = enrolled_div.find('ul')
        self.assertIsNotNone(ul, "Enrolled courses list (ul) not found")
        # Check that at least one enrolled course is listed with progress and status
        li_items = ul.find_all('li')
        self.assertGreater(len(li_items), 0, "No enrolled courses listed for user 'john'")
        # Check format of first course list item text includes 'Progress:' and 'Status:'
        first_course_text = li_items[0].text
        self.assertIn('Progress:', first_course_text)
        self.assertIn('Status:', first_course_text)
        # Check buttons with ids 'browse-courses-button' and 'my-courses-button'
        browse_button = dashboard_div.find('button', id='browse-courses-button')
        self.assertIsNotNone(browse_button, "Browse Courses button with id 'browse-courses-button' not found")
        my_courses_button = dashboard_div.find('button', id='my-courses-button')
        self.assertIsNotNone(my_courses_button, "My Courses button with id 'my-courses-button' not found")
    def test_dashboard_navigation_buttons(self):
        # Test that clicking browse courses button navigates to course catalog page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        browse_button = soup.find('button', id='browse-courses-button')
        self.assertIsNotNone(browse_button)
        # The button uses onclick with location.href, extract URL
        onclick = browse_button.get('onclick')
        self.assertIsNotNone(onclick)
        self.assertIn('/course_catalog', onclick)
        # The my courses button navigates to my_courses page
        my_courses_button = soup.find('button', id='my-courses-button')
        self.assertIsNotNone(my_courses_button)
        onclick = my_courses_button.get('onclick')
        self.assertIsNotNone(onclick)
        self.assertIn('/my_courses', onclick)
    def test_dashboard_redirects_without_login(self):
        # Test that accessing dashboard without login redirects to login page
        with self.client:
            self.client.get('/logout', follow_redirects=True)
            response = self.client.get('/', follow_redirects=False)
            self.assertEqual(response.status_code, 302)
            self.assertIn('/login', response.headers['Location'])
if __name__ == '__main__':
    unittest.main()

