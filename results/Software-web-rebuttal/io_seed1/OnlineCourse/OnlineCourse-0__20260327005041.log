        for line in f:
            line = line.strip()
            if line:
                parts = line.split('|')
                if len(parts) == 6:
                    assignment_id = parts[0]
                    assignments[assignment_id] = {
                        'assignment_id': assignment_id,
                        'course_id': parts[1],
                        'title': parts[2],
                        'description': parts[3],
                        'due_date': parts[4],
                        'max_points': int(parts[5])
                    }
    return assignments
def read_submissions():
    submissions = {}
