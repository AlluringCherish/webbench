        return courses
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if line:
                parts = line.split('|')
                if len(parts) == 7:
                    course_id = parts[0]
                    courses[course_id] = {
                        'course_id': course_id,
                        'title': parts[1],
                        'description': parts[2],
                        'category': parts[3],
