@app.before_request
def require_login():
    # Allow static files and login route
    allowed_routes = ['login', 'static']
    if request.endpoint not in allowed_routes and 'username' not in session:
        # For demo, auto-login as 'john' if no session
        session['username'] = 'john'
@app.route('/logout')
def logout():
