    <meta charset="UTF-8">
    <title>Participants Management</title>
</head>
<body>
    <div id="participants-page">
        <h1>Participants Management</h1>
        <form method="get" action="{{ url_for('participants_management') }}">
            <input id="search-participant-input" type="text" name="search" placeholder="Search participants" value="{{ search_query }}">
            <select id="participant-status-filter" name="status">
                <option value="">All Statuses</option>
                <option value="Registered" {% if status_filter == 'Registered' %}selected{% endif %}>Registered</option>
                <option value="Confirmed" {% if status_filter == 'Confirmed' %}selected{% endif %}>Confirmed</option>
                <option value="Attended" {% if status_filter == 'Attended' %}selected{% endif %}>Attended</option>
            </select>
            <button type="submit">Filter</button>
        </form>
        <button id="add-participant-button" onclick="alert('Add participant functionality not implemented.')">Add Participant</button>
        <table id="participants-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Registration Date</th>
                </tr>
            </thead>
            <tbody>
                {% for p in participants %}
                <tr>
                    <td>{{ p.name }}</td>
                    <td>{{ p.email }}</td>
                    <td>{{ p.event_name }}</td>
                    <td>{{ p.status }}</td>
                    <td>{{ p.registration_date }}</td>
                </tr>
                {% else %}
                <tr><td colspan="5">No participants found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/venues.html
