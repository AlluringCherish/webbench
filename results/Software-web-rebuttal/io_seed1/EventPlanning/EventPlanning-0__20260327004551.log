                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 9:
                        event = {
                            'event_id': parts[0],
                            'event_name': parts[1],
                            'category': parts[2],
                            'date': parts[3],
                            'time': parts[4],
                            'location': parts[5],
                            'description': parts[6],
                            'venue_id': parts[7],
                            'capacity': parts[8]
                        }
                        events.append(event)
    except FileNotFoundError:
        pass
    return events
