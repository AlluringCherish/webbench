templates/schedules.html
```html
'''
Event Schedules page template for EventPlanning web application.
Displays schedules with date and event filters.
Navigation uses url_for routing.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Schedules</title>
</head>
<body>
    <div id="schedules-page">
        <h1>Event Schedules</h1>
        <form method="get" action="{{ url_for('schedules_page') }}">
            <label for="schedule-filter-date">Filter by Date:</label>
            <input id="schedule-filter-date" type="date" name="date" value="{{ filter_date }}">
            <label for="schedule-filter-event">Filter by Event:</label>
            <select id="schedule-filter-event" name="event">
                <option value="">All Events</option>
                {% for event in events %}
                <option value="{{ event.event_id }}" {% if filter_event == event.event_id %}selected{% endif %}>{{ event.event_name }}</option>
                {% endfor %}
            </select>
            <button type="submit">Filter</button>
        </form>
        <div id="schedules-timeline">
            <ul>
                {% for schedule in schedules %}
                <li>
                    <strong>{{ schedule.session_title }}</strong> - {{ schedule.session_time }} ({{ schedule.duration_minutes }} mins) by {{ schedule.speaker }} at Venue ID {{ schedule.venue_id }} (Event: {{ schedule.event_name }})
                </li>
                {% else %}
                <li>No schedules found.</li>
                {% endfor %}
            </ul>
        </div>
        <button id="export-schedule-button" onclick="location.href='{{ url_for('export_schedule') }}'">Export Schedule</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/bookings.html
```html
'''
Bookings Summary page template for EventPlanning web application.
Displays user bookings with search and cancel booking functionality.
Navigation uses url_for routing.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings</title>
</head>
<body>
    <div id="bookings-page">
        <h1>My Bookings</h1>
        <form method="get" action="{{ url_for('bookings_summary') }}">
            <input id="booking-search-input" type="text" name="search" placeholder="Search bookings" value="{{ search_query }}">
            <button type="submit">Search</button>
        </form>
        <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Ticket Count</th>
                    <th>Ticket Type</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for booking in bookings %}
                <tr>
                    <td>{{ booking.booking_id }}</td>
                    <td>{{ booking.event_name }}</td>
                    <td>{{ booking.booking_date }}</td>
                    <td>{{ booking.ticket_count }}</td>
                    <td>{{ booking.ticket_type }}</td>
                    <td>${{ booking.total_amount }}</td>
                    <td>{{ booking.status }}</td>
                    <td>
                        {% if booking.status != 'Cancelled' %}
                        <form method="post" action="{{ url_for('cancel_booking', booking_id=booking.booking_id) }}" style="display:inline;">
                            <button id="cancel-booking-button-{{ booking.booking_id }}" type="submit">Cancel</button>
                        </form>
                        {% else %}
                        N/A
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8">No bookings found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```
