templates/showtime_selection.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="showtime-page">
        <h1>Select Showtime</h1>

        <form method="get" action="{{ url_for('showtime_selection') }}">
            <label for="movie-filter">Movie:</label>
            <select id="movie-filter" name="movie">
                {% for movie_id in movie_options %}
                    <option value="{{ movie_id }}" {% if movie_id == movie_filter %}selected{% endif %}>
                        {% if movie_id == 'All' %}
                            All
                        {% else %}
                            {{ movie_titles[movie_id] }}
                        {% endif %}
                    </option>
                {% endfor %}
            </select>

            <label for="theater-filter">Theater:</label>
            <select id="theater-filter" name="theater">
                {% for theater_id in theater_options %}
                    <option value="{{ theater_id }}" {% if theater_id == theater_filter %}selected{% endif %}>
                        {% if theater_id == 'All' %}
                            All
                        {% else %}
                            {{ theater_names[theater_id] }}
                        {% endif %}
                    </option>
                {% endfor %}
            </select>

            <label for="date-filter">Date:</label>
            <input type="date" id="date-filter" name="date" value="{{ date_filter }}">

            <button type="submit">Filter</button>
        </form>

        <div id="showtimes-list">
            {% if showtimes %}
                <table>
                    <thead>
                        <tr>
                            <th>Movie</th>
                            <th>Theater</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Price</th>
                            <th>Available Seats</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for showtime in showtimes %}
                            <tr>
                                <td>{{ showtime.movie_title }}</td>
                                <td>{{ showtime.theater_name }}</td>
                                <td>{{ showtime.showtime_date }}</td>
                                <td>{{ showtime.showtime_time }}</td>
                                <td>${{ "%.2f"|format(showtime.price) }}</td>
                                <td>{{ showtime.available_seats }}</td>
                                <td>
                                    <button id="select-showtime-button-{{ showtime.showtime_id }}" onclick="location.href='{{ url_for('seat_selection', showtime_id=showtime.showtime_id) }}'">Select</button>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p>No showtimes available for the selected filters.</p>
            {% endif %}
        </div>

        <nav>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
</body>
</html>
```

templates/seat_selection.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="seat-selection-page">
        <h1>Select Seats for {{ showtime.showtime_date }} at {{ showtime.showtime_time }}</h1>

        <form method="post" action="{{ url_for('seat_selection', showtime_id=showtime.showtime_id) }}">
            <div id="seat-map">
                {% for row, seats in seat_map.items()|sort %}
                    <div class="seat-row" id="row-{{ row }}">
                        <span class="row-label">{{ row }}</span>
                        {% for seat in seats %}
                            {% set seat_label = seat.row + seat.column %}
                            <button type="button"
                                    id="seat-{{ seat_label }}"
                                    class="seat-button {% if seat.status != 'Available' %}booked{% else %}available{% endif %}"
                                    {% if seat.status == 'Available' %}
                                        onclick="toggleSeatSelection(this)"
                                        data-seat-label="{{ seat_label }}"
                                    {% else %}
                                        disabled
                                    {% endif %}>
                                {{ seat_label }}
                            </button>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>

            <div id="selected-seats-display">
                <h3>Selected Seats:</h3>
                <div id="selected-seats-list"></div>
            </div>

            <input type="hidden" name="selected_seats" id="selected_seats_input" value="">

            <button type="submit" id="proceed-booking-button">Proceed to Booking</button>
        </form>

        <nav>
            <button onclick="location.href='{{ url_for('showtime_selection') }}'">Back to Showtimes</button>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>

    <script>
        // JavaScript to handle seat selection UI and form submission
        const selectedSeats = new Set();

        function toggleSeatSelection(button) {
            const seatLabel = button.getAttribute('data-seat-label');
            if (selectedSeats.has(seatLabel)) {
                selectedSeats.delete(seatLabel);
                button.classList.remove('selected');
            } else {
                selectedSeats.add(seatLabel);
                button.classList.add('selected');
            }
            updateSelectedSeatsDisplay();
        }

        function updateSelectedSeatsDisplay() {
            const displayDiv = document.getElementById('selected-seats-list');
            displayDiv.textContent = Array.from(selectedSeats).join(', ') || 'None';
            document.getElementById('selected_seats_input').value = Array.from(selectedSeats).join(',');
        }

        // Initialize display on page load
        document.addEventListener('DOMContentLoaded', () => {
            updateSelectedSeatsDisplay();
        });
    </script>
</body>
</html>
```

