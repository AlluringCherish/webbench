<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="catalog-page">
        <h1>Movie Catalog</h1>

        <form method="get" action="{{ url_for('movie_catalog') }}">
            <input type="text" id="search-input" name="search" placeholder="Search by title or genre" value="{{ search_query }}">
            <select id="genre-filter" name="genre">
                {% for genre in genres %}
                    <option value="{{ genre }}" {% if genre == selected_genre %}selected{% endif %}>{{ genre }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>

        <div id="movies-grid">
            {% if movies %}
                <div class="movie-cards">
                    {% for movie in movies %}
                        <div class="movie-card" id="movie-card-{{ movie.movie_id }}">
                            <!-- Placeholder for poster image if available -->
                            <div class="movie-poster">
                                <img src="{{ url_for('static', filename='images/posters/' + movie.movie_id + '.jpg') }}" alt="{{ movie.title }} poster" onerror="this.style.display='none'">
                            </div>
                            <div class="movie-info">
                                <h3>{{ movie.title }}</h3>
                                <p>Rating: {{ movie.rating }}</p>
                                <p>Duration: {{ movie.duration }} min</p>
                                <button id="view-movie-button-{{ movie.movie_id }}" onclick="location.href='{{ url_for('movie_details', movie_id=movie.movie_id) }}'">View Details</button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No movies found.</p>
            {% endif %}
        </div>

        <nav>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
</body>
</html>
