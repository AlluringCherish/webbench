                form.method = 'POST';
                form.action = '/my_inquiries';
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'delete_inquiry_id';
                input.value = inquiryId;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        });
    });
});
