'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence of featured articles, trending articles, and navigation buttons.
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class NewsPortalDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_title(self):
        # Test that the page title is "News Portal"
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string if soup.title else ''
        self.assertEqual(title, "News Portal", "Dashboard page title should be 'News Portal'")
    def test_dashboard_elements_presence(self):
        # Test presence of main container div with id 'dashboard-page'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page should contain div with id 'dashboard-page'")
        # Test presence of featured articles container
        featured_div = soup.find(id='featured-articles')
        self.assertIsNotNone(featured_div, "Dashboard page should contain div with id 'featured-articles'")
        # Test presence of buttons: browse-articles-button, view-bookmarks-button, trending-articles-button
        browse_btn = soup.find(id='browse-articles-button')
        self.assertIsNotNone(browse_btn, "Dashboard page should have button with id 'browse-articles-button'")
        self.assertEqual(browse_btn.name, 'button', "browse-articles-button should be a button element")
        bookmarks_btn = soup.find(id='view-bookmarks-button')
        self.assertIsNotNone(bookmarks_btn, "Dashboard page should have button with id 'view-bookmarks-button'")
        self.assertEqual(bookmarks_btn.name, 'button', "view-bookmarks-button should be a button element")
        trending_btn = soup.find(id='trending-articles-button')
        self.assertIsNotNone(trending_btn, "Dashboard page should have button with id 'trending-articles-button'")
        self.assertEqual(trending_btn.name, 'button', "trending-articles-button should be a button element")
    def test_dashboard_featured_articles_content(self):
        # Test that featured articles container has at least one article displayed with expected fields
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_div = soup.find(id='featured-articles')
        self.assertIsNotNone(featured_div, "Featured articles div should exist")
        # Check that featured articles contain article titles (at least one)
        # We expect the featured articles to be displayed as some elements containing titles
        # We look for any element inside featured-articles that contains text (article title)
        text_found = False
        for elem in featured_div.find_all():
            if elem.string and elem.string.strip():
                text_found = True
                break
        self.assertTrue(text_found, "Featured articles should contain at least one article title text")
    def test_dashboard_trending_articles_content(self):
        # Test that trending articles container has articles for "This Week" period with expected fields
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # Trending articles container is not explicitly named in dashboard.html by id in the code,
        # but the route passes trending_articles to template, so we expect an element with id 'trending-articles' or similar
        # According to requirements, the dashboard page has a button with id 'trending-articles-button' but no explicit trending articles div id
        # We check for presence of trending articles list or container by searching for a div with id 'trending-articles' or similar
        trending_div = soup.find(id='trending-articles')
        # If not found, try to find any container with trending articles by class or text
        # Since the requirement states 'trending-articles-button' but not a div id, we accept if no div found but button exists
        # So this test will pass if trending-articles div is found or at least the button is present (already tested)
        # We will just check that trending articles are rendered as text somewhere on the page
        trending_text_found = False
        for elem in soup.find_all():
            if elem.string and elem.string.strip():
                # Check if any trending article title from example data is present
                if "Breaking: New Technology Breakthrough" in elem.string or \
                   "Sports: Championship Victory" in elem.string or \
                   "Business: Market Trends Analysis" in elem.string:
                    trending_text_found = True
                    break
        self.assertTrue(trending_text_found, "Dashboard page should display trending articles titles")
    def test_dashboard_navigation_buttons_functionality(self):
        # Test that clicking navigation buttons leads to correct pages (simulate by GET requests)
        # Browse Articles button -> /catalog
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200, "Article Catalog page should be accessible")
        # View Bookmarks button -> /bookmarks
        response = self.client.get('/bookmarks')
        self.assertEqual(response.status_code, 200, "Bookmarks page should be accessible")
        # Trending Articles button -> /trending
        response = self.client.get('/trending')
        self.assertEqual(response.status_code, 200, "Trending Articles page should be accessible")
if __name__ == '__main__':
    unittest.main()

