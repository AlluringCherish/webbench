    <form method="get" action="{{ url_for('my_borrowings') }}">
        <label for="filter-status">Filter by status:</label>
        <select id="filter-status" name="filter-status" onchange="this.form.submit()">
            <option value="All" {% if filter_status == 'All' %}selected{% endif %}>All</option>
            <option value="Active" {% if filter_status == 'Active' %}selected{% endif %}>Active</option>
            <option value="Returned" {% if filter_status == 'Returned' %}selected{% endif %}>Returned</option>
            <option value="Overdue" {% if filter_status == 'Overdue' %}selected{% endif %}>Overdue</option>
        </select>
    </form>
    <table id="borrows-table" border="1">
        <thead>
            <tr>
                <th>Title</th>
                <th>Borrow Date</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Fine Amount</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for borrow in borrowings %}
            <tr>
                <td>{{ borrow.title }}</td>
                <td>{{ borrow.borrow_date }}</td>
                <td>{{ borrow.due_date }}</td>
                <td>{{ borrow.status }}</td>
                <td>{{ "%.2f"|format(borrow.fine_amount) }}</td>
                <td>
                    {% if borrow.status == 'Active' or borrow.status == 'Overdue' %}
                    <form method="post" action="{{ url_for('return_book', borrow_id=borrow.borrow_id) }}" style="display:inline;">
                        <button type="submit" id="return-book-button-{{ borrow.borrow_id }}">Return Book</button>
                    </form>
                    {% else %}
                    <button disabled>Returned</button>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
