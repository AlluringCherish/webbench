    {% else %}
    <button id="borrow-button" disabled>Borrow</button>
    {% endif %}
    <div id="reviews-section">
        <h2>Reviews</h2>
        {% if reviews %}
            <ul>
            {% for review in reviews %}
                <li><strong>{{ review.username }}</strong> rated {{ review.rating }} stars: {{ review.review_text }} ({{ review.review_date }})</li>
            {% endfor %}
            </ul>
        {% else %}
            <p>No reviews yet.</p>
        {% endif %}
    </div>
    <form action="{{ url_for('write_review', book_id=book.book_id) }}" method="get">
        <button type="submit" id="write-review-button">Write a Review</button>
    </form>
    <button id="back-to-catalog" onclick="location.href='{{ url_for('book_catalog') }}'">Back to Catalog</button>
</div>
</body>
</html>
