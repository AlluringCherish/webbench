'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of ALL pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class OnlineLibraryTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_access_and_elements(self):
        # Test access to dashboard page '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check dashboard container
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div not found")
        # Check welcome message with username
        welcome_msg = soup.find('h1', id='welcome-message')
        self.assertIsNotNone(welcome_msg, "Welcome message h1 not found")
        self.assertIn('john_reader', welcome_msg.text, "Username not found in welcome message")
        # Check featured books list and each book has view details button
        featured_books_div = soup.find('div', id='featured-books')
        self.assertIsNotNone(featured_books_div, "Featured books div not found")
        book_list_items = featured_books_div.find_all('li')
        self.assertGreaterEqual(len(book_list_items), 1, "No featured books listed")
        for li in book_list_items:
            button = li.find('button')
            self.assertIsNotNone(button, "View Details button missing in featured book item")
            self.assertTrue(button.has_attr('id') and button['id'].startswith('view-book-button-'),
                            "View Details button id incorrect")
        # Check navigation buttons
        browse_button = soup.find('button', id='browse-books-button')
        self.assertIsNotNone(browse_button, "Browse Books button not found")
        my_borrows_button = soup.find('button', id='my-borrows-button')
        self.assertIsNotNone(my_borrows_button, "My Borrowings button not found")
    def test_book_catalog_page_elements_and_navigation(self):
        # Access book catalog page GET
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        catalog_div = soup.find('div', id='catalog-page')
        self.assertIsNotNone(catalog_div, "Catalog page container not found")
        search_input = soup.find('input', id='search-input')
        self.assertIsNotNone(search_input, "Search input field not found")
        book_grid = soup.find('div', id='book-grid')
        self.assertIsNotNone(book_grid, "Book grid div not found")
        book_cards = book_grid.find_all('div', class_='book-card')
        self.assertGreaterEqual(len(book_cards), 1, "No book cards found in catalog")
        for card in book_cards:
            title = card.find('h3')
            author = card.find('p')
            self.assertIsNotNone(title, "Book title missing in book card")
            self.assertIsNotNone(author, "Book author missing in book card")
            # Check view details button
            form = card.find('form')
            self.assertIsNotNone(form, "Form for view details missing in book card")
            button = form.find('button')
            self.assertIsNotNone(button, "View Details button missing in book card")
            self.assertTrue(button.has_attr('id') and button['id'].startswith('view-book-button-'),
                            "View Details button id incorrect in book card")
        back_button = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button, "Back to Dashboard button not found on catalog page")
    def test_book_details_page_elements(self):
        # Use book_id=1 from example data
        response = self.client.get('/book/1')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        details_div = soup.find('div', id='book-details-page')
        self.assertIsNotNone(details_div, "Book details page container not found")
        title = soup.find('h1', id='book-title')
        self.assertIsNotNone(title, "Book title h1 not found")
        self.assertIn('To Kill a Mockingbird', title.text, "Book title text incorrect")
        author_div = soup.find('div', id='book-author')
        self.assertIsNotNone(author_div, "Book author div not found")
        self.assertIn('Harper Lee', author_div.text, "Book author text incorrect")
        status_div = soup.find('div', id='book-status')
        self.assertIsNotNone(status_div, "Book status div not found")
        self.assertIn(status_div.text.strip(), ['Status: Available', 'Status: Borrowed', 'Status: Reserved'],
                      "Book status text incorrect")
        borrow_button = soup.find('button', id='borrow-button')
        self.assertIsNotNone(borrow_button, "Borrow button not found")
        reviews_section = soup.find('div', id='reviews-section')
        self.assertIsNotNone(reviews_section, "Reviews section not found")
        write_review_button = soup.find('button', id='write-review-button')
        self.assertIsNotNone(write_review_button, "Write Review button not found")
        back_button = soup.find('button', id='back-to-catalog')
        self.assertIsNotNone(back_button, "Back to Catalog button not found")
    def test_borrow_confirmation_page_elements(self):
        # Use book_id=5 which is Available in example data
        response = self.client.get('/borrow/5')
