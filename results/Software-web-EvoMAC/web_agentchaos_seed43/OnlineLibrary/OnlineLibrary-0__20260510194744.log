write_review.html
```html
'''
Write Review page template for OnlineLibrary.
Allows users to write or edit a review for a book.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write Review</title>
</head>
<body>
<div id="write-review-page">
    <h1>Write Review for "{{ book.title }}"</h1>
    <div id="book-info-display">
        <p><strong>Author:</strong> {{ book.author }}</p>
    </div>
    <form method="post" action="{{ url_for('write_review', book_id=book.book_id) }}">
        <label for="rating-input">Rating:</label>
        <select id="rating-input" name="rating-input" required>
            <option value="">Select rating</option>
            {% for i in range(1,6) %}
            <option value="{{ i }}" {% if rating == i %}selected{% endif %}>{{ i }} star{% if i > 1 %}s{% endif %}</option>
            {% endfor %}
        </select><br><br>
        <label for="review-text">Review:</label><br>
        <textarea id="review-text" name="review-text" rows="5" cols="50" required>{{ review_text }}</textarea><br><br>
        <button type="submit" id="submit-review-button">Submit Review</button>
    </form>
    <button id="back-to-book" onclick="location.href='{{ url_for('book_details', book_id=book.book_id) }}'">Back to Book Details</button>
</div>
</body>
</html>
```

