'''
My Reviews page template for OnlineLibrary.
Displays all reviews written by the user with edit and delete options.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Reviews</title>
</head>
<body>
<div id="reviews-page">
    <h1>My Reviews</h1>
    <div id="reviews-list">
        {% if reviews %}
        <ul>
            {% for review in reviews %}
            <li>
                <strong>{{ review.title }}</strong> - Rating: {{ review.rating }}<br>
                {{ review.review_text }}<br>
                <form action="{{ url_for('edit_review', review_id=review.review_id) }}" method="get" style="display:inline;">
                    <button type="submit" id="edit-review-button-{{ review.review_id }}">Edit</button>
                </form>
                <form action="{{ url_for('delete_review', review_id=review.review_id) }}" method="post" style="display:inline;">
                    <button type="submit" id="delete-review-button-{{ review.review_id }}">Delete</button>
                </form>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p>You have not written any reviews yet.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
