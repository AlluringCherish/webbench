            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 20px;
        }
        .vehicle-card {
            border: 1px solid #ccc;
            padding: 10px;
            width: 30%;
            box-sizing: border-box;
            text-align: center;
        }
        .vehicle-card img {
            max-width: 100%;
            height: auto;
        }
        label {
            margin-right: 10px;
        }
        select, input[type="text"] {
            margin-right: 20px;
            padding: 5px;
        }
        button {
            padding: 7px 12px;
            cursor: pointer;
        }
        h1 {
            margin-bottom: 15px;
        }
