        {% if featured_vehicles %}
            {% for vehicle in featured_vehicles %}
                <div class="vehicle-card">
                    <img src="{{ url_for('static', filename='images/vehicles/' + vehicle.make|lower + '_' + vehicle.model|lower + '.jpg') }}" alt="{{ vehicle.make }} {{ vehicle.model }}">
