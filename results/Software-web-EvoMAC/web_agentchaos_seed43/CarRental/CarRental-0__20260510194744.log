    <style>
        #reservations-page {
            max-width: 900px;
            margin: 0 auto;
            font-family: Arial, sans-serif;
        }
        #reservations-list {
            margin-top: 20px;
        }
        .reservation-item {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 15px;
        }
        .reservation-item p {
            margin: 5px 0;
        }
        button {
            margin-right: 10px;
            padding: 7px 12px;
            cursor: pointer;
        }
        h1 {
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
<div id="reservations-page">
    <h1>My Reservations</h1>
    <div id="reservations-list">
        {% if reservations %}
            {% for res in reservations %}
                <div class="reservation-item">
                    <p><strong>Reservation ID:</strong> {{ res.reservation_id }}</p>
                    <p><strong>Vehicle:</strong> {{ res.vehicle.make if res.vehicle else '' }} {{ res.vehicle.model if res.vehicle else '' }}</p>
                    <p><strong>Status:</strong> {{ res.status }}</p>
                    <p><strong>Special Requests:</strong> {{ res.special_requests }}</p>
                    <button id="modify-reservation-button-{{ res.reservation_id }}">Modify Reservation</button>
                    <button id="cancel-reservation-button-{{ res.reservation_id }}">Cancel Reservation</button>
                </div>
            {% endfor %}
        {% else %}
            <p>No reservations found.</p>
        {% endif %}
    </div>
    <button id="sort-by-date-button" onclick="alert('Sorting by date is not implemented yet.')">Sort by Date</button>
    <a href="{{ url_for('dashboard') }}">
        <button id="back-to-dashboard">Back to Dashboard</button>
    </a>
</div>
</body>
</html>
