            Total Price: ${{ "%.2f"|format(total_price) }}
        </div>
        <form method="get" action="{{ url_for('insurance_options') }}">
            <button type="submit" id="proceed-to-insurance-button">Proceed to Insurance Options</button>
        </form>
    {% endif %}
</div>
</body>
</html>
