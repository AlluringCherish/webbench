Displays filters and grid of available vehicles.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Vehicles</title>
</head>
<body>
    <div id="search-page">
        <h1>Search Vehicles</h1>

        <form method="get" action="{{ url_for('vehicle_search') }}">
            <label for="location-filter">Pickup Location:</label>
            <select id="location-filter" name="location">
                <option value="">All</option>
                {% for loc in locations %}
                <option value="{{ loc.city }}" {% if loc.city == location_filter %}selected{% endif %}>{{ loc.city }}</option>
                {% endfor %}
            </select>

            <label for="vehicle-type-filter">Vehicle Type:</label>
            <select id="vehicle-type-filter" name="vehicle_type">
                <option value="">All</option>
                <option value="Economy" {% if vehicle_type_filter == 'Economy' %}selected{% endif %}>Economy</option>
                <option value="Compact" {% if vehicle_type_filter == 'Compact' %}selected{% endif %}>Compact</option>
                <option value="Sedan" {% if vehicle_type_filter == 'Sedan' %}selected{% endif %}>Sedan</option>
                <option value="SUV" {% if vehicle_type_filter == 'SUV' %}selected{% endif %}>SUV</option>
                <option value="Luxury" {% if vehicle_type_filter == 'Luxury' %}selected{% endif %}>Luxury</option>
            </select>

            <label for="date-range-input">Rental Date Range:</label>
            <input type="text" id="date-range-input" name="date_range" value="{{ date_range }}" placeholder="YYYY-MM-DD to YYYY-MM-DD">

            <button type="submit">Search</button>
        </form>

        <div id="vehicles-grid">
            <h2>Available Vehicles</h2>
            <ul>
                {% for vehicle in vehicles %}
                <li>
                    <img src="/static/images/{{ vehicle.make|lower }}_{{ vehicle.model|lower }}.jpg" alt="{{ vehicle.make }} {{ vehicle.model }}" width="150" height="100" onerror="this.onerror=null;this.src='/static/images/default_car.jpg';">
                    <div>{{ vehicle.make }} {{ vehicle.model }}</div>
                    <div>Price per day: ${{ "%.2f"|format(vehicle.daily_rate) }}</div>
                    <button id="view-details-button-{{ vehicle.vehicle_id }}" onclick="location.href='{{ url_for('vehicle_details', vehicle_id=vehicle.vehicle_id) }}'">View Details</button>
                </li>
                {% else %}
                <li>No vehicles found.</li>
                {% endfor %}
            </ul>
        </div>

        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
