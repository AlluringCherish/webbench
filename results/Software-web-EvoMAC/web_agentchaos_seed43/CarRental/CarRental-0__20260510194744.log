'''
Rental History page template.
Displays table of rentals with filter and navigation.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Rental History</title>
</head>
<body>
    <div id="history-page">
        <h1>Rental History</h1>

        <form method="get" action="{{ url_for('rental_history') }}">
            <label for="status-filter">Filter by Status:</label>
            <select id="status-filter" name="status" onchange="this.form.submit()">
                <option value="All" {% if status_filter == 'All' %}selected{% endif %}>All</option>
                <option value="Active" {% if status_filter == 'Active' %}selected{% endif %}>Active</option>
                <option value="Completed" {% if status_filter == 'Completed' %}selected{% endif %}>Completed</option>
                <option value="Cancelled" {% if status_filter == 'Cancelled' %}selected{% endif %}>Cancelled</option>
            </select>
        </form>

        <table id="rentals-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Vehicle</th>
                    <th>Pickup Date</th>
                    <th>Dropoff Date</th>
                    <th>Pickup Location</th>
                    <th>Dropoff Location</th>
                    <th>Total Price</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for rental in rentals %}
                <tr>
                    <td>{{ rental.rental_id }}</td>
                    <td>{{ rental.vehicle.make if rental.vehicle else '' }} {{ rental.vehicle.model if rental.vehicle else '' }}</td>
                    <td>{{ rental.pickup_date }}</td>
                    <td>{{ rental.dropoff_date }}</td>
                    <td>{{ rental.pickup_location }}</td>
                    <td>{{ rental.dropoff_location }}</td>
                    <td>${{ "%.2f"|format(rental.total_price) }}</td>
                    <td>{{ rental.status }}</td>
                    <td><button id="view-rental-details-{{ rental.rental_id }}" onclick="alert('Rental details for ID {{ rental.rental_id }}')">View Details</button></td>
                </tr>
                {% else %}
                <tr><td colspan="9">No rentals found.</td></tr>
                {% endfor %}
            </tbody>
        </table>

        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

