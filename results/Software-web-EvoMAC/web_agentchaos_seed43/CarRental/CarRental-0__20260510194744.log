        .vehicle-card {
            border: 1px solid #ccc;
            padding: 10px;
            width: 30%;
            box-sizing: border-box;
            text-align: center;
        }
        .vehicle-card img {
            max-width: 100%;
            height: auto;
        }
        #promotions-section {
            background-color: #f0f8ff;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }
        button {
            padding: 10px 15px;
            margin-right: 10px;
            cursor: pointer;
            font-size: 16px;
