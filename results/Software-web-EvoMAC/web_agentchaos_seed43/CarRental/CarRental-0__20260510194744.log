templates/insurance.html
```html
'''
Insurance Options page template.
Displays insurance plans and allows selection.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Select Insurance Coverage</title>
    <script>
        function updateDescription() {
            var radios = document.getElementsByName('insurance_id');
            var descriptionDiv = document.getElementById('insurance-description');
            var priceDiv = document.getElementById('insurance-price');
            for (var i = 0; i < radios.length; i++) {
                if (radios[i].checked) {
                    var desc = radios[i].getAttribute('data-description');
                    var price = radios[i].getAttribute('data-price');
                    descriptionDiv.textContent = desc;
                    priceDiv.textContent = 'Daily Cost: $' + price;
                    break;
                }
            }
        }
        window.onload = function() {
            updateDescription();
            var radios = document.getElementsByName('insurance_id');
            for (var i = 0; i < radios.length; i++) {
                radios[i].addEventListener('change', updateDescription);
            }
        }
    </script>
</head>
<body>
    <div id="insurance-page">
        <h1>Select Insurance Coverage</h1>

        <form method="post" action="{{ url_for('insurance_options') }}">
            <div id="insurance-options">
                {% for plan in insurance_plans %}
                <div>
                    <input type="radio" id="select-insurance-{{ plan.insurance_id }}" name="insurance_id" value="{{ plan.insurance_id }}"
                        data-description="{{ plan.description }}" data-price="{{ "%.2f"|format(plan.daily_cost) }}"
                        {% if selected_plan and selected_plan.insurance_id == plan.insurance_id %}checked{% elif not selected_plan and loop.first %}checked{% endif %}>
                    <label for="select-insurance-{{ plan.insurance_id }}">{{ plan.plan_name }}</label>
                </div>
                {% endfor %}
            </div>

            <div id="insurance-description"></div>
            <div id="insurance-price"></div>

            <button id="confirm-booking-button" type="submit">Confirm Booking</button>
        </form>

        {% if confirmed %}
        <p>Booking confirmed with insurance plan: {{ selected_plan.plan_name }}</p>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        {% else %}
        <button onclick="location.href='{{ url_for('booking', vehicle_id=1) }}'">Back to Booking</button>
        {% endif %}
    </div>
</body>
</html>
```

