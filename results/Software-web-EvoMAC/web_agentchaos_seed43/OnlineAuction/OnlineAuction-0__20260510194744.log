import unittest
from main import app
from bs4 import BeautifulSoup

class OnlineAuctionTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_01_dashboard_accessible(self):
