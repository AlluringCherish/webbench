'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence of featured properties, recent listings, and navigation buttons.
'''
import unittest
from main import app

class RealEstateAppTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_content(self):
        # Test Task 2 & 3: Check that dashboard page loads with required elements
        response = self.client.get('/')
        html = response.get_data(as_text=True)

        # Check page title
        self.assertIn('<title>Real Estate Dashboard</title>', html, "Dashboard page title missing or incorrect")

        # Check dashboard container div
        self.assertIn('id="dashboard-page"', html, "Dashboard container div missing")

        # Check featured properties section
        self.assertIn('id="featured-properties"', html, "Featured properties section missing")

        # Check recent listings section
        self.assertIn('id="recent-listings"', html, "Recent listings section missing")

        # Check navigation buttons with correct IDs
        self.assertIn('id="browse-properties-button"', html, "Browse Properties button missing")
        self.assertIn('id="my-inquiries-button"', html, "My Inquiries button missing")
        self.assertIn('id="my-favorites-button"', html, "My Favorites button missing")

        # Check that at least one featured property is displayed (based on example data)
        self.assertIn('123 Oak Street', html, "Example featured property address missing")
        self.assertIn('456 Park Avenue', html, "Example featured property address missing")

        # Check that buttons to view property details exist for featured properties
        self.assertIn('id="view-property-button-1"', html, "View property button for property_id=1 missing")
        self.assertIn('id="view-property-button-2"', html, "View property button for property_id=2 missing")

    def test_navigation_buttons_functionality(self):
        # Test that navigation buttons link to correct pages (by checking href in button onclick)
        response = self.client.get('/')
        html = response.get_data(as_text=True)

        self.assertIn("location.href='/property_search'", html, "Browse Properties button does not navigate correctly")
        self.assertIn("location.href='/my_inquiries'", html, "My Inquiries button does not navigate correctly")
        self.assertIn("location.href='/my_favorites'", html, "My Favorites button does not navigate correctly")

if __name__ == '__main__':
    unittest.main()
