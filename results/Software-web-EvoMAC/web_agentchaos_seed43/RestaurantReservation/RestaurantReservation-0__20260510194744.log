'''
User Profile page template for RestaurantReservation.
Displays username (not editable) and allows updating email.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile</title>
</head>
<body>
<div id="profile-page">
    <h1>My Profile</h1>
    <div>
        <label>Username:</label>
        <div id="profile-username">{{ username }}</div>
    </div>
    <form method="post">
        <label for="profile-email">Email:</label>
        <input id="profile-email" name="profile-email" type="email" value="{{ email }}" required><br><br>
        <button id="update-profile-button" type="submit">Update Profile</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
