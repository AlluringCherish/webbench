</div>
</body>
</html>
```

templates/my_reservations.html
```html
'''
My Reservations page template for RestaurantReservation.
Displays all reservations made by the user with option to cancel upcoming ones.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Reservations</title>
</head>
<body>
<div id="my-reservations-page">
    <h1>My Reservations</h1>
    <table id="reservations-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Party Size</th>
                <th>Status</th>
                <th>Special Requests</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for res in reservations %}
                <tr>
                    <td>{{ res.date }}</td>
                    <td>{{ res.time }}</td>
                    <td>{{ res.party_size }}</td>
                    <td>{{ res.status }}</td>
                    <td>{{ res.special_requests }}</td>
                    <td>
                        {% if res.status == 'Upcoming' %}
                        <form method="post" action="{{ url_for('cancel_reservation', reservation_id=res.reservation_id) }}">
                            <button id="cancel-reservation-button-{{ res.reservation_id }}" type="submit">Cancel</button>
                        </form>
                        {% else %}
                            N/A
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/waitlist.html
```html
'''
Waitlist page template for RestaurantReservation.
Allows users to join the waitlist and view their current position.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Waitlist</title>
</head>
<body>
<div id="waitlist-page">
    <h1>Waitlist</h1>
    <form method="post">
        <label for="waitlist-party-size">Party Size:</label>
        <select id="waitlist-party-size" name="waitlist-party-size" required>
            {% for i in range(1,11) %}
                <option value="{{ i }}">{{ i }}</option>
            {% endfor %}
        </select>
        <button id="join-waitlist-button" type="submit">Join Waitlist</button>
    </form>
    <div id="user-position">
        {% if user_position %}
            Your current position in the waitlist is: {{ user_position }}
        {% else %}
            You are not currently in the waitlist.
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/my_reviews.html
```html
'''
My Reviews page template for RestaurantReservation.
Displays all reviews written by the user with option to write a new review.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Reviews</title>
</head>
<body>
<div id="reviews-page">
    <h1>My Reviews</h1>
    <div id="reviews-list">
        {% if reviews %}
            <ul>
            {% for review in reviews %}
                <li>
                    <strong>{{ review.dish_name }}</strong> - Rating: {{ review.rating }} stars<br>
                    "{{ review.review_text }}"<br>
                    <em>Date: {{ review.review_date }}</em>
                </li>
            {% endfor %}
            </ul>
        {% else %}
            <p>You have not written any reviews yet.</p>
        {% endif %}
    </div>
    <button id="write-new-review-button" onclick="location.href='{{ url_for('write_review') }}'">Write New Review</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/write_review.html
```html
'''
Write Review page template for RestaurantReservation.
Form for users to write a review for a dish.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write Review</title>
</head>
<body>
<div id="write-review-page">
    <h1>Write Review</h1>
    <form method="post">
        <label for="select-dish">Select Dish:</label>
        <select id="select-dish" name="select-dish" required>
            {% for dish in menu %}
                <option value="{{ dish.dish_id }}">{{ dish.name }}</option>
            {% endfor %}
        </select><br><br>

        <label for="rating-input">Rating:</label>
        <select id="rating-input" name="rating-input" required>
            {% for i in range(1,6) %}
                <option value="{{ i }}">{{ i }} star{% if i > 1 %}s{% endif %}</option>
            {% endfor %}
        </select><br><br>

        <label for="review-text">Review:</label><br>
        <textarea id="review-text" name="review-text" rows="5" cols="40" required></textarea><br><br>

        <button id="submit-review-button" type="submit">Submit Review</button>
    </form>
    <button id="back-to-reviews" onclick="location.href='{{ url_for('my_reviews') }}'">Back to My Reviews</button>
</div>
</body>
</html>
```

templates/profile.html
