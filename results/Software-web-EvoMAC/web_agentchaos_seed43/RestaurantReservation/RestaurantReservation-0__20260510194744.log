'''
Dashboard page template for RestaurantReservation.
Displays welcome message, featured dishes, upcoming reservations,
and navigation buttons to other pages.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Restaurant Dashboard</title>
</head>
<body>
<div id="dashboard-page">
    <h1 id="welcome-message">Welcome, {{ full_name }}!</h1>

    <h2>Featured Dishes</h2>
    <div id="featured-dishes">
        {% for dish in featured_dishes %}
            <div class="dish-card">
                <h3>{{ dish.name }}</h3>
                <p>Price: ${{ "%.2f"|format(dish.price) }}</p>
                <p>{{ dish.description }}</p>
                <form action="{{ url_for('dish_details', dish_id=dish.dish_id) }}" method="get">
                    <button id="view-dish-button-{{ dish.dish_id }}" type="submit">View Details</button>
                </form>
            </div>
        {% endfor %}
    </div>

    <h2>Upcoming Reservations</h2>
    <ul id="upcoming-reservations">
        {% if upcoming_reservations %}
            {% for res in upcoming_reservations %}
                <li>{{ res.date }} at {{ res.time }} - Party of {{ res.party_size }} - {{ res.special_requests }}</li>
            {% endfor %}
        {% else %}
            <li>No upcoming reservations.</li>
        {% endif %}
    </ul>

    <button id="make-reservation-button" onclick="location.href='{{ url_for('make_reservation') }}'">Make Reservation</button>
    <button id="view-menu-button" onclick="location.href='{{ url_for('menu_page') }}'">View Menu</button>
    <button id="my-reservations-button" onclick="location.href='{{ url_for('my_reservations') }}'">My Reservations</button>
    <button id="my-reviews-button" onclick="location.href='{{ url_for('my_reviews') }}'">My Reviews</button>
    <button id="waitlist-button" onclick="location.href='{{ url_for('waitlist') }}'">Waitlist</button>
    <button id="profile-button" onclick="location.href='{{ url_for('profile') }}'">My Profile</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Refresh Dashboard</button>
</div>
</body>
</html>
