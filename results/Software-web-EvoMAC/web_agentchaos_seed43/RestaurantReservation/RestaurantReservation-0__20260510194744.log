'''
My Reservations page template for RestaurantReservation web app.
Displays all reservations made by the logged in user with option to cancel upcoming ones.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Reservations</title>
</head>
<body>
<div id="my-reservations-page">
    <h1>My Reservations</h1>
    <table id="reservations-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Party Size</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if reservations %}
                {% for res in reservations %}
                    <tr>
                        <td>{{ res.date }}</td>
                        <td>{{ res.time }}</td>
                        <td>{{ res.party_size }}</td>
                        <td>{{ res.status }}</td>
                        <td>
                            {% if res.status == 'Upcoming' %}
                                <form method="post" action="{{ url_for('cancel_reservation', reservation_id=res.reservation_id) }}" style="display:inline;">
                                    <button type="submit" id="cancel-reservation-button-{{ res.reservation_id }}">Cancel</button>
                                </form>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr><td colspan="5">No reservations found.</td></tr>
            {% endif %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
