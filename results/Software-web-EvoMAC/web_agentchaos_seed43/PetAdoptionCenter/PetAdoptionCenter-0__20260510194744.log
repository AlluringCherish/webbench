    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <style>
        .application, .pet {
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 15px;
        }
        .application-actions, .pet-actions {
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div id="admin-panel-page">
        <h1>Admin Panel</h1>
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <ul class="flashes">
              {% for category, message in messages %}
                <li class="{{ category }}">{{ message }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endwith %}
        <section id="pending-applications">
            <h2>Pending Adoption Applications</h2>
            {% if pending_applications %}
                {% for app in pending_applications %}
                    <div class="application">
                        <p><strong>Application ID:</strong> {{ app.application_id }}</p>
                        <p><strong>Applicant Name:</strong> {{ app.applicant_name }}</p>
                        <p><strong>Pet ID:</strong> {{ app.pet_id }}</p>
                        <p><strong>Reason:</strong> {{ app.reason }}</p>
                        <form method="post" action="{{ url_for('admin_panel') }}">
                            <input type="hidden" name="action" value="update_application">
                            <input type="hidden" name="application_id" value="{{ app.application_id }}">
                            <label for="new_status_{{ app.application_id }}">Update Status:</label>
                            <select id="new_status_{{ app.application_id }}" name="new_status" required>
                                <option value="Pending" {% if app.status == 'Pending' %}selected{% endif %}>Pending</option>
                                <option value="Approved" {% if app.status == 'Approved' %}selected{% endif %}>Approved</option>
                                <option value="Rejected" {% if app.status == 'Rejected' %}selected{% endif %}>Rejected</option>
                            </select>
                            <button type="submit">Update</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No pending applications.</p>
            {% endif %}
        </section>
        <section id="all-pets-list">
            <h2>All Pets</h2>
            {% if all_pets %}
                {% for pet in all_pets %}
                    <div class="pet">
                        <p><strong>Pet ID:</strong> {{ pet.pet_id }}</p>
                        <p><strong>Name:</strong> {{ pet.name }}</p>
                        <p><strong>Status:</strong> {{ pet.status }}</p>
                        <form method="post" action="{{ url_for('admin_panel') }}" style="display:inline-block; margin-right:10px;">
                            <input type="hidden" name="action" value="edit_pet">
                            <input type="hidden" name="pet_id" value="{{ pet.pet_id }}">
                            <label for="new_status_pet_{{ pet.pet_id }}">Change Status:</label>
                            <select id="new_status_pet_{{ pet.pet_id }}" name="new_status" required>
                                <option value="Available" {% if pet.status == 'Available' %}selected{% endif %}>Available</option>
                                <option value="Pending" {% if pet.status == 'Pending' %}selected{% endif %}>Pending</option>
                                <option value="Adopted" {% if pet.status == 'Adopted' %}selected{% endif %}>Adopted</option>
                            </select>
                            <button type="submit">Update</button>
                        </form>
                        <form method="post" action="{{ url_for('admin_panel') }}" style="display:inline-block;">
                            <input type="hidden" name="action" value="delete_pet">
                            <input type="hidden" name="pet_id" value="{{ pet.pet_id }}">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this pet?');">Delete</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No pets found.</p>
            {% endif %}
        </section>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('back_to_dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
