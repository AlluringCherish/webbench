'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of all pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class PetAdoptionCenterTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access dashboard page at root '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check page title
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string.strip()
        self.assertEqual(title, 'Pet Adoption Dashboard')
        # Check dashboard container div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div)
        # Check featured pets section
        featured_section = dashboard_div.find('section', id='featured-pets')
        self.assertIsNotNone(featured_section)
        # Check buttons presence and ids
        browse_button = dashboard_div.find('button', id='browse-pets-button')
        self.assertIsNotNone(browse_button)
        back_button = dashboard_div.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button)

    def test_dashboard_navigation_to_pet_listings(self):
        # Test Task 2: From dashboard, navigate to pet listings page
        response = self.client.get('/pets')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check page title
        self.assertEqual(soup.title.string.strip(), 'Available Pets')
        # Check container div
        container = soup.find('div', id='pet-listings-page')
        self.assertIsNotNone(container)
        # Check search input
        search_input = container.find('input', id='search-input')
        self.assertIsNotNone(search_input)
        # Check filter dropdown
        filter_dropdown = container.find('select', id='filter-species')
        self.assertIsNotNone(filter_dropdown)
        # Check pet grid div
        pet_grid = container.find('div', id='pet-grid')
        self.assertIsNotNone(pet_grid)
        # Check back to dashboard button
        back_button = container.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button)

    def test_pet_details_page_elements(self):
        # Test Task 3: Check pet details page elements for a known pet_id=1 (from example data)
        response = self.client.get('/pets/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='pet-details-page')
        self.assertIsNotNone(container)
        # Check pet name h1
        pet_name = container.find('h1', id='pet-name')
        self.assertIsNotNone(pet_name)
        self.assertTrue(len(pet_name.text.strip()) > 0)
        # Check pet species div
        pet_species = container.find('div', id='pet-species')
        self.assertIsNotNone(pet_species)
        self.assertIn('Species:', pet_species.text)
        # Check pet description div
        pet_description = container.find('div', id='pet-description')
        self.assertIsNotNone(pet_description)
        self.assertIn('Description:', pet_description.text)
        # Check adopt button
        adopt_button = container.find('button', id='adopt-button')
        self.assertIsNotNone(adopt_button)
        # Check back to listings button
        back_button = container.find('button', id='back-to-listings')
        self.assertIsNotNone(back_button)

    def test_add_pet_page_elements(self):
        # Test Add Pet page GET request elements
        response = self.client.get('/add_pet')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='add-pet-page')
        self.assertIsNotNone(container)
        # Check all required input fields and selects
        self.assertIsNotNone(container.find('input', id='pet-name-input'))
        self.assertIsNotNone(container.find('select', id='pet-species-input'))
        self.assertIsNotNone(container.find('input', id='pet-breed-input'))
        self.assertIsNotNone(container.find('input', id='pet-age-input'))
        self.assertIsNotNone(container.find('select', id='pet-gender-input'))
        self.assertIsNotNone(container.find('select', id='pet-size-input'))
        self.assertIsNotNone(container.find('textarea', id='pet-description-input'))
        # Check submit button
        submit_button = container.find('button', id='submit-pet-button')
        self.assertIsNotNone(submit_button)
        # Check back to dashboard button
        back_button = container.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button)

    def test_adoption_application_page_elements(self):
        # Test Adoption Application page GET for pet_id=1
        response = self.client.get('/adopt/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='application-page')
        self.assertIsNotNone(container)
        # Check form fields
        self.assertIsNotNone(container.find('input', id='applicant-name'))
        self.assertIsNotNone(container.find('input', id='applicant-phone'))
        self.assertIsNotNone(container.find('select', id='housing-type'))
        self.assertIsNotNone(container.find('textarea', id='reason'))
        # Check submit button
        submit_button = container.find('button', id='submit-application-button')
        self.assertIsNotNone(submit_button)
        # Check back to pet button
        back_button = container.find('button', id='back-to-pet')
        self.assertIsNotNone(back_button)

    def test_my_applications_page_elements(self):
        # Test My Applications page with username=guest (default)
        response = self.client.get('/my_applications?username=guest')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        container = soup.find('div', id='my-applications-page')
        self.assertIsNotNone(container)
        # Check filter dropdown
