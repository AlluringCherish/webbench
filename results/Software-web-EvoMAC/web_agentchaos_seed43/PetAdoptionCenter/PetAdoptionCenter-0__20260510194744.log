                <p>No pending applications.</p>
            {% endif %}
        </section>
        <section id="all-pets-list">
            <h2>All Pets</h2>
            {% if all_pets %}
                {% for pet in all_pets %}
                    <div class="pet">
                        <p><strong>Pet ID:</strong> {{ pet.pet_id }}</p>
                        <p><strong>Name:</strong> {{ pet.name }}</p>
                        <p><strong>Status:</strong> {{ pet.status }}</p>
                        <form method="post" action="{{ url_for('admin_panel') }}" style="display:inline-block; margin-right:10px;">
                            <input type="hidden" name="action" value="edit_pet">
                            <input type="hidden" name="pet_id" value="{{ pet.pet_id }}">
                            <label for="new_status_pet_{{ pet.pet_id }}">Change Status:</label>
                            <select id="new_status_pet_{{ pet.pet_id }}" name="new_status" required>
                                <option value="Available" {% if pet.status == 'Available' %}selected{% endif %}>Available</option>
                                <option value="Pending" {% if pet.status == 'Pending' %}selected{% endif %}>Pending</option>
                                <option value="Adopted" {% if pet.status == 'Adopted' %}selected{% endif %}>Adopted</option>
                            </select>
                            <button type="submit">Update</button>
                        </form>
                        <form method="post" action="{{ url_for('admin_panel') }}" style="display:inline-block;">
                            <input type="hidden" name="action" value="delete_pet">
                            <input type="hidden" name="pet_id" value="{{ pet.pet_id }}">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this pet?');">Delete</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No pets found.</p>
            {% endif %}
        </section>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('back_to_dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```
