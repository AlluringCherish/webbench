'''
Virtual Events page template.
Shows events and allows registration management.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Virtual Events</title>
</head>
<body>
<div id="virtual-events-page">
    <h1>Virtual Events</h1>
    {% if message %}
    <p><strong>{{ message }}</strong></p>
    {% endif %}
    <table id="event-list" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Time</th>
                <th>Type</th>
                <th>Speaker</th>
                <th>Capacity</th>
                <th>Description</th>
                <th>Registration Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for event in events %}
            <tr>
                <td>{{ event.title }}</td>
                <td>{{ event.date }}</td>
                <td>{{ event.time }}</td>
                <td>{{ event.event_type }}</td>
                <td>{{ event.speaker }}</td>
                <td>{{ event.capacity }}</td>
                <td>{{ event.description }}</td>
                <td>
                    {% if event.event_id in reg_event_ids %}
                        Registered
                    {% else %}
                        Not Registered
                    {% endif %}
                </td>
                <td>
                    {% if event.event_id in reg_event_ids %}
                    <form method="post" style="display:inline;">
                        <input type="hidden" name="action" value="cancel">
                        {% for reg in registrations %}
                            {% if reg.event_id == event.event_id and reg.username == 'visitor_mary' %}
                                <input type="hidden" name="registration_id" value="{{ reg.registration_id }}">
                            {% endif %}
                        {% endfor %}
                        <button type="submit" id="cancel-registration-button-{{ reg.registration_id }}">Cancel Registration</button>
                    </form>
                    {% else %}
                    <form method="post" style="display:inline;">
                        <input type="hidden" name="action" value="register">
                        <input type="hidden" name="event_id" value="{{ event.event_id }}">
                        <button type="submit" id="register-event-button-{{ event.event_id }}">Register</button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
