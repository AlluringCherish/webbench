                    <p><strong>Screens:</strong> {{ theater.screens }}</p>
                    <div id="facilities-display"><strong>Facilities:</strong> {{ theater.facilities }}</div>
                </div>
            {% endfor %}
        {% else %}
            <p>No theaters found for the selected location.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
