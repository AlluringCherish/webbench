<div id="theater-page">
    <h1>Theater Information</h1>
    <form method="get" action="{{ url_for('theater_information') }}">
        <label for="theater-location-filter">Filter by Location:</label>
        <select id="theater-location-filter" name="location" onchange="this.form.submit()">
            <option value="All" {% if selected_location == 'All' or not selected_location %}selected{% endif %}>All Locations</option>
            {% for location in locations %}
                <option value="{{ location }}" {% if selected_location == location %}selected{% endif %}>{{ location }}</option>
