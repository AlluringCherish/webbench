    <title>Select Showtime</title>
    <style>
        #showtime-page {
            max-width: 900px;
            margin: auto;
            font-family: Arial, sans-serif;
        }
        #showtimes-list {
            margin-top: 20px;
            border-collapse: collapse;
            width: 100%;
        }
        #showtimes-list table {
            width: 100%;
            border-collapse: collapse;
        }
        #showtimes-list th, #showtimes-list td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }
        #showtimes-list th {
            background-color: #007BFF;
            color: white;
        }
        #theater-filter, #date-filter {
            padding: 8px;
            font-size: 1em;
            margin-right: 10px;
            margin-top: 10px;
        }
        button {
            padding: 6px 12px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: none;
            background-color: #28a745;
            color: white;
        }
        button:hover {
            background-color: #1e7e34;
        }
        form.filter-form {
            margin-bottom: 15px;
        }
        a.back-link {
            display: inline-block;
            margin-bottom: 15px;
            text-decoration: none;
            color: #007BFF;
            font-weight: bold;
        }
        a.back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
<div id="showtime-page">
    <a href="{{ url_for('movie_details', movie_id=movie.movie_id) }}" class="back-link">&larr; Back to Movie Details</a>
    <h1>Select Showtime for "{{ movie.title }}"</h1>
    <form method="get" class="filter-form" action="{{ url_for('showtime_selection', movie_id=movie.movie_id) }}">
        <label for="theater-filter">Filter by Theater:</label>
        <select id="theater-filter" name="theater">
            <option value="All" {% if selected_theater == 'All' or not selected_theater %}selected{% endif %}>All</option>
            {% for theater_name in theaters %}
                <option value="{{ theater_name }}" {% if selected_theater == theater_name %}selected{% endif %}>{{ theater_name }}</option>
            {% endfor %}
        </select>
        <label for="date-filter">Filter by Date:</label>
        <input type="date" id="date-filter" name="date" value="{{ selected_date }}">
        <button type="submit">Apply Filters</button>
    </form>
    <div id="showtimes-list">
        {% if showtimes %}
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Theater</th>
                        <th>Price</th>
                        <th>Available Seats</th>
                        <th>Select</th>
                    </tr>
                </thead>
                <tbody>
                    {% for showtime in showtimes %}
                        <tr>
                            <td>{{ showtime.showtime_date }}</td>
                            <td>{{ showtime.showtime_time }}</td>
                            <td>{{ showtime.theater_name }}</td>
                            <td>${{ "%.2f"|format(showtime.price) }}</td>
                            <td>{{ showtime.available_seats }}</td>
                            <td>
                                <form action="{{ url_for('seat_selection', showtime_id=showtime.showtime_id) }}" method="get" style="margin:0;">
                                    <button type="submit" id="select-showtime-button-{{ showtime.showtime_id }}">Select</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>No showtimes available for the selected filters.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
