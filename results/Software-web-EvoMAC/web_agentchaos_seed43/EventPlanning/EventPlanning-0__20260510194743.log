```html
'''
Event Schedules page template for EventPlanning web application.
Includes date and event filters and timeline display.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Schedules</title>
</head>
<body>
    <div id="schedules-page">
        <h1>Event Schedules</h1>
        <form method="get" action="{{ url_for('schedules_page') }}">
            <label for="schedule-filter-date">Filter by Date:</label>
            <input id="schedule-filter-date" name="date" type="date" value="{{ filter_date }}">
            <label for="schedule-filter-event">Filter by Event:</label>
            <select id="schedule-filter-event" name="event">
                <option value="">All Events</option>
                {% for event in events %}
                <option value="{{ event.event_id }}" {% if event.event_id == filter_event %}selected{% endif %}>{{ event.event_name }}</option>
                {% endfor %}
            </select>
            <button type="submit">Filter</button>
        </form>
        <div id="schedules-timeline">
            {% if schedules %}
            <ul>
                {% for s in schedules %}
                <li>
                    <strong>{{ event_dict.get(s.event_id, 'Unknown Event') }}</strong>: {{ s.session_title }}<br>
                    Time: {{ s.session_time }} ({{ s.duration_minutes }} minutes)<br>
                    Speaker: {{ s.speaker }}
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p>No schedules found.</p>
            {% endif %}
        </div>
        <button id="export-schedule-button" onclick="alert('Export schedule functionality not implemented yet.')">Export Schedule</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/bookings.html
```html
'''
Bookings Summary page template for EventPlanning web application.
Displays bookings table with search and cancel booking buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings</title>
</head>
<body>
    <div id="bookings-page">
        <h1>My Bookings</h1>
        <form method="get" action="{{ url_for('bookings_page') }}">
            <input id="booking-search-input" name="search" type="text" placeholder="Search bookings" value="{{ search_query }}">
            <button type="submit">Search</button>
        </form>
        <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Ticket Count</th>
                    <th>Ticket Type</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for b in bookings %}
                <tr>
                    <td>{{ b.booking_id }}</td>
                    <td>{{ event_dict.get(b.event_id, 'Unknown') }}</td>
                    <td>{{ b.booking_date }}</td>
                    <td>{{ b.ticket_count }}</td>
                    <td>{{ b.ticket_type }}</td>
                    <td>${{ "%.2f"|format(b.total_amount) }}</td>
                    <td>{{ b.status }}</td>
                    <td>
                        {% if b.status != 'Cancelled' %}
                        <form method="post" action="{{ url_for('cancel_booking', booking_id=b.booking_id) }}" style="display:inline;">
                            <button id="cancel-booking-button-{{ b.booking_id }}" type="submit" onclick="return confirm('Are you sure you want to cancel this booking?');">Cancel</button>
                        </form>
                        {% else %}
                        N/A
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8">No bookings found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```
