            <select id="ticket-type-select" name="ticket-type-select" required>
                <option value="General">General</option>
                <option value="VIP">VIP</option>
                <option value="Early Bird">Early Bird</option>
            </select><br><br>

            <label for="customer-name">Your Name:</label>
            <input id="customer-name" name="customer-name" type="text" placeholder="Enter your name" required><br><br>

            <button id="book-now-button" type="submit">Book Now</button>
        </form>
        <div id="booking-confirmation">
            {% if booking_confirmation %}
            <p>{{ booking_confirmation }}</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/participants.html
```html
'''
Participants Management page template for EventPlanning web application.
Displays participants table with search and status filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Participants Management</title>
</head>
<body>
    <div id="participants-page">
        <h1>Participants Management</h1>
        <form method="get" action="{{ url_for('participants_management') }}">
            <input id="search-participant-input" name="search" type="text" placeholder="Search participants" value="{{ search_query }}">
            <select id="participant-status-filter" name="status">
                <option value="">All Statuses</option>
                {% for status in statuses %}
                <option value="{{ status }}" {% if status == selected_status %}selected{% endif %}>{{ status }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search/Filter</button>
        </form>
        <table id="participants-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Event</th>
                    <th>Status</th>
                    <th>Registration Date</th>
                </tr>
            </thead>
            <tbody>
                {% for p in participants %}
                <tr>
                    <td>{{ p.name }}</td>
                    <td>{{ p.email }}</td>
                    <td>{{ event_dict.get(p.event_id, 'Unknown') }}</td>
                    <td>{{ p.status }}</td>
                    <td>{{ p.registration_date }}</td>
                </tr>
                {% else %}
                <tr><td colspan="5">No participants found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="add-participant-button" onclick="alert('Add participant functionality not implemented yet.')">Add Participant</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

