                        </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="5">No participants found.</td></tr>
                {% endif %}
            </tbody>
        </table>
        <nav>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
</body>
</html>
