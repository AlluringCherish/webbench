'''
Events Listing page template for EventPlanning web application.
Includes search and category filter with form submitting to same route.
Event cards include buttons linking to event details page.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Events Catalog</title>
</head>
<body>
    <div id="events-page">
        <h1>Events Catalog</h1>
        <form method="get" action="{{ url_for('events_listing') }}">
            <input id="event-search-input" name="search" type="text" placeholder="Search events" value="{{ search_query }}">
            <select id="event-category-filter" name="category">
                <option value="">All Categories</option>
                {% for category in categories %}
                <option value="{{ category }}" {% if category == selected_category %}selected{% endif %}>{{ category }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search/Filter</button>
        </form>
        <div id="events-grid">
            {% for event in events %}
            <div class="event-card">
                <h3>{{ event.event_name }}</h3>
                <p>{{ event.date }} {{ event.time }}</p>
                <p>{{ event.location }}</p>
                <button id="view-event-button-{{ event.event_id }}" onclick="location.href='{{ url_for('event_details', event_id=event.event_id) }}'">View Details</button>
            </div>
            {% else %}
            <p>No events found.</p>
            {% endfor %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
