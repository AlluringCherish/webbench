<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Your Tickets</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script>
        function updateTicketTypes() {
            const eventId = document.getElementById('select-event-dropdown').value;
            const ticketTypeSelect = document.getElementById('ticket-type-select');
            // Clear current options
            ticketTypeSelect.innerHTML = '';
            // Fetch ticket types for selected event from a global JS object (to be rendered)
            const tickets = window.tickets || [];
            const filtered = tickets.filter(t => t.event_id === eventId);
            if (filtered.length === 0) {
                const option = document.createElement('option');
                option.text = 'No tickets available';
                option.value = '';
                ticketTypeSelect.add(option);
                return;
            }
            filtered.forEach(t => {
                const option = document.createElement('option');
                option.value = t.ticket_type;
                option.text = `${t.ticket_type} ($${t.price.toFixed(2)})`;
                ticketTypeSelect.add(option);
            });
        }
        window.onload = function() {
            updateTicketTypes();
            document.getElementById('select-event-dropdown').addEventListener('change', updateTicketTypes);
        };
    </script>
</head>
<body>
    <div id="ticket-booking-page">
        <h1>Book Your Tickets</h1>
        <form method="post" action="{{ url_for('ticket_booking') }}">
            <label for="select-event-dropdown">Select Event:</label>
            <select id="select-event-dropdown" name="select-event-dropdown" required>
                {% for event in events %}
                    <option value="{{ event.event_id }}">{{ event.event_name }} - {{ event.date }}</option>
                {% endfor %}
            </select><br><br>
            <label for="ticket-quantity-input">Number of Tickets:</label>
            <input type="number" id="ticket-quantity-input" name="ticket-quantity-input" min="1" value="1" required><br><br>
            <label for="ticket-type-select">Ticket Type:</label>
            <select id="ticket-type-select" name="ticket-type-select" required>
                <!-- Options populated by JS -->
            </select><br><br>
            <label for="customer-name">Your Name:</label>
            <input type="text" id="customer-name" name="customer-name" placeholder="Enter your name" required><br><br>
            <button type="submit" id="book-now-button">Book Now</button>
        </form>
        <div id="booking-confirmation">
            {% if booking_confirmation %}
                <p>{{ booking_confirmation }}</p>
            {% endif %}
        </div>
        <nav>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
    <script>
        // Pass tickets data to JS for dynamic ticket type selection
        window.tickets = [
            {% for ticket in tickets %}
            {
                event_id: "{{ ticket.event_id }}",
                ticket_type: "{{ ticket.ticket_type }}",
                price: {{ "%.2f"|format(ticket.price) }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
    </script>
</body>
</html>
