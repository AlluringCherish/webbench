templates/schedules.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Schedules</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script>
        function filterSchedules() {
            const date = document.getElementById('schedule-filter-date').value;
            const event = document.getElementById('schedule-filter-event').value;
            const params = new URLSearchParams();
            if (date) params.append('date', date);
            if (event) params.append('event', event);
            window.location.href = '/schedules?' + params.toString();
        }
    </script>
</head>
<body>
    <div id="schedules-page">
        <h1>Event Schedules</h1>

        <div id="schedule-filters">
            <label for="schedule-filter-date">Filter by Date:</label>
            <input type="date" id="schedule-filter-date" name="schedule-filter-date" value="{{ filter_date }}" onchange="filterSchedules()">

            <label for="schedule-filter-event">Filter by Event:</label>
            <select id="schedule-filter-event" name="schedule-filter-event" onchange="filterSchedules()">
                <option value="">All Events</option>
                {% for event in events %}
                    <option value="{{ event.event_id }}" {% if event.event_id == filter_event %}selected{% endif %}>{{ event.event_name }}</option>
                {% endfor %}
            </select>

            <button id="export-schedule-button" onclick="alert('Export schedule functionality not implemented.')">Export Schedule</button>
        </div>

        <div id="schedules-timeline">
            {% if schedules %}
                <ul>
                    {% for s in schedules %}
                        <li>
                            <strong>{{ s.session_title }}</strong><br>
                            Time: {{ s.session_time }}<br>
                            Duration: {{ s.duration_minutes }} minutes<br>
                            Speaker: {{ s.speaker }}<br>
                            Venue: {{ event_dict.get(s.event_id, 'Unknown Event') }}
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No schedules found.</p>
            {% endif %}
        </div>

        <nav>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
</body>
</html>
```

templates/bookings.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script>
        function filterBookings() {
            const search = document.getElementById('booking-search-input').value;
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            window.location.href = '/bookings?' + params.toString();
        }
        function onSearchKey(event) {
            if (event.key === 'Enter') {
                filterBookings();
            }
        }
        function cancelBooking(bookingId) {
            if (confirm('Are you sure you want to cancel this booking?')) {
                fetch('/bookings/cancel/' + bookingId, {
                    method: 'POST'
                }).then(() => {
                    window.location.reload();
                });
            }
        }
    </script>
</head>
<body>
    <div id="bookings-page">
        <h1>My Bookings</h1>

        <div id="booking-filters">
            <input type="text" id="booking-search-input" placeholder="Search by event name or booking ID" value="{{ search_query }}" onkeypress="onSearchKey(event)">
            <button onclick="filterBookings()">Search</button>
        </div>

        <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Ticket Count</th>
                    <th>Ticket Type</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if bookings %}
                    {% for b in bookings %}
                        <tr>
                            <td>{{ b.booking_id }}</td>
                            <td>{{ event_dict.get(b.event_id, 'Unknown Event') }}</td>
                            <td>{{ b.booking_date }}</td>
                            <td>{{ b.ticket_count }}</td>
                            <td>{{ b.ticket_type }}</td>
                            <td>${{ "%.2f"|format(b.total_amount) }}</td>
                            <td>{{ b.status }}</td>
                            <td>
                                {% if b.status != 'Cancelled' %}
                                    <button id="cancel-booking-button-{{ b.booking_id }}" onclick="cancelBooking('{{ b.booking_id }}')">Cancel Booking</button>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="8">No bookings found.</td></tr>
                {% endif %}
            </tbody>
        </table>

        <nav>
            <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </nav>
    </div>
</body>
</html>
```
