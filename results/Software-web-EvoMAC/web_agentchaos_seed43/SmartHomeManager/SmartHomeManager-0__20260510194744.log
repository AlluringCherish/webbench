                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ device_names.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.date }}</td>
                <td>{{ '%.2f'|format(log.consumption_kwh) }}</td>
            </tr>
            {% else %}
