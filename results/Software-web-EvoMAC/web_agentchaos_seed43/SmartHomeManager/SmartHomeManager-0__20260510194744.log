'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of ALL pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class SmartHomeManagerTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
        self.current_user = 'john_doe'

    def test_01_dashboard_accessible_and_elements(self):
        # Test access to dashboard page '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Check page container
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container missing")

        # Check device summary div and counts
        device_summary = soup.find(id='device-summary')
        self.assertIsNotNone(device_summary, "Device summary div missing")

        total_devices = device_summary.find(id='total-devices')
        active_devices = device_summary.find(id='active-devices')
        offline_devices = device_summary.find(id='offline-devices')
        self.assertIsNotNone(total_devices, "Total devices count missing")
        self.assertIsNotNone(active_devices, "Active devices count missing")
        self.assertIsNotNone(offline_devices, "Offline devices count missing")

        # Check dashboard buttons presence and correct ids
        expected_buttons = [
            'device-list-button',
            'add-device-button',
            'automation-button',
            'energy-button',
            'activity-button'
        ]
        for btn_id in expected_buttons:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Dashboard button '{btn_id}' missing")

        # Check room list container and list items
        room_list = soup.find(id='room-list')
        self.assertIsNotNone(room_list, "Room list div missing")
        ul = room_list.find('ul')
        self.assertIsNotNone(ul, "Room list ul missing")
        # At least one room or "No rooms found." text
        lis = ul.find_all('li')
        self.assertTrue(len(lis) > 0, "Room list has no items")

    def test_02_device_list_page_elements(self):
        response = self.client.get('/devices')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data.decode('utf-8'), 'html.parser')

        device_list_page = soup.find(id='device-list-page')
        self.assertIsNotNone(device_list_page, "Device list page container missing")

        device_table = soup.find('table', id='device-table')
        self.assertIsNotNone(device_table, "Device table missing")

        # Check table headers
        headers = [th.text.strip() for th in device_table.find_all('th')]
        expected_headers = ['Name', 'Type', 'Room', 'Status', 'Actions']
        self.assertEqual(headers, expected_headers, "Device table headers incorrect")

        # Check control buttons for each device row
        tbody = device_table.find('tbody')
        rows = tbody.find_all('tr')
        # If no devices, check for no devices message row
        if len(rows) == 1 and 'No devices found.' in rows[0].text:
            pass
        else:
            for row in rows:
                btn = row.find('button', class_='control-device-button')
                self.assertIsNotNone(btn, "Control button missing in device row")
                self.assertTrue(btn['id'].startswith('control-device-button-'), "Control button id format incorrect")

        back_btn = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_btn, "Back to dashboard button missing on device list page")

    def test_03_add_device_page_elements(self):
        response = self.client.get('/devices/add')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data.decode('utf-8'), 'html.parser')

        add_device_page = soup.find(id='add-device-page')
        self.assertIsNotNone(add_device_page, "Add device page container missing")

        # Check input fields and dropdowns
        device_name = soup.find('input', id='device-name')
        device_type = soup.find('select', id='device-type')
        device_room = soup.find('select', id='device-room')
        submit_btn = soup.find('button', id='submit-device-button')
        back_btn = soup.find('button', id='back-to-dashboard')

        self.assertIsNotNone(device_name, "Device name input missing")
        self.assertIsNotNone(device_type, "Device type dropdown missing")
        self.assertIsNotNone(device_room, "Device room dropdown missing")
        self.assertIsNotNone(submit_btn, "Submit device button missing")
        self.assertIsNotNone(back_btn, "Back to dashboard button missing on add device page")

        # Check device type options
        expected_types = ['Light', 'Thermostat', 'Camera', 'Lock', 'Sensor', 'Appliance']
        options = [opt.text.strip() for opt in device_type.find_all('option') if opt.get('value')]
        for etype in expected_types:
            self.assertIn(etype, options, f"Device type option '{etype}' missing")

        # Check room options
        expected_rooms = ['Living Room', 'Bedroom', 'Kitchen', 'Bathroom', 'Garage']
        room_options = [opt.text.strip() for opt in device_room.find_all('option') if opt.get('value')]
        for room in expected_rooms:
            self.assertIn(room, room_options, f"Device room option '{room}' missing")

    def test_04_device_control_page_elements(self):
        # Get a device_id from devices.txt for current user
        from main import parse_devices
        devices = parse_devices(self.current_user)
        if not devices:
            self.skipTest("No devices found for current user to test device control page")
        device_id = devices[0]['device_id']

        response = self.client.get(f'/devices/control/{device_id}')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data.decode('utf-8'), 'html.parser')

        control_page = soup.find(id='device-control-page')
