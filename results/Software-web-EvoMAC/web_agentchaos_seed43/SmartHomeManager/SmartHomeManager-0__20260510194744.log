            background-color: #007BFF;
            color: white;
            font-weight: bold;
        }
        #energy-table tr:hover {
            background-color: #f1f9ff;
        }
        form {
            margin-bottom: 20px;
            text-align: center;
        }
        input[type="date"] {
            padding: 8px 12px;
            font-size: 1em;
            border: 1px solid #ccc;
            border-radius: 5px;
            margin-right: 10px;
            transition: border-color 0.3s ease;
        }
        input[type="date"]:focus {
            border-color: #007BFF;
            outline: none;
        }
        #apply-filter-button {
            background-color: #007BFF;
            border: none;
            color: white;
            padding: 9px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        #apply-filter-button:hover {
            background-color: #0056b3;
        }
        #back-to-dashboard {
            margin-top: 20px;
            background-color: #6c757d;
            border: none;
            color: white;
            padding: 10px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            display: block;
            width: 150px;
            text-align: center;
            margin-left: auto;
            margin-right: auto;
            transition: background-color 0.3s ease;
