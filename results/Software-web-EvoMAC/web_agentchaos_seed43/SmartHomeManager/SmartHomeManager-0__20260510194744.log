            cursor: pointer;
            width: 100%;
            transition: background-color 0.3s ease;
        }
        #power-toggle:hover {
            background-color: #0056b3;
        }
        #save-settings-button {
            background-color: #28a745;
            border: none;
            color: white;
            padding: 12px 20px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            width: 100%;
            transition: background-color 0.3s ease;
        }
        #save-settings-button:hover {
            background-color: #1e7e34;
        }
        #back-to-devices {
            margin-top: 15px;
            background-color: #6c757d;
            border: none;
            color: white;
            padding: 10px 18px;
            font-size: 1em;
            border-radius: 5px;
