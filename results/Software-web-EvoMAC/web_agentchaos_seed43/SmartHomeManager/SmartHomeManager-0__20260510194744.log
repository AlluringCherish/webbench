        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check page container
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container missing")
        # Check device summary div and counts
        device_summary = soup.find(id='device-summary')
        self.assertIsNotNone(device_summary, "Device summary div missing")
        total_devices = device_summary.find(id='total-devices')
        active_devices = device_summary.find(id='active-devices')
        offline_devices = device_summary.find(id='offline-devices')
        self.assertIsNotNone(total_devices, "Total devices count missing")
        self.assertIsNotNone(active_devices, "Active devices count missing")
        self.assertIsNotNone(offline_devices, "Offline devices count missing")
        # Check dashboard buttons presence and correct ids
        expected_buttons = [
            'device-list-button',
            'add-device-button',
            'automation-button',
            'energy-button',
            'activity-button'
        ]
        for btn_id in expected_buttons:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Dashboard button '{btn_id}' missing")
        # Check room list container and list items
        room_list = soup.find(id='room-list')
        self.assertIsNotNone(room_list, "Room list div missing")
        ul = room_list.find('ul')
        self.assertIsNotNone(ul, "Room list ul missing")
        # At least one room or "No rooms found." text
        lis = ul.find_all('li')
        self.assertTrue(len(lis) > 0, "Room list has no items")
