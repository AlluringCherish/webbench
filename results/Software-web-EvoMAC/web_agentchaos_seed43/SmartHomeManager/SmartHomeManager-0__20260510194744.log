<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Automation Rules</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f6f8;
        }
        #automation-page {
            max-width: 900px;
            margin: 0 auto;
            background-color: #fff;
            padding: 25px 30px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 25px;
        }
        #rules-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }
        #rules-table th, #rules-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #ddd;
            text-align: left;
            color: #555;
        }
        #rules-table th {
            background-color: #007BFF;
            color: white;
            font-weight: bold;
        }
        #rules-table tr:hover {
            background-color: #f1f9ff;
        }
        form {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
            align-items: flex-end;
        }
        label {
            font-weight: bold;
            color: #444;
            display: block;
            margin-bottom: 5px;
        }
        input[type="text"], select {
            padding: 8px 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 1em;
            box-sizing: border-box;
            min-width: 150px;
        }
        #add-rule-button {
            background-color: #28a745;
            border: none;
            color: white;
            padding: 10px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            min-width: 120px;
        }
        #add-rule-button:hover {
            background-color: #1e7e34;
        }
        #back-to-dashboard {
            background-color: #6c757d;
            border: none;
            color: white;
            padding: 10px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
            width: 150px;
            display: block;
            margin: 0 auto;
        }
        #back-to-dashboard:hover {
            background-color: #5a6268;
        }
        /* For action-value input, show/hide dynamically */
        #action-value-container {
            display: none;
            flex-direction: column;
        }
    </style>
    <script>
        function onActionTypeChange() {
            const actionTypeSelect = document.getElementById('action-type');
            const actionValueContainer = document.getElementById('action-value-container');
            const actionValueInput = document.getElementById('action-value');
            if (actionTypeSelect.value === 'Set Brightness' || actionTypeSelect.value === 'Set Temperature') {
                actionValueContainer.style.display = 'flex';
                actionValueInput.required = true;
                if (actionTypeSelect.value === 'Set Brightness') {
                    actionValueInput.type = 'number';
                    actionValueInput.min = 0;
                    actionValueInput.max = 100;
                    actionValueInput.placeholder = 'Enter brightness (0-100)';
                } else {
                    actionValueInput.type = 'number';
                    actionValueInput.min = 50;
                    actionValueInput.max = 90;
                    actionValueInput.placeholder = 'Enter temperature (50-90)';
                }
            } else {
                actionValueContainer.style.display = 'none';
                actionValueInput.required = false;
                actionValueInput.value = '';
            }
        }
        window.onload = function() {
            onActionTypeChange();
            document.getElementById('action-type').addEventListener('change', onActionTypeChange);
        }
    </script>
</head>
<body>
<div id="automation-page">
    <h1>Automation Rules</h1>
    <table id="rules-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Trigger</th>
                <th>Action</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for rule in rules %}
            <tr>
                <td>{{ rule.rule_name }}</td>
                <td>{{ rule.trigger_type }}: {{ rule.trigger_value }}</td>
                <td>
                    {% set action_device = devices | selectattr('device_id', 'equalto', rule.action_device_id) | list | first %}
                    {% if action_device %}
                        {{ action_device.device_name }} - {{ rule.action_type }}
                        {% if rule.action_value %}
                            ({{ rule.action_value }})
                        {% endif %}
                    {% else %}
                        Unknown Device - {{ rule.action_type }}
                    {% endif %}
                </td>
                <td>{{ 'Enabled' if rule.enabled else 'Disabled' }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4" style="text-align:center; color:#777;">No automation rules found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <form method="post" action="{{ url_for('automation_rules') }}">
        <div>
            <label for="rule-name">Rule Name</label>
            <input type="text" id="rule-name" name="rule-name" required>
        </div>
        <div>
            <label for="trigger-type">Trigger Type</label>
            <select id="trigger-type" name="trigger-type" required>
                <option value="" disabled selected>Select trigger type</option>
                <option value="Time">Time</option>
                <option value="Motion">Motion</option>
                <option value="Temperature">Temperature</option>
            </select>
        </div>
        <div>
            <label for="trigger-value">Trigger Value</label>
            <input type="text" id="trigger-value" name="trigger-value" placeholder="e.g., 07:00 or detected or 75" required>
        </div>
        <div>
            <label for="action-device">Action Device</label>
            <select id="action-device" name="action-device" required>
                <option value="" disabled selected>Select device</option>
                {% for device in devices %}
                <option value="{{ device.device_id }}">{{ device.device_name }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="action-type">Action Type</label>
            <select id="action-type" name="action-type" required>
                <option value="" disabled selected>Select action</option>
                <option value="Turn On">Turn On</option>
                <option value="Turn Off">Turn Off</option>
                <option value="Set Brightness">Set Brightness</option>
                <option value="Set Temperature">Set Temperature</option>
            </select>
        </div>
        <div id="action-value-container">
            <label for="action-value">Action Value</label>
            <input type="text" id="action-value" name="action-value" placeholder="">
        </div>
        <button type="submit" id="add-rule-button">Add Rule</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
