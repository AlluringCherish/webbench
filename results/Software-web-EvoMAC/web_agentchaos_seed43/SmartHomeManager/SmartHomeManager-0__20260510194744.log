            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        #room-list h2 {
            margin-top: 0;
            color: #333;
            margin-bottom: 15px;
        }
        #room-list ul {
            list-style: none;
            padding-left: 0;
        }
        #room-list ul li {
            padding: 10px 15px;
            border-bottom: 1px solid #ddd;
            font-size: 1em;
            color: #555;
            display: flex;
            justify-content: space-between;
        }
        #room-list ul li:last-child {
            border-bottom: none;
        }
        #room-list ul li span.count {
            font-weight: bold;
            color: #007BFF;
        }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1>Smart Home Dashboard</h1>
    <div id="device-summary">
        <div>
            Total Devices
            <span class="count" id="total-devices">{{ total_devices }}</span>
        </div>
        <div>
            Active Devices
            <span class="count" id="active-devices">{{ active_devices }}</span>
        </div>
        <div>
            Offline Devices
            <span class="count" id="offline-devices">{{ offline_devices }}</span>
        </div>
    </div>
    <div id="dashboard-buttons">
        <button id="device-list-button" onclick="location.href='{{ url_for('device_list') }}'">Device List</button>
        <button id="add-device-button" onclick="location.href='{{ url_for('add_device') }}'">Add Device</button>
        <button id="automation-button" onclick="location.href='{{ url_for('automation_rules') }}'">Automation Rules</button>
        <button id="energy-button" onclick="location.href='{{ url_for('energy_report') }}'">Energy Report</button>
        <button id="activity-button" onclick="location.href='{{ url_for('activity_logs') }}'">Activity Logs</button>
    </div>
    <div id="room-list">
        <h2>Rooms and Device Counts</h2>
        <ul>
            {% for room_name, count in room_counts.items() %}
            <li>
                <span class="room-name">{{ room_name }}</span>
                <span class="count">{{ count }}</span>
            </li>
            {% else %}
            <li>No rooms found.</li>
            {% endfor %}
        </ul>
    </div>
</div>
</body>
</html>
