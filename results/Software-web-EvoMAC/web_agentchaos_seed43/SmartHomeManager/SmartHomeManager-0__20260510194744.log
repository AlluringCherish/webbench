        Total Consumption: {{ '%.2f'|format(total_consumption) }} kWh |
        Estimated Cost: ${{ '%.2f'|format(cost_estimate) }}
    </div>
    <form method="post" action="{{ url_for('energy_report') }}">
        <input type="date" id="date-filter" name="date-filter" value="{{ filter_date }}">
        <button type="submit" id="apply-filter-button">Apply Filter</button>
    </form>
    <table id="energy-table">
        <thead>
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ device_names.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.date }}</td>
                <td>{{ '%.2f'|format(log.consumption_kwh) }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="3" style="text-align:center; color:#777;">No energy consumption data found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
