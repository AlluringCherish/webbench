energy_report.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Energy Report</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f4f6f8;
        }
        #energy-page {
            max-width: 900px;
            margin: 0 auto;
            background-color: #fff;
            padding: 25px 30px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 25px;
        }
        #energy-summary {
            font-size: 1.1em;
            color: #444;
            margin-bottom: 20px;
            text-align: center;
        }
        #energy-table {
            width: 100%;
            border-collapse: collapse;
            background-color: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        #energy-table th, #energy-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #ddd;
            text-align: left;
            color: #555;
        }
        #energy-table th {
            background-color: #007BFF;
            color: white;
            font-weight: bold;
        }
        #energy-table tr:hover {
            background-color: #f1f9ff;
        }
        form {
            margin-bottom: 20px;
            text-align: center;
        }
        input[type="date"] {
            padding: 8px 12px;
            font-size: 1em;
            border: 1px solid #ccc;
            border-radius: 5px;
            margin-right: 10px;
            transition: border-color 0.3s ease;
        }
        input[type="date"]:focus {
            border-color: #007BFF;
            outline: none;
        }
        #apply-filter-button {
            background-color: #007BFF;
            border: none;
            color: white;
            padding: 9px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        #apply-filter-button:hover {
            background-color: #0056b3;
        }
        #back-to-dashboard {
            margin-top: 20px;
            background-color: #6c757d;
            border: none;
            color: white;
            padding: 10px 18px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            display: block;
            width: 150px;
            text-align: center;
            margin-left: auto;
            margin-right: auto;
            transition: background-color 0.3s ease;
        }
        #back-to-dashboard:hover {
            background-color: #5a6268;
        }
    </style>
</head>
<body>
<div id="energy-page">
    <h1>Energy Report</h1>
    <div id="energy-summary">
        Total Consumption: {{ '%.2f'|format(total_consumption) }} kWh |
        Estimated Cost: ${{ '%.2f'|format(cost_estimate) }}
    </div>
    <form method="post" action="{{ url_for('energy_report') }}">
        <input type="date" id="date-filter" name="date-filter" value="{{ filter_date }}">
        <button type="submit" id="apply-filter-button">Apply Filter</button>
    </form>
    <table id="energy-table">
        <thead>
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ device_names.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.date }}</td>
                <td>{{ '%.2f'|format(log.consumption_kwh) }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="3" style="text-align:center; color:#777;">No energy consumption data found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

