            pass
        else:
            for row in rows:
                btn = row.find('button', class_='control-device-button')
                self.assertIsNotNone(btn, "Control button missing in device row")
                self.assertTrue(btn['id'].startswith('control-device-button-'), "Control button id format incorrect")
        back_btn = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_btn, "Back to dashboard button missing on device list page")
