        title = soup.find('title')
        self.assertIsNotNone(title)
        self.assertEqual(title.text.strip(), 'Bookstore Dashboard')
    def test_dashboard_container_div(self):
        # Test presence of dashboard-page div container
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div)
    def test_featured_books_div(self):
        # Test presence of featured-books div and that it contains at least one featured book
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_div = soup.find('div', id='featured-books')
        self.assertIsNotNone(featured_div)
        # Check that featured books are listed (e.g. at least one book card or title inside)
        # We expect at least one child element or text inside featured-books div
        self.assertTrue(len(featured_div.contents) > 0 or featured_div.text.strip() != '')
    def test_navigation_buttons_presence(self):
        # Test presence of browse-catalog-button, view-cart-button, bestsellers-button
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        browse_button = soup.find('button', id='browse-catalog-button')
        cart_button = soup.find('button', id='view-cart-button')
        bestsellers_button = soup.find('button', id='bestsellers-button')
        self.assertIsNotNone(browse_button)
        self.assertIsNotNone(cart_button)
        self.assertIsNotNone(bestsellers_button)
