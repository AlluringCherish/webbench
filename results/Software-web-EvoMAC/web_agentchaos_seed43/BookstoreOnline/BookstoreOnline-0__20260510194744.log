import unittest
from app import app
from bs4 import BeautifulSoup

class TestBookstoreOnlineDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible at root '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)

    def test_dashboard_page_title(self):
        # Test that the page title is "Bookstore Dashboard"
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.find('title')
        self.assertIsNotNone(title)
        self.assertEqual(title.text.strip(), 'Bookstore Dashboard')

    def test_dashboard_container_div(self):
        # Test presence of dashboard-page div container
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div)

    def test_featured_books_div(self):
        # Test presence of featured-books div and that it contains at least one featured book
