        self.assertIsNotNone(browse_button)
        self.assertIsNotNone(cart_button)
        self.assertIsNotNone(bestsellers_button)

    def test_navigation_buttons_functionality(self):
        # Test that navigation buttons link to correct pages by simulating clicks (GET requests)
