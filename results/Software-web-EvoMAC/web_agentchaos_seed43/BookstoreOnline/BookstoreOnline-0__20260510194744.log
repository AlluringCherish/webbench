        self.assertIsNotNone(featured_div)
        # Check that featured books are listed (e.g. at least one book card or title inside)
        # We expect at least one child element or text inside featured-books div
        self.assertTrue(len(featured_div.contents) > 0 or featured_div.text.strip() != '')

    def test_navigation_buttons_presence(self):
