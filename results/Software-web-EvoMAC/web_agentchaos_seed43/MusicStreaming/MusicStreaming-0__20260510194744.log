        browse_songs_button = soup.find('button', id='browse-songs-button')
        self.assertIsNotNone(browse_songs_button, "Browse songs button with id 'browse-songs-button' not found")

        # Check for my-playlists-button button
        my_playlists_button = soup.find('button', id='my-playlists-button')
        self.assertIsNotNone(my_playlists_button, "My playlists button with id 'my-playlists-button' not found")

        # Check for trending-artists-button button
        trending_artists_button = soup.find('button', id='trending-artists-button')
        self.assertIsNotNone(trending_artists_button, "Trending artists button with id 'trending-artists-button' not found")

    def test_featured_songs_content(self):
        # Test that featured songs are displayed with expected keys in the rendered page
        response = self.client.get('/')
