'''
Dashboard page template for MusicStreaming web app.
Displays featured songs, trending artists, and navigation buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Music Streaming Dashboard</title>
    <style>
        #dashboard-page { padding: 20px; font-family: Arial, sans-serif; }
        #featured-songs, #trending-artists { margin-bottom: 30px; }
        .song-card, .artist-card { border: 1px solid #ccc; padding: 10px; margin: 5px; display: inline-block; vertical-align: top; width: 180px; }
        button { margin: 5px; padding: 10px 15px; font-size: 16px; cursor: pointer; }
        a { text-decoration: none; color: #333; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1>Music Streaming Dashboard</h1>

    <section id="featured-songs">
        <h2>Featured Songs</h2>
        {% if featured_songs %}
            {% for song in featured_songs %}
                <div class="song-card">
                    <div><strong>{{ song.title }}</strong></div>
                    <div>Artist: <a href="{{ url_for('artist_profile', artist_id=song.artist_id) }}">{{ song.artist_name }}</a></div>
                    <div>Album: {{ song.album_name }}</div>
                    <div>Duration: {{ (song.duration // 60) }}:{{ '%02d' % (song.duration % 60) }}</div>
                </div>
            {% endfor %}
        {% else %}
            <p>No featured songs available.</p>
        {% endif %}
    </section>

    <section id="trending-artists">
        <h2>Trending Artists</h2>
        {% if trending_artists %}
            {% for artist in trending_artists %}
                <div class="artist-card">
                    <div><strong>{{ artist.name }}</strong></div>
                    <div>Genre: {{ artist.genre }}</div>
                    <div>Country: {{ artist.country }}</div>
                </div>
            {% endfor %}
        {% else %}
            <p>No trending artists available.</p>
        {% endif %}
    </section>

    <nav>
        <button id="browse-songs-button" onclick="location.href='{{ url_for('song_catalog') }}'">Browse Songs</button>
        <button id="my-playlists-button" onclick="location.href='{{ url_for('playlists') }}'">My Playlists</button>
        <button id="trending-artists-button" onclick="location.href='{{ url_for('artists') }}'">Trending Artists</button>
    </nav>
</div>
</body>
</html>
```

