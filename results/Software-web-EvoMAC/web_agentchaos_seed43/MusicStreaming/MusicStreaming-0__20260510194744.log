                    })
    except FileNotFoundError:
        pass
    return songs
def load_artists():
    artists = []
    try:
        with open(os.path.join(DATA_DIR, 'artists.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    artist_id, name, genre, country, formation_year = line.split('|')
                    artists.append({
