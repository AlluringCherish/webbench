            {% for restaurant in featured_restaurants %}
            <div class="restaurant-card">
                <img src="{{ url_for('static', filename='images/restaurants/' + restaurant.restaurant_id + '.jpg') }}" alt="{{ restaurant.name }} Logo" class="restaurant-logo" onerror="this.onerror=null;this.src='{{ url_for('static', filename='images/restaurants/default.jpg') }}';">
                <h3>{{ restaurant.name }}</h3>
                <p>Cuisine: {{ restaurant.cuisine }}</p>
                <p>Rating: {{ restaurant.rating }}</p>
                <p>Delivery Time: {{ restaurant.delivery_time }} mins</p>
                <form action="{{ url_for('menu_page', restaurant_id=restaurant.restaurant_id) }}" method="get">
                    <button type="submit" id="view-restaurant-button-{{ restaurant.restaurant_id }}">View Menu</button>
                </form>
            </div>
            {% else %}
            <p>No featured restaurants available.</p>
            {% endfor %}
        </div>
    </section>
    <section id="popular-cuisines" class="section">
        <h2>Popular Cuisines</h2>
