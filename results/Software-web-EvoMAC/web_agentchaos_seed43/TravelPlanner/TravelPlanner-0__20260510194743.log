from fpdf import FPDF
app = Flask(__name__)
DATA_DIR = 'data'
def load_destinations():
    destinations = []
    try:
        with open(os.path.join(DATA_DIR, 'destinations.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        dest = {
                            'dest_id': parts[0],
                            'name': parts[1],
                            'country': parts[2],
                            'region': parts[3],
                            'description': parts[4],
                            'attractions': parts[5],
                            'climate': parts[6]
                        }
                        destinations.append(dest)
    except FileNotFoundError:
        pass
    return destinations
def load_trips():
    trips = []
    try:
        with open(os.path.join(DATA_DIR, 'trips.txt'), 'r', encoding='utf-8') as f:
