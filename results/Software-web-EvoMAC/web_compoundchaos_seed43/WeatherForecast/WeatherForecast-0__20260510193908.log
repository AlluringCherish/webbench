<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Alerts</title>
</head>
<body>
    <h1>Weather Alerts</h1>
    <form method="get">
        <label for="severity-filter">Filter by Severity:</label>
        <select id="severity-filter" name="severity" onchange="this.form.submit()">
            <option value="">All</option>
            {% for sev in severities %}
            <option value="{{ sev }}" {% if sev == selected_severity %}selected{% endif %}>{{ sev }}</option>
            {% endfor %}
        </select>
        <label for="location-filter">Filter by Location:</label>
        <select id="location-filter" name="location_id" onchange="this.form.submit()">
            <option value="">All</option>
            {% for loc_id, loc in locations.items() %}
            <option value="{{ loc_id }}" {% if loc_id == selected_location %}selected{% endif %}>{{ loc.name }}</option>
            {% endfor %}
        </select>
    </form>
    <div id="alerts-list">
        {% if alerts %}
        <ul>
            {% for alert in alerts %}
            <li>
                <strong>{{ alert.alert_type }}</strong> ({{ alert.severity }}) - {{ alert.description }}<br>
                Location: {{ alert.location_name }}<br>
                From: {{ alert.start_time }} To: {{ alert.end_time }}
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p>No alerts found.</p>
        {% endif %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
