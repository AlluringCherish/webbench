</head>
<body>
    <h1>Settings</h1>
    <form method="post">
        <div>
            <label for="temperature_unit">Temperature Unit:</label>
            <select id="temperature_unit" name="temperature_unit">
                <option value="Celsius" {% if settings.temperature_unit == 'Celsius' %}selected{% endif %}>Celsius</option>
                <option value="Fahrenheit" {% if settings.temperature_unit == 'Fahrenheit' %}selected{% endif %}>Fahrenheit</option>
            </select>
        </div>
        <div>
            <label for="default_location_id">Default Location:</label>
            <select id="default_location_id" name="default_location_id">
                <option value="">-- Select --</option>
                {% for loc_id, loc in locations.items() %}
                <option value="{{ loc_id }}" {% if loc_id == settings.default_location_id %}selected{% endif %}>{{ loc.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label for="alert_notifications_toggle">Alert Notifications:</label>
            <input type="checkbox" id="alert_notifications_toggle" name="alert_notifications_enabled" {% if settings.alert_notifications_enabled == '1' %}checked{% endif %}>
        </div>
        <button type="submit">Save Changes</button>
    </form>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
