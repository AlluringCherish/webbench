```python
from flask import Flask, render_template, request, redirect, url_for, jsonify
import os
from datetime import datetime

app = Flask(__name__)

DATA_DIR = 'data'

# Utility functions to read data files

def read_current_weather():
    path = os.path.join(DATA_DIR, 'current_weather.txt')
    weather = {}
    if not os.path.exists(path):
        return weather
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 7:
                continue
            location_id = parts[0]
            weather[location_id] = {
                'location_name': parts[1],
                'temperature': parts[2],
                'condition': parts[3],
                'humidity': parts[4],
                'wind_speed': parts[5],
                'last_updated': parts[6]
            }
    return weather

def read_forecasts():
    path = os.path.join(DATA_DIR, 'forecasts.txt')
    forecasts = []
    if not os.path.exists(path):
        return forecasts
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            forecasts.append({
                'forecast_id': parts[0],
                'location_id': parts[1],
                'date': parts[2],
                'high_temp': parts[3],
                'low_temp': parts[4],
                'condition': parts[5],
                'precipitation': parts[6],
                'humidity': parts[7]
            })
    return forecasts

def read_locations():
    path = os.path.join(DATA_DIR, 'locations.txt')
    locations = {}
    if not os.path.exists(path):
        return locations
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 6:
                continue
            location_id = parts[0]
            locations[location_id] = {
                'name': parts[1],
                'latitude': parts[2],
                'longitude': parts[3],
                'country': parts[4],
                'timezone': parts[5]
            }
    return locations

def read_alerts():
    path = os.path.join(DATA_DIR, 'alerts.txt')
    alerts = []
    if not os.path.exists(path):
        return alerts
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            alerts.append({
                'alert_id': parts[0],
                'location_id': parts[1],
                'alert_type': parts[2],
                'severity': parts[3],
                'description': parts[4],
                'start_time': parts[5],
                'end_time': parts[6],
                'is_acknowledged': parts[7]
            })
    return alerts

def read_air_quality():
    path = os.path.join(DATA_DIR, 'air_quality.txt')
    air_quality = []
    if not os.path.exists(path):
        return air_quality
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            air_quality.append({
                'aqi_id': parts[0],
                'location_id': parts[1],
                'aqi_value': parts[2],
                'pm25': parts[3],
                'pm10': parts[4],
                'no2': parts[5],
                'o3': parts[6],
                'last_updated': parts[7]
            })
    return air_quality

def read_saved_locations():
    path = os.path.join(DATA_DIR, 'saved_locations.txt')
    saved = []
    if not os.path.exists(path):
        return saved
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 4:
                continue
            saved.append({
                'id': parts[0],
                'user_id': parts[1],
                'location_id': parts[2],
                'location_name': parts[3],
                'is_default': parts[4] if len(parts) > 4 else '0'
            })
    return saved

# Routes

@app.route('/')
def dashboard():
    current_weather = read_current_weather()
    saved_locations = read_saved_locations()
    locations = read_locations()
    # Show current weather for default location or first saved location
    default_location_id = None
    for loc in saved_locations:
        if loc['is_default'] == '1':
            default_location_id = loc['location_id']
            break
    if not default_location_id and saved_locations:
        default_location_id = saved_locations[0]['location_id']
    weather = current_weather.get(default_location_id, None)
    location_name = locations.get(default_location_id, {}).get('name', '') if default_location_id else ''
    return render_template('dashboard.html',
                           weather=weather,
                           location_name=location_name,
                           saved_locations=saved_locations,
                           locations=locations)

@app.route('/current/<location_id>')
def current_weather_page(location_id):
    current_weather = read_current_weather()
    weather = current_weather.get(location_id)
    locations = read_locations()
    location = locations.get(location_id)
    if not weather or not location:
        return "Location or weather data not found", 404
    return render_template('current_weather.html',
                           weather=weather,
                           location=location)

@app.route('/forecast/<location_id>')
def forecast_page(location_id):
    forecasts = read_forecasts()
    locations = read_locations()
    location = locations.get(location_id)
    if not location:
        return "Location not found", 404
    # Filter forecasts for location and sort by date ascending
    location_forecasts = [f for f in forecasts if f['location_id'] == location_id]
    location_forecasts.sort(key=lambda x: x['date'])
    # Get unique conditions for dropdown filter
    conditions = sorted(set(f['condition'] for f in location_forecasts))
    # Get filter from query param
    condition_filter = request.args.get('condition', None)
    if condition_filter:
        location_forecasts = [f for f in location_forecasts if f['condition'] == condition_filter]
    return render_template('forecast.html',
                           location=location,
                           forecasts=location_forecasts,
                           conditions=conditions,
                           selected_condition=condition_filter)

@app.route('/search', methods=['GET', 'POST'])
def search_page():
    locations = read_locations()
    query = request.args.get('q', '').lower()
    matched = []
    if query:
        for loc_id, loc in locations.items():
            if query in loc['name'].lower():
                matched.append({'location_id': loc_id, 'name': loc['name']})
    return render_template('search.html', matched=matched, query=query)

@app.route('/alerts')
def alerts_page():
    alerts = read_alerts()
    locations = read_locations()
    severity_filter = request.args.get('severity', None)
    location_filter = request.args.get('location_id', None)
    filtered_alerts = alerts
    if severity_filter:
        filtered_alerts = [a for a in filtered_alerts if a['severity'].lower() == severity_filter.lower()]
    if location_filter:
        filtered_alerts = [a for a in filtered_alerts if a['location_id'] == location_filter]
    # Attach location names
    for alert in filtered_alerts:
        alert['location_name'] = locations.get(alert['location_id'], {}).get('name', 'Unknown')
    severities = sorted(set(a['severity'] for a in alerts))
    return render_template('alerts.html',
                           alerts=filtered_alerts,
                           severities=severities,
                           selected_severity=severity_filter,
                           locations=locations,
                           selected_location=location_filter)

@app.route('/air_quality')
def air_quality_page():
    air_quality = read_air_quality()
    locations = read_locations()
    location_filter = request.args.get('location_id', None)
    filtered_aq = air_quality
    if location_filter:
        filtered_aq = [aq for aq in filtered_aq if aq['location_id'] == location_filter]
    # Attach location names
    for aq in filtered_aq:
        aq['location_name'] = locations.get(aq['location_id'], {}).get('name', 'Unknown')
        aqi_val = int(aq['aqi_value'])
        if aqi_val <= 50:
            aq['aqi_desc'] = 'Good'
        elif aqi_val <= 100:
            aq['aqi_desc'] = 'Moderate'
        elif aqi_val <= 150:
            aq['aqi_desc'] = 'Unhealthy for Sensitive Groups'
        elif aqi_val <= 200:
            aq['aqi_desc'] = 'Unhealthy'
        elif aqi_val <= 300:
            aq['aqi_desc'] = 'Very Unhealthy'
        else:
            aq['aqi_desc'] = 'Hazardous'
    return render_template('air_quality.html',
                           air_quality=filtered_aq,
                           locations=locations,
                           selected_location=location_filter)

@app.route('/saved_locations')
def saved_locations_page():
    saved_locations = read_saved_locations()
    current_weather = read_current_weather()
    locations = read_locations()
    # Attach current weather condition to saved locations
    for loc in saved_locations:
        weather = current_weather.get(loc['location_id'])
        loc['temperature'] = weather['temperature'] if weather else 'N/A'
        loc['condition'] = weather['condition'] if weather else 'N/A'
    return render_template('saved_locations.html',
                           saved_locations=saved_locations,
                           locations=locations)

@app.route('/settings', methods=['GET', 'POST'])
def settings_page():
    # For simplicity, settings stored in a file settings.txt as key=value per line
    settings_path = os.path.join(DATA_DIR, 'settings.txt')
    settings = {
        'temperature_unit': 'Celsius',
        'default_location_id': '',
        'alert_notifications_enabled': '1'
    }
    if os.path.exists(settings_path):
        with open(settings_path, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if '=' in line:
                    k,v = line.split('=',1)
                    settings[k] = v
    if request.method == 'POST':
        temperature_unit = request.form.get('temperature_unit', 'Celsius')
        default_location_id = request.form.get('default_location_id', '')
        alert_notifications_enabled = '1' if request.form.get('alert_notifications_enabled') == 'on' else '0'
        settings['temperature_unit'] = temperature_unit
        settings['default_location_id'] = default_location_id
        settings['alert_notifications_enabled'] = alert_notifications_enabled
        with open(settings_path, 'w', encoding='utf-8') as f:
            for k,v in settings.items():
                f.write(f"{k}={v}\n")
        return redirect(url_for('dashboard'))
    locations = read_locations()
    return render_template('settings.html',
                           settings=settings,
                           locations=locations)

if __name__ == '__main__':
    app.run(debug=True)
```

