from flask import Flask, render_template, request, redirect, url_for
import os
from datetime import datetime

app = Flask(__name__)

DATA_DIR = 'data'

def read_current_weather():
    path = os.path.join(DATA_DIR, 'weather.txt')
    current_weather = {}
    if not os.path.exists(path):
        return current_weather
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 7:
                continue
            location_id = parts[0]
            current_weather[location_id] = {
                'location_name': parts[1],
                'temperature': parts[2],
                'condition': parts[3],
                'humidity': parts[4],
                'wind_speed': parts[5],
                'last_updated': parts[6]
            }
    return current_weather

def read_forecasts():
    path = os.path.join(DATA_DIR, 'forecasts.txt')
    forecasts = []
    if not os.path.exists(path):
        return forecasts
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            forecasts.append({
                'forecast_id': parts[0],
                'location_id': parts[1],
                'date': parts[2],
                'high_temp': parts[3],
                'low_temp': parts[4],
                'condition': parts[5],
                'precipitation': parts[6],
                'humidity': parts[7]
            })
    return forecasts

def read_locations():
    path = os.path.join(DATA_DIR, 'locations.txt')
    locations = {}
    if not os.path.exists(path):
        return locations
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 6:
                continue
            location_id = parts[0]
            locations[location_id] = {
                'name': parts[1],
                'latitude': parts[2],
                'longitude': parts[3],
                'country': parts[4],
                'timezone': parts[5]
            }
    return locations

def read_alerts():
    path = os.path.join(DATA_DIR, 'alerts.txt')
    alerts = []
    if not os.path.exists(path):
        return alerts
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            alerts.append({
                'alert_id': parts[0],
                'location_id': parts[1],
                'alert_type': parts[2],
                'severity': parts[3],
                'description': parts[4],
                'start_time': parts[5],
                'end_time': parts[6],
                'acknowledged': parts[7]
            })
    return alerts

def read_air_quality():
    path = os.path.join(DATA_DIR, 'air_quality.txt')
    air_quality = []
    if not os.path.exists(path):
        return air_quality
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 8:
                continue
            air_quality.append({
                'aqi_id': parts[0],
                'location_id': parts[1],
                'aqi_value': parts[2],
                'pm25': parts[3],
                'pm10': parts[4],
                'no2': parts[5],
                'o3': parts[6],
                'last_updated': parts[7]
            })
    return air_quality

def read_saved_locations():
    path = os.path.join(DATA_DIR, 'saved_locations.txt')
    saved = []
    if not os.path.exists(path):
        return saved
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 4:
                continue
            saved.append({
                'id': parts[0],
                'user_id': parts[1],
                'location_id': parts[2],
                'location_name': parts[3],
                'is_default': parts[4] if len(parts) > 4 else '0'
            })
    return saved

def read_settings():
    path = os.path.join(DATA_DIR, 'settings.txt')
    settings = {
        'temperature_unit': 'Celsius',
        'default_location_id': '',
        'alert_notifications_enabled': '1'
    }
    if not os.path.exists(path):
        return settings
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line or '=' not in line:
                continue
            k, v = line.split('=', 1)
            settings[k.strip()] = v.strip()
    return settings

def write_settings(settings):
    path = os.path.join(DATA_DIR, 'settings.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for k, v in settings.items():
            f.write(f"{k}={v}\n")

@app.route('/')
def dashboard():
    saved_locations = read_saved_locations()
    current_weather = read_current_weather()
    locations = read_locations()
    default_location_id = ''
    for loc in saved_locations:
        if loc.get('is_default') == '1':
            default_location_id = loc.get('location_id')
            break
    if not default_location_id and saved_locations:
        default_location_id = saved_locations[0].get('location_id')
    weather = current_weather.get(default_location_id, None)
    location_name = locations.get(default_location_id, {}).get('name', '') if default_location_id else ''
    return render_template('dashboard.html',
                           location_name=location_name,
                           weather=weather,
                           saved_locations=saved_locations)

@app.route('/current/<location_id>')
def current_weather_page(location_id):
    current_weather = read_current_weather()
    locations = read_locations()
    weather = current_weather.get(location_id)
    location = locations.get(location_id)
    if not location or not weather:
        return "Location not found", 404
    return render_template('current.html', weather=weather, location=location)

@app.route('/forecast/<location_id>', methods=['GET', 'POST'])
def forecast_page(location_id):
    locations = read_locations()
    forecasts = read_forecasts()
    location = locations.get(location_id)
    if not location:
        return "Location not found", 404
    location_forecasts = [f for f in forecasts if f['location_id'] == location_id]
    conditions = sorted(set(f['condition'] for f in location_forecasts))
    selected_condition = request.args.get('condition', '')
    if selected_condition:
        location_forecasts = [f for f in location_forecasts if f['condition'] == selected_condition]
    return render_template('forecast.html',
                           location=location,
                           forecasts=location_forecasts,
                           conditions=conditions,
                           selected_condition=selected_condition)

@app.route('/search', methods=['GET'])
def search_page():
    query = request.args.get('q', '').strip()
    locations = read_locations()
    matched = []
    if query:
        for loc_id, loc in locations.items():
            if query.lower() in loc['name'].lower():
                matched.append({'location_id': loc_id, 'name': loc['name']})
    return render_template('search.html', matched=matched, query=query)

@app.route('/alerts', methods=['GET'])
def alerts_page():
    alerts = read_alerts()
    locations = read_locations()
    location_filter = request.args.get('location_id', '')
    severity_filter = request.args.get('severity', '')
    filtered_alerts = alerts
    if location_filter:
        filtered_alerts = [a for a in filtered_alerts if a['location_id'] == location_filter]
    if severity_filter and severity_filter != 'All':
        filtered_alerts = [a for a in filtered_alerts if a['severity'] == severity_filter]
    # Attach location names
    for alert in filtered_alerts:
        alert['location_name'] = locations.get(alert['location_id'], {}).get('name', '')
    severities = sorted(set(a['severity'] for a in alerts))
    return render_template('alerts.html',
                           alerts=filtered_alerts,
                           severities=severities,
                           selected_location=location_filter,
                           selected_severity=severity_filter,
                           locations=locations)

@app.route('/air_quality', methods=['GET'])
def air_quality_page():
    air_quality = read_air_quality()
    locations = read_locations()
    location_filter = request.args.get('location_id', '')
    filtered_aq = air_quality
    if location_filter:
        filtered_aq = [aq for aq in filtered_aq if aq['location_id'] == location_filter]
    for aq in filtered_aq:
        loc = locations.get(aq['location_id'], {})
        aq['location_name'] = loc.get('name', '')
        try:
            aqi_val = int(aq['aqi_value'])
        except:
            aqi_val = 0
        if aqi_val <= 50:
            aq['aqi_desc'] = 'Good'
        elif aqi_val <= 100:
            aq['aqi_desc'] = 'Moderate'
        elif aqi_val <= 150:
            aq['aqi_desc'] = 'Unhealthy for Sensitive Groups'
        elif aqi_val <= 200:
            aq['aqi_desc'] = 'Unhealthy'
        elif aqi_val <= 300:
            aq['aqi_desc'] = 'Very Unhealthy'
        else:
            aq['aqi_desc'] = 'Hazardous'
    return render_template('air_quality.html',
                           air_quality=filtered_aq,
                           locations=locations,
                           selected_location=location_filter)

@app.route('/locations', methods=['GET'])
def saved_locations_page():
    saved_locations = read_saved_locations()
    current_weather = read_current_weather()
    for loc in saved_locations:
        weather = current_weather.get(loc['location_id'])
        loc['condition'] = weather['condition'] if weather else ''
    return render_template('locations.html', saved_locations=saved_locations)

@app.route('/settings', methods=['GET', 'POST'])
def settings_page():
    settings = read_settings()
    locations = read_locations()
    if request.method == 'POST':
        temperature_unit = request.form.get('temperature_unit', 'Celsius')
        default_location_id = request.form.get('default_location_id', '')
        alert_notifications_enabled = '1' if request.form.get('alert_notifications_enabled') == 'on' else '0'
        settings['temperature_unit'] = temperature_unit
        settings['default_location_id'] = default_location_id
        settings['alert_notifications_enabled'] = alert_notifications_enabled
        write_settings(settings)
        return redirect(url_for('dashboard'))
    return render_template('settings.html', settings=settings, locations=locations)

if __name__ == '__main__':
    app.run(debug=True, port=5000)

