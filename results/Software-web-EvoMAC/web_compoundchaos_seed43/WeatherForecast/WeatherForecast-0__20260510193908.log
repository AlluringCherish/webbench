<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Dashboard</title>
</head>
<body>
    <h1>Weather Dashboard</h1>
    {% if weather %}
    <div id="current-weather">
        <h2>Current Weather for {{ location_name }}</h2>
        <div>Temperature: {{ weather.temperature }}°</div>
        <div>Condition: {{ weather.condition }}</div>
        <div>Humidity: {{ weather.humidity }}%</div>
        <div>Wind Speed: {{ weather.wind_speed }} mph</div>
        <div>Last Updated: {{ weather.last_updated }}</div>
    </div>
    {% else %}
    <p>No weather data available.</p>
    {% endif %}
    <button id="view-forecast-button" onclick="location.href='{{ url_for('forecast_page', location_id=weather and weather.location_name or '') }}'">View Forecast</button>
    <button onclick="location.href='{{ url_for('alerts_page') }}'">View Alerts</button>
    <button onclick="location.href='{{ url_for('search_page') }}'">Search Locations</button>
    <button onclick="location.href='{{ url_for('saved_locations_page') }}'">Saved Locations</button>
    <button onclick="location.href='{{ url_for('air_quality_page') }}'">Air Quality</button>
    <button onclick="location.href='{{ url_for('settings_page') }}'">Settings</button>
</body>
</html>
