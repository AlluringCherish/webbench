<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forecast - {{ location.name }}</title>
</head>
<body>
    <h1>Forecast for {{ location.name }}</h1>
    <form method="get">
        <label for="condition-filter">Filter by Condition:</label>
        <select id="condition-filter" name="condition" onchange="this.form.submit()">
            <option value="">All</option>
            {% for cond in conditions %}
            <option value="{{ cond }}" {% if cond == selected_condition %}selected{% endif %}>{{ cond }}</option>
            {% endfor %}
        </select>
    </form>
    <div id="forecast-list" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px;">
        {% for f in forecasts %}
        <div class="forecast-card" style="border:1px solid #ccc; padding:10px;">
            <div>Date: {{ f.date }}</div>
            <div>High: {{ f.high_temp }}°</div>
            <div>Low: {{ f.low_temp }}°</div>
            <div>Condition: {{ f.condition }}</div>
            <div>Precipitation: {{ f.precipitation }}%</div>
            <div>Humidity: {{ f.humidity }}%</div>
        </div>
        {% endfor %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
