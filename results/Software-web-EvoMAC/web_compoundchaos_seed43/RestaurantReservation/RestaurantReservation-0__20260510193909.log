    <!-- Make Reservation Page -->
    <div id="reservation-page" class="page" style="display:none;">
        <h1>Make Reservation</h1>
        <label for="party-size">Party Size (1-10):</label>
        <select id="party-size">
            <option value="" disabled selected>Select party size</option>
            <option value="1">1</option><option value="2">2</option><option value="3">3</option>
            <option value="4">4</option><option value="5">5</option><option value="6">6</option>
            <option value="7">7</option><option value="8">8</option><option value="9">9</option>
            <option value="10">10</option>
        </select>
        <label for="reservation-date">Reservation Date:</label>
        <input type="date" id="reservation-date" />
        <button id="submit-reservation-button">Submit Reservation</button>
        <button id="back-to-dashboard-from-reservation">Back to Dashboard</button>
    </div>

    <!-- My Reservations Page -->
    <div id="my-reservations-page" class="page" style="display:none;">
        <h1>My Reservations</h1>
        <div id="my-reservations"></div>
        <button id="back-to-dashboard-from-reservations">Back to Dashboard</button>
    </div>

    <!-- Waitlist Page -->
    <div id="waitlist-page" class="page" style="display:none;">
        <h1>Waitlist</h1>
        <label for="waitlist-party-size">Select Party Size:</label>
        <select id="waitlist-party-size">
            <option value="" disabled selected>Select party size</option>
            <option value="1">1</option><option value="2">2</option><option value="3">3</option>
            <option value="4">4</option><option value="5">5</option><option value="6">6</option>
            <option value="7">7</option><option value="8">8</option><option value="9">9</option>
            <option value="10">10</option>
        </select>
        <button id="join-waitlist-button">Join Waitlist</button>
        <div id="user-waitlist-position"></div>
        <button id="back-to-dashboard-from-waitlist">Back to Dashboard</button>
    </div>

    <!-- Reviews Page -->
    <div id="reviews-page" class="page" style="display:none;">
        <h1>My Reviews</h1>
        <div id="reviews-list"></div>
        <button id="write-new-review-button">Write New Review</button>
        <button id="back-to-dashboard-from-reviews">Back to Dashboard</button>
    </div>

    <!-- Write Review Page -->
    <div id="write-review-page" class="page" style="display:none;">
        <h1>Write Review</h1>
        <label for="select-dish">Select Dish:</label>
        <select id="select-dish"></select>
        <label for="select-rating">Rating:</label>
        <select id="select-rating">
            <option value="" disabled selected>Select rating</option>
            <option value="1">1</option><option value="2">2</option><option value="3">3</option>
            <option value="4">4</option><option value="5">5</option>
        </select>
        <label for="review-text">Review:</label>
        <textarea id="review-text" rows="4"></textarea>
        <button id="submit-review-button">Submit Review</button>
        <button id="back-to-reviews">Back to Reviews</button>
    </div>

    <!-- Profile Page -->
    <div id="profile-page" class="page" style="display:none;">
        <h1>Profile</h1>
        <div id="profile-username"></div>
        <label for="profile-email">Email:</label>
        <input type="email" id="profile-email" />
        <button id="update-profile-button">Update Profile</button>
        <button id="back-to-dashboard-from-profile">Back to Dashboard</button>
    </div>

    <script src="app.js"></script>
</body>
</html>
