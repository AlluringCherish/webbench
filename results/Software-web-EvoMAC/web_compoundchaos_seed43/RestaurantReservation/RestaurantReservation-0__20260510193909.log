```js
// app.js

// Data storage simulation (localStorage keys)
const STORAGE_KEYS = {
    USERS: 'rr_users',
    CURRENT_USER: 'rr_current_user',
    MENU: 'rr_menu',
    RESERVATIONS: 'rr_reservations',
    WAITLIST: 'rr_waitlist',
    REVIEWS: 'rr_reviews'
};

// Utility: parse pipe-delimited string to object array
function parseData(text, keys) {
    if (!text) return [];
    return text.trim().split('\n').map(line => {
        const parts = line.split('|');
        let obj = {};
        keys.forEach((key, i) => obj[key] = parts[i] || '');
        return obj;
    });
}

// Utility: serialize object array to pipe-delimited string
function serializeData(arr, keys) {
    return arr.map(obj => keys.map(k => obj[k] || '').join('|')).join('\n');
}

// Initial sample data load (only if not present)
function loadSampleData() {
    if (!localStorage.getItem(STORAGE_KEYS.MENU)) {
        const sampleMenu = [
            {dish_id:'1', name:'Caesar Salad', category:'Appetizers', price:'8.99', description:'Fresh lettuce with Caesar dressing', ingredients:'lettuce,croutons,parmesan', dietary:'Vegetarian', avg_rating:'4.2'},
            {dish_id:'2', name:'Grilled Salmon', category:'Main Course', price:'24.99', description:'Fresh grilled salmon with herbs', ingredients:'salmon,herbs,lemon', dietary:'Gluten-Free', avg_rating:'4.7'},
            {dish_id:'3', name:'Chocolate Lava Cake', category:'Desserts', price:'7.99', description:'Warm cake with molten chocolate center', ingredients:'chocolate,flour,sugar,eggs', dietary:'Vegetarian', avg_rating:'4.9'},
            {dish_id:'4', name:'Green Tea', category:'Beverages', price:'3.99', description:'Premium green tea leaves', ingredients:'green tea leaves,water', dietary:'Vegan', avg_rating:'4.6'}
        ];
        localStorage.setItem(STORAGE_KEYS.MENU, serializeData(sampleMenu, Object.keys(sampleMenu[0])));
    }
    if (!localStorage.getItem(STORAGE_KEYS.USERS)) {
        // One default user: jane_food
        const sampleUsers = [
            {username:'jane_food', full_name:'Jane Foodie', phone:'555-5678', email:'jane@example.com'}
        ];
        localStorage.setItem(STORAGE_KEYS.USERS, serializeData(sampleUsers, Object.keys(sampleUsers[0])));
        localStorage.setItem(STORAGE_KEYS.CURRENT_USER, 'jane_food');
    }
    if (!localStorage.getItem(STORAGE_KEYS.RESERVATIONS)) {
        const sampleReservations = [
            {reservation_id:'1', username:'jane_food', full_name:'Jane Foodie', phone:'555-5678', email:'jane@example.com', party_size:'2', date:'2024-11-20', time:'19:30', notes:'Anniversary dinner', status:'Completed'}
        ];
        localStorage.setItem(STORAGE_KEYS.RESERVATIONS, serializeData(sampleReservations, Object.keys(sampleReservations[0])));
    }
    if (!localStorage.getItem(STORAGE_KEYS.WAITLIST)) {
        localStorage.setItem(STORAGE_KEYS.WAITLIST, '');
    }
    if (!localStorage.getItem(STORAGE_KEYS.REVIEWS)) {
        const sampleReviews = [
            {review_id:'1', username:'jane_food', dish_id:'3', rating:'5', review_text:'Absolutely divine dessert!', review_date:'2024-11-20'}
        ];
        localStorage.setItem(STORAGE_KEYS.REVIEWS, serializeData(sampleReviews, Object.keys(sampleReviews[0])));
    }
}

// Get current logged in user object
function getCurrentUser() {
    const username = localStorage.getItem(STORAGE_KEYS.CURRENT_USER);
    if (!username) return null;
    const users = parseData(localStorage.getItem(STORAGE_KEYS.USERS), ['username','full_name','phone','email']);
    return users.find(u => u.username === username) || null;
}

// Save updated user info
function saveUser(updatedUser) {
    let users = parseData(localStorage.getItem(STORAGE_KEYS.USERS), ['username','full_name','phone','email']);
    users = users.map(u => u.username === updatedUser.username ? updatedUser : u);
    localStorage.setItem(STORAGE_KEYS.USERS, serializeData(users, ['username','full_name','phone','email']));
}

// Show only one page by id
function showPage(pageId) {
    document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
    const page = document.getElementById(pageId);
    if (page) page.style.display = 'block';
}

// Format price as currency
function formatPrice(price) {
    return `$${parseFloat(price).toFixed(2)}`;
}

// Format date YYYY-MM-DD to readable
function formatDate(dateStr) {
    const d = new Date(dateStr);
    if (isNaN(d)) return dateStr;
    return d.toLocaleDateString();
}

// Format time HH:mm to readable
function formatTime(timeStr) {
    if (!timeStr) return '';
    const [h,m] = timeStr.split(':');
    let hour = parseInt(h);
    const ampm = hour >= 12 ? 'PM' : 'AM';
    hour = hour % 12 || 12;
    return `${hour}:${m} ${ampm}`;
}

// Generate unique ID for new entries
function generateId(prefix='id') {
    return prefix + '_' + Math.random().toString(36).substr(2,9);
}

// --- Dashboard Page ---
function loadDashboard() {
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    document.getElementById('welcome-message').textContent = `Welcome, ${user.full_name}`;
    showPage('dashboard-page');
}

// --- Menu Page ---
function loadMenu() {
    const menuGrid = document.getElementById('menu-grid');
    menuGrid.innerHTML = '';
    const menu = parseData(localStorage.getItem(STORAGE_KEYS.MENU), ['dish_id','name','category','price','description','ingredients','dietary','avg_rating']);
    menu.forEach(dish => {
        const card = document.createElement('div');
        card.className = 'card';
        card.innerHTML = `
            <h3>${dish.name}</h3>
            <p><strong>Category:</strong> ${dish.category}</p>
            <p><strong>Price:</strong> ${formatPrice(dish.price)}</p>
            <p>${dish.description}</p>
            <button id="view-dish-button-${dish.dish_id}">View Details</button>
        `;
        menuGrid.appendChild(card);
        document.getElementById(`view-dish-button-${dish.dish_id}`).addEventListener('click', () => {
            loadDishDetails(dish.dish_id);
        });
    });
    showPage('menu-page');
}

// --- Dish Details Page ---
function loadDishDetails(dishId) {
    const menu = parseData(localStorage.getItem(STORAGE_KEYS.MENU), ['dish_id','name','category','price','description','ingredients','dietary','avg_rating']);
    const dish = menu.find(d => d.dish_id === dishId);
    if (!dish) {
        alert('Dish not found.');
        return;
    }
    document.getElementById('dish-name').textContent = dish.name;
    document.getElementById('dish-price').textContent = `Price: ${formatPrice(dish.price)}`;
    document.getElementById('dish-description').textContent = `Description: ${dish.description}`;
    document.getElementById('dish-ingredients').textContent = `Ingredients: ${dish.ingredients}`;
    document.getElementById('dish-dietary').textContent = `Dietary Info: ${dish.dietary}`;
    showPage('dish-details-page');
}

// --- Make Reservation Page ---
function loadMakeReservation() {
    document.getElementById('party-size').value = '';
    document.getElementById('reservation-date').value = '';
    showPage('reservation-page');
}

function submitReservation() {
    const partySize = document.getElementById('party-size').value;
    const date = document.getElementById('reservation-date').value;
    if (!partySize || !date) {
        alert('Please select party size and reservation date.');
        return;
    }
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    let reservations = parseData(localStorage.getItem(STORAGE_KEYS.RESERVATIONS), ['reservation_id','username','full_name','phone','email','party_size','date','time','notes','status']);
    const newReservation = {
        reservation_id: generateId('res'),
        username: user.username,
        full_name: user.full_name,
        phone: user.phone,
        email: user.email,
        party_size: partySize,
        date: date,
        time: '18:00', // default time, can be extended
        notes: '',
        status: 'Upcoming'
    };
    reservations.push(newReservation);
    localStorage.setItem(STORAGE_KEYS.RESERVATIONS, serializeData(reservations, ['reservation_id','username','full_name','phone','email','party_size','date','time','notes','status']));
    alert('Reservation submitted successfully.');
    loadDashboard();
}

// --- My Reservations Page ---
function loadMyReservations() {
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    const reservationsDiv = document.getElementById('my-reservations');
    reservationsDiv.innerHTML = '';
    let reservations = parseData(localStorage.getItem(STORAGE_KEYS.RESERVATIONS), ['reservation_id','username','full_name','phone','email','party_size','date','time','notes','status']);
    reservations = reservations.filter(r => r.username === user.username);
    if (reservations.length === 0) {
        reservationsDiv.textContent = 'No reservations found.';
        showPage('my-reservations-page');
        return;
    }
    const table = document.createElement('table');
    const thead = document.createElement('thead');
    thead.innerHTML = `<tr>
        <th>Date</th><th>Party Size</th><th>Time</th><th>Status</th><th>Action</th>
    </tr>`;
    table.appendChild(thead);
    const tbody = document.createElement('tbody');
    reservations.forEach(r => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>${formatDate(r.date)}</td>
            <td>${r.party_size}</td>
            <td>${formatTime(r.time)}</td>
            <td>${r.status}</td>
            <td><button id="cancel-reservation-button-${r.reservation_id}">Cancel</button></td>
        `;
        tbody.appendChild(tr);
        tr.querySelector(`#cancel-reservation-button-${r.reservation_id}`).addEventListener('click', () => {
            cancelReservation(r.reservation_id);
        });
    });
    table.appendChild(tbody);
    reservationsDiv.appendChild(table);
    showPage('my-reservations-page');
}

function cancelReservation(reservationId) {
    let reservations = parseData(localStorage.getItem(STORAGE_KEYS.RESERVATIONS), ['reservation_id','username','full_name','phone','email','party_size','date','time','notes','status']);
    const index = reservations.findIndex(r => r.reservation_id === reservationId);
    if (index === -1) {
        alert('Reservation not found.');
        return;
    }
    if (!confirm('Are you sure you want to cancel this reservation?')) return;
    reservations.splice(index, 1);
    localStorage.setItem(STORAGE_KEYS.RESERVATIONS, serializeData(reservations, ['reservation_id','username','full_name','phone','email','party_size','date','time','notes','status']));
    alert('Reservation cancelled.');
    loadMyReservations();
}

// --- Waitlist Page ---
function loadWaitlist() {
    document.getElementById('waitlist-party-size').value = '';
    updateWaitlistPosition();
    showPage('waitlist-page');
}

function updateWaitlistPosition() {
    const user = getCurrentUser();
    if (!user) return;
    const waitlistDiv = document.getElementById('user-waitlist-position');
    let waitlist = parseData(localStorage.getItem(STORAGE_KEYS.WAITLIST), ['time','status','position','username','party_size','date']);
    waitlist = waitlist.filter(w => w.username === user.username);
    if (waitlist.length === 0) {
        waitlistDiv.textContent = 'You are not currently on the waitlist.';
    } else {
        const w = waitlist[0];
        waitlistDiv.textContent = `You are on the waitlist for party size ${w.party_size} on ${formatDate(w.date)}. Status: ${w.status}`;
    }
}

function joinWaitlist() {
    const partySize = document.getElementById('waitlist-party-size').value;
    if (!partySize) {
        alert('Please select party size.');
        return;
    }
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    let waitlist = parseData(localStorage.getItem(STORAGE_KEYS.WAITLIST), ['time','status','position','username','party_size','date']);
    // Check if user already on waitlist
    if (waitlist.some(w => w.username === user.username)) {
        alert('You are already on the waitlist.');
        return;
    }
    const now = new Date();
    const timeStr = now.toTimeString().split(' ')[0];
    const newEntry = {
        time: timeStr,
        status: 'Active',
        position: (waitlist.length + 1).toString(),
        username: user.username,
        party_size: partySize,
        date: now.toISOString().split('T')[0]
    };
    waitlist.push(newEntry);
    localStorage.setItem(STORAGE_KEYS.WAITLIST, serializeData(waitlist, ['time','status','position','username','party_size','date']));
    alert('You have joined the waitlist.');
    updateWaitlistPosition();
}

// --- Reviews Page ---
function loadReviews() {
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    const reviewsList = document.getElementById('reviews-list');
    reviewsList.innerHTML = '';
    let reviews = parseData(localStorage.getItem(STORAGE_KEYS.REVIEWS), ['review_id','username','dish_id','rating','review_text','review_date']);
    reviews = reviews.filter(r => r.username === user.username);
    if (reviews.length === 0) {
        reviewsList.textContent = 'No reviews found.';
        showPage('reviews-page');
        return;
    }
    reviews.forEach(r => {
        const div = document.createElement('div');
        div.className = 'card';
        div.innerHTML = `
            <p><strong>Dish ID:</strong> ${r.dish_id}</p>
            <p><strong>Rating:</strong> ${r.rating}</p>
            <p>${r.review_text}</p>
            <p><em>${formatDate(r.review_date)}</em></p>
        `;
        reviewsList.appendChild(div);
    });
    showPage('reviews-page');
}

// --- Write Review Page ---
function loadWriteReview() {
    const selectDish = document.getElementById('select-dish');
    selectDish.innerHTML = '<option value="" disabled selected>Select dish</option>';
    const menu = parseData(localStorage.getItem(STORAGE_KEYS.MENU), ['dish_id','name','category','price','description','ingredients','dietary','avg_rating']);
    menu.forEach(dish => {
        const option = document.createElement('option');
        option.value = dish.dish_id;
        option.textContent = dish.name;
        selectDish.appendChild(option);
    });
    document.getElementById('select-rating').value = '';
    document.getElementById('review-text').value = '';
    showPage('write-review-page');
}

function submitReview() {
    const dishId = document.getElementById('select-dish').value;
    const rating = document.getElementById('select-rating').value;
    const reviewText = document.getElementById('review-text').value.trim();
    if (!dishId || !rating || !reviewText) {
        alert('Please select dish, rating and write a review.');
        return;
    }
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    let reviews = parseData(localStorage.getItem(STORAGE_KEYS.REVIEWS), ['review_id','username','dish_id','rating','review_text','review_date']);
    const newReview = {
        review_id: generateId('rev'),
        username: user.username,
        dish_id: dishId,
        rating: rating,
        review_text: reviewText,
        review_date: new Date().toISOString().split('T')[0]
    };
    reviews.push(newReview);
    localStorage.setItem(STORAGE_KEYS.REVIEWS, serializeData(reviews, ['review_id','username','dish_id','rating','review_text','review_date']));
    alert('Review submitted.');
    loadReviews();
}

// --- Profile Page ---
function loadProfile() {
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    document.getElementById('profile-username').textContent = `Username: ${user.username}`;
    document.getElementById('profile-email').value = user.email;
    showPage('profile-page');
}

function updateProfile() {
    const email = document.getElementById('profile-email').value.trim();
    if (!email) {
        alert('Email cannot be empty.');
        return;
    }
    const user = getCurrentUser();
    if (!user) {
        alert('No user logged in.');
        return;
    }
    user.email = email;
    saveUser(user);
    alert('Profile updated.');
    loadDashboard();
}

// --- Event Listeners ---
function setupEventListeners() {
    // Dashboard buttons
    document.getElementById('make-reservation-button').addEventListener('click', loadMakeReservation);
    document.getElementById('view-menu-button').addEventListener('click', loadMenu);
    document.getElementById('refresh-button').addEventListener('click', loadDashboard);
    document.getElementById('my-reviews-button').addEventListener('click', loadReviews);
    document.getElementById('waitlist-button').addEventListener('click', loadWaitlist);

    // Menu page
    document.getElementById('back-to-dashboard-from-menu').addEventListener('click', loadDashboard);

    // Dish details page
    document.getElementById('back-to-menu').addEventListener('click', loadMenu);

    // Make reservation page
    document.getElementById('submit-reservation-button').addEventListener('click', submitReservation);
    document.getElementById('back-to-dashboard-from-reservation').addEventListener('click', loadDashboard);

    // My reservations page
    document.getElementById('back-to-dashboard-from-reservations').addEventListener('click', loadDashboard);

    // Waitlist page
    document.getElementById('join-waitlist-button').addEventListener('click', joinWaitlist);
    document.getElementById('back-to-dashboard-from-waitlist').addEventListener('click', loadDashboard);

    // Reviews page
    document.getElementById('write-new-review-button').addEventListener('click', loadWriteReview);
    document.getElementById('back-to-dashboard-from-reviews').addEventListener('click', loadDashboard);

    // Write review page
    document.getElementById('submit-review-button').addEventListener('click', submitReview);
    document.getElementById('back-to-reviews').addEventListener('click', loadReviews);

    // Profile page
    document.getElementById('back-to-dashboard-from-profile').addEventListener('click', loadDashboard);
    document.getElementById('update-profile-button').addEventListener('click', updateProfile);
}

// --- Initialization ---
function init() {
    loadSampleData();
    setupEventListeners();
    loadDashboard();
}

window.onload = init;
```"

Think step by step and reason yourself to the right decisions to decompose the overall coding plans into smaller tasks and assign them to different programmers.

The decomposition should be in the following format: "COMPOSITION" is the composition of tasks, and "Workflow" is the workflow of the programmers. Each task is assigned to a programmer, and the workflow shows the dependencies between tasks.

