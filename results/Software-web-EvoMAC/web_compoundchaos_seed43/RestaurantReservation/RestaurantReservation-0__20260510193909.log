'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of ALL pages. This includes verifying the presence and correctness of all specified elements on each page as per the requirements.
'''
import unittest
import requests
from bs4 import BeautifulSoup

BASE_URL = "http://localhost:5000"

class TestRestaurantReservation(unittest.TestCase):

    def test_01_access_website(self):
        """Test whether the website can be accessed through local port 5000 and the first page loads."""
        try:
            response = requests.get(BASE_URL, timeout=5)
        except requests.exceptions.RequestException as e:
            self.fail(f"Could not access the website at {BASE_URL}: {e}")
        self.assertEqual(response.status_code, 200, "Website did not return status code 200 on root URL")
        self.assertIn("RestaurantReservation", response.text, "Page title or content does not contain 'RestaurantReservation'")

    def test_02_dashboard_page_elements(self):
        """Test the Dashboard page elements presence and correctness."""
        response = requests.get(BASE_URL)
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.text, 'html.parser')
        dashboard = soup.find(id="dashboard-page")
        self.assertIsNotNone(dashboard, "Dashboard page container with id 'dashboard-page' not found")
        # Check welcome message
        welcome = dashboard.find(id="welcome-message")
        self.assertIsNotNone(welcome, "Welcome message with id 'welcome-message' not found")
        self.assertTrue(welcome.text.strip().startswith("Welcome"), "Welcome message text does not start with 'Welcome'")
        # Check buttons and their ids
        expected_buttons = [
            "make-reservation-button",
            "view-menu-button",
            "back-to-dashboard",
            "my-reservations-button",
            "my-reviews-button",
            "waitlist-button",
            "profile-button"
        ]
        for btn_id in expected_buttons:
            btn = dashboard.find(id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' not found on Dashboard page")
            self.assertEqual(btn.name, "button", f"Element with id '{btn_id}' is not a button")

    def test_03_all_pages_elements_presence(self):
        """Test presence of all specified elements on all pages as per requirements."""
        response = requests.get(BASE_URL)
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.text, 'html.parser')

        # 1. Dashboard Page
        dashboard = soup.find(id="dashboard-page")
        self.assertIsNotNone(dashboard)
        dashboard_expected_ids = [
            "welcome-message",
            "make-reservation-button",
            "view-menu-button",
            "back-to-dashboard",
            "my-reservations-button",
            "my-reviews-button",
            "waitlist-button",
            "profile-button"
        ]
        for eid in dashboard_expected_ids:
            self.assertIsNotNone(dashboard.find(id=eid), f"Dashboard page missing element with id '{eid}'")

        # 2. Menu Page
        menu = soup.find(id="menu-page")
        self.assertIsNotNone(menu)
        self.assertIsNotNone(menu.find(id="menu-grid"))
        self.assertIsNotNone(menu.find(id="back-to-dashboard"))

        # 3. Dish Details Page
        dish_details = soup.find(id="dish-details-page")
        self.assertIsNotNone(dish_details)
        dish_details_expected = ["dish-name", "dish-price", "back-to-menu"]
        for eid in dish_details_expected:
            self.assertIsNotNone(dish_details.find(id=eid), f"Dish Details page missing element with id '{eid}'")

        # 4. Make Reservation Page
        reservation = soup.find(id="reservation-page")
        self.assertIsNotNone(reservation)
        reservation_expected = [
            "guest-name",
            "party-size",
            "reservation-date",
            "submit-reservation-button",
            "back-to-dashboard"
        ]
        for eid in reservation_expected:
            self.assertIsNotNone(reservation.find(id=eid), f"Make Reservation page missing element with id '{eid}'")

        # 5. My Reservations Page
        my_reservations = soup.find(id="my-reservations-page")
        self.assertIsNotNone(my_reservations)
        self.assertIsNotNone(my_reservations.find(id="reservations-table"))
        self.assertIsNotNone(my_reservations.find(id="back-to-dashboard"))

        # 6. Waitlist Page
        waitlist = soup.find(id="waitlist-page")
        self.assertIsNotNone(waitlist)
        waitlist_expected = [
            "waitlist-party-size",
            "join-waitlist-button",
            "user-position",
            "back-to-dashboard"
        ]
        for eid in waitlist_expected:
            self.assertIsNotNone(waitlist.find(id=eid), f"Waitlist page missing element with id '{eid}'")

        # 7. My Reviews Page
        reviews = soup.find(id="reviews-page")
        self.assertIsNotNone(reviews)
        self.assertIsNotNone(reviews.find(id="reviews-list"))
        self.assertIsNotNone(reviews.find(id="write-new-review-button"))
        self.assertIsNotNone(reviews.find(id="back-to-dashboard"))

        # 8. Write Review Page
        write_review = soup.find(id="write-review-page")
        self.assertIsNotNone(write_review)
        write_review_expected = [
            "select-dish",
            "rating-input",
            "review-text",
            "submit-review-button",
            "back-to-reviews"
        ]
        for eid in write_review_expected:
            self.assertIsNotNone(write_review.find(id=eid), f"Write Review page missing element with id '{eid}'")

        # 9. User Profile Page
        profile = soup.find(id="profile-page")
        self.assertIsNotNone(profile)
        profile_expected = [
            "profile-username",
            "profile-email",
            "update-profile-button",
            "back-to-dashboard"
        ]
        for eid in profile_expected:
            self.assertIsNotNone(profile.find(id=eid), f"User Profile page missing element with id '{eid}'")

if __name__ == "__main__":
    unittest.main()
