from flask import session

def get_current_user():
    username = session.get('username')
    if not username:
        return None
    users = parse_pipe_file(USERS_FILE, ['username', 'email', 'phone', 'full_name'])
    for u in users:
        if u['username'] == username:
            return u
    return None
```

- Add login/logout routes as needed.

