from flask import Flask, request, jsonify, send_from_directory
import os
import datetime
import threading

app = Flask(__name__, static_folder='static', static_url_path='')

DATA_DIR = 'data'
USERS_FILE = os.path.join(DATA_DIR, 'users.txt')
MENU_FILE = os.path.join(DATA_DIR, 'menu.txt')
RESERVATIONS_FILE = os.path.join(DATA_DIR, 'reservations.txt')
WAITLIST_FILE = os.path.join(DATA_DIR, 'waitlist.txt')
REVIEWS_FILE = os.path.join(DATA_DIR, 'reviews.txt')

LOCK = threading.Lock()

def parse_pipe_file(filepath, keys):
    if not os.path.exists(filepath):
        return []
    with open(filepath, 'r', encoding='utf-8') as f:
        lines = f.read().strip().split('\n')
    result = []
    for line in lines:
        parts = line.split('|')
        if len(parts) != len(keys):
            continue
        obj = dict(zip(keys, parts))
        result.append(obj)
    return result

def write_pipe_file(filepath, keys, data):
    with LOCK:
        with open(filepath, 'w', encoding='utf-8') as f:
            for obj in data:
                line = '|'.join(str(obj.get(k, '')) for k in keys)
                f.write(line + '\n')

def generate_id(prefix):
    import random, string
    return prefix + ''.join(random.choices(string.ascii_lowercase + string.digits, k=9))

def ensure_data_dir():
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)

def init_sample_data():
    ensure_data_dir()
    # Users
    if not os.path.exists(USERS_FILE):
        users = [
            {'username':'john_diner','email':'john@example.com','phone':'555-1234','full_name':'John Diner'},
            {'username':'jane_food','email':'jane@example.com','phone':'555-5678','full_name':'Jane Foodie'}
        ]
        write_pipe_file(USERS_FILE, ['username','email','phone','full_name'], users)
    # Menu
    if not os.path.exists(MENU_FILE):
        menu = [
            {'dish_id':'1','name':'Caesar Salad','category':'Appetizers','price':'8.99',
             'description':'Fresh lettuce with Caesar dressing',
             'ingredients':'lettuce,croutons,parmesan','dietary':'Vegetarian','avg_rating':'4.2'},
            {'dish_id':'2','name':'Grilled Salmon','category':'Main Course','price':'24.99',
             'description':'Fresh grilled salmon with herbs',
             'ingredients':'salmon,herbs,lemon','dietary':'Gluten-Free','avg_rating':'4.7'},
            {'dish_id':'3','name':'Chocolate Lava Cake','category':'Desserts','price':'7.99',
             'description':'Warm cake with molten chocolate center',
             'ingredients':'chocolate,flour,sugar,eggs','dietary':'Vegetarian','avg_rating':'4.9'},
            {'dish_id':'4','name':'Green Tea','category':'Beverages','price':'3.99',
             'description':'Premium green tea leaves',
             'ingredients':'green tea leaves,water','dietary':'Vegan','avg_rating':'4.6'}
        ]
        write_pipe_file(MENU_FILE, ['dish_id','name','category','price','description','ingredients','dietary','avg_rating'], menu)
    # Reservations
    if not os.path.exists(RESERVATIONS_FILE):
        reservations = [
            {'reservation_id':'1','username':'jane_food','guest_name':'Jane Foodie','phone':'555-5678','email':'jane@example.com',
             'party_size':'2','date':'2024-11-20','time':'19:30','special_requests':'Anniversary dinner','status':'Completed'}
        ]
        write_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'], reservations)
    # Waitlist
    if not os.path.exists(WAITLIST_FILE):
        waitlist = []
        write_pipe_file(WAITLIST_FILE, ['position','username','party_size','date','time','status'], waitlist)
    # Reviews
    if not os.path.exists(REVIEWS_FILE):
        reviews = [
            {'review_id':'1','username':'jane_food','dish_id':'3','rating':'5','review_text':'Absolutely divine dessert!','review_date':'2024-11-20'}
        ]
        write_pipe_file(REVIEWS_FILE, ['review_id','username','dish_id','rating','review_text','review_date'], reviews)

@app.route('/')
def index():
    return send_from_directory('static', 'index.html')

@app.route('/<path:path>')
def static_files(path):
    return send_from_directory('static', path)

# --- USERS ---

@app.route('/api/users/<username>', methods=['GET'])
def get_user(username):
    users = parse_pipe_file(USERS_FILE, ['username','email','phone','full_name'])
    user = next((u for u in users if u['username'] == username), None)
    if not user:
        return jsonify({'error':'User not found'}), 404
    return jsonify(user)

@app.route('/api/users/<username>', methods=['PUT'])
def update_user(username):
    data = request.json
    if not data or 'email' not in data:
        return jsonify({'error':'Email required'}), 400
    users = parse_pipe_file(USERS_FILE, ['username','email','phone','full_name'])
    updated = False
    for u in users:
        if u['username'] == username:
            u['email'] = data['email']
            updated = True
            break
    if not updated:
        return jsonify({'error':'User not found'}), 404
    write_pipe_file(USERS_FILE, ['username','email','phone','full_name'], users)
    return jsonify({'message':'Profile updated'})

# --- MENU ---

@app.route('/api/menu', methods=['GET'])
def get_menu():
    menu = parse_pipe_file(MENU_FILE, ['dish_id','name','category','price','description','ingredients','dietary','avg_rating'])
    return jsonify(menu)

@app.route('/api/menu/<dish_id>', methods=['GET'])
def get_dish(dish_id):
    menu = parse_pipe_file(MENU_FILE, ['dish_id','name','category','price','description','ingredients','dietary','avg_rating'])
    dish = next((d for d in menu if d['dish_id'] == dish_id), None)
    if not dish:
        return jsonify({'error':'Dish not found'}), 404
    return jsonify(dish)

# --- RESERVATIONS ---

@app.route('/api/reservations/<username>', methods=['GET'])
def get_reservations(username):
    reservations = parse_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'])
    user_reservations = [r for r in reservations if r['username'] == username]
    return jsonify(user_reservations)

@app.route('/api/reservations', methods=['POST'])
def make_reservation():
    data = request.json
    required_fields = ['username','guest_name','phone','email','party_size','date']
    if not data or not all(field in data for field in required_fields):
        return jsonify({'error':'Missing required fields'}), 400
    # Validate date format
    try:
        datetime.datetime.strptime(data['date'], '%Y-%m-%d')
    except ValueError:
        return jsonify({'error':'Invalid date format, expected YYYY-MM-DD'}), 400
    reservations = parse_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'])
    new_id = generate_id('res')
    new_reservation = {
        'reservation_id': new_id,
        'username': data['username'],
        'guest_name': data['guest_name'],
        'phone': data['phone'],
        'email': data['email'],
        'party_size': str(data['party_size']),
        'date': data['date'],
        'time': data.get('time', '18:00'),
        'special_requests': data.get('special_requests', ''),
        'status': 'Upcoming'
    }
    reservations.append(new_reservation)
    write_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'], reservations)
    return jsonify({'message':'Reservation created', 'reservation_id': new_id})

@app.route('/api/reservations/cancel/<reservation_id>', methods=['POST'])
def cancel_reservation(reservation_id):
    reservations = parse_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'])
    found = False
    for r in reservations:
        if r['reservation_id'] == reservation_id:
            if r['status'] == 'Cancelled':
                return jsonify({'error':'Reservation already cancelled'}), 400
            r['status'] = 'Cancelled'
            found = True
            break
    if not found:
        return jsonify({'error':'Reservation not found'}), 404
    write_pipe_file(RESERVATIONS_FILE, ['reservation_id','username','guest_name','phone','email','party_size','date','time','special_requests','status'], reservations)
    return jsonify({'message':'Reservation cancelled'})

# --- WAITLIST ---

@app.route('/api/waitlist/<username>', methods=['GET'])
def get_waitlist_position(username):
    waitlist = parse_pipe_file(WAITLIST_FILE, ['position','username','party_size','date','time','status'])
    user_entries = [w for w in waitlist if w['username'] == username and w['status'] == 'Active']
    if not user_entries:
        return jsonify({'message':'Not on waitlist'}), 404
    # Return first active entry
    return jsonify(user_entries[0])

@app.route('/api/waitlist/join', methods=['POST'])
def join_waitlist():
    data = request.json
    required_fields = ['username','party_size']
    if not data or not all(field in data for field in required_fields):
        return jsonify({'error':'Missing required fields'}), 400
    waitlist = parse_pipe_file(WAITLIST_FILE, ['position','username','party_size','date','time','status'])
    # Check if user already on waitlist active
    for w in waitlist:
        if w['username'] == data['username'] and w['status'] == 'Active':
            return jsonify({'error':'User already on waitlist'}), 400
    now = datetime.datetime.now()
    position = str(len(waitlist) + 1)
    new_entry = {
        'position': position,
        'username': data['username'],
        'party_size': str(data['party_size']),
        'date': now.strftime('%Y-%m-%d'),
        'time': now.strftime('%H:%M:%S'),
        'status': 'Active'
    }
    waitlist.append(new_entry)
    write_pipe_file(WAITLIST_FILE, ['position','username','party_size','date','time','status'], waitlist)
    return jsonify({'message':'Joined waitlist', 'position': position})

# --- REVIEWS ---

@app.route('/api/reviews/<username>', methods=['GET'])
def get_reviews(username):
    reviews = parse_pipe_file(REVIEWS_FILE, ['review_id','username','dish_id','rating','review_text','review_date'])
    user_reviews = [r for r in reviews if r['username'] == username]
    return jsonify(user_reviews)

@app.route('/api/reviews', methods=['POST'])
def submit_review():
    data = request.json
    required_fields = ['username','dish_id','rating','review_text']
    if not data or not all(field in data for field in required_fields):
        return jsonify({'error':'Missing required fields'}), 400
    try:
        rating = int(data['rating'])
        if rating < 1 or rating > 5:
            return jsonify({'error':'Rating must be between 1 and 5'}), 400
    except:
        return jsonify({'error':'Invalid rating'}), 400
    reviews = parse_pipe_file(REVIEWS_FILE, ['review_id','username','dish_id','rating','review_text','review_date'])
    new_id = generate_id('rev')
    new_review = {
        'review_id': new_id,
        'username': data['username'],
        'dish_id': data['dish_id'],
        'rating': str(rating),
        'review_text': data['review_text'],
        'review_date': datetime.datetime.now().strftime('%Y-%m-%d')
    }
    reviews.append(new_review)
    write_pipe_file(REVIEWS_FILE, ['review_id','username','dish_id','rating','review_text','review_date'], reviews)
    return jsonify({'message':'Review submitted', 'review_id': new_id})

if __name__ == '__main__':
    init_sample_data()
    app.run(port=5000, debug=True)
