<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RestaurantReservation</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body>
    <!-- Dashboard Page -->
    <div id="dashboard-page" class="page">
        <h1 id="welcome-message">Welcome, User</h1>
        <button id="make-reservation-button" onclick="location.href='/make-reservation'">Make Reservation</button>
        <button id="view-menu-button" onclick="location.href='/menu'">View Menu</button>
        <button id="back-to-dashboard" onclick="location.href='/'">Refresh</button>
        <button id="my-reservations-button" onclick="location.href='/my-reservations'">My Reservations</button>
        <button id="my-reviews-button" onclick="location.href='/my-reviews'">My Reviews</button>
        <button id="waitlist-button" onclick="location.href='/waitlist'">Waitlist</button>
        <button id="profile-button" onclick="location.href='/profile'">Profile</button>
    </div>
    <!-- Menu Page -->
    <div id="menu-page" class="page" style="display:none;">
        <h1>Restaurant Menu</h1>
        <div id="menu-grid" class="grid"></div>
        <button id="back-to-dashboard" onclick="location.href='/'">Back to Dashboard</button>
    </div>
    <!-- Dish Details Page -->
    <div id="dish-details-page" class="page" style="display:none;">
        <h1 id="dish-name"></h1>
        <div id="dish-price"></div>
        <div id="dish-description"></div>
        <div id="dish-ingredients"></div>
        <div id="dish-dietary"></div>
        <button id="back-to-menu" onclick="location.href='/menu'">Back to Menu</button>
    </div>
    <!-- Make Reservation Page -->
    <div id="reservation-page" class="page" style="display:none;">
        <h1>Make Reservation</h1>
        <form id="reservation-form" method="post" action="/make-reservation">
            <label for="guest-name">Guest Name:</label>
            <input type="text" id="guest-name" name="guest_name" required />
            <label for="party-size">Party Size (1-10):</label>
            <select id="party-size" name="party_size" required>
                <option value="" disabled selected>Select party size</option>
                <option value="1">1</option><option value="2">2</option><option value="3">3</option>
                <option value="4">4</option><option value="5">5</option><option value="6">6</option>
                <option value="7">7</option><option value="8">8</option><option value="9">9</option>
                <option value="10">10</option>
            </select>
            <label for="reservation-date">Reservation Date:</label>
