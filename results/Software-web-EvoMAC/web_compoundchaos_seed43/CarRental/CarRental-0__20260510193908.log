              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr><td colspan="6">No reservations found.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
"""

special_requests_template = """
