<td>
{% if r.status != 'Cancelled' %}
<form method="post" action="{{ url_for('cancel_reservation', reservation_id=r.reservation_id) }}" style="display:inline;">
<button type="submit" id="cancel-reservation-button-{{ r.reservation_id }}">Cancel</button>
</form>
{% else %}
Cancelled
{% endif %}
</td>
</tr>
{% else %}
<tr><td colspan="6">No reservations found.</td></tr>
{% endfor %}
</tbody>
</table>
<button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
"""

@app.route('/reservations', methods=['GET'])
def reservations():
    reservations = load_reservations()
    rentals = load_rentals()
    vehicles = load_vehicles()
    vehicles_map = {v['vehicle_id']: v for v in vehicles}
    rentals_map = {r['rental_id']: r for r in rentals}
    selected_status = request.args.get('status', 'All')
    filtered = reservations
    if selected_status != 'All':
        filtered = [r for r in reservations if r['status'] == selected_status]
    return render_template_string(reservations_template,
                                  reservations=filtered,
                                  vehicles_map=vehicles_map,
                                  rentals_map=rentals_map,
                                  selected_status=selected_status)

@app.route('/cancel_reservation/<reservation_id>', methods=['POST'])
def cancel_reservation(reservation_id):
    reservations = load_reservations()
    rentals = load_rentals()
    updated = False
    for r in reservations:
        if r['reservation_id'] == reservation_id and r['status'] != 'Cancelled':
            r['status'] = 'Cancelled'
            # Also update rental status to Cancelled
            for rental in rentals:
                if rental['rental_id'] == r['rental_id']:
                    rental['status'] = 'Cancelled'
                    break
            updated = True
            break
    if updated:
        save_reservations(reservations)
        save_rentals(rentals)
    else:
        abort(404, description="Reservation not found or already cancelled")
    return redirect(url_for('reservations'))

# Special Requests Page
special_requests_template = """
<!DOCTYPE html>
<html>
<head><title>Special Requests</title></head>
<body>
<h1>Special Requests</h1>
<form method="post" action="{{ url_for('special_requests') }}">
<label for="select-reservation">Select Reservation:</label>
<select id="select-reservation" name="reservation_id" required>
<option value="">-- Select --</option>
{% for r in reservations %}
<option value="{{ r.reservation_id }}">{{ vehicles_map[r.vehicle_id].make }} {{ vehicles_map[r.vehicle_id].model }} (ID: {{ r.reservation_id }})</option>
{% endfor %}
</select><br>
<input type="checkbox" id="driver-assistance-checkbox" name="driver_assistance" value="yes">
<label for="driver-assistance-checkbox">Driver Assistance</label><br>
<label for="child-seat-quantity">Child Seat Quantity:</label>
<input type="number" id="child-seat-quantity" name="child_seats" min="0" value="0"><br>
<label for="special-notes">Special Notes:</label><br>
<textarea id="special-notes" name="special_notes" rows="4" cols="50"></textarea><br>
<button type="submit" id="submit-requests-button">Submit Request</button>
</form>
<button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
"""

@app.route('/special_requests', methods=['GET', 'POST'])
def special_requests():
    reservations = load_reservations()
    vehicles = load_vehicles()
    vehicles_map = {v['vehicle_id']: v for v in vehicles}
    message = ''
    if request.method == 'POST':
        reservation_id = request.form.get('reservation_id')
        driver_assistance = request.form.get('driver_assistance')
        child_seats = request.form.get('child_seats', '0')
        special_notes = request.form.get('special_notes', '').strip()
        try:
            child_seats_int = int(child_seats)
            if child_seats_int < 0:
                child_seats_int = 0
        except Exception:
            child_seats_int = 0
        special_requests_list = []
        if driver_assistance == 'yes':
            special_requests_list.append('Driver assistance requested')
        if child_seats_int > 0:
            special_requests_list.append(f'{child_seats_int} child seat(s) requested')
        if special_notes:
            special_requests_list.append(f'Notes: {special_notes}')
        special_requests_str = '; '.join(special_requests_list)
        if update_reservation_special_requests(reservation_id, special_requests_str):
            message = f"Special requests for reservation {reservation_id} submitted successfully."
        else:
            message = "Failed to submit special requests. Reservation not found."
    return render_template_string(special_requests_template,
                                  reservations=reservations,
                                  vehicles_map=vehicles_map,
                                  message=message)

# Locations Page
locations_template = """
<!DOCTYPE html>
<html>
<head><title>Pickup and Dropoff Locations</title></head>
<body>
<h1>Locations</h1>
<form method="get" action="{{ url_for('locations') }}">
<label for="hours-filter">Filter by Operating Hours:</label>
<select id="hours-filter" name="hours_filter" onchange="this.form.submit()">
<option value="">All</option>
<option value="24/7" {% if selected_hours == '24/7' %}selected{% endif %}>24/7</option>
<option value="Business Hours" {% if selected_hours == 'Business Hours' %}selected{% endif %}>Business Hours</option>
<option value="Weekend" {% if selected_hours == 'Weekend' %}selected{% endif %}>Weekend</option>
</select>
<label for="search-location-input">Search by City:</label>
<input type="text" id="search-location-input" name="search_city" value="{{ search_city|default('') }}">
<button type="submit">Search</button>
</form>
<div id="locations-list">
{% for loc in locations %}
<div style="border:1px solid #ccc; padding:5px; margin:5px;">
<strong>{{ loc.city }}</strong><br>
Address: {{ loc.address }}<br>
Phone: {{ loc.phone }}<br>
Hours: {{ loc.hours }}<br>
<button onclick="alert('Location: {{ loc.city }}\\nAddress: {{ loc.address }}\\nPhone: {{ loc.phone }}\\nHours: {{ loc.hours }}')">View Details</button>
</div>
{% else %}
<p>No locations found.</p>
{% endfor %}
</div>
<button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</body>
</html>
"""

@app.route('/locations', methods=['GET'])
def locations():
    locations = load_locations()
    selected_hours = request.args.get('hours_filter', '')
    search_city = request.args.get('search_city', '').strip().lower()
    filtered = locations
    if selected_hours:
        filtered = [loc for loc in filtered if selected_hours.lower() in loc['hours'].lower()]
    if search_city:
        filtered = [loc for loc in filtered if search_city in loc['city'].lower()]
    return render_template_string(locations_template,
                                  locations=filtered,
                                  selected_hours=selected_hours,
                                  search_city=search_city)

if __name__ == '__main__':
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)
    app.run(debug=True)
