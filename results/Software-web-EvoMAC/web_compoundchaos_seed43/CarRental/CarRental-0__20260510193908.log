'''
Test whether the website can be accessed through local port 5000.
In this test, you only need to test whether the first page of the website can be accessed through the local 5000 port.
'''
import unittest
from app import app

class TestCarRentalApp(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page (first page) is accessible via GET request
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check that the response contains the dashboard page container id
        self.assertIn(b'id="dashboard-page"', response.data)
        # Check that the page title is correct
        self.assertIn(b'Car Rental Dashboard', response.data)

if __name__ == '__main__':
    unittest.main()
