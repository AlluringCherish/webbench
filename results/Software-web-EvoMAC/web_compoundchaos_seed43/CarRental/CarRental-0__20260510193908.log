# Routes

@app.route('/')
@app.route('/dashboard')
def dashboard():
    vehicles = load_vehicles()
    featured_vehicles = [v for v in vehicles if v['status'] == 'Available'][:3]
    return render_template_string(dashboard_template, featured_vehicles=featured_vehicles)

@app.route('/vehicles', methods=['GET'])
def vehicle_search():
    vehicles = load_vehicles()
    locations = load_locations()
    vehicle_types = ['Economy', 'Compact', 'Sedan', 'SUV', 'Luxury']
    selected_location = request.args.get('location', '')
    selected_type = request.args.get('vehicle_type', '')
    date_range = request.args.get('date_range', '')

    filtered = vehicles
    if selected_location:
        # Filter vehicles by availability at location - since no direct link, skip filtering by location for vehicles
        pass
    if selected_type:
        filtered = [v for v in filtered if v['vehicle_type'] == selected_type]
    # Date range filtering is not implemented due to lack of availability data per date
    return render_template_string(vehicle_search_template,
                                  vehicles=filtered,
                                  locations=locations,
                                  vehicle_types=vehicle_types,
                                  selected_location=selected_location,
                                  selected_type=selected_type,
                                  date_range=date_range)

@app.route('/vehicle/<vehicle_id>')
def vehicle_details(vehicle_id):
    vehicles = load_vehicles()
    vehicle = next((v for v in vehicles if v['vehicle_id'] == vehicle_id), None)
    if not vehicle:
        abort(404, description="Vehicle not found")
    return render_template_string(vehicle_details_template, vehicle=vehicle)

@app.route('/booking/<vehicle_id>', methods=['GET', 'POST'])
def booking(vehicle_id):
    vehicles = load_vehicles()
    vehicle = next((v for v in vehicles if v['vehicle_id'] == vehicle_id), None)
    if not vehicle:
        abort(404, description="Vehicle not found")
    locations = load_locations()
    form_data = {
        'pickup_location': '',
        'dropoff_location': '',
        'pickup_date': '',
        'dropoff_date': ''
    }
    total_price = None
    if request.method == 'POST':
        form_data['pickup_location'] = request.form.get('pickup_location', '')
        form_data['dropoff_location'] = request.form.get('dropoff_location', '')
        form_data['pickup_date'] = request.form.get('pickup_date', '')
        form_data['dropoff_date'] = request.form.get('dropoff_date', '')
        action = request.form.get('action')
        if action == 'calculate_price':
            try:
                dt_pickup = datetime.strptime(form_data['pickup_date'], '%Y-%m-%d')
                dt_dropoff = datetime.strptime(form_data['dropoff_date'], '%Y-%m-%d')
                days = (dt_dropoff - dt_pickup).days
                if days <= 0:
                    total_price = 0
                else:
                    total_price = days * vehicle['daily_rate']
            except Exception:
                total_price = 0
        elif action == 'proceed_to_insurance':
            # Redirect to insurance page with booking data as query parameters
            try:
                dt_pickup = datetime.strptime(form_data['pickup_date'], '%Y-%m-%d')
                dt_dropoff = datetime.strptime(form_data['dropoff_date'], '%Y-%m-%d')
                days = (dt_dropoff - dt_pickup).days
                if days <= 0:
                    total_price = 0
                else:
                    total_price = days * vehicle['daily_rate']
            except Exception:
                total_price = 0
            return redirect(url_for('insurance',
                                    vehicle_id=vehicle_id,
                                    pickup_location=form_data['pickup_location'],
                                    dropoff_location=form_data['dropoff_location'],
                                    pickup_date=form_data['pickup_date'],
                                    dropoff_date=form_data['dropoff_date'],
                                    total_price=total_price))
    return render_template_string(booking_template,
                                  vehicle=vehicle,
                                  locations=locations,
                                  form_data=form_data,
                                  total_price=total_price)

@app.route('/insurance', methods=['GET', 'POST'])
def insurance():
    insurance_plans = load_insurance()
    if request.method == 'GET':
        booking_data = {
            'vehicle_id': request.args.get('vehicle_id', ''),
            'pickup_location': request.args.get('pickup_location', ''),
            'dropoff_location': request.args.get('dropoff_location', ''),
            'pickup_date': request.args.get('pickup_date', ''),
            'dropoff_date': request.args.get('dropoff_date', ''),
            'total_price': float(request.args.get('total_price', 0))
        }
        selected_plan = None
        return render_template_string(insurance_template,
                                      insurance_plans=insurance_plans,
                                      selected_plan=selected_plan,
                                      booking_data=booking_data)
    else:
        insurance_id = request.form.get('insurance_id')
        booking_data = {
            'vehicle_id': request.form.get('vehicle_id', ''),
            'pickup_location': request.form.get('pickup_location', ''),
            'dropoff_location': request.form.get('dropoff_location', ''),
            'pickup_date': request.form.get('pickup_date', ''),
            'dropoff_date': request.form.get('dropoff_date', ''),
            'total_price': float(request.form.get('total_price', 0))
        }
        selected_plan = next((p for p in insurance_plans if p['insurance_id'] == insurance_id), None)
        if not selected_plan:
            abort(400, description="Invalid insurance plan selected")
        # Calculate total price including insurance
        try:
            dt_pickup = datetime.strptime(booking_data['pickup_date'], '%Y-%m-%d')
            dt_dropoff = datetime.strptime(booking_data['dropoff_date'], '%Y-%m-%d')
            days = (dt_dropoff - dt_pickup).days
            if days <= 0:
                days = 0
        except Exception:
            days = 0
        total_price = booking_data['total_price'] + days * selected_plan['daily_cost']
        # Save rental
        rentals = load_rentals()
        new_rental_id = str(max([int(r['rental_id']) for r in rentals], default=0) + 1)
        new_rental = {
            'rental_id': new_rental_id,
            'vehicle_id': booking_data['vehicle_id'],
            'customer_id': '1',  # Since no authentication, use default customer id 1
            'pickup_date': booking_data['pickup_date'],
            'dropoff_date': booking_data['dropoff_date'],
            'pickup_location': booking_data['pickup_location'],
            'dropoff_location': booking_data['dropoff_location'],
            'total_price': total_price,
            'status': 'Active'
        }
        rentals.append(new_rental)
        save_rentals(rentals)
        # Save reservation
        reservations = load_reservations()
        new_reservation_id = str(max([int(r['reservation_id']) for r in reservations], default=0) + 1)
        new_reservation = {
            'reservation_id': new_reservation_id,
            'rental_id': new_rental_id,
            'vehicle_id': booking_data['vehicle_id'],
            'customer_id': '1',
            'status': 'Confirmed',
            'insurance_id': insurance_id,
            'special_requests': ''
        }
        reservations.append(new_reservation)
        save_reservations(reservations)
        return f"Booking confirmed! Booking ID: {new_rental_id}. Total Price: ${total_price:.2f}. <a href='{url_for('dashboard')}'>Back to Dashboard</a>"

@app.route('/history')
def history():
    rentals = load_rentals()
    vehicles = load_vehicles()
    vehicles_map = {v['vehicle_id']: v for v in vehicles}
    selected_status = request.args.get('status', 'All')
    sort = request.args.get('sort', None)
    filtered = rentals
    if selected_status != 'All':
        filtered = [r for r in rentals if r['status'] == selected_status]
    if sort == 'date':
        filtered.sort(key=lambda r: r['pickup_date'])
    return render_template_string(history_template,
                                  rentals=filtered,
                                  vehicles_map=vehicles_map,
                                  selected_status=selected_status)

@app.route('/reservations', methods=['GET', 'POST'])
def reservations():
    reservations = load_reservations()
    rentals = load_rentals()
    vehicles = load_vehicles()
    vehicles_map = {v['vehicle_id']: v for v in vehicles}
    rentals_map = {r['rental_id']: r for r in rentals}
    selected_status = request.args.get('status', 'All')
    sort = request.args.get('sort', None)
    filtered = reservations
    if selected_status != 'All':
        filtered = [r for r in reservations if r['status'] == selected_status]
    if sort == 'date':
        filtered.sort(key=lambda r: rentals_map.get(r['rental_id'], {}).get('pickup_date', ''))
    return render_template_string(reservations_template,
                                  reservations=filtered,
                                  vehicles_map=vehicles_map,
                                  rentals_map=rentals_map,
                                  selected_status=selected_status)

@app.route('/cancel_reservation/<reservation_id>', methods=['POST'])
def cancel_reservation(reservation_id):
    reservations = load_reservations()
    rentals = load_rentals()
    found = False
    for r in reservations:
        if r['reservation_id'] == reservation_id:
            r['status'] = 'Cancelled'
            found = True
            # Also update rental status
            for rental in rentals:
                if rental['rental_id'] == r['rental_id']:
                    rental['status'] = 'Cancelled'
                    break
            break
    if found:
        save_reservations(reservations)
        save_rentals(rentals)
        return redirect(url_for('reservations'))
    else:
        abort(404, description="Reservation not found")

@app.route('/special_requests', methods=['GET', 'POST'])
def special_requests():
    reservations = load_reservations()
    vehicles = load_vehicles()
    vehicles_map = {v['vehicle_id']: v for v in vehicles}
    if request.method == 'POST':
        reservation_id = request.form.get('reservation_id')
        driver_assistance = request.form.get('driver_assistance')
        gps_option = request.form.get('gps_option')
        child_seats = request.form.get('child_seats', '0')
        notes = request.form.get('notes', '').strip()
        try:
            child_seats = int(child_seats)
            if child_seats < 0:
                child_seats = 0
        except Exception:
            child_seats = 0
        special_requests_list = []
        if driver_assistance == 'yes':
            special_requests_list.append('Driver assistance requested')
        if gps_option == 'yes':
            special_requests_list.append('GPS option requested')
        if child_seats > 0:
            special_requests_list.append(f'{child_seats} child seat(s) requested')
        if notes:
            special_requests_list.append(f'Notes: {notes}')
        special_requests_str = '; '.join(special_requests_list)
        updated = False
        for r in reservations:
            if r['reservation_id'] == reservation_id:
                r['special_requests'] = special_requests_str
                updated = True
                break
        if updated:
            save_reservations(reservations)
            return f"Special requests updated for reservation {reservation_id}. <a href='{url_for('dashboard')}'>Back to Dashboard</a>"
        else:
            return "Reservation not found. <a href='{}'>Back</a>".format(url_for('special_requests'))
    else:
        return render_template_string(special_requests_template,
                                      reservations=reservations,
                                      vehicles_map=vehicles_map)

@app.route('/locations', methods=['GET'])
def locations():
    locations = load_locations()
    selected_hours = request.args.get('hours', '')
    search_city = request.args.get('search_city', '').strip().lower()
    filtered = locations
    if selected_hours:
        filtered = [loc for loc in filtered if loc['hours'] == selected_hours]
    if search_city:
        filtered = [loc for loc in filtered if search_city in loc['city'].lower() or search_city in loc['address'].lower()]
    return render_template_string(locations_template,
                                  locations=filtered,
                                  selected_hours=selected_hours,
                                  search_city=search_city)

if __name__ == '__main__':
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)
    app.run(debug=True)
