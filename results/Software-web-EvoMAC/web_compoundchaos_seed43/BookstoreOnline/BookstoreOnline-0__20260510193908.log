'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly.
Test basic navigation buttons on the Dashboard page:
- Browse Catalog button navigates to book_catalog.html
- View Cart button navigates to cart.html
- Order History button navigates to order_history.html
Test presence and correctness of required elements on the Dashboard page:
- Div with id "dashboard-page"
- Div with id "featured-books"
- Button with id "browse-catalog-button"
- Button with id "view-cart-button"
- Button with id "bestsellers-button"
'''
import unittest
from http.server import HTTPServer, SimpleHTTPRequestHandler
import threading
import socket
import time
import requests
from bs4 import BeautifulSoup
# Since the provided source code is static HTML files, we will serve them locally using HTTPServer
# and test access on port 5000.
PORT = 5000
class TestBookstoreOnlineDashboard(unittest.TestCase):
    @classmethod
    def setUpClass(cls):
        # Start a simple HTTP server serving current directory on port 5000 in a separate thread
        # so that requests can be made to it.
        handler = SimpleHTTPRequestHandler
        cls.httpd = HTTPServer(('localhost', PORT), handler)
        cls.server_thread = threading.Thread(target=cls.httpd.serve_forever)
        cls.server_thread.daemon = True
        cls.server_thread.start()
        # Wait a moment for server to start
        time.sleep(0.5)
    @classmethod
    def tearDownClass(cls):
        cls.httpd.shutdown()
        cls.server_thread.join()
    def test_access_dashboard_page(self):
        # Test if the dashboard page is accessible at http://localhost:5000/dashboard.html
        url = f'http://localhost:{PORT}/dashboard.html'
        response = requests.get(url)
        self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")
    def test_dashboard_page_elements(self):
        url = f'http://localhost:{PORT}/dashboard.html'
        response = requests.get(url)
        soup = BeautifulSoup(response.text, 'html.parser')
        # Check for div with id "dashboard-page"
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, 'Div with id "dashboard-page" not found')
        # Check for div with id "featured-books"
        featured_div = soup.find('div', id='featured-books')
        self.assertIsNotNone(featured_div, 'Div with id "featured-books" not found')
        # Check for button with id "browse-catalog-button"
        browse_button = soup.find('button', id='browse-catalog-button')
        self.assertIsNotNone(browse_button, 'Button with id "browse-catalog-button" not found')
        # Check for button with id "view-cart-button"
        view_cart_button = soup.find('button', id='view-cart-button')
        self.assertIsNotNone(view_cart_button, 'Button with id "view-cart-button" not found')
        # Check for button with id "bestsellers-button"
        bestsellers_button = soup.find('button', id='bestsellers-button')
        self.assertIsNotNone(bestsellers_button, 'Button with id "bestsellers-button" not found')
    def test_dashboard_navigation_buttons(self):
        url = f'http://localhost:{PORT}/dashboard.html'
        response = requests.get(url)
        soup = BeautifulSoup(response.text, 'html.parser')
        # Check Browse Catalog button navigates to book_catalog.html
        browse_button = soup.find('button', id='browse-catalog-button')
        self.assertIn('book_catalog.html', browse_button.get('onclick', ''), 'Browse Catalog button does not navigate to book_catalog.html')
        # Check View Cart button navigates to cart.html
        view_cart_button = soup.find('button', id='view-cart-button')
        self.assertIn('cart.html', view_cart_button.get('onclick', ''), 'View Cart button does not navigate to cart.html')
        # Check Order History button navigates to order_history.html
        order_history_button = soup.find('button', id='bestsellers-button')
        self.assertIn('bestsellers.html', order_history_button.get('onclick', ''), 'Bestsellers button does not navigate to bestsellers.html')
if __name__ == '__main__':
    unittest.main()

