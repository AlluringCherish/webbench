Book Details page for BookstoreOnline web application.
Displays detailed information about a selected book and customer reviews.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Details</title>
</head>
<body>
    <div id="book-details-page">
        <h1 id="book-title">Book Title</h1>
        <div id="book-info">
            <p id="book-author">Author: </p>
            <p id="book-price">Price: </p>
            <p id="book-description">Description: </p>
        </div>
        <button id="add-to-cart-button">Add to Cart</button>
        <div id="book-reviews">
            <!-- Reviews will be displayed here -->
        </div>
    </div>
</body>
</html>
