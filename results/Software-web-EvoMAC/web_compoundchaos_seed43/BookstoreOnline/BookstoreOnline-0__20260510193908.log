write_review.html
```html
'''
Write Review page for BookstoreOnline web application.
Allows users to write reviews for purchased books.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write a Review</title>
</head>
<body>
    <div id="write-review-page">
        <h1>Write a Review</h1>
        <form>
            <label for="select-book">Select Book:</label>
            <select id="select-book" name="select-book" required>
                <!-- Book options dynamically inserted -->
            </select><br><br>
            <label for="rating-select">Rating:</label>
            <select id="rating-select" name="rating" required>
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
            </select><br><br>
            <label for="review-text">Review:</label><br>
            <textarea id="review-text" name="review-text" rows="5" cols="50" required></textarea><br><br>
            <button id="submit-review-button" type="submit">Submit Review</button>
        </form>
        <button id="back-to-dashboard" onclick="location.href='dashboard.html'">Back to Dashboard</button>
    </div>
</body>
</html>
```

