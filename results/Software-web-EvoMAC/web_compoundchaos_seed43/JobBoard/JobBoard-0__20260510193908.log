        self.assertIn(b'id="browse-jobs-button"', response.data)
        self.assertIn(b'id="my-applications-button"', response.data)
        self.assertIn(b'id="companies-button"', response.data)

    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons exist and their href or form actions route correctly
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check buttons by id and their presence
        self.assertIn(b'id="browse-jobs-button"', response.data)
        self.assertIn(b'id="my-applications-button"', response.data)
        self.assertIn(b'id="companies-button"', response.data)

        # Since buttons may be form submit or links, test navigation by simulating clicks:
        # Browse Jobs button navigates to /jobs
        response_jobs = self.client.get('/jobs')
        self.assertEqual(response_jobs.status_code, 200)
        self.assertIn(b'id="listings-page"', response_jobs.data)

        # My Applications button navigates to /applications
        response_apps = self.client.get('/applications')
        self.assertEqual(response_apps.status_code, 200)
        self.assertIn(b'id="tracking-page"', response_apps.data)

        # Companies button navigates to /companies
        response_companies = self.client.get('/companies')
        self.assertEqual(response_companies.status_code, 200)
        self.assertIn(b'id="companies-page"', response_companies.data)

if __name__ == '__main__':
    unittest.main()
