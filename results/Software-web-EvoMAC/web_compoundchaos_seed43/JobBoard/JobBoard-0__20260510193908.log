'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) can be accessed and loads correctly.
Test basic navigation buttons on the Dashboard page to ensure they route to the expected pages.
'''

import unittest
from app import app

class TestJobBoardApp(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page loads successfully on root or /dashboard route
