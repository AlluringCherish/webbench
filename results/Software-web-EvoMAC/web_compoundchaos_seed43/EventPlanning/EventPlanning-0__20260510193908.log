'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly.
Test basic navigation buttons on the Dashboard page.
'''

import unittest
from main import app

class TestEventPlanningDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test if the dashboard page is accessible via '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)

    def test_dashboard_page_title(self):
        # Test if the dashboard page contains the correct page title
        response = self.client.get('/')
        self.assertIn(b'Event Planning Dashboard', response.data)

    def test_dashboard_elements_present(self):
        # Test presence of key elements by their IDs in the dashboard page HTML
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        self.assertIn('id="dashboard-page"', html)
        self.assertIn('id="featured-events"', html)
        self.assertIn('id="browse-events-button"', html)
        self.assertIn('id="view-tickets-button"', html)
        self.assertIn('id="venues-button"', html)

    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons exist and have expected href or form actions
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        # Check buttons by id and that they are buttons (not links)
        self.assertIn('id="browse-events-button"', html)
        self.assertIn('id="view-tickets-button"', html)
        self.assertIn('id="venues-button"', html)
        # Since these are buttons, we expect some JavaScript or form to handle navigation,
        # but at minimum the buttons should be present.

if __name__ == '__main__':
    unittest.main()
