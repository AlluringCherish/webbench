'''
Ticket Booking page template.
Allows users to select event, ticket type, quantity and book tickets.
Displays booking confirmation after successful booking.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Your Tickets</title>
</head>
<body>
    <div id="ticket-booking-page">
        <h1>Book Your Tickets</h1>
        {% if error %}
        <p style="color:red;">{{ error }}</p>
        {% endif %}
        {% if booking_confirmation %}
        <div id="booking-confirmation">
            <h2>Booking Confirmed!</h2>
            <p>Booking ID: {{ booking_confirmation.booking_id }}</p>
            <p>Event ID: {{ booking_confirmation.event_id }}</p>
            <p>Name: {{ booking_confirmation.customer_name }}</p>
            <p>Date: {{ booking_confirmation.booking_date }}</p>
            <p>Tickets: {{ booking_confirmation.ticket_count }} ({{ booking_confirmation.ticket_type }})</p>
            <p>Total Amount: ${{ "%.2f"|format(booking_confirmation.total_amount) }}</p>
            <p>Status: {{ booking_confirmation.status }}</p>
        </div>
        <button onclick="location.href='/book-tickets'">Book Another Ticket</button>
        {% else %}
        <form method="post" action="/book-tickets">
            <label for="select-event-dropdown">Select Event:</label>
            <select id="select-event-dropdown" name="select-event-dropdown" required>
                {% for event in events %}
                <option value="{{ event.event_id }}">{{ event.event_name }} - {{ event.date }}</option>
                {% endfor %}
            </select><br><br>
            <label for="ticket-quantity-input">Number of Tickets:</label>
            <input id="ticket-quantity-input" name="ticket-quantity-input" type="number" min="1" required><br><br>
            <label for="ticket-type-select">Ticket Type:</label>
            <select id="ticket-type-select" name="ticket-type-select" required>
                <option value="General">General</option>
                <option value="VIP">VIP</option>
                <option value="Early Bird">Early Bird</option>
            </select><br><br>
            <label for="customer-name-input">Your Name:</label>
            <input id="customer-name-input" name="customer-name-input" type="text" placeholder="Optional"><br><br>
            <button id="book-now-button" type="submit">Book Now</button>
        </form>
        {% endif %}
        <button onclick="location.href='/'">Back to Dashboard</button>
    </div>
</body>
</html>
