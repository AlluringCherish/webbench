'''
Main application for the EventPlanning web application.
Handles all routes including pages for events, venues, bookings, participants, and schedules.
All routes correspond exactly to the specified requirements document.
'''
import os
from flask import Flask, render_template, request, redirect, url_for, abort, Response
import datetime

app = Flask(__name__)

DATA_DIR = 'data'

def read_events():
    events = []
    try:
        with open(os.path.join(DATA_DIR, 'events.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 9:
                    event = {
                        'event_id': parts[0],
                        'event_name': parts[1],
                        'category': parts[2],
                        'date': parts[3],
                        'time': parts[4],
                        'location': parts[5],
                        'description': parts[6],
                        'venue_id': parts[7],
                        'capacity': parts[8]
                    }
                    events.append(event)
    except FileNotFoundError:
        pass
    return events

def read_venues():
    venues = []
    try:
        with open(os.path.join(DATA_DIR, 'venues.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 6:
                    venue = {
                        'venue_id': parts[0],
                        'venue_name': parts[1],
                        'location': parts[2],
                        'capacity': parts[3],
                        'amenities': parts[4],
                        'contact': parts[5]
                    }
                    venues.append(venue)
    except FileNotFoundError:
        pass
    return venues

def read_tickets():
    tickets = []
    try:
        with open(os.path.join(DATA_DIR, 'tickets.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 6:
                    ticket = {
                        'ticket_id': parts[0],
                        'event_id': parts[1],
                        'ticket_type': parts[2],
                        'price': float(parts[3]),
                        'available_count': int(parts[4]),
                        'sold_count': int(parts[5])
                    }
                    tickets.append(ticket)
    except FileNotFoundError:
        pass
    return tickets

def read_bookings():
    bookings = []
    try:
        with open(os.path.join(DATA_DIR, 'bookings.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 8:
                    booking = {
                        'booking_id': parts[0],
                        'event_id': parts[1],
                        'customer_name': parts[2],
                        'booking_date': parts[3],
                        'ticket_count': int(parts[4]),
                        'ticket_type': parts[5],
                        'total_amount': float(parts[6]),
                        'status': parts[7]
                    }
                    bookings.append(booking)
    except FileNotFoundError:
        pass
    return bookings

def read_participants():
    participants = []
    try:
        with open(os.path.join(DATA_DIR, 'participants.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 7:
                    participant = {
                        'participant_id': parts[0],
                        'event_id': parts[1],
                        'name': parts[2],
                        'email': parts[3],
                        'booking_id': parts[4],
                        'status': parts[5],
                        'registration_date': parts[6]
                    }
                    participants.append(participant)
    except FileNotFoundError:
        pass
    return participants

def read_schedules():
    schedules = []
    try:
        with open(os.path.join(DATA_DIR, 'schedules.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 7:
                    schedule = {
                        'schedule_id': parts[0],
                        'event_id': parts[1],
                        'session_title': parts[2],
                        'session_time': parts[3],
                        'duration_minutes': parts[4],
                        'speaker': parts[5],
                        'venue_id': parts[6]
                    }
                    schedules.append(schedule)
    except FileNotFoundError:
        pass
    return schedules

@app.route('/')
def dashboard():
    '''
    Route for Dashboard page.
    Displays upcoming events, featured venues, and navigation buttons.
    '''
    events = read_events()
    # Sort events by date ascending
    upcoming_events = sorted(events, key=lambda e: e['date'])
    # Select first 3 upcoming events as featured
    featured_events = upcoming_events[:3]
    venues = read_venues()
    return render_template('dashboard.html', featured_events=featured_events, venues=venues)

@app.route('/events')
def events_listing():
    '''
    Route for Events Listing page.
    Supports search and category filter via query parameters.
    '''
    events = read_events()
    search_query = request.args.get('search', '').lower()
    category_filter = request.args.get('category', '')
    filtered_events = []
    for event in events:
        if search_query:
            if (search_query not in event['event_name'].lower() and
                search_query not in event['location'].lower() and
                search_query not in event['date']):
                continue
        if category_filter and category_filter != 'All':
            if event['category'] != category_filter:
                continue
        filtered_events.append(event)
    return render_template('events.html', events=filtered_events, category=category_filter, search=search_query)

@app.route('/event/<event_id>')
def event_details(event_id):
    '''
    Route for Event Details page.
    Displays detailed information about a specific event.
    '''
    events = read_events()
    event = next((e for e in events if e['event_id'] == event_id), None)
    if not event:
        abort(404)
    return render_template('event_details.html', event=event)

@app.route('/book-tickets', methods=['GET', 'POST'])
def book_tickets():
    '''
    Route for Ticket Booking page.
    GET: Display booking form.
    POST: Process booking and update data files.
    '''
    events = read_events()
    tickets = read_tickets()
    if request.method == 'POST':
        event_id = request.form.get('select-event-dropdown')
        ticket_type = request.form.get('ticket-type-select')
        ticket_quantity_str = request.form.get('ticket-quantity-input')
        customer_name = request.form.get('customer-name-input', '').strip()

        # Validate ticket quantity
        try:
            ticket_quantity = int(ticket_quantity_str)
            if ticket_quantity <= 0:
                raise ValueError
        except (ValueError, TypeError):
            error_msg = "Please enter a valid positive number for ticket quantity."
            return render_template('book_tickets.html', events=events, error=error_msg)

        # Validate event selection
        event = next((e for e in events if e['event_id'] == event_id), None)
        if not event:
            error_msg = "Selected event does not exist."
            return render_template('book_tickets.html', events=events, error=error_msg)

        # Validate ticket type availability
        ticket_info = next((t for t in tickets if t['event_id'] == event_id and t['ticket_type'] == ticket_type), None)
        if not ticket_info:
            error_msg = "Selected ticket type is not available for this event."
            return render_template('book_tickets.html', events=events, error=error_msg)

        if ticket_quantity > ticket_info['available_count']:
            error_msg = f"Only {ticket_info['available_count']} tickets are available for the selected ticket type."
            return render_template('book_tickets.html', events=events, error=error_msg)

        # Calculate total amount
        total_amount = ticket_info['price'] * ticket_quantity

        # Generate new booking ID
        bookings = read_bookings()
        max_booking_id = 0
        for b in bookings:
            try:
                bid = int(b['booking_id'])
                if bid > max_booking_id:
                    max_booking_id = bid
            except ValueError:
                continue
        new_booking_id = str(max_booking_id + 1)

        booking_date = datetime.date.today().isoformat()

        # Create new booking record
        new_booking = {
            'booking_id': new_booking_id,
            'event_id': event_id,
            'customer_name': customer_name,
            'booking_date': booking_date,
            'ticket_count': ticket_quantity,
            'ticket_type': ticket_type,
            'total_amount': total_amount,
            'status': 'Confirmed'
        }

        # Append new booking to bookings.txt
        with open(os.path.join(DATA_DIR, 'bookings.txt'), 'a', encoding='utf-8') as f:
            line = '|'.join([
                new_booking['booking_id'],
                new_booking['event_id'],
                new_booking['customer_name'],
                new_booking['booking_date'],
                str(new_booking['ticket_count']),
                new_booking['ticket_type'],
                f"{new_booking['total_amount']:.2f}",
                new_booking['status']
            ])
            f.write(line + '\n')

        # Update tickets.txt to reduce available_count and increase sold_count
        updated_tickets = []
        for t in tickets:
            if t['ticket_id'] == ticket_info['ticket_id']:
                t['available_count'] -= ticket_quantity
                t['sold_count'] += ticket_quantity
            updated_tickets.append(t)
        with open(os.path.join(DATA_DIR, 'tickets.txt'), 'w', encoding='utf-8') as f:
            for t in updated_tickets:
                line = '|'.join([
                    t['ticket_id'],
                    t['event_id'],
                    t['ticket_type'],
                    f"{t['price']:.2f}",
                    str(t['available_count']),
                    str(t['sold_count'])
                ])
                f.write(line + '\n')

        booking_confirmation = new_booking
        return render_template('book_tickets.html', events=events, booking_confirmation=booking_confirmation)

    # GET request
    return render_template('book_tickets.html', events=events)

@app.route('/participants')
def participants_management():
    '''
    Route for Participants Management page.
    Supports search and status filter via query parameters.
    '''
    participants = read_participants()
    events = read_events()
    search_query = request.args.get('search', '').lower()
    status_filter = request.args.get('status', '')

    filtered_participants = []
    for p in participants:
        if search_query:
            if (search_query not in p['name'].lower() and
                search_query not in p['email'].lower()):
                continue
        if status_filter and status_filter != 'All':
            if p['status'] != status_filter:
                continue
        filtered_participants.append(p)

    event_dict = {e['event_id']: e['event_name'] for e in events}
    return render_template('participants.html', participants=filtered_participants, events=event_dict, search=search_query, status=status_filter)

@app.route('/venues')
def venues_page():
    '''
    Route for Venue Information page.
    Supports search and capacity filter via query parameters.
    '''
    venues = read_venues()
    search_query = request.args.get('search', '').lower()
    capacity_filter = request.args.get('capacity', '')

    filtered_venues = []
    for v in venues:
        if search_query:
            if (search_query not in v['venue_name'].lower() and
                search_query not in v['location'].lower()):
                continue
        if capacity_filter and capacity_filter != 'All':
            try:
                cap = int(v['capacity'])
            except ValueError:
                continue
            if capacity_filter == 'Small' and cap > 500:
                continue
            elif capacity_filter == 'Medium' and (cap <= 500 or cap > 2000):
                continue
            elif capacity_filter == 'Large' and cap <= 2000:
                continue
        filtered_venues.append(v)
    return render_template('venues.html', venues=filtered_venues, search=search_query, capacity=capacity_filter)

@app.route('/venue/<venue_id>')
def venue_details(venue_id):
    '''
    Route for Venue Details page.
    Displays detailed information about a specific venue.
    '''
    venues = read_venues()
    venue = next((v for v in venues if v['venue_id'] == venue_id), None)
    if not venue:
        abort(404)
    return render_template('venue_details.html', venue=venue)

@app.route('/schedules')
def schedules_page():
    '''
    Route for Event Schedules page.
    Supports filtering by date and event via query parameters.
    '''
    schedules = read_schedules()
    events = read_events()
    filter_date = request.args.get('date', '')
    filter_event = request.args.get('event', '')

    filtered_schedules = []
    for s in schedules:
        if filter_date:
            # session_time format: 'YYYY-MM-DD HH:MM'
            if not s['session_time'].startswith(filter_date):
                continue
        if filter_event and filter_event != 'All':
            if s['event_id'] != filter_event:
                continue
        filtered_schedules.append(s)

    event_dict = {e['event_id']: e['event_name'] for e in events}
    return render_template('schedules.html', schedules=filtered_schedules, event_dict=event_dict, filter_date=filter_date, filter_event=filter_event)

@app.route('/export-schedule')
def export_schedule():
    '''
    Route to export schedule data as plain text.
    '''
    schedules = read_schedules()
    lines = []
    for s in schedules:
        line = '|'.join([
            s['schedule_id'],
            s['event_id'],
            s['session_title'],
            s['session_time'],
            s['duration_minutes'],
            s['speaker'],
            s['venue_id']
        ])
        lines.append(line)
    content = '\n'.join(lines)
    return Response(content, mimetype='text/plain; charset=utf-8')

@app.route('/bookings')
def bookings_summary():
    '''
    Route for Bookings Summary page.
    Supports search by event name or booking ID via query parameter.
    '''
    bookings = read_bookings()
    events = read_events()
    search_query = request.args.get('search', '').lower()
    event_dict = {e['event_id']: e['event_name'] for e in events}

    filtered_bookings = []
    for b in bookings:
        event_name = event_dict.get(b['event_id'], '').lower()
        if search_query:
            if (search_query not in event_name and
                search_query not in b['booking_id'].lower()):
                continue
        filtered_bookings.append(b)

    return render_template('bookings.html', bookings=filtered_bookings, event_dict=event_dict, search=search_query)

@app.route('/cancel-booking/<booking_id>', methods=['POST'])
def cancel_booking(booking_id):
    '''
    Route to cancel a booking by booking_id.
    Updates booking status to 'Cancelled' in bookings.txt.
    '''
    bookings = read_bookings()
    booking_found = False
    for b in bookings:
        if b['booking_id'] == booking_id:
            if b['status'] == 'Cancelled':
                # Already cancelled
                booking_found = True
                break
            b['status'] = 'Cancelled'
            booking_found = True
            break
    if not booking_found:
        abort(404)

    # Write updated bookings back to file
    with open(os.path.join(DATA_DIR, 'bookings.txt'), 'w', encoding='utf-8') as f:
        for b in bookings:
            line = '|'.join([
                b['booking_id'],
                b['event_id'],
                b['customer_name'],
                b['booking_date'],
                str(b['ticket_count']),
                b['ticket_type'],
                f"{b['total_amount']:.2f}",
                b['status']
            ])
            f.write(line + '\n')

    return redirect(url_for('bookings_summary'))

@app.route('/back-to-dashboard')
def back_to_dashboard():
    '''
    Route to navigate back to dashboard.
    '''
    return redirect(url_for('dashboard'))

if __name__ == '__main__':
    app.run(debug=True)
```
