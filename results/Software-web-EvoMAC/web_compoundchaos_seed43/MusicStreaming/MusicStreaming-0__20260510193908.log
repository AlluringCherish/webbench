'''
Playlist Details Page Template
Displays songs in a specific playlist with management options.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Playlist Details</title>
    <style>
        #playlist-details-page { padding: 20px; font-family: Arial, sans-serif; }
        table { border-collapse: collapse; width: 100%; margin-top: 15px; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        button { padding: 5px 10px; cursor: pointer; }
    </style>
</head>
<body>
<div id="playlist-details-page">
    <h1 id="playlist-title">{{ playlist.title }}</h1>
    <div id="playlist-description">{{ playlist.description }}</div>

    <table id="songs-in-playlist">
        <thead>
            <tr>
                <th>Title</th>
                <th>Artist</th>
                <th>Duration</th>
                <th>Remove</th>
            </tr>
        </thead>
        <tbody>
            {% for song in songs_in_playlist %}
            <tr>
                <td><a href="{{ url_for('song_details', song_id=song.song_id) }}">{{ song.title }}</a></td>
                <td><a href="{{ url_for('artist_profile', artist_id=song.artist_id) }}">{{ song.artist_name }}</a></td>
                <td>{{ (song.duration // 60) }}:{{ '%02d' % (song.duration % 60) }}</td>
                <td>
                    <form method="post" action="{{ url_for('remove_song_from_playlist', playlist_id=playlist.playlist_id, song_id=song.song_id) }}" style="margin:0;">
                        <button id="remove-song-button-{{ song.song_id }}" type="submit" onclick="return confirm('Remove this song from playlist?');">Remove</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4">No songs in this playlist.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <form method="post" action="{{ url_for('delete_playlist', playlist_id=playlist.playlist_id) }}" onsubmit="return confirm('Delete this entire playlist?');" style="margin-top: 15px;">
        <button id="delete-playlist-button" type="submit">Delete Playlist</button>
    </form>

    <p><a href="{{ url_for('playlists') }}">Back to My Playlists</a></p>
</div>
</body>
</html>
