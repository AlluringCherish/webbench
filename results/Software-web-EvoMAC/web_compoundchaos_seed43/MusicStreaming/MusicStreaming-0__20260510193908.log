        #dashboard-page { padding: 20px; font-family: Arial, sans-serif; }
        #featured-songs, #trending-artists { margin-bottom: 30px; }
        .song-card, .artist-card { border: 1px solid #ccc; padding: 10px; margin: 5px; display: inline-block; width: 180px; vertical-align: top; }
