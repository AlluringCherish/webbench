'''
Song Catalog Page Template
Displays all songs with search and genre filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Song Catalog</title>
    <style>
        #catalog-page { padding: 20px; font-family: Arial, sans-serif; }
        #songs-grid { display: flex; flex-wrap: wrap; gap: 10px; }
        .song-card { border: 1px solid #ccc; padding: 10px; width: 200px; }
        button { margin-top: 5px; padding: 5px 10px; cursor: pointer; }
        #search-input, #genre-filter { margin: 5px; padding: 5px; font-size: 16px; }
    </style>
</head>
<body>
<div id="catalog-page">
    <h1>Song Catalog</h1>
    <form method="get" action="{{ url_for('song_catalog') }}">
        <input id="search-input" name="search" type="text" placeholder="Search songs, artists, albums" value="{{ search_query }}">
        <select id="genre-filter" name="genre">
            {% for genre in genres %}
            <option value="{{ genre }}" {% if genre == selected_genre %}selected{% endif %}>{{ genre }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="songs-grid">
        {% for song in songs %}
        <div class="song-card">
            <strong>{{ song.title }}</strong><br>
            Artist: {{ song.artist_name }}<br>
            Album: {{ song.album_title }}<br>
            Duration: {{ (song.duration // 60) }}:{{ '%02d' % (song.duration % 60) }}<br>
            <form method="post" action="{{ url_for('playlists') }}" style="margin-top:5px;">
                <!-- Since no authentication, we can redirect to playlists page for user to add songs -->
                <button type="button" onclick="alert('To add this song to a playlist, please go to My Playlists and select a playlist.')">Add to Playlist</button>
            </form>
            <a href="{{ url_for('song_details', song_id=song.song_id) }}">Details</a>
        </div>
        {% else %}
        <p>No songs found.</p>
        {% endfor %}
    </div>
    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
