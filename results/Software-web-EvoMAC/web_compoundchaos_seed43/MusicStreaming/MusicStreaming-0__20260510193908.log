templates/genres.html
```html
'''
Genre Exploration Page Template
Displays all genres and allows exploration of songs and artists per genre.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Genre Exploration</title>
    <style>
        #genres-page { padding: 20px; font-family: Arial, sans-serif; }
        #genres-list { margin-bottom: 20px; }
        .genre-item { display: inline-block; margin-right: 10px; padding: 5px 10px; border: 1px solid #ccc; cursor: pointer; }
        .selected { background-color: #ddd; }
        #genre-songs, #genre-artists { margin-top: 20px; }
        .song-item, .artist-item { margin-bottom: 5px; }
        button { padding: 5px 10px; cursor: pointer; }
    </style>
</head>
<body>
<div id="genres-page">
    <h1>Genre Exploration</h1>
    <form method="get" action="{{ url_for('genres') }}">
        <label for="select-genre">Select Genre:</label>
        <select id="select-genre" name="genre" onchange="this.form.submit()">
            <option value="">-- Select a genre --</option>
            {% for genre in genres %}
            <option value="{{ genre.genre_name }}" {% if genre.genre_name == selected_genre %}selected{% endif %}>{{ genre.genre_name }}</option>
            {% endfor %}
        </select>
    </form>

    {% if selected_genre %}
    <h2>Songs in {{ selected_genre }}</h2>
    <div id="genre-songs">
        {% for song in genre_songs %}
        <div class="song-item">
            <a href="{{ url_for('song_details', song_id=song.song_id) }}">{{ song.title }}</a> - {{ song.artist_name }} - {{ song.duration_formatted }}
        </div>
        {% else %}
        <p>No songs found for this genre.</p>
        {% endfor %}
    </div>

    <h2>Artists in {{ selected_genre }}</h2>
    <div id="genre-artists">
        {% for artist in genre_artists %}
        <div class="artist-item">
            <a href="{{ url_for('artist_profile', artist_id=artist.artist_id) }}">{{ artist.name }}</a> - {{ artist.country }}
        </div>
        {% else %}
        <p>No artists found for this genre.</p>
        {% endfor %}
    </div>
    {% endif %}

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

