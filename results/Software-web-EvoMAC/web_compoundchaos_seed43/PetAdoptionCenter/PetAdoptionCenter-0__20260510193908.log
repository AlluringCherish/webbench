templates/admin_panel.html
```html
'''
Admin Panel page template for PetAdoptionCenter.
Allows administrators to manage applications and pets.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Panel</title>
</head>
<body>
<div id="admin-panel-page">
    <h1>Admin Panel</h1>

    <h2>Pending Adoption Applications</h2>
    {% if pending_applications %}
        <ul>
            {% for app in pending_applications %}
                <li>
                    Application ID: {{ app.application_id }} - Applicant: {{ app.applicant_name }} - Pet ID: {{ app.pet_id }} - Status: {{ app.status }}
                    <form method="post" action="{{ url_for('admin_update_application', application_id=app.application_id) }}" style="display:inline;">
                        <select name="status" required>
                            <option value="Pending" {% if app.status == 'Pending' %}selected{% endif %}>Pending</option>
                            <option value="Approved" {% if app.status == 'Approved' %}selected{% endif %}>Approved</option>
                            <option value="Rejected" {% if app.status == 'Rejected' %}selected{% endif %}>Rejected</option>
                        </select>
                        <button type="submit">Update</button>
                    </form>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>No pending applications.</p>
    {% endif %}

    <h2>All Pets</h2>
    {% if all_pets %}
        <ul>
            {% for pet in all_pets %}
                <li>
                    {{ pet.name }} ({{ pet.species }}) - Status: {{ pet.status }}
                    <form method="post" action="{{ url_for('admin_delete_pet', pet_id=pet.pet_id) }}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this pet?');">
                        <button type="submit">Delete</button>
                    </form>
                    <button onclick="location.href='{{ url_for('admin_edit_pet', pet_id=pet.pet_id) }}'">Edit</button>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>No pets found.</p>
    {% endif %}

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

