templates/messages.html
```html
'''
Messages page template for PetAdoptionCenter.
Allows users to view and send messages to shelters or other users.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Messages</title>
</head>
<body>
<div id="messages-page">
    <h1>Messages</h1>

    <div id="conversation-list">
        {% if conversations %}
            {% for participants, msgs in conversations.items() %}
                <h3>Conversation between {{ participants[0] }} and {{ participants[1] }}</h3>
                <ul>
                    {% for msg in msgs %}
                        <li>
                            <strong>{{ msg.timestamp }} - {{ msg.sender_username }}:</strong> {{ msg.content }}
                        </li>
                    {% endfor %}
                </ul>
            {% endfor %}
        {% else %}
            <p>No conversations found.</p>
        {% endif %}
    </div>

    <h2>Send New Message</h2>
    <form method="post" action="{{ url_for('messages') }}">
        <label for="recipient_username">Recipient Username:</label><br>
        <input id="recipient_username" name="recipient_username" type="text" required><br><br>

        <label for="subject">Subject:</label><br>
        <input id="subject" name="subject" type="text" required><br><br>

        <label for="message-input">Message:</label><br>
        <textarea id="message-input" name="message-input" rows="5" cols="40" required></textarea><br><br>

        <button id="send-message-button" type="submit">Send Message</button>
    </form>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
