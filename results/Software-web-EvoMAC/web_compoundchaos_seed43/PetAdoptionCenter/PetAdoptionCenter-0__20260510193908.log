templates/my_applications.html
```html
'''
My Applications page template for PetAdoptionCenter.
Displays all adoption applications submitted by the current user with filtering by status.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Applications</title>
</head>
<body>
<div id="my-applications-page">
    <h1>My Applications</h1>

    <form method="get" action="{{ url_for('my_applications') }}">
        <label for="filter-status">Filter by Status:</label>
        <select id="filter-status" name="status" onchange="this.form.submit()">
            {% set status_options = ['All', 'Pending', 'Approved', 'Rejected'] %}
            {% for status in status_options %}
                <option value="{{ status }}" {% if status == filter_status %}selected{% endif %}>{{ status }}</option>
            {% endfor %}
        </select>
    </form>

    <table id="applications-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Pet Name</th>
                <th>Date Submitted</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if applications %}
                {% for app in applications %}
                    <tr>
                        <td><a href="{{ url_for('pet_details', pet_id=app.pet_id) }}">{{ app.pet_name }}</a></td>
                        <td>{{ app.date_submitted }}</td>
                        <td>{{ app.status }}</td>
                        <td>
                            <!-- Actions could be view details or cancel application -->
                            <!-- For now, just view pet details -->
                            <a href="{{ url_for('pet_details', pet_id=app.pet_id) }}">View Pet</a>
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr><td colspan="4">No applications found.</td></tr>
            {% endif %}
        </tbody>
    </table>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
