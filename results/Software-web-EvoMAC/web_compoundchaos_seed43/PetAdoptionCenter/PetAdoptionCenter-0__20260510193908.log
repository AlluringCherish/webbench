            'sender_username': username,
            'recipient_username': recipient,
            'subject': subject,
            'content': content,
            'timestamp': timestamp,
            'is_read': False
        }
        messages.append(new_message)
        write_messages(messages)
        flash('Message sent.', 'success')
        return redirect(url_for('messages'))
