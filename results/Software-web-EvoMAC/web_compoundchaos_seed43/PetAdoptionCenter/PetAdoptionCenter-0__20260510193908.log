            <option value="Medium" {% if pet.size == 'Medium' %}selected{% endif %}>Medium</option>
            <option value="Large" {% if pet.size == 'Large' %}selected{% endif %}>Large</option>
        </select><br><br>

        <label for="pet-description-input">Description:</label><br>
        <textarea id="pet-description-input" name="pet-description-input" rows="5" cols="40">{{ pet.description }}</textarea><br><br>

        <label for="pet-status-input">Status:</label><br>
        <select id="pet-status-input" name="pet-status-input" required>
