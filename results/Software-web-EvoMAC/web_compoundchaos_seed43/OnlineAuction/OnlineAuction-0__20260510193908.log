'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of the Dashboard page including presence of:
- ID: dashboard-page (Div container)
- ID: featured-auctions (Div container for featured auction items)
- ID: browse-auctions-button (Button to navigate to auction catalog page)
- ID: view-bids-button (Button to navigate to bid history page)
- ID: trending-auctions-button (Button to navigate to trending auctions page)
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class OnlineAuctionDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible (status 200)")

    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements by ID
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Check for dashboard-page div
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must contain div with id 'dashboard-page'")

        # Check for featured-auctions div
        featured_div = soup.find(id='featured-auctions')
        self.assertIsNotNone(featured_div, "Dashboard page must contain div with id 'featured-auctions'")

        # Check for browse-auctions-button button
        browse_button = soup.find(id='browse-auctions-button')
        self.assertIsNotNone(browse_button, "Dashboard page must contain button with id 'browse-auctions-button'")

        # Check for view-bids-button button
        view_bids_button = soup.find(id='view-bids-button')
        self.assertIsNotNone(view_bids_button, "Dashboard page must contain button with id 'view-bids-button'")

        # Check for trending-auctions-button button
        trending_button = soup.find(id='trending-auctions-button')
        self.assertIsNotNone(trending_button, "Dashboard page must contain button with id 'trending-auctions-button'")

    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons link to correct pages
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        browse_button = soup.find(id='browse-auctions-button')
        self.assertIsNotNone(browse_button)
        # Check if button has an href or onclick attribute linking to /catalog or similar
        browse_link = browse_button.get('onclick') or browse_button.get('href')
        self.assertIsNotNone(browse_link, "Browse auctions button should have a link or onclick attribute")
        self.assertTrue('/catalog' in browse_link or 'catalog' in browse_link.lower(), "Browse auctions button should link to catalog page")

        view_bids_button = soup.find(id='view-bids-button')
        self.assertIsNotNone(view_bids_button)
        view_bids_link = view_bids_button.get('onclick') or view_bids_button.get('href')
        self.assertIsNotNone(view_bids_link, "View bids button should have a link or onclick attribute")
        self.assertTrue('history' in view_bids_link.lower(), "View bids button should link to bid history page")

        trending_button = soup.find(id='trending-auctions-button')
        self.assertIsNotNone(trending_button)
        trending_link = trending_button.get('onclick') or trending_button.get('href')
        self.assertIsNotNone(trending_link, "Trending auctions button should have a link or onclick attribute")
        self.assertTrue('trending' in trending_link.lower(), "Trending auctions button should link to trending auctions page")

if __name__ == '__main__':
    unittest.main()
