'''
Flask backend for OnlineAuction application.

- Runs on port 5000.
- Routes correspond to pages and UI elements as specified.
- Uses data files in 'data' directory.
- Renders templates named as lowercase html files.
- Implements all required pages and features.
- No authentication; all pages accessible directly.
'''

from flask import Flask, render_template, request, redirect, url_for
import os
import datetime

app = Flask(__name__)

DATA_DIR = 'data'

# Utility functions to load data from files

def load_auctions():
    auctions = []
    path = os.path.join(DATA_DIR, 'auctions.txt')
    if not os.path.exists(path):
        return auctions
    with open(path, encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            # Format:
            # item_name|description|category|starting_price|current_bid|end_date [HH:MM]|status|image
            parts = line.split('|')
            if len(parts) < 7:
                continue
            item_name = parts[0]
            description = parts[1]
            category = parts[2]
            try:
                starting_price = float(parts[3])
                current_bid = float(parts[4])
            except ValueError:
                starting_price = 0.0
                current_bid = 0.0
            end_date_str = parts[5]
            status = parts[6]
            image = parts[7] if len(parts) > 7 else ''
            # Parse end_date with optional time
            try:
                if ' ' in end_date_str:
                    end_date = datetime.datetime.strptime(end_date_str, '%Y-%m-%d %H:%M')
                else:
                    end_date = datetime.datetime.strptime(end_date_str, '%Y-%m-%d')
            except Exception:
                end_date = None
            auctions.append({
                'item_name': item_name,
                'description': description,
                'category': category,
                'starting_price': starting_price,
                'current_bid': current_bid,
                'end_date': end_date,
                'status': status,
                'image': image
            })
    return auctions

def load_categories():
    categories = []
    path = os.path.join(DATA_DIR, 'categories.txt')
    if not os.path.exists(path):
        return categories
    with open(path, encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            # Format: category_id|category_name|description|item_count
            parts = line.split('|')
            if len(parts) < 4:
                continue
            try:
                category_id = int(parts[0])
                category_name = parts[1]
                description = parts[2]
                item_count = int(parts[3])
            except Exception:
                continue
            categories.append({
                'category_id': category_id,
                'category_name': category_name,
                'description': description,
                'item_count': item_count
            })
    return categories

def load_bids():
    bids = []
    path = os.path.join(DATA_DIR, 'bids.txt')
    if not os.path.exists(path):
        return bids
    with open(path, encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            # Format: bid_id|auction_id|bidder_name|bid_amount|bid_timestamp
            parts = line.split('|')
            if len(parts) < 5:
                continue
            try:
                bid_id = int(parts[0])
                auction_id = int(parts[1])
                bidder_name = parts[2]
                bid_amount = float(parts[3])
                bid_timestamp = datetime.datetime.strptime(parts[4], '%Y-%m-%d %H:%M:%S')
            except Exception:
                continue
            bids.append({
                'bid_id': bid_id,
                'auction_id': auction_id,
                'bidder_name': bidder_name,
                'bid_amount': bid_amount,
                'bid_timestamp': bid_timestamp
            })
    return bids

def load_winners():
    winners = []
    path = os.path.join(DATA_DIR, 'winners.txt')
    if not os.path.exists(path):
        return winners
    with open(path, encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            # Format: winner_id|auction_id|item_name|winner_name|winning_bid|win_date
            parts = line.split('|')
            if len(parts) < 6:
                continue
            try:
                winner_id = int(parts[0])
                auction_id = int(parts[1])
                item_name = parts[2]
                winner_name = parts[3]
                winning_bid = float(parts[4])
                win_date = datetime.datetime.strptime(parts[5], '%Y-%m-%d')
            except Exception:
                continue
            winners.append({
                'winner_id': winner_id,
                'auction_id': auction_id,
                'item_name': item_name,
                'winner_name': winner_name,
                'winning_bid': winning_bid,
                'win_date': win_date
            })
    return winners

def save_bid(auction_id, bidder_name, bid_amount):
    bids = load_bids()
    new_id = max([b['bid_id'] for b in bids], default=0) + 1
    now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    line = f"{new_id}|{auction_id}|{bidder_name}|{bid_amount}|{now}\n"
    path = os.path.join(DATA_DIR, 'bids.txt')
    with open(path, 'a', encoding='utf-8') as f:
        f.write(line)

def find_auction_by_name(name):
    auctions = load_auctions()
    for idx, a in enumerate(auctions):
        if a['item_name'] == name:
            return idx, a
    return None, None

def find_auction_by_id(auction_id):
    auctions = load_auctions()
    if 0 <= auction_id < len(auctions):
        return auctions[auction_id]
    return None

def get_auction_id_by_name(name):
    auctions = load_auctions()
    for idx, a in enumerate(auctions):
        if a['item_name'] == name:
            return idx
    return None

# Routes

@app.route('/')
def dashboard():
    # Dashboard page with trending auctions and navigation buttons
    auctions = load_auctions()
    # Trending auctions: top 5 by current_bid descending and active status
    trending = [a for a in auctions if a['status'].lower() == 'active']
    trending.sort(key=lambda x: x['current_bid'], reverse=True)
    trending = trending[:5]
    return render_template('dashboard.html',
                           auctions=auctions,
                           trending=trending)

@app.route('/catalog')
def catalog():
    # Catalog page with search and category filter
    auctions = load_auctions()
    categories = load_categories()
    search = request.args.get('search', '').lower()
    category_filter = request.args.get('category', '')
    filtered = []
    for a in auctions:
        if a['status'].lower() != 'active':
            continue
        if search and (search not in a['item_name'].lower() and search not in a['description'].lower()):
            continue
        if category_filter and category_filter != 'All' and a['category'] != category_filter:
            continue
        filtered.append(a)
    return render_template('catalog.html',
                           auctions=filtered,
                           categories=categories,
                           search=search,
                           category_filter=category_filter)

@app.route('/auction/<item_name>')
def auction_details(item_name):
    # Auction details page
    idx, auction = find_auction_by_name(item_name)
    if auction is None:
        return "Auction not found", 404
    bids = load_bids()
    auction_bids = [b for b in bids if b['auction_id'] == idx]
    auction_bids.sort(key=lambda x: x['bid_timestamp'], reverse=True)
    return render_template('auction_details.html',
                           auction=auction,
                           bids=auction_bids,
                           auction_id=idx)

@app.route('/place_bid/<item_name>', methods=['GET', 'POST'])
def place_bid(item_name):
    idx, auction = find_auction_by_name(item_name)
    if auction is None:
        return "Auction not found", 404
    if request.method == 'POST':
        bidder_name = request.form.get('bidder_name', '').strip()
        bid_amount_str = request.form.get('bid_amount', '').strip()
        if not bidder_name or not bid_amount_str:
            error = "Bidder name and bid amount are required."
            return render_template('place_bid.html', auction=auction, error=error)
        try:
            bid_amount = float(bid_amount_str)
        except ValueError:
            error = "Invalid bid amount."
            return render_template('place_bid.html', auction=auction, error=error)
        min_bid = max(auction['starting_price'], auction['current_bid'])
        if bid_amount <= min_bid:
            error = f"Bid must be greater than current bid ({min_bid})."
            return render_template('place_bid.html', auction=auction, error=error)
        # Save bid
        save_bid(idx, bidder_name, bid_amount)
        # Update current bid in auctions.txt
        update_auction_current_bid(idx, bid_amount)
        return redirect(url_for('auction_details', item_name=item_name))
    return render_template('place_bid.html', auction=auction)

def update_auction_current_bid(auction_idx, new_bid):
    path = os.path.join(DATA_DIR, 'auctions.txt')
    lines = []
    with open(path, encoding='utf-8') as f:
        lines = f.readlines()
    if 0 <= auction_idx < len(lines):
        parts = lines[auction_idx].strip().split('|')
        if len(parts) >= 5:
            parts[4] = f"{new_bid:.2f}"
            lines[auction_idx] = '|'.join(parts) + '\n'
    with open(path, 'w', encoding='utf-8') as f:
        f.writelines(lines)

@app.route('/bid_history')
def bid_history():
    bids = load_bids()
    auction_id = request.args.get('auction_id', type=int)
    if auction_id is not None:
        bids = [b for b in bids if b['auction_id'] == auction_id]
    bids.sort(key=lambda x: x['bid_timestamp'], reverse=True)
    return render_template('bid_history.html', bids=bids)

@app.route('/categories')
def categories():
    categories = load_categories()
    return render_template('categories.html', categories=categories)

@app.route('/category/<int:category_id>')
def view_category(category_id):
    categories = load_categories()
    category = next((c for c in categories if c['category_id'] == category_id), None)
    if category is None:
        return "Category not found", 404
    auctions = load_auctions()
    filtered = [a for a in auctions if a['category'] == category['category_name'] and a['status'].lower() == 'active']
    return render_template('category.html', category=category, auctions=filtered)

@app.route('/winners')
def winners():
    winners = load_winners()
    filter_name = request.args.get('filter', '').lower()
    if filter_name:
        winners = [w for w in winners if filter_name in w['winner_name'].lower()]
    return render_template('winners.html', winners=winners)

@app.route('/trending')
def trending():
    auctions = load_auctions()
    # Trending auctions by bid count or current bid descending
    # For simplicity, sort by current_bid descending
    trending = [a for a in auctions if a['status'].lower() == 'active']
    trending.sort(key=lambda x: x['current_bid'], reverse=True)
    return render_template('trending.html', trending=trending)

@app.route('/status')
def status():
    auctions = load_auctions()
    status_filter = request.args.get('filter', 'All')
    if status_filter != 'All':
        auctions = [a for a in auctions if a['status'].lower() == status_filter.lower()]
    return render_template('status.html', auctions=auctions, status_filter=status_filter)

if __name__ == '__main__':
    app.run(port=5000, debug=True)
```
