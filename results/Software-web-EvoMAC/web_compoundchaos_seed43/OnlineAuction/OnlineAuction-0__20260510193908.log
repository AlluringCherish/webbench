"""
app.py

Complete backend implementation for the 'OnlineAuction' application using Flask.
This code manages auctions, bids, categories, trending, status, and history pages.
Data is stored and loaded from local text files in the 'data' directory.
"""

import os
from flask import Flask, render_template, request, redirect, url_for, abort
from datetime import datetime

app = Flask(__name__)

DATA_DIR = 'data'
AUCTIONS_FILE = os.path.join(DATA_DIR, 'auctions.txt')
CATEGORIES_FILE = os.path.join(DATA_DIR, 'categories.txt')
BIDS_FILE = os.path.join(DATA_DIR, 'bids.txt')
TRENDING_FILE = os.path.join(DATA_DIR, 'trending.txt')
WINNERS_FILE = os.path.join(DATA_DIR, 'winners.txt')


def load_auctions():
    auctions = []
    if not os.path.exists(AUCTIONS_FILE):
        return auctions
    with open(AUCTIONS_FILE, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 9:
                continue
            try:
                auction_id = parts[0]
                item_name = parts[1]
                description = parts[2]
                category = parts[3]
                starting_price = float(parts[4])
                current_bid = float(parts[5])
                end_date = datetime.strptime(parts[6], '%Y-%m-%d %H:%M')
                status = parts[7].lower()
                image = parts[8]
            except Exception:
                continue
            auctions.append({
                'auction_id': auction_id,
                'item_name': item_name,
                'description': description,
                'category': category,
                'starting_price': starting_price,
                'current_bid': current_bid,
                'end_date': end_date,
                'status': status,
                'image': image
            })
    return auctions


def save_auctions(auctions):
    lines = []
    for a in auctions:
        line = '|'.join([
            str(a['auction_id']),
            a['item_name'],
            a['description'],
            a['category'],
            f"{a['starting_price']:.2f}",
            f"{a['current_bid']:.2f}",
            a['end_date'].strftime('%Y-%m-%d %H:%M'),
            a['status'],
            a['image']
        ])
        lines.append(line + '\n')
    with open(AUCTIONS_FILE, 'w', encoding='utf-8') as f:
        f.writelines(lines)


def load_categories():
    categories = []
    if not os.path.exists(CATEGORIES_FILE):
        return categories
    with open(CATEGORIES_FILE, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 4:
                continue
            categories.append({
                'category_id': parts[0],
                'category_name': parts[1],
                'description': parts[2],
                'item_count': parts[3]
            })
    return categories


def load_bids():
    bids = []
    if not os.path.exists(BIDS_FILE):
        return bids
    with open(BIDS_FILE, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 5:
                continue
            try:
                bid_id = parts[0]
                auction_id = parts[1]
                bidder_name = parts[2]
                bid_amount = float(parts[3])
                bid_timestamp = datetime.strptime(parts[4], '%Y-%m-%d %H:%M')
            except Exception:
                continue
            bids.append({
                'bid_id': bid_id,
                'auction_id': auction_id,
                'bidder_name': bidder_name,
                'bid_amount': bid_amount,
                'bid_timestamp': bid_timestamp
            })
    return bids


def save_bid(bid):
    # Append a new bid line to bids.txt
    with open(BIDS_FILE, 'a', encoding='utf-8') as f:
        line = '|'.join([
            str(bid['bid_id']),
            str(bid['auction_id']),
            bid['bidder_name'],
            f"{bid['bid_amount']:.2f}",
            bid['bid_timestamp'].strftime('%Y-%m-%d %H:%M')
        ]) + '\n'
        f.write(line)


def load_trending():
    trending = []
    if not os.path.exists(TRENDING_FILE):
        return trending
    with open(TRENDING_FILE, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 6:
                continue
            trending.append({
                'auction_id': parts[0],
                'item_name': parts[1],
                'rank': int(parts[2]),
                'current_bid': float(parts[3]),
                'bid_count': int(parts[4]),
                'time_period': parts[5]
            })
    return trending


def load_winners():
    winners = []
    if not os.path.exists(WINNERS_FILE):
        return winners
    with open(WINNERS_FILE, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 6:
                continue
            winners.append({
                'winner_id': parts[0],
                'auction_id': parts[1],
                'item_name': parts[2],
                'winner_name': parts[3],
                'winning_bid': float(parts[4]),
                'win_date': parts[5]
            })
    return winners


@app.route('/')
def dashboard():
    auctions = load_auctions()
    active_auctions = [a for a in auctions if a['status'] == 'active']
    trending = load_trending()
    # Show top 5 trending auctions by rank ascending
    trending_sorted = sorted(trending, key=lambda x: x['rank'])[:5]
    return render_template('dashboard.html',
                           auctions=active_auctions,
                           trending=trending_sorted)


@app.route('/catalog')
def catalog():
    auctions = load_auctions()
    categories = load_categories()
    category_filter = request.args.get('category', '').strip().lower()
    search_input = request.args.get('search', '').strip().lower()

    filtered_auctions = [a for a in auctions if a['status'] == 'active']

    if category_filter:
        filtered_auctions = [a for a in filtered_auctions if a['category'].lower() == category_filter]

    if search_input:
        filtered_auctions = [a for a in filtered_auctions if search_input in a['item_name'].lower() or search_input in a['auction_id'].lower()]

    return render_template('catalog.html',
                           auctions=filtered_auctions,
                           categories=categories,
                           category_filter=category_filter,
                           search_input=search_input)


@app.route('/auction/<item_name>')
def auction_details(item_name):
    auctions = load_auctions()
    auction = next((a for a in auctions if a['item_name'].lower() == item_name.lower()), None)
    if not auction:
        abort(404, description="Auction not found")

    bids = load_bids()
    auction_bids = [b for b in bids if b['auction_id'] == auction['auction_id']]
    auction_bids_sorted = sorted(auction_bids, key=lambda x: x['bid_amount'], reverse=True)

    return render_template('auction_details.html',
                           auction=auction,
                           bids=auction_bids_sorted)


@app.route('/place_bid/<item_name>', methods=['GET', 'POST'])
def place_bid(item_name):
    auctions = load_auctions()
    auction = next((a for a in auctions if a['item_name'].lower() == item_name.lower()), None)
    if not auction:
        abort(404, description="Auction not found")

    error = None
    if request.method == 'POST':
        bidder_name = request.form.get('bidder_name', '').strip()
        bid_amount_str = request.form.get('bid_amount', '').strip()

        if not bidder_name:
            error = "Bidder name is required."
        else:
            try:
                bid_amount = float(bid_amount_str)
            except ValueError:
                error = "Invalid bid amount."
            else:
                minimum_bid = max(auction['starting_price'], auction['current_bid']) + 0.01
                if bid_amount < minimum_bid:
                    error = f"Bid must be at least {minimum_bid:.2f}."
        
        if not error:
            # Save bid
            bids = load_bids()
            bid_id = str(int(bids[-1]['bid_id']) + 1) if bids else '1'
            bid_timestamp = datetime.now()
            new_bid = {
                'bid_id': bid_id,
                'auction_id': auction['auction_id'],
                'bidder_name': bidder_name,
                'bid_amount': bid_amount,
                'bid_timestamp': bid_timestamp
            }
            save_bid(new_bid)

            # Update current bid in auctions.txt
            for a in auctions:
                if a['auction_id'] == auction['auction_id']:
                    a['current_bid'] = bid_amount
                    break
            save_auctions(auctions)

            return redirect(url_for('auction_details', item_name=item_name))

    minimum_bid = max(auction['starting_price'], auction['current_bid']) + 0.01
    return render_template('place_bid.html',
                           auction=auction,
                           minimum_bid=minimum_bid,
                           error=error)


@app.route('/history')
def bid_history():
    bids = load_bids()
    sort_by = request.args.get('sort_by', 'timestamp')
    filter_auction = request.args.get('filter_auction', '').strip()

    filtered_bids = bids
    if filter_auction:
        filtered_bids = [b for b in bids if b['auction_id'] == filter_auction]

    if sort_by == 'amount':
        filtered_bids = sorted(filtered_bids, key=lambda x: x['bid_amount'], reverse=True)
    else:
        filtered_bids = sorted(filtered_bids, key=lambda x: x['bid_timestamp'], reverse=True)

    auctions = load_auctions()
    auction_map = {a['auction_id']: a['item_name'] for a in auctions}

    # Add auction name to bids for display
    for b in filtered_bids:
        b['auction_name'] = auction_map.get(b['auction_id'], 'Unknown')

    return render_template('bid_history.html',
                           bids=filtered_bids,
                           sort_by=sort_by,
                           filter_auction=filter_auction,
                           auctions=auctions)


@app.route('/categories')
def categories():
    categories = load_categories()
    return render_template('categories.html', categories=categories)


@app.route('/category/<int:category_id>')
def category_view(category_id):
    categories = load_categories()
    category = next((c for c in categories if int(c['category_id']) == category_id), None)
    if not category:
        abort(404, description="Category not found")

    auctions = load_auctions()
    filtered_auctions = [a for a in auctions if a['category'].lower() == category['category_name'].lower() and a['status'] == 'active']

    return render_template('category_view.html',
                           category=category,
                           auctions=filtered_auctions)


@app.route('/trending')
def trending():
    trending = load_trending()
    time_range = request.args.get('time_range', 'All').lower()
    if time_range != 'all':
        filtered = [t for t in trending if t['time_period'].lower() == time_range]
    else:
        filtered = trending
    filtered_sorted = sorted(filtered, key=lambda x: x['rank'])
    return render_template('trending.html',
                           trending=filtered_sorted,
                           time_range=time_range.capitalize())


@app.route('/status')
def status():
    auctions = load_auctions()
    status_filter = request.args.get('status', 'all').lower()
    if status_filter != 'all':
        filtered_auctions = [a for a in auctions if a['status'] == status_filter]
    else:
        filtered_auctions = auctions
    filtered_sorted = sorted(filtered_auctions, key=lambda x: x['end_date'])
    return render_template('status.html',
                           auctions=filtered_sorted,
                           status_filter=status_filter)


@app.route('/refresh_status')
def refresh_status():
    # Update auction statuses based on current time
    auctions = load_auctions()
    now = datetime.now()
    updated = False
    for a in auctions:
        if a['status'] == 'active' and a['end_date'] <= now:
            a['status'] = 'closed'
            updated = True
    if updated:
        save_auctions(auctions)
    return redirect(url_for('status'))


@app.route('/winners')
def winners():
    winners = load_winners()
    filter_name = request.args.get('filter_name', '').strip().lower()
    filtered_winners = winners
    if filter_name:
        filtered_winners = [w for w in winners if filter_name in w['winner_name'].lower()]
    return render_template('winners.html',
                           winners=filtered_winners,
                           filter_name=filter_name)


if __name__ == '__main__':
    app.run(debug=True)
```
