'''
Testing Task 1: Test whether the website can be accessed through local port 5000.
Testing Task 2: Test whether the first page of the website (Dashboard) loads correctly and basic navigation buttons exist.
Testing Task 3: Test the presence and correctness of all specified elements on the Dashboard page as per requirements.
'''

import unittest
from main import app

class TestSmartHomeManagerDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access root URL and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test Task 2: Check if page title is present and correct
        response = self.client.get('/')
        self.assertIn(b'<title>Smart Home Dashboard</title>', response.data, "Dashboard page title should be 'Smart Home Dashboard'")

    def test_dashboard_elements_presence(self):
        # Test Task 3: Check presence of all required elements on Dashboard page by their IDs
        response = self.client.get('/')
        html = response.data.decode('utf-8')

        # IDs to check on Dashboard page
        required_ids = [
            'dashboard-page',
            'device-summary',
            'device-list-button',
            'add-device-button',
            'automation-button',
            'energy-button',
            'activity-button',
            'room-list'
        ]

        for element_id in required_ids:
            self.assertIn(f'id="{element_id}"', html, f"Element with ID '{element_id}' should be present on Dashboard page")

    def test_dashboard_navigation_buttons(self):
        # Test Task 2: Check that navigation buttons have correct href or form action URLs
        response = self.client.get('/')
        html = response.data.decode('utf-8')

        # Check that device-list-button navigates to /device_list
        self.assertIn('id="device-list-button"', html)
        self.assertIn('/device_list', html, "device-list-button should navigate to /device_list")

        # Check that add-device-button navigates to /add_device
        self.assertIn('id="add-device-button"', html)
        self.assertIn('/add_device', html, "add-device-button should navigate to /add_device")

        # Check that automation-button navigates to /automation_rules
        self.assertIn('id="automation-button"', html)
        self.assertIn('/automation_rules', html, "automation-button should navigate to /automation_rules")

        # Check that energy-button navigates to /energy_report
        self.assertIn('id="energy-button"', html)
        self.assertIn('/energy_report', html, "energy-button should navigate to /energy_report")

        # Check that activity-button navigates to /activity_logs
        self.assertIn('id="activity-button"', html)
        self.assertIn('/activity_logs', html, "activity-button should navigate to /activity_logs")

if __name__ == '__main__':
    unittest.main()
