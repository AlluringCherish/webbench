## Python Backend Logic (Conceptual)

```python
def load_devices(username):
    devices = []
    with open('devices.txt') as f:
        for line in f:
            fields = line.strip().split('|')
            if fields[0] == username:
                devices.append({
                    'device_id': fields[1],
                    'device_name': fields[2],
                    'device_type': fields[3],
                    'room': fields[4],
                    'status': fields[7],
                    'power': fields[8],
                    'brightness': fields[9],
                    'temperature': fields[10],
                    'mode': fields[11],
                    'schedule_time': fields[12]
                })
    return devices

def filter_automation_rules(username, trigger_type, trigger_value):
    filtered_rules = []
    with open('automation_rules.txt') as f:
        for line in f:
            fields = line.strip().split('|')
            if fields[0] == username and fields[3] == trigger_type and fields[4] == trigger_value:
                filtered_rules.append({
                    'rule_id': fields[1],
                    'rule_name': fields[2],
                    'trigger_type': fields[3],
                    'trigger_value': fields[4],
                    'action_device_id': fields[5],
                    'action_type': fields[6],
                    'action_value': fields[7],
                    'enabled': fields[8]
                })
    return filtered_rules

def get_energy_consumption(username, device_id, date):
    with open('energy_logs.txt') as f:
        for line in f:
            fields = line.strip().split('|')
            if fields[0] == username and fields[1] == device_id and fields[2] == date:
                return float(fields[3])
    return 0.0
```

