from flask import Flask, render_template, request, redirect, url_for
import os
from datetime import datetime

app = Flask(__name__)

DATA_DIR = 'data'

def load_restaurants():
    restaurants = []
    path = os.path.join(DATA_DIR, 'restaurants.txt')
    if not os.path.exists(path):
        return restaurants
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 7:
                continue
            restaurant = {
                'id': int(parts[0]),
                'name': parts[1],
                'cuisine': parts[2],
                'address': parts[3],
                'phone': parts[4],
                'rating': float(parts[5]),
                'delivery_time': int(parts[6]),
                'delivery_fee': float(parts[7]) if len(parts) > 7 else 0.0
            }
            restaurants.append(restaurant)
    return restaurants

def load_menu_items():
    items = []
    path = os.path.join(DATA_DIR, 'menu_items.txt')
    if not os.path.exists(path):
        return items
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 6:
                continue
            item = {
                'id': int(parts[0]),
                'restaurant_id': int(parts[1]),
                'name': parts[2],
                'category': parts[3],
                'description': parts[4],
                'price': float(parts[5])
            }
            items.append(item)
    return items

def load_cart():
    cart = []
    path = os.path.join(DATA_DIR, 'cart.txt')
    if not os.path.exists(path):
        return cart
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 5:
                continue
            cart_item = {
                'cart_id': int(parts[0]),
                'item_id': int(parts[1]),
                'restaurant_id': int(parts[2]),
                'quantity': int(parts[3]),
                'added_date': parts[4]
            }
            cart.append(cart_item)
    return cart

def load_orders():
    orders = []
    path = os.path.join(DATA_DIR, 'orders.txt')
    if not os.path.exists(path):
        return orders
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 8:
                continue
            order = {
                'order_id': int(parts[0]),
                'customer_name': parts[1],
                'restaurant_id': int(parts[2]),
                'order_date': parts[3],
                'total_price': float(parts[4]),
                'status': parts[5],
                'delivery_address': parts[6],
                'phone': parts[7]
            }
            orders.append(order)
    return orders

def load_order_items():
    order_items = []
    path = os.path.join(DATA_DIR, 'order_items.txt')
    if not os.path.exists(path):
        return order_items
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 5:
                continue
            oi = {
                'order_item_id': int(parts[0]),
                'order_id': int(parts[1]),
                'item_id': int(parts[2]),
                'quantity': int(parts[3]),
                'price': float(parts[4])
            }
            order_items.append(oi)
    return order_items

def load_deliveries():
    deliveries = []
    path = os.path.join(DATA_DIR, 'deliveries.txt')
    if not os.path.exists(path):
        return deliveries
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 7:
                continue
            delivery = {
                'delivery_id': int(parts[0]),
                'order_id': int(parts[1]),
                'driver_name': parts[2],
                'driver_phone': parts[3],
                'vehicle_info': parts[4],
                'status': parts[5],
                'estimated_time': parts[6]
            }
            deliveries.append(delivery)
    return deliveries

def load_reviews():
    reviews = []
    path = os.path.join(DATA_DIR, 'reviews.txt')
    if not os.path.exists(path):
        return reviews
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) < 6:
                continue
            review = {
                'review_id': int(parts[0]),
                'restaurant_id': int(parts[1]),
                'customer_name': parts[2],
                'rating': int(parts[3]),
                'review_text': parts[4],
                'review_date': parts[5]
            }
            reviews.append(review)
    return reviews

@app.route('/')
def dashboard():
    restaurants = load_restaurants()
    # For featured restaurants, pick top 3 by rating
    featured = sorted(restaurants, key=lambda r: r['rating'], reverse=True)[:3]
    return render_template('dashboard.html', featured_restaurants=featured)

@app.route('/restaurants')
def restaurants():
    cuisine_filter = request.args.get('cuisine', '')
    restaurants = load_restaurants()
    if cuisine_filter:
        restaurants = [r for r in restaurants if r['cuisine'].lower() == cuisine_filter.lower()]
    cuisines = sorted(set(r['cuisine'] for r in load_restaurants()))
    return render_template('restaurants.html', restaurants=restaurants, cuisines=cuisines, selected_cuisine=cuisine_filter)

@app.route('/menu/<int:restaurant_id>')
def menu(restaurant_id):
    restaurants = load_restaurants()
    restaurant = next((r for r in restaurants if r['id'] == restaurant_id), None)
    if not restaurant:
        return "Restaurant not found", 404
    items = [item for item in load_menu_items() if item['restaurant_id'] == restaurant_id]
    return render_template('menu.html', restaurant=restaurant, menu_items=items)

@app.route('/item/<int:item_id>')
def item(item_id):
    items = load_menu_items()
    item = next((i for i in items if i['id'] == item_id), None)
    if not item:
        return "Item not found", 404
    return render_template('item.html', item=item)

@app.route('/cart')
def cart():
    cart_items = load_cart()
    menu_items = load_menu_items()
    restaurants = load_restaurants()
    # Build detailed cart items with item info and restaurant name
    detailed_cart = []
    for c in cart_items:
        item = next((i for i in menu_items if i['id'] == c['item_id']), None)
        restaurant = next((r for r in restaurants if r['id'] == c['restaurant_id']), None)
        if item and restaurant:
            detailed_cart.append({
                'cart_id': c['cart_id'],
                'item_id': item['id'],
                'item_name': item['name'],
                'restaurant_name': restaurant['name'],
                'quantity': c['quantity'],
                'price': item['price'],
                'subtotal': item['price'] * c['quantity']
            })
    total = sum(d['subtotal'] for d in detailed_cart)
    return render_template('cart.html', cart_items=detailed_cart, total=total)

@app.route('/cart/update', methods=['POST'])
def update_cart():
    # Update quantities or remove items
    cart_items = load_cart()
    updated = []
    for c in cart_items:
        qty_str = request.form.get(f'quantity_{c["cart_id"]}')
        remove = request.form.get(f'remove_{c["cart_id"]}')
        if remove == 'on':
            continue
        try:
            qty = int(qty_str)
            if qty > 0:
                c['quantity'] = qty
                updated.append(c)
        except:
            updated.append(c)
    # Save updated cart
    path = os.path.join(DATA_DIR, 'cart.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for c in updated:
            line = f"{c['cart_id']}|{c['item_id']}|{c['restaurant_id']}|{c['quantity']}|{c['added_date']}\n"
            f.write(line)
    return redirect(url_for('cart'))

@app.route('/cart/add/<int:item_id>', methods=['POST'])
def add_to_cart(item_id):
    quantity = request.form.get('quantity', '1')
    try:
        quantity = int(quantity)
        if quantity < 1:
            quantity = 1
    except:
        quantity = 1
    menu_items = load_menu_items()
    item = next((i for i in menu_items if i['id'] == item_id), None)
    if not item:
        return "Item not found", 404
    cart_items = load_cart()
    # Check if item already in cart
    existing = next((c for c in cart_items if c['item_id'] == item_id), None)
    if existing:
        existing['quantity'] += quantity
    else:
        new_id = max([c['cart_id'] for c in cart_items], default=0) + 1
        cart_items.append({
            'cart_id': new_id,
            'item_id': item_id,
            'restaurant_id': item['restaurant_id'],
            'quantity': quantity,
            'added_date': datetime.now().strftime('%Y-%m-%d')
        })
    # Save cart
    path = os.path.join(DATA_DIR, 'cart.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for c in cart_items:
            line = f"{c['cart_id']}|{c['item_id']}|{c['restaurant_id']}|{c['quantity']}|{c['added_date']}\n"
            f.write(line)
    return redirect(url_for('cart'))

@app.route('/checkout', methods=['GET', 'POST'])
def checkout():
    if request.method == 'POST':
        customer_name = request.form.get('customer_name', '').strip()
        delivery_address = request.form.get('delivery_address', '').strip()
        phone = request.form.get('phone', '').strip()
        payment_method = request.form.get('payment_method', '').strip()
        if not (customer_name and delivery_address and phone and payment_method):
            error = "All fields are required."
            return render_template('checkout.html', error=error)
        cart_items = load_cart()
        if not cart_items:
            error = "Cart is empty."
            return render_template('checkout.html', error=error)
        menu_items = load_menu_items()
        total_price = 0.0
        # Calculate total price
        for c in cart_items:
            item = next((i for i in menu_items if i['id'] == c['item_id']), None)
            if item:
                total_price += item['price'] * c['quantity']
        # Create new order id
        orders = load_orders()
        new_order_id = max([o['order_id'] for o in orders], default=0) + 1
        # For simplicity, assign restaurant_id of first cart item
        restaurant_id = cart_items[0]['restaurant_id']
        order_date = datetime.now().strftime('%Y-%m-%d')
        new_order = {
            'order_id': new_order_id,
            'customer_name': customer_name,
            'restaurant_id': restaurant_id,
            'order_date': order_date,
            'total_price': total_price,
            'status': 'Pending',
            'delivery_address': delivery_address,
            'phone': phone
        }
        orders.append(new_order)
        # Save orders
        path_orders = os.path.join(DATA_DIR, 'orders.txt')
        with open(path_orders, 'w', encoding='utf-8') as f:
            for o in orders:
                line = f"{o['order_id']}|{o['customer_name']}|{o['restaurant_id']}|{o['order_date']}|{o['total_price']:.2f}|{o['status']}|{o['delivery_address']}|{o['phone']}\n"
                f.write(line)
        # Save order items
        order_items = load_order_items()
        new_order_item_id = max([oi['order_item_id'] for oi in order_items], default=0) + 1
        for c in cart_items:
            item = next((i for i in menu_items if i['id'] == c['item_id']), None)
            if item:
                order_items.append({
                    'order_item_id': new_order_item_id,
                    'order_id': new_order_id,
                    'item_id': item['id'],
                    'quantity': c['quantity'],
                    'price': item['price']
                })
                new_order_item_id += 1
        path_order_items = os.path.join(DATA_DIR, 'order_items.txt')
        with open(path_order_items, 'w', encoding='utf-8') as f:
            for oi in order_items:
                line = f"{oi['order_item_id']}|{oi['order_id']}|{oi['item_id']}|{oi['quantity']}|{oi['price']:.2f}\n"
                f.write(line)
        # Clear cart
        path_cart = os.path.join(DATA_DIR, 'cart.txt')
        open(path_cart, 'w').close()
        return redirect(url_for('orders'))
    else:
        return render_template('checkout.html')

@app.route('/orders')
def orders():
    orders = load_orders()
    restaurants = load_restaurants()
    status_filter = request.args.get('status', '')
    if status_filter:
        orders = [o for o in orders if o['status'].lower() == status_filter.lower()]
    for o in orders:
        r = next((r for r in restaurants if r['id'] == o['restaurant_id']), None)
        o['restaurant_name'] = r['name'] if r else 'Unknown'
    statuses = ['Pending', 'On Way', 'Delivered']
    return render_template('orders.html', orders=orders, statuses=statuses, selected_status=status_filter)

@app.route('/track/<int:order_id>')
def track(order_id):
    orders = load_orders()
    order = next((o for o in orders if o['order_id'] == order_id), None)
    if not order:
        return "Order not found", 404
    deliveries = load_deliveries()
    delivery = next((d for d in deliveries if d['order_id'] == order_id), None)
    order_items = load_order_items()
    menu_items = load_menu_items()
    items = []
    for oi in order_items:
        if oi['order_id'] == order_id:
            item = next((i for i in menu_items if i['id'] == oi['item_id']), None)
            if item:
                items.append({
                    'name': item['name'],
                    'quantity': oi['quantity'],
                    'price': oi['price']
                })
    return render_template('track.html', order=order, delivery=delivery, items=items)

@app.route('/reviews')
def reviews():
    reviews = load_reviews()
    restaurants = load_restaurants()
    rating_filter = request.args.get('rating', '')
    if rating_filter:
        try:
            rating_filter_int = int(rating_filter)
            reviews = [r for r in reviews if r['rating'] == rating_filter_int]
        except:
            pass
    for r in reviews:
        rest = next((res for res in restaurants if res['id'] == r['restaurant_id']), None)
        r['restaurant_name'] = rest['name'] if rest else 'Unknown'
    return render_template('reviews.html', reviews=reviews, selected_rating=rating_filter)

@app.route('/reviews/add', methods=['GET', 'POST'])
def add_review():
    restaurants = load_restaurants()
    if request.method == 'POST':
        restaurant_id = request.form.get('restaurant_id')
        customer_name = request.form.get('customer_name', '').strip()
        rating = request.form.get('rating')
        review_text = request.form.get('review_text', '').strip()
        if not (restaurant_id and customer_name and rating and review_text):
            error = "All fields are required."
            return render_template('add_review.html', restaurants=restaurants, error=error)
        try:
            restaurant_id = int(restaurant_id)
            rating = int(rating)
            if rating < 1 or rating > 5:
                raise ValueError
        except:
            error = "Invalid restaurant or rating."
            return render_template('add_review.html', restaurants=restaurants, error=error)
        reviews = load_reviews()
        new_review_id = max([r['review_id'] for r in reviews], default=0) + 1
        review_date = datetime.now().strftime('%Y-%m-%d')
        reviews.append({
            'review_id': new_review_id,
            'restaurant_id': restaurant_id,
            'customer_name': customer_name,
            'rating': rating,
            'review_text': review_text,
            'review_date': review_date
        })
        path = os.path.join(DATA_DIR, 'reviews.txt')
        with open(path, 'w', encoding='utf-8') as f:
            for r in reviews:
                line = f"{r['review_id']}|{r['restaurant_id']}|{r['customer_name']}|{r['rating']}|{r['review_text']}|{r['review_date']}\n"
                f.write(line)
        return redirect(url_for('reviews'))
    else:
        return render_template('add_review.html', restaurants=restaurants)

if __name__ == '__main__':
    app.run(debug=True)

