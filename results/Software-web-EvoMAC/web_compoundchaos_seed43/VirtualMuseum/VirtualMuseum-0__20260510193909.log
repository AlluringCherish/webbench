'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page, verifying the presence and correctness of the required elements:
- ID: dashboard-page (Div container)
- ID: exhibition-summary (Div summary)
- ID: artifact-catalog-button (Button)
- ID: exhibitions-button (Button)
- ID: visitor-tickets-button (Button)
- ID: virtual-events-button (Button)
- ID: audio-guides-button (Button)
'''

import unittest
import requests
from bs4 import BeautifulSoup

class TestVirtualMuseumDashboard(unittest.TestCase):
    BASE_URL = "http://127.0.0.1:5000/"

    def test_website_accessible(self):
        """Test whether the website is accessible through local port 5000 and returns status code 200."""
        try:
            response = requests.get(self.BASE_URL)
            self.assertEqual(response.status_code, 200, "Website is not accessible on port 5000 or returned non-200 status.")
        except requests.exceptions.ConnectionError as e:
            self.fail(f"Connection to the website on port 5000 failed: {e}")

    def test_dashboard_page_title(self):
        """Test whether the first page loads with correct page title 'Museum Dashboard'."""
        response = requests.get(self.BASE_URL)
        soup = BeautifulSoup(response.text, 'html.parser')
        title = soup.title.string if soup.title else ""
        self.assertIn("Museum Dashboard", title, "Dashboard page title is incorrect or missing.")

    def test_dashboard_elements_presence(self):
        """Test presence and correctness of all required elements on the Dashboard page."""
        response = requests.get(self.BASE_URL)
        soup = BeautifulSoup(response.text, 'html.parser')

        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find(id="dashboard-page")
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' not found.")

        # Check exhibition summary div
        exhibition_summary = soup.find(id="exhibition-summary")
        self.assertIsNotNone(exhibition_summary, "Exhibition summary div with id 'exhibition-summary' not found.")

        # Check buttons by id
        button_ids = [
            "artifact-catalog-button",
            "exhibitions-button",
            "visitor-tickets-button",
            "virtual-events-button",
            "audio-guides-button"
        ]
        for btn_id in button_ids:
            btn = soup.find(id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' not found.")
            self.assertEqual(btn.name, "button", f"Element with id '{btn_id}' is not a button.")

    def test_basic_navigation_links(self):
        """Test that the dashboard buttons have href or onclick attributes to navigate to other pages."""
        response = requests.get(self.BASE_URL)
        soup = BeautifulSoup(response.text, 'html.parser')

        # For each button, check if it has a link or onclick attribute for navigation
        navigation_buttons = {
            "artifact-catalog-button": ["href", "onclick"],
            "exhibitions-button": ["href", "onclick"],
            "visitor-tickets-button": ["href", "onclick"],
            "virtual-events-button": ["href", "onclick"],
            "audio-guides-button": ["href", "onclick"]
        }

        for btn_id, attrs in navigation_buttons.items():
            btn = soup.find(id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' not found for navigation test.")
            has_nav = any(btn.has_attr(attr) for attr in attrs)
            self.assertTrue(has_nav, f"Button '{btn_id}' does not have navigation attribute (href or onclick).")

if __name__ == "__main__":
    unittest.main()
```
