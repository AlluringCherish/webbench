'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence and correctness of:
- Page container (id: dashboard-page)
- Welcome message with username (id: welcome-message)
- Quick stats section (id: quick-stats)
- Create Article button (id: create-article-button)
- Recent activity feed (id: recent-activity)
'''

import unittest
from flask import Flask, session
from dashboard import dashboard_bp
from bs4 import BeautifulSoup

class DashboardPageTestCase(unittest.TestCase):
    def setUp(self):
        # Create Flask app and register blueprint
        self.app = Flask(__name__)
        self.app.secret_key = 'test_secret_key'
        self.app.register_blueprint(dashboard_bp)
        self.client = self.app.test_client()

        # Set a test username in session for welcome message
        @self.app.before_request
        def set_session_username():
            session['username'] = 'john'

    def test_server_running_and_dashboard_accessible(self):
        # Test if the /dashboard route is accessible (simulate local port 5000)
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_elements_and_content(self):
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Check page container
        container = soup.find(id='dashboard-page')
        self.assertIsNotNone(container, "Dashboard page container with id 'dashboard-page' should be present")

        # Check welcome message with username
        welcome = soup.find(id='welcome-message')
        self.assertIsNotNone(welcome, "Welcome message with id 'welcome-message' should be present")
        self.assertIn('john', welcome.text.lower(), "Welcome message should contain the username 'john'")

        # Check quick stats section
        quick_stats = soup.find(id='quick-stats')
        self.assertIsNotNone(quick_stats, "Quick stats section with id 'quick-stats' should be present")
        # Check that quick stats contain keys: total_articles, published_articles, drafts, pending_reviews
        stats_text = quick_stats.text.lower()
        self.assertIn('total', stats_text)
        self.assertIn('published', stats_text)
        self.assertIn('draft', stats_text)
        self.assertIn('pending', stats_text)

        # Check Create Article button
        create_button = soup.find(id='create-article-button')
        self.assertIsNotNone(create_button, "Create Article button with id 'create-article-button' should be present")
        self.assertIn('create', create_button.text.lower())

        # Check recent activity feed
        recent_activity = soup.find(id='recent-activity')
        self.assertIsNotNone(recent_activity, "Recent activity feed with id 'recent-activity' should be present")
        # Should contain some activity items (approval or comment)
        activity_items = recent_activity.find_all()
        self.assertGreaterEqual(len(activity_items), 0, "Recent activity feed should contain activity items or be empty")

if __name__ == '__main__':
    unittest.main()
