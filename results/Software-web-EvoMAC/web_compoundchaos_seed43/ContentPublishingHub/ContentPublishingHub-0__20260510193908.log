'''
Dashboard page template for ContentPublishingHub.
Displays welcome message, quick stats, create article button, and recent activity feed.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - ContentPublishingHub</title>
    <style>
        #dashboard-page {
            max-width: 900px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #welcome-message {
            font-size: 1.5em;
            margin-bottom: 20px;
        }
        #quick-stats {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }
        .stat-box {
            flex: 1;
            background-color: #f0f0f0;
            padding: 15px;
            border-radius: 6px;
            text-align: center;
        }
        #create-article-button {
            display: inline-block;
            margin-bottom: 30px;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
        #recent-activity {
            border-top: 1px solid #ccc;
            padding-top: 20px;
        }
        .activity-item {
            border-bottom: 1px solid #ddd;
            padding: 10px 0;
        }
        .activity-type-approval {
            color: green;
            font-weight: bold;
        }
        .activity-type-comment {
            color: #555;
        }
        .timestamp {
            color: #999;
            font-size: 0.9em;
        }
    </style>
</head>
<body>
<div id="dashboard-page">
    <div id="welcome-message">
        Welcome, {{ fullname }}!
    </div>

    <div id="quick-stats">
        <div class="stat-box">
            <div>Total Articles</div>
            <div><strong>{{ quick_stats.total_articles }}</strong></div>
        </div>
        <div class="stat-box">
            <div>Published</div>
            <div><strong>{{ quick_stats.published_articles }}</strong></div>
        </div>
        <div class="stat-box">
            <div>Drafts</div>
            <div><strong>{{ quick_stats.drafts }}</strong></div>
        </div>
        <div class="stat-box">
            <div>Pending Review</div>
            <div><strong>{{ quick_stats.pending_reviews }}</strong></div>
        </div>
    </div>

    <a href="/article/create" id="create-article-button">Create Article</a>

    <div id="recent-activity">
        <h3>Recent Activity</h3>
        {% if recent_activity %}
            {% for item in recent_activity %}
                <div class="activity-item">
                    {% if item.type == 'approval' %}
                        <div class="activity-type-approval">
                            Approval by {{ item.user }} on Article ID {{ item.article_id }} (Version {{ item.version_id }}) - Status: {{ item.status|capitalize }}
                        </div>
                        <div>Comments: {{ item.comments }}</div>
                        <div class="timestamp">{{ item.timestamp.strftime('%Y-%m-%d %H:%M:%S') }}</div>
                    {% elif item.type == 'comment' %}
                        <div class="activity-type-comment">
                            Comment by {{ item.user }} on Article ID {{ item.article_id }} (Version {{ item.version_id }})
                        </div>
                        <div>Comment: {{ item.comment_text }}</div>
                        <div class="timestamp">{{ item.timestamp.strftime('%Y-%m-%d %H:%M:%S') }}</div>
                    {% endif %}
                </div>
            {% endfor %}
        {% else %}
            <p>No recent activity.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
