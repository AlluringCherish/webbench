```python
"""
Flask routes for 'MovieTicketing' application.
This code defines the root '/' route serving the Dashboard page,
loads featured movies from 'movies.txt', and renders the dashboard.html template.
All buttons in the frontend use Flask's url_for for navigation.
"""

from flask import Flask, render_template, url_for
import os

app = Flask(__name__)

def load_featured_movies():
    featured = []
    movies_file = os.path.join(os.path.dirname(__file__), 'movies.txt')
    if os.path.exists(movies_file):
        with open(movies_file, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) < 8:
                    continue
                movie_id, title, director, genre, rating, duration, description, release_date = parts
                # For simplicity, consider all movies as featured
                featured.append({
                    'movie_id': movie_id,
                    'title': title,
                    'director': director,
                    'genre': genre,
                    'rating': rating,
                    'duration': duration,
                    'description': description,
                    'release_date': release_date
                })
    return featured

@app.route('/')
def dashboard():
    featured_movies = load_featured_movies()
    return render_template('dashboard.html', featured_movies=featured_movies)

# Additional routes for other pages should be defined similarly with descriptive names
# e.g. @app.route('/catalog'), @app.route('/movie/<movie_id>'), etc.

if __name__ == '__main__':
    app.run(debug=True)
```

