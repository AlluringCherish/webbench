</head>
<body>
    <div id="membership-page">
        <h1>Membership Plans</h1>
        <div>
            <label for="plan-filter">Filter by Membership Type:</label>
            <select id="plan-filter" onchange="filterPlans()">
                <option value="">All</option>
                <option value="Basic" {% if filter_type == 'Basic' or filter_type == 'basic' %}selected{% endif %}>Basic</option>
                <option value="Premium" {% if filter_type == 'Premium' or filter_type == 'premium' %}selected{% endif %}>Premium</option>
                <option value="Elite" {% if filter_type == 'Elite' or filter_type == 'elite' %}selected{% endif %}>Elite</option>
            </select>
        </div>
        <div id="plans-grid">
            {% for plan in memberships %}
                <div>
                    <h3>{{ plan.plan_name }}</h3>
                    <p>Price: ${{ plan.price }} / {{ plan.billing_cycle }}</p>
                    <p>Features: {{ plan.features }}</p>
                    <button id="view-details-button-{{ plan.membership_id }}" onclick="location.href='{{ url_for('plan_details', plan_id=plan.membership_id) }}'">View Details</button>
                </div>
            {% else %}
                <p>No membership plans found.</p>
            {% endfor %}
        </div>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
    <script>
        function filterPlans() {
            const filter = document.getElementById('plan-filter').value;
            let url = '{{ url_for("membership_plans") }}';
            if (filter) {
                url += '?filter=' + encodeURIComponent(filter);
            }
            window.location.href = url;
        }
    </script>
</body>
</html>
