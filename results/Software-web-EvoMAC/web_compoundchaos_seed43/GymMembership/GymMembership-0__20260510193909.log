<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Membership Plans</title>
</head>
<body>

<h1>Membership Plans</h1>

<label for="plan-filter">Type:</label>
<select id="plan-filter" onchange="filterPlans()">
    <option value="" {% if filter_type == '' %}selected{% endif %}>All</option>
    <option value="Basic" {% if filter_type.lower() == 'basic' %}selected{% endif %}>Basic</option>
    <option value="Premium" {% if filter_type.lower() == 'premium' %}selected{% endif %}>Premium</option>
    <option value="Elite" {% if filter_type.lower() == 'elite' %}selected{% endif %}>Elite</option>
</select>

<div id="plans-container">
    {% for plan in memberships %}
    <div class="plan-card">
        <h3>{{ plan.plan_name }}</h3>
        <p>Price: ${{ plan.price }} {{ plan.billing_cycle }}</p>
        <p>Features: {{ plan.features }}</p>
        <button onclick="location.href='{{ url_for('plan_details', plan_id=plan.membership_id) }}'">View Details</button>
    </div>
    <hr>
    {% else %}
    <p>No plans found.</p>
    {% endfor %}
</div>

<button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>

<script>
function filterPlans() {
    const filter = document.getElementById('plan-filter').value;
    let url = '{{ url_for("membership_plans") }}';
    if (filter) {
        url += '?filter=' + encodeURIComponent(filter);
    }
    window.location.href = url;
}
</script>

</body>
</html>
