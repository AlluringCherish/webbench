        <h3>{{ trainer.name }}</h3>
        <p>Expertise: {{ trainer.specialty }}</p>
        <button id="view-trainer-button-{{ trainer.trainer_id }}" onclick="location.href='{{ url_for('trainer_detail', trainer_id=trainer.trainer_id) }}'">View Profile</button>
    </div>
    <hr>
    {% else %}
    <p>No trainers found.</p>
    {% endfor %}
</div>

<script>
function applyFilters() {
    const search = document.getElementById('trainer-search').value.trim();
    const filter = document.getElementById('specialty-filter').value;
    let url = '{{ url_for("trainer_profiles") }}';
    let params = [];
    if (search) {
        params.push('search=' + encodeURIComponent(search));
    }
    if (filter) {
        params.push('filter=' + encodeURIComponent(filter));
    }
    if (params.length > 0) {
        url += '?' + params.join('&');
    }
    window.location.href = url;
}
</script>

</body>
</html>
