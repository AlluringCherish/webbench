'''
Main Flask application for TravelPlanner web application.
Handles routing, data loading from text files, and rendering templates.
Implements all required pages with data parsed from local text files in 'data' directory.
'''
from flask import Flask, render_template, request, redirect, url_for, send_file
import os
import datetime
import csv
import io
app = Flask(__name__)
DATA_DIR = 'data'
def parse_pipe_delimited_file(filename, fieldnames):
    filepath = os.path.join(DATA_DIR, filename)
    data = []
    if not os.path.exists(filepath):
        return data
    with open(filepath, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f, fieldnames=fieldnames, delimiter='|')
        for row in reader:
            data.append(row)
    return data
def write_pipe_delimited_file(filename, fieldnames, data):
    filepath = os.path.join(DATA_DIR, filename)
    with open(filepath, 'w', encoding='utf-8', newline='') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames, delimiter='|')
        for row in data:
            writer.writerow(row)
# Load data functions
def load_destinations():
    fieldnames = ['dest_id','name','country','region','description','attractions','climate']
    return parse_pipe_delimited_file('destinations.txt', fieldnames)
def load_itineraries():
    fieldnames = ['itinerary_id','itinerary_name','destination','start_date','end_date','activities','status']
    return parse_pipe_delimited_file('itineraries.txt', fieldnames)
def load_hotels():
    fieldnames = ['hotel_id','name','city','rating','price_per_night','amenities','category']
    return parse_pipe_delimited_file('hotels.txt', fieldnames)
def load_flights():
    fieldnames = ['flight_id','airline','departure_city','arrival_city','departure_time','arrival_time','price','class_type','duration']
    return parse_pipe_delimited_file('flights.txt', fieldnames)
def load_packages():
    fieldnames = ['package_id','package_name','destination','duration_days','price','included_items','difficulty_level']
    return parse_pipe_delimited_file('packages.txt', fieldnames)
def load_trips():
    fieldnames = ['trip_id','trip_name','destination','start_date','end_date','total_budget','status','created_date']
    return parse_pipe_delimited_file('trips.txt', fieldnames)
def load_bookings():
    fieldnames = ['booking_id','trip_id','booking_type','booking_date','amount','confirmation_number','status']
    return parse_pipe_delimited_file('bookings.txt', fieldnames)
# Helper to get next ID for new entries
def get_next_id(data, id_field):
    max_id = 0
    for item in data:
        try:
            val = int(item[id_field])
            if val > max_id:
                max_id = val
        except:
            continue
    return str(max_id + 1)
@app.route('/')
def dashboard():
    destinations = load_destinations()
    trips = load_trips()
    # Featured destinations: first 3
    featured = destinations[:3]
    # Upcoming trips: trips with start_date >= today, sorted ascending
    today = datetime.date.today()
    upcoming = []
    for trip in trips:
        try:
            sd = datetime.datetime.strptime(trip['start_date'], '%Y-%m-%d').date()
            if sd >= today:
                upcoming.append(trip)
        except:
            continue
    upcoming = sorted(upcoming, key=lambda x: x['start_date'])[:3]
    return render_template('dashboard.html',
                           featured_destinations=featured,
                           upcoming_trips=upcoming)
@app.route('/destinations', methods=['GET'])
def destinations():
    destinations = load_destinations()
    search_query = request.args.get('search', '').strip().lower()
    region_filter = request.args.get('region', '')
    filtered = []
    for dest in destinations:
        if search_query:
            if search_query not in dest['name'].lower() and search_query not in dest['country'].lower():
                continue
        if region_filter and region_filter != 'All':
            if dest['region'] != region_filter:
                continue
        filtered.append(dest)
    return render_template('destinations.html',
                           destinations=filtered,
                           search_query=search_query,
                           region_filter=region_filter)
@app.route('/destination/<dest_id>', methods=['GET', 'POST'])
def destination_details(dest_id):
    destinations = load_destinations()
    destination = None
    for d in destinations:
        if d['dest_id'] == dest_id:
            destination = d
            break
    if not destination:
        return "Destination not found", 404
    if request.method == 'POST':
        # Add to trip functionality: redirect to itinerary planning page with destination pre-selected
        return redirect(url_for('itinerary_planning', preselect_destination=destination['name']))
    return render_template('destination_details.html', destination=destination)
@app.route('/itinerary', methods=['GET', 'POST'])
def itinerary_planning():
    itineraries = load_itineraries()
    preselect_destination = request.args.get('preselect_destination', '')
    if request.method == 'POST':
        itinerary_name = request.form.get('itinerary_name', '').strip()
        destination = request.form.get('destination', '').strip()
        start_date = request.form.get('start_date', '').strip()
        end_date = request.form.get('end_date', '').strip()
        activities = request.form.get('activities', '').strip()
        status = request.form.get('status', 'Planned').strip()
        if not itinerary_name or not destination or not start_date or not end_date:
            error = "Please fill in all required fields."
            return render_template('itinerary.html', itineraries=itineraries, error=error, preselect_destination=preselect_destination)
        new_id = get_next_id(itineraries, 'itinerary_id')
        new_itinerary = {
            'itinerary_id': new_id,
            'itinerary_name': itinerary_name,
            'destination': destination,
            'start_date': start_date,
            'end_date': end_date,
            'activities': activities,
            'status': status
        }
        itineraries.append(new_itinerary)
        write_pipe_delimited_file('itineraries.txt',
                                  ['itinerary_id','itinerary_name','destination','start_date','end_date','activities','status'],
                                  itineraries)
        return redirect(url_for('itinerary_planning'))
    return render_template('itinerary.html', itineraries=itineraries, preselect_destination=preselect_destination)
@app.route('/accommodations', methods=['GET'])
def accommodations():
    hotels = load_hotels()
    destination_input = request.args.get('destination', '').strip().lower()
    check_in_date = request.args.get('check_in_date', '')
    check_out_date = request.args.get('check_out_date', '')
    price_filter = request.args.get('price_filter', '')
    filtered = []
    for hotel in hotels:
        if destination_input and destination_input not in hotel['city'].lower():
            continue
        if price_filter and price_filter != 'All':
            if hotel['category'].lower() != price_filter.lower():
                continue
        filtered.append(hotel)
    return render_template('accommodations.html',
                           hotels=filtered,
                           destination_input=destination_input,
                           check_in_date=check_in_date,
                           check_out_date=check_out_date,
                           price_filter=price_filter)
@app.route('/transportation', methods=['GET'])
def transportation():
    flights = load_flights()
    departure_city = request.args.get('departure_city', '').strip().lower()
    arrival_city = request.args.get('arrival_city', '').strip().lower()
    departure_date = request.args.get('departure_date', '')
    flight_class_filter = request.args.get('flight_class_filter', '')
    filtered = []
    for flight in flights:
        if departure_city and departure_city not in flight['departure_city'].lower():
            continue
        if arrival_city and arrival_city not in flight['arrival_city'].lower():
            continue
        if flight_class_filter and flight_class_filter != 'All':
            if flight['class_type'].lower() != flight_class_filter.lower():
                continue
        filtered.append(flight)
    return render_template('transportation.html',
                           flights=filtered,
                           departure_city=departure_city,
                           arrival_city=arrival_city,
                           departure_date=departure_date,
                           flight_class_filter=flight_class_filter)
@app.route('/packages', methods=['GET'])
def packages():
    packages = load_packages()
    duration_filter = request.args.get('duration_filter', '')
    filtered = []
    for pkg in packages:
        if duration_filter and duration_filter != 'All':
            try:
                dur = int(pkg['duration_days'])
                if duration_filter == '3-5 days' and not (3 <= dur <= 5):
                    continue
                elif duration_filter == '7-10 days' and not (7 <= dur <= 10):
                    continue
                elif duration_filter == '14+ days' and dur < 14:
                    continue
            except:
                continue
        filtered.append(pkg)
    return render_template('packages.html',
                           packages=filtered,
                           duration_filter=duration_filter)
@app.route('/book_package/<pkg_id>', methods=['POST'])
def book_package(pkg_id):
    packages = load_packages()
    package = None
    for pkg in packages:
        if pkg['package_id'] == pkg_id:
            package = pkg
            break
    if not package:
        return "Package not found", 404
    trips = load_trips()
    new_trip_id = get_next_id(trips, 'trip_id')
    today_str = datetime.date.today().strftime('%Y-%m-%d')
    new_trip = {
        'trip_id': new_trip_id,
        'trip_name': package['package_name'],
        'destination': package['destination'],
        'start_date': '',
        'end_date': '',
        'total_budget': package['price'],
        'status': 'Pending',
        'created_date': today_str
    }
    trips.append(new_trip)
    write_pipe_delimited_file('trips.txt',
                              ['trip_id','trip_name','destination','start_date','end_date','total_budget','status','created_date'],
                              trips)
    return redirect(url_for('trip_management'))
@app.route('/trips', methods=['GET'])
def trip_management():
    trips = load_trips()
    return render_template('trips.html', trips=trips)
@app.route('/trip/<trip_id>', methods=['GET'])
def trip_details(trip_id):
    trips = load_trips()
    trip = None
    for t in trips:
        if t['trip_id'] == trip_id:
            trip = t
            break
    if not trip:
        return "Trip not found", 404
    bookings = load_bookings()
    trip_bookings = [b for b in bookings if b['trip_id'] == trip_id]
    return render_template('trip_details.html', trip=trip, bookings=trip_bookings)
@app.route('/trip/edit/<trip_id>', methods=['GET', 'POST'])
def edit_trip(trip_id):
    trips = load_trips()
    trip = None
    for t in trips:
        if t['trip_id'] == trip_id:
            trip = t
            break
    if not trip:
        return "Trip not found", 404
    if request.method == 'POST':
        trip_name = request.form.get('trip_name', '').strip()
        destination = request.form.get('destination', '').strip()
        start_date = request.form.get('start_date', '').strip()
        end_date = request.form.get('end_date', '').strip()
        total_budget = request.form.get('total_budget', '').strip()
        status = request.form.get('status', '').strip()
        if not trip_name or not destination or not start_date or not end_date or not total_budget or not status:
            error = "Please fill in all required fields."
            return render_template('edit_trip.html', trip=trip, error=error)
        trip['trip_name'] = trip_name
        trip['destination'] = destination
        trip['start_date'] = start_date
        trip['end_date'] = end_date
        trip['total_budget'] = total_budget
        trip['status'] = status
        write_pipe_delimited_file('trips.txt',
                                  ['trip_id','trip_name','destination','start_date','end_date','total_budget','status','created_date'],
                                  trips)
        return redirect(url_for('trip_management'))
    return render_template('edit_trip.html', trip=trip)
@app.route('/trip/delete/<trip_id>', methods=['POST'])
def delete_trip(trip_id):
    trips = load_trips()
    trips = [t for t in trips if t['trip_id'] != trip_id]
    write_pipe_delimited_file('trips.txt',
                              ['trip_id','trip_name','destination','start_date','end_date','total_budget','status','created_date'],
                              trips)
    return redirect(url_for('trip_management'))
@app.route('/booking_confirmation/<booking_id>', methods=['GET'])
def booking_confirmation(booking_id):
    bookings = load_bookings()
    booking = None
    for b in bookings:
        if b['booking_id'] == booking_id:
            booking = b
            break
    if not booking:
        return "Booking not found", 404
    trips = load_trips()
    trip = None
    for t in trips:
        if t['trip_id'] == booking['trip_id']:
            trip = t
            break
    return render_template('booking_confirmation.html', booking=booking, trip=trip)
@app.route('/download_itinerary/<trip_id>', methods=['GET'])
def download_itinerary(trip_id):
    itineraries = load_itineraries()
    trip_itineraries = [i for i in itineraries if i['destination'] == '']  # No direct link, so just empty list
    # For demo, generate a simple text file with itinerary info
    output = io.StringIO()
    output.write(f"Trip Itinerary for Trip ID: {trip_id}\n\n")
    for i in itineraries:
        if i['itinerary_id'] == trip_id:
            output.write(f"Name: {i['itinerary_name']}\n")
            output.write(f"Destination: {i['destination']}\n")
            output.write(f"Start Date: {i['start_date']}\n")
            output.write(f"End Date: {i['end_date']}\n")
            output.write(f"Activities: {i['activities']}\n")
            output.write(f"Status: {i['status']}\n\n")
    output.seek(0)
    return send_file(io.BytesIO(output.getvalue().encode('utf-8')),
                     mimetype='text/plain',
                     as_attachment=True,
                     download_name=f'itinerary_{trip_id}.txt')
@app.route('/recommendations', methods=['GET'])
def recommendations():
    destinations = load_destinations()
    season_filter = request.args.get('season', '')
    budget_filter = request.args.get('budget', '')
    # For demo, trending destinations are first 3 sorted by dest_id
    trending = sorted(destinations, key=lambda x: int(x['dest_id']))[:3]
    # Filtering logic for season and budget is not specified in data, so just pass filters
    return render_template('recommendations.html',
                           trending_destinations=trending,
                           season_filter=season_filter,
                           budget_filter=budget_filter)
if __name__ == '__main__':
    app.run(debug=True)
