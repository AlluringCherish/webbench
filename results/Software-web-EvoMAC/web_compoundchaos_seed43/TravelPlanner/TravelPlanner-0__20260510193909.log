            output.write(f"Status: {i['status']}\n\n")
    output.seek(0)
    return send_file(io.BytesIO(output.getvalue().encode('utf-8')),
                     mimetype='text/plain',
                     as_attachment=True,
                     download_name=f'itinerary_{trip_id}.txt')
@app.route('/recommendations', methods=['GET'])
def recommendations():
    destinations = load_destinations()
    season_filter = request.args.get('season', '')
    budget_filter = request.args.get('budget', '')
    # For demo, trending destinations are first 3 sorted by dest_id
    trending = sorted(destinations, key=lambda x: int(x['dest_id']))[:3]
    # Filtering logic for season and budget is not specified in data, so just pass filters
    return render_template('recommendations.html',
                           trending_destinations=trending,
                           season_filter=season_filter,
                           budget_filter=budget_filter)
if __name__ == '__main__':
    app.run(debug=True)
