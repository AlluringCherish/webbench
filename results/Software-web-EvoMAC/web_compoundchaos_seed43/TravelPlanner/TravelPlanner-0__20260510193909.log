        function confirmDelete(tripId) {
            if (confirm("Are you sure you want to delete this trip?")) {
                document.getElementById('delete-form-' + tripId).submit();
            }
        }
    </script>
</head>
<body>
<div id="trips-page">
    <h1>My Trips</h1>

    <table id="trips-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Trip Name</th>
                <th>Destination</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for trip in trips %}
            <tr>
                <td>{{ trip.trip_name }}</td>
                <td>{{ trip.destination }}</td>
                <td>{{ trip.start_date }}</td>
                <td>{{ trip.end_date }}</td>
                <td>{{ trip.status }}</td>
                <td>
                    <form action="{{ url_for('trip_details', trip_id=trip.trip_id) }}" method="get" style="display:inline;">
                        <button type="submit" id="view-trip-details-button-{{ trip.trip_id }}">View</button>
                    </form>
                    <form action="{{ url_for('edit_trip', trip_id=trip.trip_id) }}" method="get" style="display:inline;">
                        <button type="submit" id="edit-trip-button-{{ trip.trip_id }}">Edit</button>
                    </form>
                    <form id="delete-form-{{ trip.trip_id }}" action="{{ url_for('delete_trip', trip_id=trip.trip_id) }}" method="post" style="display:inline;">
                        <button type="button" id="delete-trip-button-{{ trip.trip_id }}" onclick="confirmDelete('{{ trip.trip_id }}')">Delete</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6">No trips found.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
