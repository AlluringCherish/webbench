            <option value="Pending" {% if trip.status == 'Pending' %}selected{% endif %}>Pending</option>
            <option value="Planned" {% if trip.status == 'Planned' %}selected{% endif %}>Planned</option>
            <option value="Booked" {% if trip.status == 'Booked' %}selected{% endif %}>Booked</option>
            <option value="Completed" {% if trip.status == 'Completed' %}selected{% endif %}>Completed</option>
        </select><br>

        <button type="submit">Save Changes</button>
    </form>

    <button onclick="location.href='{{ url_for('trip_management') }}'">Back to My Trips</button>
</div>
</body>
</html>
```

templates/booking_confirmation.html
```html
'''
Booking Confirmation page template for TravelPlanner.
Displays booking confirmation details with options to download itinerary and share trip.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking Confirmation</title>
</head>
<body>
<div id="confirmation-page">
    <h1>Booking Confirmation</h1>

    <div id="confirmation-number"><strong>Confirmation Number:</strong> {{ booking.confirmation_number }}</div>
    <div id="booking-details">
        <p><strong>Booking Type:</strong> {{ booking.booking_type }}</p>
        <p><strong>Booking Date:</strong> {{ booking.booking_date }}</p>
        <p><strong>Amount:</strong> ${{ booking.amount }}</p>
        <p><strong>Status:</strong> {{ booking.status }}</p>
        {% if trip %}
        <p><strong>Trip Name:</strong> {{ trip.trip_name }}</p>
        <p><strong>Destination:</strong> {{ trip.destination }}</p>
        <p><strong>Trip Dates:</strong> {{ trip.start_date }} to {{ trip.end_date }}</p>
        {% endif %}
    </div>

    <button id="download-itinerary-button" onclick="location.href='{{ url_for('download_itinerary', trip_id=booking.trip_id) }}'">Download Itinerary</button>
    <button id="share-trip-button" onclick="alert('Sharing functionality is not implemented yet.')">Share Trip</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/recommendations.html
```html
'''
Travel Recommendations page template for TravelPlanner.
Displays personalized travel recommendations and trending destinations with filters.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Travel Recommendations</title>
</head>
<body>
<div id="recommendations-page">
    <h1>Travel Recommendations</h1>

    <form method="get" action="{{ url_for('recommendations') }}">
        <label for="recommendation-season-filter">Travel Season:</label>
        <select id="recommendation-season-filter" name="season">
            <option value="" {% if not season_filter %}selected{% endif %}>All</option>
            <option value="Spring" {% if season_filter == 'Spring' %}selected{% endif %}>Spring</option>
            <option value="Summer" {% if season_filter == 'Summer' %}selected{% endif %}>Summer</option>
            <option value="Fall" {% if season_filter == 'Fall' %}selected{% endif %}>Fall</option>
            <option value="Winter" {% if season_filter == 'Winter' %}selected{% endif %}>Winter</option>
        </select>

        <label for="budget-filter">Budget Range:</label>
        <select id="budget-filter" name="budget">
            <option value="" {% if not budget_filter %}selected{% endif %}>All</option>
            <option value="Low" {% if budget_filter == 'Low' %}selected{% endif %}>Low</option>
            <option value="Medium" {% if budget_filter == 'Medium' %}selected{% endif %}>Medium</option>
            <option value="High" {% if budget_filter == 'High' %}selected{% endif %}>High</option>
        </select>

        <button type="submit">Filter</button>
    </form>

    <div id="trending-destinations">
        <h2>Trending Destinations</h2>
        <ol id="trending-destinations-list">
            {% for dest in trending_destinations %}
            <li>{{ dest.name }} - {{ dest.country }}</li>
            {% else %}
            <li>No trending destinations available.</li>
            {% endfor %}
        </ol>
    </div>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
