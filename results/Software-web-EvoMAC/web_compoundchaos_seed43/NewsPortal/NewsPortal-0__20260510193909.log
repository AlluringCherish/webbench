```html
'''
Dashboard page template for NewsPortal.
Displays featured articles, trending news, and navigation buttons.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>News Portal</title>
    <style>
        #dashboard-page { padding: 20px; font-family: Arial, sans-serif; }
        #featured-articles { margin-bottom: 20px; }
        .article-card { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }
        button { margin-right: 10px; padding: 10px 15px; }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1>News Portal</h1>
    <div id="featured-articles">
        <h2>Featured Articles</h2>
        {% if featured_articles %}
            {% for article in featured_articles %}
                <div class="article-card">
                    <h3>{{ article.title }}</h3>
                    <p><strong>Author:</strong> {{ article.author }}</p>
                    <p><strong>Date:</strong> {{ article.date }}</p>
                    <form action="{{ url_for('article_details', article_id=article.article_id) }}" method="get">
                        <button type="submit">Read More</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No featured articles available.</p>
        {% endif %}
    </div>
    <div id="trending-articles">
        <h2>Trending News</h2>
        {% if trending %}
            <ul>
                {% for item in trending %}
                    <li>
                        <strong>{{ item.article_title }}</strong> ({{ item.category }}) - Views: {{ item.view_count }}
                        <form style="display:inline" action="{{ url_for('article_details', article_id=item.article_id) }}" method="get">
                            <button type="submit">View</button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No trending articles available.</p>
        {% endif %}
    </div>
    <div id="navigation-buttons">
        <form action="{{ url_for('go_to_catalog') }}" method="post" style="display:inline;">
            <button id="browse-articles-button" type="submit">Browse Articles</button>
        </form>
        <form action="{{ url_for('go_to_bookmarks') }}" method="post" style="display:inline;">
            <button id="view-bookmarks-button" type="submit">View Bookmarks</button>
        </form>
        <form action="{{ url_for('go_to_trending') }}" method="post" style="display:inline;">
            <button id="trending-articles-button" type="submit">Trending Articles</button>
        </form>
    </div>
</div>
</body>
</html>
