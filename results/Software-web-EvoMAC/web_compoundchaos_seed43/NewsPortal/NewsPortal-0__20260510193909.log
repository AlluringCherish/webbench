        #catalog-page { padding: 20px; font-family: Arial, sans-serif; }
        #articles-grid { display: flex; flex-wrap: wrap; gap: 15px; }
        .article-card { border: 1px solid #ccc; padding: 10px; width: 300px; }
        button { margin-top: 10px; }
        #search-input, #category-filter { padding: 5px; margin-right: 10px; }
    </style>
</head>
