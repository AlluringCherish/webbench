                    <p><strong>Date:</strong> {{ article.date }}</p>
                    <form action="{{ url_for('article_details', article_id=article.article_id) }}" method="get">
                        <button id="view-article-button-{{ article.article_id }}" type="submit">View Article</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No articles found.</p>
        {% endif %}
    </div>
    <form action="{{ url_for('back_to_dashboard') }}" method="post">
        <button type="submit">Back to Dashboard</button>
    </form>
</div>
</body>
</html>
