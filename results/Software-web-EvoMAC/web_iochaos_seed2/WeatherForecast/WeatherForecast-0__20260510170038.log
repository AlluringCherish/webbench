weekly_forecast.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weekly Forecast</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <style>
        #forecast-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
        }
        .forecast-card {
            border: 1px solid #ccc;
            padding: 0.5rem;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
    </style>
</head>
<body>
<div id="forecast-page">
    <h1>Weekly Forecast</h1>
    <form method="post" action="{{ url_for('weekly_forecast') }}">
        <label for="location-filter">Select Location:</label>
        <select id="location-filter" name="location_filter" onchange="this.form.submit()">
            {% for loc in locations %}
                <option value="{{ loc.location_id }}" {% if loc.location_id == selected_location_id %}selected{% endif %}>{{ loc.location_name }}</option>
            {% endfor %}
        </select>
    </form>
    <table id="forecast-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Date</th>
                <th>High Temp</th>
                <th>Low Temp</th>
                <th>Condition</th>
            </tr>
        </thead>
        <tbody>
            {% for f in forecasts %}
            <tr>
                <td>{{ f.date }}</td>
                <td>{{ f.high_temp }}</td>
                <td>{{ f.low_temp }}</td>
                <td>{{ f.condition }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <div id="forecast-list">
        {% for f in forecasts %}
        <div class="forecast-card">
            <strong>{{ f.date }}</strong><br>
            High: {{ f.high_temp }}<br>
            Low: {{ f.low_temp }}<br>
            Condition: {{ f.condition }}<br>
            Precipitation: {{ f.precipitation }}%<br>
            Humidity: {{ f.humidity }}%
        </div>
        {% endfor %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

location_search.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Locations</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="search-page">
    <h1>Search Locations</h1>
    <form method="post" action="{{ url_for('location_search') }}">
        <input type="text" id="location-search-input" name="location_search_input" placeholder="Enter city name or coordinates" value="{{ search_query }}">
        <button type="submit">Search</button>
    </form>
    <div id="search-results">
        <h2>Search Results</h2>
        {% if search_results %}
            <ul>
                {% for loc in search_results %}
                <li>
                    {{ loc.location_name }} ({{ loc.latitude }}, {{ loc.longitude }})
                    <form method="post" action="{{ url_for('select_location', location_id=loc.location_id) }}" style="display:inline;">
                        <button type="submit" id="select-location-button-{{ loc.location_id }}">Select</button>
                    </form>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No matching locations found.</p>
        {% endif %}
    </div>
    <div id="saved-locations-list">
        <h2>Saved Locations</h2>
        {% if saved_locations %}
            <ul>
                {% for loc in saved_locations %}
                <li>{{ loc.location_name }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No saved locations.</p>
        {% endif %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
