'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) can be accessed and loads correctly.
Test basic navigation from Dashboard to Location Search, Weekly Forecast, and Weather Alerts pages.
'''
import unittest
from main import app

class WeatherForecastBasicAccessTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page loads successfully
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Weather Dashboard', response.data)
        self.assertIn(b'id="dashboard-page"', response.data)
        # Check presence of main buttons by their IDs
        self.assertIn(b'id="search-location-button"', response.data)
        self.assertIn(b'id="view-forecast-button"', response.data)
        self.assertIn(b'id="view-alerts-button"', response.data)

    def test_navigation_to_location_search(self):
        # Test navigation link/button to location search page from dashboard
        response = self.client.get('/location_search')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Search Locations', response.data)
        self.assertIn(b'id="search-page"', response.data)
        self.assertIn(b'id="location-search-input"', response.data)

    def test_navigation_to_weekly_forecast(self):
        # Test navigation link/button to weekly forecast page from dashboard
        response = self.client.get('/weekly_forecast')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Weekly Forecast', response.data)
        self.assertIn(b'id="forecast-page"', response.data)
        self.assertIn(b'id="location-filter"', response.data)
        self.assertIn(b'id="forecast-table"', response.data)

    def test_navigation_to_weather_alerts(self):
        # Test navigation link/button to weather alerts page from dashboard
        response = self.client.get('/weather_alerts')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Weather Alerts', response.data)
        self.assertIn(b'id="alerts-page"', response.data)
        self.assertIn(b'id="alerts-list"', response.data)
        self.assertIn(b'id="severity-filter"', response.data)
        self.assertIn(b'id="location-filter-alerts"', response.data)

if __name__ == '__main__':
    unittest.main()
