                'pm25': aqi['pm25'],
                'pm10': aqi['pm10'],
                'no2': aqi['no2'],
                'o3': aqi['o3'],
                'last_updated': aqi['last_updated'],
                'health_recommendation': health_rec
            }
    return render_template('air_quality.html',
