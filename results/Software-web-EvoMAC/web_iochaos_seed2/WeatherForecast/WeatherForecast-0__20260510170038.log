<head>
    <meta charset="UTF-8">
    <title>Current Weather</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="current-weather-page">
    <h1 id="location-name">{{ location_name }}</h1>
    {% if weather %}
        <div id="temperature-display">Temperature: {{ weather.temperature }}</div>
        <div id="weather-condition">Condition: {{ weather.condition }}</div>
        <div id="humidity-info">Humidity: {{ weather.humidity }}%</div>
        <div id="wind-speed-info">Wind Speed: {{ weather.wind_speed }} mph</div>
    {% else %}
        <p>No current weather data available for this location.</p>
    {% endif %}
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
