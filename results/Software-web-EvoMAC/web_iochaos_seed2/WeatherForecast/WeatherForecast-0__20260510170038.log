styles.css
```css
/*
CSS styles for WeatherForecast web application
Ensures consistent UI design across all pages
*/
/* Reset some default styles */
body, h1, h2, h3, p, ul, li, table, th, td, button, input, select, form, div {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}
/* Body and container styling */
body {
    background-color: #e6f0ff;
    color: #333;
    line-height: 1.5;
    padding: 20px;
    min-height: 100vh;
}
/* Page container divs */
#dashboard-page,
#current-weather-page,
#forecast-page,
#search-page,
#alerts-page,
#air-quality-page,
