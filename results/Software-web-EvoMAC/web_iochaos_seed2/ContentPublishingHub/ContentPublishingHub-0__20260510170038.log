}
.flash-message.error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
/* Form inputs and textareas */
input[type="text"],
input[type="email"],
textarea,
select {
    width: 100%;
    padding: 8px 12px;
    margin: 6px 0 16px 0;
