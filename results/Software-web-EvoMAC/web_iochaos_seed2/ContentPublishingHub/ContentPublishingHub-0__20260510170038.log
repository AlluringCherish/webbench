    color: #444;
}
.recent-activity ul li a {
    color: #2980b9;
    text-decoration: none;
    font-weight: 600;
}
.recent-activity ul li a:hover,
.recent-activity ul li a:focus {
    text-decoration: underline;
    outline: none;
}
.recent-activity em {
    color: #888;
    font-style: normal;
    font-size: 0.85rem;
    margin-left: 6px;
}
/* Flash messages */
.flash-message {
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 4px;
    font-weight: 600;
}
.flash-message.success {
    background-color: #d4edda;
    color: #155724;
