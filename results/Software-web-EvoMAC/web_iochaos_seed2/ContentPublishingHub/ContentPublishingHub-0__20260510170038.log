}
table th {
    background-color: #3498db;
    color: white;
    font-weight: 700;
}
table tr:nth-child(even) {
    background-color: #f2f2f2;
}
/* Dropdowns */
select {
    max-width: 250px;
}
/* Responsive */
@media (max-width: 600px) {
    .quick-stats ul {
        flex-direction: column;
    }
    .quick-stats ul li {
        min-width: auto;
        width: 100%;
        margin-bottom: 10px;
    }
}
