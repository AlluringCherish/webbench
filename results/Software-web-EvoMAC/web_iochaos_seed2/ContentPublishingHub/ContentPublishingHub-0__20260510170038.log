    background-color: #2980b9;
    outline: none;
}
/* Actions Section */
.actions {
    margin: 20px 0 30px 0;
}
/* Recent Activity Section */
.recent-activity h2 {
    font-size: 1.5rem;
    margin-bottom: 12px;
    color: #34495e;
    border-bottom: 2px solid #3498db;
    padding-bottom: 6px;
}
