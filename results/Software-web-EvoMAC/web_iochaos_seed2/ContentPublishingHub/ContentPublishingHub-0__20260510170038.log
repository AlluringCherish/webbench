/*
Stylesheet for ContentPublishingHub
Provides consistent UI styling across all pages
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}
.page-container {
    max-width: 960px;
    margin: 20px auto 40px auto;
    background-color: #fff;
    padding: 20px 30px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
/* Header */
header h1 {
    font-size: 2rem;
    color: #2c3e50;
    margin-bottom: 8px;
}
#welcome-message {
    font-size: 1.1rem;
    color: #555;
    margin-bottom: 20px;
}
/* Quick Stats Section */
.quick-stats h2 {
    font-size: 1.5rem;
    margin-bottom: 12px;
    color: #34495e;
    border-bottom: 2px solid #3498db;
    padding-bottom: 6px;
}
.quick-stats ul {
    list-style: none;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}
.quick-stats ul li {
    background-color: #ecf0f1;
    padding: 10px 15px;
    border-radius: 4px;
    font-weight: 600;
    color: #2c3e50;
    min-width: 140px;
    text-align: center;
    box-shadow: inset 0 -2px 0 #3498db;
}
/* Buttons */
.button {
    display: inline-block;
    background-color: #3498db;
    color: white;
    padding: 10px 18px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
    cursor: pointer;
    border: none;
    font-size: 1rem;
    user-select: none;
}
.button:hover,
.button:focus {
    background-color: #2980b9;
    outline: none;
}
/* Actions Section */
.actions {
    margin: 20px 0 30px 0;
}
/* Recent Activity Section */
.recent-activity h2 {
    font-size: 1.5rem;
    margin-bottom: 12px;
    color: #34495e;
    border-bottom: 2px solid #3498db;
    padding-bottom: 6px;
}
.recent-activity ul {
    list-style: none;
    max-height: 300px;
    overflow-y: auto;
    padding-right: 10px;
}
.recent-activity ul li {
    padding: 10px 12px;
    border-bottom: 1px solid #ddd;
    font-size: 0.95rem;
    color: #444;
}
.recent-activity ul li a {
    color: #2980b9;
    text-decoration: none;
    font-weight: 600;
}
.recent-activity ul li a:hover,
.recent-activity ul li a:focus {
    text-decoration: underline;
    outline: none;
}
.recent-activity em {
    color: #888;
    font-style: normal;
    font-size: 0.85rem;
    margin-left: 6px;
}
/* Flash messages */
.flash-message {
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 4px;
    font-weight: 600;
}
.flash-message.success {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}
.flash-message.error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
/* Form inputs and textareas */
input[type="text"],
input[type="email"],
textarea,
select {
    width: 100%;
    padding: 8px 12px;
    margin: 6px 0 16px 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    font-family: inherit;
    resize: vertical;
    transition: border-color 0.3s ease;
}
input[type="text"]:focus,
input[type="email"]:focus,
textarea:focus,
select:focus {
    border-color: #3498db;
    outline: none;
}
/* Textarea specific */
textarea {
    min-height: 150px;
}
/* Labels */
label {
    font-weight: 600;
    color: #2c3e50;
    display: block;
    margin-bottom: 4px;
}
/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
}
table th,
table td {
    border: 1px solid #ddd;
    padding: 10px 12px;
