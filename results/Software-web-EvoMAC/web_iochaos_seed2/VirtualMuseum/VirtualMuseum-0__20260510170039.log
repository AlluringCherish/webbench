                        'start_date': parts[5],
                        'end_date': parts[6],
                        'curator_name': parts[7],
                        'created_by': parts[8]
                    })
    return exhibitions
def read_artifacts():
    path = os.path.join(DATA_DIR, 'artifacts.txt')
    artifacts = []
    if os.path.exists(path):
        with open(path, 'r', encoding='utf-8') as f:
            for line in f:
                line=line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 9:
                    artifacts.append({
                        'artifact_id': parts[0],
