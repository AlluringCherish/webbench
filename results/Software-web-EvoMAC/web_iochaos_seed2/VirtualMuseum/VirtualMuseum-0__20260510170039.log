                        'period': parts[2],
                        'origin': parts[3],
                        'description': parts[4],
                        'exhibition_id': parts[5],
                        'storage_location': parts[6],
                        'acquisition_date': parts[7],
                        'added_by': parts[8]
                    })
    return artifacts
def read_audioguides():
    path = os.path.join(DATA_DIR, 'audioguides.txt')
    guides = []
    if os.path.exists(path):
        with open(path, 'r', encoding='utf-8') as f:
            for line in f:
                line=line.strip()
                if not line:
                    continue
                parts = line.split('|')
                if len(parts) == 8:
                    guides.append({
                        'guide_id': parts[0],
