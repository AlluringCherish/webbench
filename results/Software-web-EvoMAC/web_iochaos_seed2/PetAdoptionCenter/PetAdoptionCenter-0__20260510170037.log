            <button type="submit" id="submit-application-button">Submit Application</button>
            <button type="button" id="back-to-pet" onclick="location.href='{{ url_for('pet_details', pet_id=pet.pet_id) }}'">Back to Pet Details</button>
        </form>
    </div>
</body>
</html>
