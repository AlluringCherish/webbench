                <option value="Bird" {% if filter_species == 'Bird' %}selected{% endif %}>Bird</option>
                <option value="Rabbit" {% if filter_species == 'Rabbit' %}selected{% endif %}>Rabbit</option>
                <option value="Other" {% if filter_species == 'Other' %}selected{% endif %}>Other</option>
            </select>
            <button onclick="applyFilters()">Search</button>
        </div>
