        function applyFilters() {
            const species = document.getElementById('filter-species').value;
            const search = document.getElementById('search-input').value;
            const params = new URLSearchParams();
            if (species) params.append('filter-species', species);
            if (search) params.append('search-input', search);
            window.location.href = '{{ url_for("pet_listings") }}' + '?' + params.toString();
        }
    </script>
