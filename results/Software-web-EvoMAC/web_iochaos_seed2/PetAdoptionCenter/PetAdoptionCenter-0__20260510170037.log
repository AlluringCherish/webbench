<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Pet Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="pet-details-page">
        <h1 id="pet-name">{{ pet.name }}</h1>
        <div id="pet-species"><strong>Species:</strong> {{ pet.species }}</div>
        <div id="pet-description"><strong>Description:</strong> {{ pet.description }}</div>
        <div><strong>Breed:</strong> {{ pet.breed }}</div>
        <div><strong>Age:</strong> {{ pet.age }}</div>
        <div><strong>Gender:</strong> {{ pet.gender }}</div>
        <div><strong>Size:</strong> {{ pet.size }}</div>
        <div><strong>Status:</strong> {{ pet.status }}</div>
        {% if pet.status == 'Available' %}
            <button id="adopt-button" onclick="location.href='{{ url_for('adoption_application', pet_id=pet.pet_id) }}'">Adopt</button>
        {% else %}
            <p>This pet is currently not available for adoption.</p>
        {% endif %}
        <button id="back-to-listings" onclick="location.href='{{ url_for('pet_listings') }}'">Back to Listings</button>
    </div>
</body>
</html>
