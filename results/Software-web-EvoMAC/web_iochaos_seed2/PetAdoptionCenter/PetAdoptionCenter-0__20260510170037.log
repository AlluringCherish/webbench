                    })
    return pets
def write_pets(pets):
    path = os.path.join(DATA_DIR, 'pets.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for p in pets:
            line = '|'.join([
                p['pet_id'], p['name'], p['species'], p['breed'], p['age'], p['gender'],
                p['size'], p['description'], p['shelter_id'], p['status'], p['date_added']
            ])
            f.write(line + '\n')
def read_applications():
