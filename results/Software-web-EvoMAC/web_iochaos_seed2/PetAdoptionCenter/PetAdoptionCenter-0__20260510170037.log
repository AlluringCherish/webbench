<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add New Pet</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="add-pet-page">
        <h1>Add New Pet</h1>
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <ul class="flashes">
              {% for category, message in messages %}
                <li class="{{ category }}">{{ message }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endwith %}
        <form method="post" action="{{ url_for('add_pet') }}">
            <label for="pet-name-input">Pet Name:</label><br>
            <input type="text" id="pet-name-input" name="pet-name-input" required><br><br>
            <label for="pet-species-input">Species:</label><br>
            <select id="pet-species-input" name="pet-species-input" required>
                <option value="">Select species</option>
                <option value="Dog">Dog</option>
                <option value="Cat">Cat</option>
                <option value="Bird">Bird</option>
                <option value="Rabbit">Rabbit</option>
                <option value="Other">Other</option>
            </select><br><br>
            <label for="pet-breed-input">Breed:</label><br>
            <input type="text" id="pet-breed-input" name="pet-breed-input" required><br><br>
            <label for="pet-age-input">Age (e.g., "2 years"):</label><br>
            <input type="text" id="pet-age-input" name="pet-age-input" required><br><br>
            <label for="pet-gender-input">Gender:</label><br>
            <select id="pet-gender-input" name="pet-gender-input" required>
                <option value="">Select gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </select><br><br>
            <label for="pet-size-input">Size:</label><br>
            <select id="pet-size-input" name="pet-size-input" required>
                <option value="">Select size</option>
                <option value="Small">Small</option>
                <option value="Medium">Medium</option>
                <option value="Large">Large</option>
            </select><br><br>
            <label for="pet-description-input">Description:</label><br>
            <textarea id="pet-description-input" name="pet-description-input" rows="5" required></textarea><br><br>
            <button type="submit" id="submit-pet-button">Submit</button>
            <button type="button" id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
