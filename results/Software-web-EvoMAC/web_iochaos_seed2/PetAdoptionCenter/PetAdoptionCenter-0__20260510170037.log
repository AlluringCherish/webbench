# Helper functions
def get_next_id(items, id_key):
    max_id = 0
    for item in items:
        try:
            current_id = int(item[id_key])
            if current_id > max_id:
                max_id = current_id
        except Exception:
            continue
    return str(max_id + 1)
def get_pet_by_id(pet_id):
    pets = read_pets()
    for pet in pets:
        if pet['pet_id'] == pet_id:
            return pet
    return None
