        for a in applications:
            line = '|'.join([
                a['application_id'], a['username'], a['pet_id'], a['applicant_name'], a['phone'], a['address'],
                a['housing_type'], a['has_yard'], a['other_pets'], a['experience'], a['reason'], a['status'], a['date_submitted']
            ])
            f.write(line + '\n')
def read_favorites():
