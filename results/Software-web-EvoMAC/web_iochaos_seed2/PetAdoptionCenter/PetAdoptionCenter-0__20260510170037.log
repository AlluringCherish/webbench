'''
Test the elements and integrity of all pages by verifying the presence and correctness of the specified elements on each page as per the requirements document.
'''

import unittest
from app import app
from bs4 import BeautifulSoup

class TestPetAdoptionCenterPages(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_page_elements(self):
        """Test Dashboard page elements and correctness"""
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check container div with id dashboard-page
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div missing")

        # Check page title
        self.assertIn('Pet Adoption Dashboard', soup.title.string)

        # Check featured-pets div
        featured_div = soup.find('div', id='featured-pets')
        self.assertIsNotNone(featured_div, "Featured pets div missing")

        # Check featured pets limit 5 (if pets exist)
        pet_cards = featured_div.find_all(class_='pet-card')
        self.assertLessEqual(len(pet_cards), 5, "More than 5 featured pets displayed")

        # Check browse-pets-button button
        browse_btn = soup.find('button', id='browse-pets-button')
        self.assertIsNotNone(browse_btn, "Browse Pets button missing")

        # Check back-to-dashboard button
        back_btn = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_btn, "Back to Dashboard button missing")

    def test_pet_listings_page_elements(self):
        """Test Pet Listings page elements and correctness"""
        response = self.client.get('/pet_listings')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Container div
        container = soup.find('div', id='pet-listings-page')
        self.assertIsNotNone(container, "Pet listings container div missing")

        # Page title
        self.assertIn('Available Pets', soup.title.string)

        # Search input
        search_input = soup.find('input', id='search-input')
        self.assertIsNotNone(search_input, "Search input missing")

        # Filter species dropdown
        filter_species = soup.find('select', id='filter-species')
        self.assertIsNotNone(filter_species, "Filter species dropdown missing")

        # Check dropdown options
        expected_options = ['All', 'Dog', 'Cat', 'Bird', 'Rabbit', 'Other']
        options = [opt.get_text() for opt in filter_species.find_all('option')]
        for eo in expected_options:
            self.assertIn(eo, options, f"Species option '{eo}' missing")

        # Pet grid div
        pet_grid = soup.find('div', id='pet-grid')
        self.assertIsNotNone(pet_grid, "Pet grid div missing")

        # Back to dashboard button
        back_btn = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_btn, "Back to Dashboard button missing")

    def test_pet_details_page_elements(self):
        """Test Pet Details page elements and correctness"""
        # Use a known pet_id from example data: '1'
        response = self.client.get('/pet_details/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        container = soup.find('div', id='pet-details-page')
        self.assertIsNotNone(container, "Pet details container div missing")

        # Page title
        self.assertIn('Pet Details', soup.title.string)

        # Pet name h1
        pet_name = soup.find('h1', id='pet-name')
        self.assertIsNotNone(pet_name, "Pet name h1 missing")
        self.assertTrue(len(pet_name.text.strip()) > 0, "Pet name is empty")

        # Pet species div
