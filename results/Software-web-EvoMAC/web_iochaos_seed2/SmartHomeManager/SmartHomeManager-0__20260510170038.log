<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Energy Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        #energy-page { max-width: 900px; margin: auto; }
        #energy-summary { margin-bottom: 20px; padding: 15px; border: 1px solid #ccc; border-radius: 5px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        form { margin-bottom: 20px; }
        input[type="date"] { padding: 6px; font-size: 14px; }
        button { padding: 8px 15px; cursor: pointer; }
    </style>
</head>
<body>
<div id="energy-page">
    <h1>Energy Report</h1>

    <div id="energy-summary">
        Total Consumption: {{ '%.2f'|format(total_consumption) }} kWh<br>
        Estimated Cost: ${{ '%.2f'|format(cost_estimate) }}
    </div>

    <form method="post" action="{{ url_for('energy_report') }}">
        <label for="date-filter">Filter by Date:</label>
        <input type="date" id="date-filter" name="date_filter" value="{{ filter_date if filter_date else '' }}">
        <button id="apply-filter-button" type="submit">Apply Filter</button>
    </form>

    <table id="energy-table">
        <thead>
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ device_map.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.date }}</td>
                <td>{{ '%.2f'|format(log.consumption_kwh) }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="3">No energy consumption data found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

