<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add New Device</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        #add-device-page { max-width: 600px; margin: auto; }
        form { display: flex; flex-direction: column; }
        label { margin-top: 10px; font-weight: bold; }
        input[type="text"], select { padding: 8px; font-size: 14px; margin-top: 5px; }
        button { margin-top: 20px; padding: 10px 15px; font-size: 14px; cursor: pointer; }
    </style>
</head>
<body>
<div id="add-device-page">
    <h1>Add New Device</h1>
    <form method="post" action="{{ url_for('add_device') }}">
        <label for="device-name">Device Name</label>
        <input type="text" id="device-name" name="device_name" required>

        <label for="device-type">Device Type</label>
        <select id="device-type" name="device_type" required>
            <option value="" disabled selected>Select device type</option>
            {% for dtype in device_types %}
            <option value="{{ dtype }}">{{ dtype }}</option>
            {% endfor %}
        </select>

        <label for="device-room">Device Room</label>
        <select id="device-room" name="device_room" required>
            <option value="" disabled selected>Select room</option>
            {% for room in rooms %}
            <option value="{{ room }}">{{ room }}</option>
            {% endfor %}
        </select>

        <label for="brand">Brand (optional)</label>
        <input type="text" id="brand" name="brand" placeholder="Brand">

        <label for="model">Model (optional)</label>
        <input type="text" id="model" name="model" placeholder="Model">

        <button id="submit-device-button" type="submit">Add Device</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
