        # Example rooms for john_doe: Living Room, Bedroom, Kitchen
        room_names = ['Living Room', 'Bedroom', 'Kitchen']
        room_list_text = room_list.get_text()
        for room_name in room_names:
            self.assertIn(room_name, room_list_text, f"Room list should include room '{room_name}'")
