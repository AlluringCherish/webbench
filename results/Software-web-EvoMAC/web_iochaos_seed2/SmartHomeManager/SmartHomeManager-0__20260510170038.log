'''
Energy Report page template for SmartHomeManager.
Displays energy consumption summary and detailed logs with date filter.
Navigation uses Flask url_for routing.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Energy Report</title>
</head>
<body>
<div id="energy-page">
    <h1>Energy Report</h1>
    <div id="energy-summary">
        <p>Total Energy Consumption: {{ '%.2f'|format(total_consumption) }} kWh</p>
        <p>Estimated Cost: ${{ '%.2f'|format(cost_estimate) }}</p>
    </div>

    <form method="post" action="{{ url_for('energy_report') }}">
        <label for="date-filter">Filter by Date:</label>
        <input type="date" id="date-filter" name="date_filter" value="{{ filter_date }}">
        <button id="apply-filter-button" type="submit">Apply Filter</button>
    </form>

    <table id="energy-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Device</th>
                <th>Date</th>
                <th>Consumption (kWh)</th>
            </tr>
        </thead>
        <tbody>
            {% for log in energy_logs %}
            <tr>
                <td>{{ device_map.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.date }}</td>
                <td>{{ '%.2f'|format(log.consumption_kwh) }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/activity_logs.html
```html
'''
Activity Logs page template for SmartHomeManager.
Displays device activity logs with search functionality.
Navigation uses Flask url_for routing.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Activity Logs</title>
</head>
<body>
<div id="activity-page">
    <h1>Activity Logs</h1>

    <form method="post" action="{{ url_for('activity_logs') }}">
        <label for="search-activity">Search:</label>
        <input type="text" id="search-activity" name="search_activity" value="{{ search_term or '' }}">
        <button id="apply-search-button" type="submit">Search</button>
    </form>

    <table id="activity-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Timestamp</th>
                <th>Device</th>
                <th>Action</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
            <tr>
                <td>{{ log.timestamp }}</td>
                <td>{{ device_map.get(log.device_id, 'Unknown Device') }}</td>
                <td>{{ log.action }}</td>
                <td>{{ log.details }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
