    def test_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_title(self):
        # Test Task 2: Check page title on dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.find('title')
        self.assertIsNotNone(title, "Dashboard page should have a <title> element")
        self.assertIn("Smart Home Dashboard", title.text, "Dashboard page title should be 'Smart Home Dashboard'")
    def test_dashboard_elements_presence(self):
        # Test Task 3: Verify presence of all specified elements on dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must have a div with id 'dashboard-page'")
        # Check device summary div
        device_summary = soup.find('div', id='device-summary')
        self.assertIsNotNone(device_summary, "Dashboard page must have a div with id 'device-summary'")
        # Check buttons for navigation
        buttons_ids = [
            'device-list-button',
            'add-device-button',
            'automation-button',
            'energy-button',
            'activity-button'
        ]
        for btn_id in buttons_ids:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Dashboard page must have a button with id '{btn_id}'")
        # Check room list div
        room_list = soup.find('div', id='room-list')
        self.assertIsNotNone(room_list, "Dashboard page must have a div with id 'room-list'")
    def test_dashboard_device_counts(self):
        # Test Task 2: Check that device counts are displayed and consistent with example data
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        device_summary = soup.find('div', id='device-summary')
        self.assertIsNotNone(device_summary, "Device summary div must be present")
        # Check that total devices, active devices, and offline devices counts appear as text
        text = device_summary.get_text().lower()
        self.assertIn('total devices', text, "Device summary should mention 'total devices'")
        self.assertIn('active devices', text, "Device summary should mention 'active devices'")
        self.assertIn('offline devices', text, "Device summary should mention 'offline devices'")
    def test_dashboard_room_list_content(self):
