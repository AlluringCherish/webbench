            for line in f:
                line = line.strip()
                if line:
                    username, email, phone, full_name = line.split('|')
                    users[username] = {
                        'email': email,
                        'phone': phone,
                        'full_name': full_name
                    }
    except FileNotFoundError:
        pass
    return users
