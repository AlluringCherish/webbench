  if (writeReviewBtn) {
    writeReviewBtn.addEventListener("click", () => {
      window.location.href = "/write_review";
    });
  }
  // Reviews page and Bestsellers page: back to dashboard buttons
  const backToDashboardBtns = document.querySelectorAll("#back-to-dashboard");
