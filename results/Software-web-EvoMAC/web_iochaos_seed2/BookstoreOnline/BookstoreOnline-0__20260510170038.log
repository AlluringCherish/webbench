    <section id="bestsellers-section">
      <h2>Bestsellers (This Month)</h2>
      <div id="bestsellers-list">
        {% if bestsellers %}
        <ol>
          {% for b in bestsellers %}
          <li>
            <span class="rank">{{ b.rank }}.</span>
            <span class="title">{{ b.title }}</span> by
            <span class="author">{{ b.author }}</span>
            <span class="sales-count">({{ b.sales_count }} sales)</span>
            <button id="view-book-button-{{ b.book_id }}">View Details</button>
          </li>
          {% endfor %}
        </ol>
        {% else %}
        <p>No bestsellers data available.</p>
        {% endif %}
      </div>
    </section>
    <nav class="dashboard-nav">
      <button id="browse-catalog-button">Browse Catalog</button>
      <button id="view-cart-button">View Cart</button>
      <button id="bestsellers-button">Bestsellers</button>
    </nav>
  </div>
</body>
</html>
