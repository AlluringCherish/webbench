<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bookstore Dashboard</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}" />
  <script src="{{ url_for('static', filename='js/scripts.js') }}" defer></script>
</head>
<body>
  <div id="dashboard-page" class="container">
    <h1>Bookstore Dashboard</h1>

    <section id="featured-books">
      <h2>Featured Books</h2>
      <div class="books-list">
        {% for book in featured_books %}
        <div class="book-card" data-title="{{ book.title }}" data-author="{{ book.author }}" data-isbn="{{ book.isbn }}" data-category="{{ book.category }}">
          <h3>{{ book.title }}</h3>
          <p><strong>Author:</strong> {{ book.author }}</p>
          <p><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</p>
          <button id="view-book-button-{{ book.book_id }}">View Details</button>
        </div>
        {% else %}
        <p>No featured books available.</p>
        {% endfor %}
      </div>
    </section>

    <section id="bestsellers-section">
      <h2>Bestsellers (This Month)</h2>
      <div id="bestsellers-list">
        {% if bestsellers %}
        <ol>
          {% for b in bestsellers %}
          <li>
            <span class="rank">{{ b.rank }}.</span>
            <span class="title">{{ b.title }}</span> by
            <span class="author">{{ b.author }}</span>
            <span class="sales-count">({{ b.sales_count }} sales)</span>
            <button id="view-book-button-{{ b.book_id }}">View Details</button>
          </li>
          {% endfor %}
        </ol>
        {% else %}
        <p>No bestsellers data available.</p>
        {% endif %}
      </div>
    </section>

    <nav class="dashboard-nav">
      <button id="browse-catalog-button">Browse Catalog</button>
      <button id="view-cart-button">View Cart</button>
      <button id="bestsellers-button">Bestsellers</button>
    </nav>
  </div>
</body>
</html>
