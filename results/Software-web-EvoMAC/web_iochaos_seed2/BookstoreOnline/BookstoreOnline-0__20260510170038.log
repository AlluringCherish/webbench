'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence of:
- ID: dashboard-page (Div container)
- ID: featured-books (Div for featured books)
- ID: browse-catalog-button (Button to navigate to catalog)
- ID: view-cart-button (Button to navigate to cart)
- ID: bestsellers-button (Button to navigate to bestsellers)
'''
import unittest
from app import app
from bs4 import BeautifulSoup
class TestDashboardPage(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_server_running_and_dashboard_accessible(self):
        # Test if server responds on root URL
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")
    def test_dashboard_page_elements(self):
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check dashboard-page div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' not found")
        # Check featured-books div
        featured_div = soup.find('div', id='featured-books')
        self.assertIsNotNone(featured_div, "Featured books div with id 'featured-books' not found")
        # Check browse-catalog-button button
        browse_btn = soup.find('button', id='browse-catalog-button')
        self.assertIsNotNone(browse_btn, "Browse catalog button with id 'browse-catalog-button' not found")
        # Check view-cart-button button
        cart_btn = soup.find('button', id='view-cart-button')
        self.assertIsNotNone(cart_btn, "View cart button with id 'view-cart-button' not found")
        # Check bestsellers-button button
        bestsellers_btn = soup.find('button', id='bestsellers-button')
        self.assertIsNotNone(bestsellers_btn, "Bestsellers button with id 'bestsellers-button' not found")
    def test_dashboard_navigation_buttons(self):
        # Since navigation is client-side JS, we test that buttons exist and have correct IDs
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Buttons should have type=button
        for btn_id in ['browse-catalog-button', 'view-cart-button', 'bestsellers-button']:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' not found")
            self.assertEqual(btn.name, 'button', f"Element with id '{btn_id}' is not a button")
if __name__ == '__main__':
    unittest.main()

