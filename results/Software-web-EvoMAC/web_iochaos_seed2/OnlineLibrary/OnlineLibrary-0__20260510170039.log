import unittest
from main import app
from bs4 import BeautifulSoup

class OnlineLibraryTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_01_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status 200")

    def test_02_dashboard_content_and_navigation_buttons(self):
        # Test Task 2: Check dashboard page content and navigation buttons
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check dashboard container div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' should be present")

        # Check welcome message with username
        welcome_message = soup.find('h1', id='welcome-message')
        self.assertIsNotNone(welcome_message, "Welcome message h1 with id 'welcome-message' should be present")
        self.assertIn('john_reader', welcome_message.text, "Welcome message should contain the username 'john_reader'")

        # Check featured books container
        featured_books_div = soup.find('div', id='featured-books')
        self.assertIsNotNone(featured_books_div, "Featured books container with id 'featured-books' should be present")

        # Check that featured books are displayed as book cards
        book_cards = featured_books_div.find_all('div', class_='book-card')
        self.assertTrue(len(book_cards) > 0, "There should be at least one featured book card displayed")

        # Check each book card has required elements: cover img, title, author, status, avg_rating, view details button
        for card in book_cards:
            img = card.find('img')
            self.assertIsNotNone(img, "Book card should have an image for cover")
            title = card.find('h3')
            self.assertIsNotNone(title, "Book card should have a title h3")
            author_p = card.find('p', string=lambda text: text and text.startswith('by '))
            self.assertIsNotNone(author_p, "Book card should have author paragraph starting with 'by '")
            status_p = card.find('p', string=lambda text: text and text.startswith('Status:'))
            self.assertIsNotNone(status_p, "Book card should have status paragraph starting with 'Status:'")
            rating_p = card.find('p', string=lambda text: text and text.startswith('Avg. Rating:'))
            self.assertIsNotNone(rating_p, "Book card should have average rating paragraph starting with 'Avg. Rating:'")
            view_button = card.find('button', id=lambda x: x and x.startswith('view-book-button-'))
            self.assertIsNotNone(view_button, "Book card should have a 'View Details' button with correct id")

        # Check dashboard buttons: browse books and my borrowings
        browse_button = soup.find('button', id='browse-books-button')
        self.assertIsNotNone(browse_button, "Dashboard should have a 'Browse Books' button with id 'browse-books-button'")
        my_borrows_button = soup.find('button', id='my-borrows-button')
        self.assertIsNotNone(my_borrows_button, "Dashboard should have a 'My Borrowings' button with id 'my-borrows-button'")

    def test_03_basic_navigation_from_dashboard(self):
        # Test Task 2: Test navigation from dashboard to book catalog and my borrowings pages
        # Navigate to book catalog page via GET
        response_catalog = self.client.get('/book_catalog')
        self.assertEqual(response_catalog.status_code, 200, "Book Catalog page should be accessible")

        # Navigate to my borrowings page via GET
        response_borrows = self.client.get('/my_borrowings')
        self.assertEqual(response_borrows.status_code, 200, "My Borrowings page should be accessible")

