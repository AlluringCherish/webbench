                                <td>
                                    {% if reservation.status == 'Active' %}
                                        <button type="submit" name="cancel-reservation-button-{{ reservation.reservation_id }}" id="cancel-reservation-button-{{ reservation.reservation_id }}">Cancel Reservation</button>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="4">No reservations found.</td></tr>
                    {% endif %}
                </tbody>
            </table>
        </form>
        <form action="{{ url_for('dashboard') }}" method="get" style="margin-top: 20px;">
            <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/my_reviews.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Reviews</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="reviews-page">
        <h1>My Reviews</h1>
        <form method="post">
            <div id="reviews-list">
                {% if reviews %}
                    {% for review in reviews %}
                        <div class="review-item" style="margin-bottom: 15px;">
                            <div class="review-header">
                                <strong>{{ review.title }}</strong> &nbsp;
                                <span class="review-rating">{% for i in range(review.rating) %}★{% endfor %}{% for i in range(5 - review.rating) %}☆{% endfor %}</span>
                                &nbsp;on {{ review.review_date }}
                            </div>
                            <div class="review-text">{{ review.review_text }}</div>
                            <div style="margin-top: 8px;">
                                <button type="submit" name="edit-review-button-{{ review.review_id }}" id="edit-review-button-{{ review.review_id }}">Edit</button>
                                <button type="submit" name="delete-review-button-{{ review.review_id }}" id="delete-review-button-{{ review.review_id }}" style="margin-left: 10px;">Delete</button>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <p>No reviews written yet.</p>
                {% endif %}
            </div>
        </form>
        <form action="{{ url_for('dashboard') }}" method="get" style="margin-top: 20px;">
            <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/write_review.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write Review</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="write-review-page">
        <h1>Write Review</h1>
        <div id="book-info-display">
            <h2>{{ book.title }}</h2>
            <p><strong>Author:</strong> {{ book.author }}</p>
            <p><strong>ISBN:</strong> {{ book.isbn }}</p>
            <p><strong>Genre:</strong> {{ book.genre }}</p>
            <p><strong>Publisher:</strong> {{ book.publisher }}</p>
            <p><strong>Year:</strong> {{ book.year }}</p>
        </div>
        <form method="post" style="margin-top: 20px;">
            <label for="rating-input">Rating:</label>
            <select id="rating-input" name="rating-input" required>
                <option value="">Select rating</option>
                {% for i in range(1,6) %}
                    <option value="{{ i }}" {% if review and review.rating == i %}selected{% endif %}>{{ i }} Star{% if i > 1 %}s{% endif %}</option>
                {% endfor %}
            </select>
            <label for="review-text">Review:</label>
            <textarea id="review-text" name="review-text" required>{{ review.review_text if review else '' }}</textarea>
            <button type="submit" id="submit-review-button" style="margin-top: 10px;">Submit Review</button>
        </form>
        <form action="{{ url_for('book_details', book_id=book.book_id) }}" method="get" style="margin-top: 15px;">
            <button type="submit" id="back-to-book">Back to Book Details</button>
        </form>
    </div>
</body>
</html>
```

templates/user_profile.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="profile-page">
        <h1>My Profile</h1>
        <form method="post">
            <div>
                <label for="profile-username"><strong>Username:</strong></label>
                <div id="profile-username">{{ user.username }}</div>
            </div>
            <div>
                <label for="profile-email"><strong>Email:</strong></label>
                <input type="email" id="profile-email" name="profile-email" value="{{ user.email }}" required>
            </div>
            <button type="submit" id="update-profile-button">Update Profile</button>
        </form>
        <div id="borrow-history" style="margin-top: 30px;">
            <h2>Borrowing History</h2>
            {% if borrow_history %}
                <ul>
                    {% for borrow in borrow_history %}
                        <li>{{ borrow.title }} (Borrowed on {{ borrow.borrow_date }}, Returned on {{ borrow.return_date }})</li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No borrowing history available.</p>
            {% endif %}
        </div>
        <form action="{{ url_for('dashboard') }}" method="get" style="margin-top: 20px;">
            <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/payment_confirmation.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Payment Confirmation</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="payment-page">
        <h1>Payment Confirmation</h1>
        <div id="fine-amount-display">
            <p><strong>Fine Amount to be Paid:</strong> ${{ '%.2f'|format(fine_amount) }}</p>
        </div>
        <form method="post" style="margin-top: 20px;">
            <button type="submit" name="confirm-payment-button" id="confirm-payment-button">Confirm Payment</button>
            <button type="submit" name="back-to-profile" id="back-to-profile" style="margin-left: 10px;">Back to Profile</button>
        </form>
    </div>
</body>
</html>
```
