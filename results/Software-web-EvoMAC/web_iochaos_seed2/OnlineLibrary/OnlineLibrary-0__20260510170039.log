    display: inline-block;
}
/* Reviews section */
#reviews-section {
    margin-top: 25px;
}
.review-item {
    border-bottom: 1px solid #ddd;
    padding: 12px 0;
}
.review-item:last-child {
    border-bottom: none;
}
.review-header {
    font-weight: 600;
    margin-bottom: 6px;
    color: #34495e;
}
.review-rating {
    color: #f39c12;
    font-weight: 700;
}
.review-text {
    margin-top: 4px;
    font-style: italic;
    color: #555;
}
/* Error and flash messages */
.flash-message {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
    padding: 10px 15px;
    margin-bottom: 20px;
    border-radius: 5px;
}
/* Responsive adjustments */
@media (max-width: 768px) {
    .book-grid {
        justify-content: center;
    }
    .book-card {
        width: 140px;
    }
    #dashboard-page,
    #catalog-page,
    #book-details-page,
    #borrow-page,
    #my-borrows-page,
    #reservations-page,
    #reviews-page,
    #write-review-page,
    #profile-page,
    #payment-page {
        padding: 15px 20px;
    }
}
