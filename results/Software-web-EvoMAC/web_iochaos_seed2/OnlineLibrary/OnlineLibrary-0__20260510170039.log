<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write Review</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="write-review-page">
        <h1>Write Review</h1>
        <div id="book-info-display">
            <h2>{{ book.title }}</h2>
            <p><strong>Author:</strong> {{ book.author }}</p>
            <p><strong>ISBN:</strong> {{ book.isbn }}</p>
            <p><strong>Genre:</strong> {{ book.genre }}</p>
            <p><strong>Publisher:</strong> {{ book.publisher }}</p>
            <p><strong>Year:</strong> {{ book.year }}</p>
        </div>
        <form method="post" style="margin-top: 20px;">
            <label for="rating-input">Rating:</label>
            <select id="rating-input" name="rating-input" required>
                <option value="">Select rating</option>
                {% for i in range(1,6) %}
                    <option value="{{ i }}" {% if review and review.rating == i %}selected{% endif %}>{{ i }} Star{% if i > 1 %}s{% endif %}</option>
                {% endfor %}
            </select>
            <label for="review-text">Review:</label>
            <textarea id="review-text" name="review-text" required>{{ review.review_text if review else '' }}</textarea>
            <button type="submit" id="submit-review-button" style="margin-top: 10px;">Submit Review</button>
        </form>
        <form action="{{ url_for('book_details', book_id=book.book_id) }}" method="get" style="margin-top: 15px;">
            <button type="submit" id="back-to-book">Back to Book Details</button>
        </form>
    </div>
</body>
</html>
