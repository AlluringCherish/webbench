/*
Stylesheet for OnlineLibrary web application
Provides consistent styling across all pages
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    padding: 20px;
}
/* Container for pages */
#dashboard-page,
#catalog-page,
#book-details-page,
#borrow-page,
#my-borrows-page,
#reservations-page,
#reviews-page,
#write-review-page,
#profile-page,
#payment-page {
    max-width: 1000px;
    margin: 0 auto;
    background-color: #fff;
    padding: 25px 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
