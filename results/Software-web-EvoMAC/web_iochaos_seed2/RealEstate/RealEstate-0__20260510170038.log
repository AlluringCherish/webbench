}

tr:nth-child(even) {
    background-color: #f2f2f2;
}

/* IDs for specific elements */

/* Featured properties section */
#featured-properties {
    margin-bottom: 40px;
}

/* Recent listings section */
#recent-listings {
    margin-bottom: 40px;
}

/* Properties grid for search page */
#properties-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

/* Favorites list */
#favorites-list {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

/* Agents list */
#agents-list {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

/* Agent card */
.agent-card {
    background-color: #ecf0f1;
    border-radius: 8px;
    padding: 15px 20px;
    width: 280px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.agent-photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 12px;
}

/* Locations list */
#locations-list {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

/* Location card */
.location-card {
    background-color: #ecf0f1;
    border-radius: 8px;
    padding: 15px 20px;
    width: 300px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

/* Error message */
.error-message {
    color: #e74c3c;
    font-weight: bold;
    margin-bottom: 15px;
}

/* Responsive Design */
@media (max-width: 768px) {
    .property-cards,
    #properties-grid,
    #favorites-list,
    #agents-list,
    #locations-list {
        flex-direction: column;
        align-items: center;
    }

    .property-card,
    .agent-card,
    .location-card {
        width: 90%;
    }

    #dashboard-navigation {
        flex-direction: column;
    }
}
