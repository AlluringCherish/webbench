        <input type="text" id="inquiry-name" name="inquiry-name" value="{{ form_data.get('inquiry-name') if form_data else '' }}" required>
        <label for="inquiry-email">Your Email:</label>
        <input type="email" id="inquiry-email" name="inquiry-email" value="{{ form_data.get('inquiry-email') if form_data else '' }}" required>
        <label for="inquiry-phone">Your Phone:</label>
        <input type="tel" id="inquiry-phone" name="inquiry-phone" value="{{ form_data.get('inquiry-phone') if form_data else '' }}">
        <label for="inquiry-message">Message:</label>
        <textarea id="inquiry-message" name="inquiry-message" required>{{ form_data.get('inquiry-message') if form_data else '' }}</textarea>
