'''
Property Details page template for RealEstate web application.
Displays detailed information about a specific property,
with options to add to favorites and submit an inquiry.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Property Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="property-details-page">
    <h1 id="property-address">{{ property.address }}</h1>
    <div id="property-price"><strong>Price:</strong> ${{ "{:,}".format(property.price) }}</div>
    <div id="property-description"><strong>Description:</strong> {{ property.description }}</div>
    <div id="property-features">
        <p><strong>Beds:</strong> {{ property.bedrooms }}</p>
        <p><strong>Baths:</strong> {{ property.bathrooms }}</p>
        <p><strong>Square Feet:</strong> {{ property.square_feet }}</p>
        <p><strong>Type:</strong> {{ property.property_type }}</p>
        <p><strong>Status:</strong> {{ property.status }}</p>
    </div>
    <div id="property-actions">
        {% if property.status.lower() == 'available' %}
            {% if not is_favorite %}
                <form action="{{ url_for('add_to_favorites', property_id=property.property_id) }}" method="post" style="display:inline;">
                    <button type="submit" id="add-to-favorites-button">Add to Favorites</button>
                </form>
            {% else %}
                <p>This property is in your favorites.</p>
            {% endif %}
            <form action="{{ url_for('property_inquiry') }}" method="get" style="display:inline;">
                <input type="hidden" name="property_id" value="{{ property.property_id }}">
                <button type="submit" id="submit-inquiry-button">Submit Inquiry</button>
            </form>
        {% else %}
            <p>This property is not available.</p>
        {% endif %}
    </div>
    <nav>
        <button onclick="location.href='{{ url_for('property_search') }}'">Back to Search</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
