</head>
<body>
<div id="{{ submit_page_id }}">
    <h1>Submit Assignment</h1>
    <div id="assignment-info">
        <h2>{{ assignment_info.title }}</h2>
        <p>{{ assignment_info.description }}</p>
    </div>
    <form method="post" action="{{ url_for('submit_assignment', assignment_id=request.view_args.assignment_id) }}">
        <textarea id="submission-text" name="submission-text" rows="10" cols="50" placeholder="Enter your submission here..."></textarea><br>
        <button id="submit-button" type="submit">Submit</button>
    </form>
    <button id="back-to-assignments" onclick="location.href='{{ url_for('my_assignments') }}'">Back to Assignments</button>
</div>
</body>
</html>
```

certificates.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Certificates</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ certificates_page_id }}">
    <h1>My Certificates</h1>
    <div id="certificates-grid">
        {% if certificates %}
            <ul>
                {% for cert in certificates %}
                    <li>
                        <strong>{{ cert.course_title }}</strong> - Issued on {{ cert.issue_date }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You have not earned any certificates yet.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

