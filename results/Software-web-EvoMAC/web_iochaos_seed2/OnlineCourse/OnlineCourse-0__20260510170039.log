        <h2>{{ assignment_info.title }}</h2>
        <p>{{ assignment_info.description }}</p>
    </div>
    <form method="post" action="{{ url_for('submit_assignment', assignment_id=request.view_args.assignment_id) }}">
        <textarea id="submission-text" name="submission-text" rows="10" cols="50" placeholder="Enter your submission here..."></textarea><br>
        <button id="submit-button" type="submit">Submit</button>
    </form>
    <button id="back-to-assignments" onclick="location.href='{{ url_for('my_assignments') }}'">Back to Assignments</button>
</div>
</body>
</html>
```

