    if not username:
        return redirect(url_for('dashboard'))
    enrollments = get_user_enrollments(username)
    courses = read_courses()
    courses_list = []
    for eid, e in enrollments.items():
        course = courses.get(e['course_id'])
        if course:
            courses_list.append({
                'enrollment_id': eid,
                'course_id': e['course_id'],
                'title': course['title'],
                'progress': int(e['progress']),
                'status': e['status']
            })
