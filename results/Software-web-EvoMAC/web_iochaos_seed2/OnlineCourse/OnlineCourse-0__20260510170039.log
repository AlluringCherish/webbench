<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Course Learning</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ learning_page_id }}">
    <h1>Course Learning</h1>
    <div id="lessons-list">
        <ul>
            {% for lesson in lessons_list %}
                <li>
                    {% if lesson.completed %}
                        <strong>{{ lesson.title }} (Completed)</strong>
                    {% else %}
                        {{ lesson.title }}
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
    <div id="lesson-content">
        <h2>Current Lesson: Lesson {{ current_lesson_number }}</h2>
        <p>{{ lesson_content }}</p>
    </div>
    <form method="post" action="{{ url_for('course_learning', course_id=course_id) }}">
        <button id="mark-complete-button" type="submit">Mark Complete</button>
    </form>
    <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
</div>
</body>
</html>
```

my_assignments.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Assignments</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ assignments_page_id }}">
    <h1>My Assignments</h1>
    <table id="assignments-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Assignment Title</th>
                <th>Description</th>
                <th>Due Date</th>
                <th>Max Points</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% if assignments %}
                {% for assignment in assignments %}
                    <tr>
                        <td>{{ assignment.title }}</td>
                        <td>{{ assignment.description }}</td>
                        <td>{{ assignment.due_date }}</td>
                        <td>{{ assignment.max_points }}</td>
                        <td>
                            {% if assignment.submitted %}
                                Submitted
                            {% else %}
                                Pending
                            {% endif %}
                        </td>
                        <td>
                            {% if not assignment.submitted %}
                                <button id="submit-assignment-button-{{ assignment.assignment_id }}" onclick="location.href='{{ url_for('submit_assignment', assignment_id=assignment.assignment_id) }}'">Submit</button>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="6">No assignments available.</td>
                </tr>
            {% endif %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
