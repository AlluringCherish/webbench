    <div id="certificates-grid">
        {% if certificates %}
            <ul>
                {% for cert in certificates %}
                    <li>
                        <strong>{{ cert.course_title }}</strong> - Issued on {{ cert.issue_date }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You have not earned any certificates yet.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
