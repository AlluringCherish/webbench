```css
/*
Stylesheet for OnlineCourse web application
Ensures consistent and responsive UI design across all pages
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}
body {
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    padding: 20px;
}
/* Container divs */
#dashboard-page,
#catalog-page,
#course-details-page,
#my-courses-page,
#learning-page,
#assignments-page,
#submit-page,
#certificates-page,
#profile-page {
    max-width: 900px;
    margin: 0 auto;
    background-color: #fff;
    padding: 25px 30px;
    border-radius: 8px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
}
/* Headings */
h1 {
    font-size: 2.2rem;
    margin-bottom: 20px;
    color: #2c3e50;
}
h2 {
    font-size: 1.6rem;
    margin-bottom: 15px;
    color: #34495e;
}
/* Buttons */
button {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 10px 18px;
    margin: 10px 5px 0 0;
    border-radius: 5px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
}
button:hover:not(:disabled) {
    background-color: #2980b9;
}
button:disabled,
button[disabled] {
    background-color: #95a5a6;
    cursor: not-allowed;
}
/* Links styled as buttons */
a.button-link {
    display: inline-block;
    background-color: #3498db;
    color: white;
    padding: 10px 18px;
    border-radius: 5px;
    text-decoration: none;
    font-size: 1rem;
    transition: background-color 0.3s ease;
}
a.button-link:hover {
    background-color: #2980b9;
}
/* Lists */
ul {
    list-style-type: none;
    margin-bottom: 20px;
}
ul li {
    padding: 8px 0;
    border-bottom: 1px solid #ddd;
}
ul li:last-child {
    border-bottom: none;
}
/* Course cards in catalog */
#course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 20px;
}
.course-card {
    background-color: #ecf0f1;
    padding: 15px 20px;
    border-radius: 6px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.course-card h3 {
    margin-bottom: 10px;
    color: #2c3e50;
}
.course-card p {
    flex-grow: 1;
    margin-bottom: 15px;
    color: #555;
}
/* Assignments table */
#assignments-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}
#assignments-table th,
#assignments-table td {
    padding: 10px 12px;
    text-align: left;
    border: 1px solid #ddd;
}
#assignments-table th {
    background-color: #3498db;
    color: white;
}
/* Lessons list */
#lessons-list ul {
    list-style-type: none;
    margin-bottom: 20px;
}
#lessons-list li {
    padding: 8px 12px;
    border-bottom: 1px solid #ddd;
    cursor: default;
}
#lessons-list li strong {
    color: #27ae60;
}
/* Lesson content */
#lesson-content {
    background-color: #ecf0f1;
    padding: 15px 20px;
    border-radius: 6px;
    margin-bottom: 20px;
}
#lesson-content h2 {
    margin-bottom: 10px;
}
/* Textarea for assignment submission */
#submission-text {
    width: 100%;
    padding: 10px;
    font-size: 1rem;
    border-radius: 5px;
    border: 1px solid #ccc;
    resize: vertical;
    min-height: 150px;
}
/* Certificates grid */
#certificates-grid ul {
    list-style-type: none;
    margin-top: 20px;
}
#certificates-grid li {
    background-color: #ecf0f1;
    padding: 15px 20px;
    border-radius: 6px;
    margin-bottom: 15px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    color: #2c3e50;
}
/* Form labels and inputs in profile */
form label {
    font-weight: bold;
    color: #34495e;
}
form input[type="email"],
form input[type="text"] {
    width: 100%;
    padding: 8px 10px;
    margin-top: 5px;
    margin-bottom: 15px;
    border-radius: 5px;
    border: 1px solid #ccc;
    font-size: 1rem;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    #course-grid {
        grid-template-columns: 1fr;
    }
    button {
        width: 100%;
        margin: 10px 0 0 0;
    }
}
