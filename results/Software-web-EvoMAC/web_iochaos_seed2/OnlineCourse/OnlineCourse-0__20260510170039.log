<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Courses</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ my_courses_page_id }}">
    <h1>My Courses</h1>
    <div id="courses-list">
        {% if courses_list %}
            <ul>
                {% for course in courses_list %}
                    <li>
                        <strong>{{ course.title }}</strong> - Progress: {{ course.progress }}% - Status: {{ course.status }}
                        <button id="continue-learning-button-{{ course.course_id }}" onclick="location.href='{{ url_for('course_learning', course_id=course.course_id) }}'">Continue Learning</button>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You have no enrolled courses.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

course_learning.html
