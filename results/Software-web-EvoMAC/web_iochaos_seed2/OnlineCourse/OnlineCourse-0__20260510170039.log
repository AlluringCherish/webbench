'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly and basic navigation buttons on it work.
'''
import unittest
from main import app

class TestOnlineCourseApp(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check that the page title is correct
        self.assertIn(b'<title>Learning Dashboard</title>', response.data)
        # Check that welcome message container exists
        self.assertIn(b'id="welcome-message"', response.data)
        # Check that enrolled courses container exists
        self.assertIn(b'id="enrolled-courses"', response.data)
        # Check that browse courses button exists
        self.assertIn(b'id="browse-courses-button"', response.data)
        # Check that my courses button exists
        self.assertIn(b'id="my-courses-button"', response.data)

    def test_dashboard_navigation_buttons(self):
        # Test that clicking browse courses button leads to course catalog page
        response = self.client.get('/')
        self.assertIn(b'id="browse-courses-button"', response.data)
        # Simulate navigation by requesting course_catalog page
        response_catalog = self.client.get('/course_catalog')
        self.assertEqual(response_catalog.status_code, 200)
        self.assertIn(b'<title>Available Courses</title>', response_catalog.data)

        # Simulate navigation by requesting my_courses page
        response_my_courses = self.client.get('/my_courses')
        self.assertEqual(response_my_courses.status_code, 200)
        self.assertIn(b'<title>My Courses</title>', response_my_courses.data)

if __name__ == '__main__':
    unittest.main()
