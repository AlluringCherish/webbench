import unittest
from app import app
from bs4 import BeautifulSoup

class FoodDeliveryDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the root URL '/' is accessible and returns 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)

    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements with correct IDs
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check for dashboard-page div
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "dashboard-page div not found")

        # Check for featured-restaurants div inside dashboard-page
        featured_div = soup.find(id='featured-restaurants')
        self.assertIsNotNone(featured_div, "featured-restaurants div not found")

        # Check for browse-restaurants-button button
        browse_button = soup.find(id='browse-restaurants-button')
        self.assertIsNotNone(browse_button, "browse-restaurants-button not found")
        self.assertEqual(browse_button.name, 'button')

        # Check for view-cart-button button
        cart_button = soup.find(id='view-cart-button')
        self.assertIsNotNone(cart_button, "view-cart-button not found")
        self.assertEqual(cart_button.name, 'button')

        # Check for active-orders-button button
        active_orders_button = soup.find(id='active-orders-button')
        self.assertIsNotNone(active_orders_button, "active-orders-button not found")
        self.assertEqual(active_orders_button.name, 'button')

    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons have correct links or form actions (if any)
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        # browse-restaurants-button should navigate to /restaurants
        browse_button = soup.find(id='browse-restaurants-button')
        self.assertIsNotNone(browse_button)
        # It might be a button with onclick or inside a form or anchor tag
        # Check if it has an onclick attribute with url or is inside a form or anchor
        onclick = browse_button.get('onclick', '')
        href = None
        if browse_button.name == 'button' and onclick:
            self.assertIn('/restaurants', onclick)
        else:
            # Try to find anchor or form around it
            parent_a = browse_button.find_parent('a')
            if parent_a:
                href = parent_a.get('href', '')
                self.assertIn('/restaurants', href)
            else:
                # No anchor, no onclick, fail test
                self.fail("browse-restaurants-button does not have navigation link or onclick")

        # view-cart-button should navigate to /cart
        cart_button = soup.find(id='view-cart-button')
        self.assertIsNotNone(cart_button)
        onclick = cart_button.get('onclick', '')
        if cart_button.name == 'button' and onclick:
            self.assertIn('/cart', onclick)
        else:
            parent_a = cart_button.find_parent('a')
            if parent_a:
                href = parent_a.get('href', '')
                self.assertIn('/cart', href)
            else:
                self.fail("view-cart-button does not have navigation link or onclick")

        # active-orders-button should navigate to /orders
        active_orders_button = soup.find(id='active-orders-button')
        self.assertIsNotNone(active_orders_button)
        onclick = active_orders_button.get('onclick', '')
        if active_orders_button.name == 'button' and onclick:
            self.assertIn('/orders', onclick)
        else:
            parent_a = active_orders_button.find_parent('a')
            if parent_a:
                href = parent_a.get('href', '')
                self.assertIn('/orders', href)
            else:
                self.fail("active-orders-button does not have navigation link or onclick")

if __name__ == '__main__':
    unittest.main()
