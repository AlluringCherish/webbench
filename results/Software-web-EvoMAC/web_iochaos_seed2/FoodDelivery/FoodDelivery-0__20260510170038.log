<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Browse Restaurants</title>
</head>
<body>
<div id="restaurants-page">
    <h1>Browse Restaurants</h1>
    <form method="get" action="{{ url_for('restaurants') }}">
        <input type="text" id="search-input" name="search" placeholder="Search by name or cuisine" value="{{ search_query }}">
        <select id="cuisine-filter" name="cuisine">
            <option value="All" {% if cuisine_filter == 'All' %}selected{% endif %}>All</option>
