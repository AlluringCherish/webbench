        for d in deliveries:
            line = f"{d['delivery_id']}|{d['order_id']}|{d['driver_name']}|{d['driver_phone']}|{d['vehicle_info']}|{d['status']}|{d['estimated_time']}\n"
            f.write(line)
def write_reviews(reviews):
