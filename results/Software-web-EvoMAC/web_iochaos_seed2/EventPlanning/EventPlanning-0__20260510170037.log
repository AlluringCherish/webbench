'''
Clean and valid HTML template for the Dashboard page of EventPlanning web application.
Includes proper element IDs and navigation buttons linking to Flask backend routes.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Event Planning Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f9f9f9;
        }
        #dashboard-page {
            max-width: 1200px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #007BFF;
        }
        #featured-events, #featured-venues {
            background-color: #fff;
            padding: 15px;
            margin-bottom: 30px;
            border-radius: 8px;
            box-shadow: 0 0 8px #ccc;
        }
        #featured-events h2, #featured-venues h2 {
            margin-top: 0;
            margin-bottom: 15px;
            border-bottom: 2px solid #007BFF;
            padding-bottom: 5px;
            color: #007BFF;
        }
        .event-card, .venue-card {
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 10px;
            margin-bottom: 10px;
            background-color: #fafafa;
        }
        .event-title, .venue-name {
            font-weight: bold;
            font-size: 1.1em;
            margin-bottom: 5px;
        }
        .event-info, .venue-info {
            font-size: 0.9em;
            color: #555;
        }
        #navigation-buttons {
            text-align: center;
            margin-top: 40px;
        }
        #navigation-buttons button {
            background-color: #007BFF;
            color: white;
            border: none;
            padding: 12px 25px;
            margin: 0 10px;
            font-size: 1em;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }
        #navigation-buttons button:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>
    <div id="dashboard-page">
        <h1>Event Planning Dashboard</h1>

        <div id="featured-events">
            <h2>Featured Events</h2>
            {% if events %}
                {% for event in events %}
                    <div class="event-card">
                        <div class="event-title">{{ event.event_name }}</div>
                        <div class="event-info">
                            {{ event.date }} {{ event.time }}<br />
                            {{ event.location }}<br />
                            {{ event.description }}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p>No featured events available.</p>
            {% endif %}
        </div>

        <div id="featured-venues">
            <h2>Featured Venues</h2>
            {% if venues %}
                {% for venue in venues %}
                    <div class="venue-card">
                        <div class="venue-name">{{ venue.venue_name }}</div>
                        <div class="venue-info">
                            {{ venue.location }}<br />
                            <strong>Capacity:</strong> {{ venue.capacity }}<br />
                            <strong>Amenities:</strong> {{ venue.amenities }}
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p>No featured venues available.</p>
            {% endif %}
        </div>

        <div id="navigation-buttons">
            <button id="browse-events-button" onclick="location.href='{{ url_for('events_listing') }}'">Browse Events</button>
            <button id="view-tickets-button" onclick="location.href='{{ url_for('book_tickets') }}'">Book Tickets</button>
            <button id="venues-button" onclick="location.href='{{ url_for('venues_page') }}'">View Venues</button>
            <button id="participants-button" onclick="location.href='{{ url_for('participants_management') }}'">Participants</button>
            <button id="schedules-button" onclick="location.href='{{ url_for('schedules_page') }}'">Event Schedules</button>
            <button id="bookings-button" onclick="location.href='{{ url_for('bookings_summary') }}'">My Bookings</button>
        </div>
    </div>
</body>
</html>
