        <p>Date: {{ booking_confirmation.booking_date }}</p>
        <p>Tickets: {{ booking_confirmation.ticket_count }} ({{ booking_confirmation.ticket_type }})</p>
        <p>Total Amount: ${{ "%.2f"|format(booking_confirmation.total_amount) }}</p>
        <p>Status: {{ booking_confirmation.status }}</p>
    </div>
    {% else %}
    <form method="post" action="{{ url_for('book_tickets') }}">
        <label for="select-event-dropdown">Select Event:</label>
        <select id="select-event-dropdown" name="select-event-dropdown" required>
            {% for event in events %}
            <option value="{{ event.event_id }}">{{ event.event_name }} - {{ event.date }}</option>
            {% endfor %}
        </select><br><br>
        <label for="ticket-quantity-input">Number of Tickets:</label>
        <input type="number" id="ticket-quantity-input" name="ticket-quantity-input" min="1" required><br><br>
        <label for="ticket-type-select">Ticket Type:</label>
        <select id="ticket-type-select" name="ticket-type-select" required>
            <option value="General">General</option>
            <option value="VIP">VIP</option>
            <option value="Early Bird">Early Bird</option>
        </select><br><br>
        <label for="customer-name">Your Name:</label>
        <input type="text" id="customer-name" name="customer-name" placeholder="Optional"><br><br>
        <button type="submit" id="book-now-button">Book Now</button>
    </form>
    {% endif %}
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/participants.html
```html
'''
Participants Management page template for EventPlanning application.
Displays participants with search and status filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Participants Management</title>
</head>
<body>
<div id="participants-page">
    <h1>Participants Management</h1>
    <form method="get" action="{{ url_for('participants_management') }}">
        <input type="text" id="search-participant-input" name="search" placeholder="Search participants" value="{{ search_query }}">
        <select id="participant-status-filter" name="status">
            <option value="">All Statuses</option>
            {% for status in statuses %}
            <option value="{{ status }}" {% if status == selected_status %}selected{% endif %}>{{ status }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <table id="participants-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Event</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
            <tr>
                <td>{{ p.name }}</td>
                <td>{{ p.email }}</td>
                <td>
                    {% for e in events %}
                        {% if e.event_id == p.event_id %}
                            {{ e.event_name }}
                        {% endif %}
                    {% endfor %}
                </td>
                <td>{{ p.status }}</td>
            </tr>
            {% else %}
            <tr><td colspan="4">No participants found.</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="add-participant-button" onclick="alert('Add participant feature not implemented.')">Add Participant</button>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/venues.html
