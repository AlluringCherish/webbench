'''
Venue Information page template for EventPlanning application.
Displays venues with search and capacity filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Venues</title>
</head>
<body>
<div id="venues-page">
    <h1>Venues</h1>
    <form method="get" action="{{ url_for('venues_page') }}">
        <input type="text" id="venue-search-input" name="search" placeholder="Search venues" value="{{ search_query }}">
        <select id="venue-capacity-filter" name="capacity">
            <option value="">All Capacities</option>
            {% for cap in capacities %}
            <option value="{{ cap }}" {% if cap == selected_capacity %}selected{% endif %}>{{ cap }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="venues-grid">
        {% for venue in venues %}
        <div class="venue-card">
            <h3>{{ venue.venue_name }}</h3>
            <p>Capacity: {{ venue.capacity }}</p>
            <p>Amenities: {{ venue.amenities }}</p>
            <form action="{{ url_for('venue_details', venue_id=venue.venue_id) }}" method="get">
                <button type="submit" id="view-venue-details-{{ venue.venue_id }}">View Details</button>
            </form>
        </div>
        {% else %}
        <p>No venues found.</p>
        {% endfor %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
