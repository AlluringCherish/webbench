        </select>
        <button type="submit">Search</button>
    </form>
    <div id="events-grid">
        {% for event in events %}
        <div class="event-card">
            <h3>{{ event.event_name }}</h3>
            <p>{{ event.date }} {{ event.time }}</p>
            <p>{{ event.location }}</p>
            <form action="{{ url_for('event_details', event_id=event.event_id) }}" method="get">
                <button type="submit" id="view-event-button-{{ event.event_id }}">View Details</button>
            </form>
        </div>
        {% else %}
        <p>No events found.</p>
        {% endfor %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
