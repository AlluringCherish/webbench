'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including:
- ID: dashboard-page (Div container)
- ID: featured-events (Div container for featured events)
- ID: browse-events-button (Button to navigate to events listing page)
- ID: view-tickets-button (Button to navigate to tickets page)
- ID: venues-button (Button to navigate to venues page)
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class EventPlanningDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test if root URL '/' is accessible (port 5000 is default for Flask)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_elements(self):
        # Test presence of required elements on the dashboard page
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check for dashboard-page div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page div with id 'dashboard-page' should be present")
        # Check for featured-events div
        featured_events_div = soup.find('div', id='featured-events')
        self.assertIsNotNone(featured_events_div, "Featured events div with id 'featured-events' should be present")
        # Check for browse-events-button button
        browse_events_button = soup.find('button', id='browse-events-button')
        self.assertIsNotNone(browse_events_button, "Button with id 'browse-events-button' should be present")
        # Check for view-tickets-button button
        view_tickets_button = soup.find('button', id='view-tickets-button')
        self.assertIsNotNone(view_tickets_button, "Button with id 'view-tickets-button' should be present")
        # Check for venues-button button
