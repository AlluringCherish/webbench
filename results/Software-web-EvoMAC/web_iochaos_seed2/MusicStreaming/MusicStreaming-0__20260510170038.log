import unittest
from main import app
from bs4 import BeautifulSoup

class MusicStreamingDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test if the root URL '/' is accessible (port 5000 is default for Flask)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test if the Dashboard page title is correct
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string if soup.title else ''
        self.assertEqual(title, 'Music Streaming Dashboard', "Dashboard page title should be 'Music Streaming Dashboard'")

    def test_dashboard_page_elements(self):
        # Test presence of required elements on the Dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must contain div with id 'dashboard-page'")

        # Check featured songs container
        featured_songs_div = soup.find('div', id='featured-songs')
        self.assertIsNotNone(featured_songs_div, "Dashboard page must contain div with id 'featured-songs'")

        # Check buttons for navigation
        browse_songs_button = soup.find('button', id='browse-songs-button')
        self.assertIsNotNone(browse_songs_button, "Dashboard page must contain button with id 'browse-songs-button'")

        my_playlists_button = soup.find('button', id='my-playlists-button')
        self.assertIsNotNone(my_playlists_button, "Dashboard page must contain button with id 'my-playlists-button'")

        trending_artists_button = soup.find('button', id='trending-artists-button')
        self.assertIsNotNone(trending_artists_button, "Dashboard page must contain button with id 'trending-artists-button'")

    def test_featured_songs_content(self):
        # Test that featured songs are displayed with artist names
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_songs_div = soup.find('div', id='featured-songs')
        self.assertIsNotNone(featured_songs_div, "Featured songs div must be present")

        # Check that at least one featured song is shown with title and artist name
        # We expect the featured songs to be rendered inside this div
        # We look for song titles and artist names inside
        text = featured_songs_div.get_text(strip=True)
        self.assertTrue(len(text) > 0, "Featured songs div should contain song information")

    def test_trending_artists_content(self):
        # Test that trending artists are displayed with name and genre
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # The trending artists container is not explicitly specified with an id in the code,
        # but the requirements say there is a trending artists section.
        # We check for the button with id 'trending-artists-button' exists (already tested),
        # and also check if trending artists info is present somewhere on the page.
        # Since the template is not provided, we check that the trending artists data is rendered.
        # We look for artist names from example data in the page text.
        page_text = response.get_data(as_text=True)
        # Example artist names from example data: Queen, The Weeknd, Ed Sheeran
        self.assertTrue(any(name in page_text for name in ['Queen', 'The Weeknd', 'Ed Sheeran']),
                        "Trending artists section should contain known artist names")

if __name__ == '__main__':
    unittest.main()
