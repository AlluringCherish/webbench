import unittest
from app import app
class TestJobBoardDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
    def test_dashboard_page_title(self):
        # Test that the page title is correct
        response = self.client.get('/')
        self.assertIn(b'<title>Job Board Dashboard</title>', response.data)
    def test_dashboard_page_elements(self):
        # Test presence of main container div with id dashboard-page
        response = self.client.get('/')
        self.assertIn(b'id="dashboard-page"', response.data)
        # Test presence of featured-jobs section
        self.assertIn(b'id="featured-jobs"', response.data)
        # Test presence of navigation buttons with correct ids
        self.assertIn(b'id="browse-jobs-button"', response.data)
        self.assertIn(b'id="my-applications-button"', response.data)
        self.assertIn(b'id="companies-button"', response.data)
    def test_navigation_buttons_functionality(self):
        # Test that navigation buttons have correct hrefs in onclick attributes
        response = self.client.get('/')
        data = response.data.decode('utf-8')
        self.assertIn("onclick=\"location.href='/jobs'\"", data)
        self.assertIn("onclick=\"location.href='/applications'\"", data)
        self.assertIn("onclick=\"location.href='/companies'\"", data)
    def test_featured_jobs_display(self):
        # Test that featured jobs are displayed with required fields if any featured jobs exist
        response = self.client.get('/')
        data = response.data.decode('utf-8')
        # Since example data has jobs, check for job title and company name presence
        self.assertIn('Senior Python Developer', data)
        self.assertIn('TechCorp', data)
        # Check for salary formatting with commas and dollar sign
        self.assertIn('$80,000', data)
        self.assertIn('$120,000', data)
        # Check for location display
        self.assertIn('Remote', data)
        # Check that view details button exists with correct id pattern
        self.assertIn('id="view-job-button-1"', data)
if __name__ == '__main__':
    unittest.main()

