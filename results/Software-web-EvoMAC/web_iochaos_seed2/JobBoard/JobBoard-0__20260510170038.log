/*
    styles.css
    Consistent styling for the JobBoard web application.
    Moved from app.py and enhanced for UI consistency and responsiveness.
*/
/* Reset and base styles */
*,
*::before,
*::after {
    box-sizing: border-box;
}
body {
    margin: 0;
    padding: 20px;
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
}
/* Container Divs */
#dashboard-page,
#listings-page,
#job-details-page,
#application-form-page,
#tracking-page,
#companies-page,
#company-profile-page,
#resume-page,
#search-results-page {
    max-width: 960px;
    margin: 0 auto 40px auto;
    background-color: #fff;
    padding: 20px 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
/* Headings */
h1 {
    font-size: 2.2rem;
    margin-bottom: 20px;
    color: #2c3e50;
}
h2 {
    font-size: 1.6rem;
    margin-bottom: 15px;
    color: #34495e;
}
/* Buttons */
button {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
}
button:hover,
button:focus {
    background-color: #2980b9;
    outline: none;
}
button:disabled {
    background-color: #95a5a6;
    cursor: not-allowed;
}
/* Navigation buttons container */
nav {
    margin-top: 30px;
    display: flex;
    gap: 15px;
    justify-content: center;
}
/* Lists */
ul {
    list-style-type: none;
    padding-left: 0;
}
li {
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #ddd;
}
/* Forms and inputs */
input[type="text"],
input[type="email"],
select,
textarea {
    width: 100%;
    padding: 8px 10px;
    margin: 8px 0 15px 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    resize: vertical;
}
textarea {
    min-height: 100px;
}
/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}
th, td {
    padding: 12px 15px;
    border: 1px solid #ddd;
    text-align: left;
}
th {
    background-color: #3498db;
    color: white;
}
tr:nth-child(even) {
    background-color: #f2f2f2;
}
/* Job cards grid */
#jobs-grid,
#company-jobs,
#companies-list,
#resumes-list,
#job-results,
#company-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
}
/* Job card */
.job-card,
.company-card,
.resume-card {
    background-color: #ecf0f1;
    padding: 15px 20px;
    border-radius: 6px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.job-card h3,
.company-card h3,
.resume-card h3 {
    margin-bottom: 8px;
    color: #2c3e50;
}
.job-card .job-info,
.company-card .industry,
.company-card .employee-count,
.resume-card .upload-date {
    font-size: 0.9rem;
    margin-bottom: 6px;
    color: #555;
}
.job-card button,
.company-card button,
.resume-card button {
    align-self: flex-start;
    margin-top: auto;
}
/* Status colors */
.status-Applied {
    color: #27ae60;
    font-weight: bold;
}
.status-Under\ Review {
    color: #2980b9;
    font-weight: bold;
}
.status-Interview {
    color: #f39c12;
    font-weight: bold;
}
.status-Rejected {
    color: #c0392b;
    font-weight: bold;
}
/* Search and filter containers */
#search-input,
#search-company-input,
#category-filter,
#location-filter,
#status-filter {
    max-width: 400px;
    margin-bottom: 20px;
}
/* Search Results Tabs */
#results-tabs {
    display: flex;
    border-bottom: 2px solid #3498db;
    margin-bottom: 20px;
}
#results-tabs button {
    background: none;
    border: none;
    padding: 10px 20px;
    font-size: 1rem;
    cursor: pointer;
    color: #3498db;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s ease;
}
#results-tabs button.active {
    border-bottom-color: #2980b9;
    font-weight: bold;
}
#job-results,
#company-results {
    display: none;
}
#job-results.active,
#company-results.active {
    display: block;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    nav {
        flex-direction: column;
    }
    #companies-list,
    #jobs-grid,
    #company-jobs,
    #resumes-list,
    #job-results,
    #company-results {
        grid-template-columns: 1fr;
    }
}
