}
.status-Under\ Review {
    color: #2980b9;
    font-weight: bold;
}
.status-Interview {
    color: #f39c12;
    font-weight: bold;
}
.status-Rejected {
    color: #c0392b;
    font-weight: bold;
}
/* Search and filter containers */
#search-input,
#search-company-input,
#category-filter,
#location-filter,
#status-filter {
    max-width: 400px;
    margin-bottom: 20px;
}
/* Search Results Tabs */
#results-tabs {
    display: flex;
    border-bottom: 2px solid #3498db;
    margin-bottom: 20px;
}
#results-tabs button {
    background: none;
    border: none;
    padding: 10px 20px;
    font-size: 1rem;
    cursor: pointer;
    color: #3498db;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s ease;
}
#results-tabs button.active {
    border-bottom-color: #2980b9;
    font-weight: bold;
}
#job-results,
#company-results {
    display: none;
}
#job-results.active,
#company-results.active {
    display: block;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    nav {
        flex-direction: column;
    }
    #companies-list,
    #jobs-grid,
    #company-jobs,
    #resumes-list,
    #job-results,
    #company-results {
        grid-template-columns: 1fr;
    }
}
