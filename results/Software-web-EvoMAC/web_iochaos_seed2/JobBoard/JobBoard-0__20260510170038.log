```python
'''
Backend implementation for the JobBoard web application using Flask.
Handles routing, data loading/saving from local text files, and rendering templates.
Supports all pages and features as per requirements.
'''
import os
from flask import Flask, render_template, request, redirect, url_for, flash, send_from_directory
from datetime import datetime
from werkzeug.utils import secure_filename
app = Flask(__name__)
app.secret_key = 'jobboard_secret_key'  # Needed for flashing messages
# Constants for data directories and files
DATA_DIR = 'data'
UPLOADS_DIR = os.path.join('uploads', 'resumes')
os.makedirs(DATA_DIR, exist_ok=True)
os.makedirs(UPLOADS_DIR, exist_ok=True)
JOBS_FILE = os.path.join(DATA_DIR, 'jobs.txt')
COMPANIES_FILE = os.path.join(DATA_DIR, 'companies.txt')
CATEGORIES_FILE = os.path.join(DATA_DIR, 'categories.txt')
APPLICATIONS_FILE = os.path.join(DATA_DIR, 'applications.txt')
RESUMES_FILE = os.path.join(DATA_DIR, 'resumes.txt')
JOB_CATEGORIES_FILE = os.path.join(DATA_DIR, 'job_categories.txt')
# Utility functions for file operations
def read_file_lines(filename):
    if not os.path.exists(filename):
        return []
    with open(filename, 'r', encoding='utf-8') as f:
        lines = [line.strip() for line in f if line.strip()]
    return lines
def write_file_lines(filename, lines):
    with open(filename, 'w', encoding='utf-8') as f:
        for line in lines:
            f.write(line + '\n')
def get_next_id(items, id_key):
    max_id = 0
    for item in items:
        try:
            item_id = int(item[id_key])
            if item_id > max_id:
                max_id = item_id
        except:
            continue
    return max_id + 1
# Data loading functions
def load_jobs():
    jobs = []
    lines = read_file_lines(JOBS_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 9:
            continue
        job = {
            'job_id': parts[0],
            'title': parts[1],
            'company_id': parts[2],
            'location': parts[3],
            'salary_min': int(parts[4]),
            'salary_max': int(parts[5]),
            'category': parts[6],
            'description': parts[7],
            'posted_date': parts[8]
        }
        jobs.append(job)
    return jobs
def save_jobs(jobs):
    lines = []
    for job in jobs:
        line = '|'.join([
            job['job_id'],
            job['title'],
            job['company_id'],
            job['location'],
            str(job['salary_min']),
            str(job['salary_max']),
            job['category'],
            job['description'],
            job['posted_date']
        ])
        lines.append(line)
    write_file_lines(JOBS_FILE, lines)
def load_companies():
    companies = []
    lines = read_file_lines(COMPANIES_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 6:
            continue
        company = {
            'company_id': parts[0],
            'company_name': parts[1],
            'industry': parts[2],
            'location': parts[3],
            'employee_count': parts[4],
            'description': parts[5]
        }
        companies.append(company)
    return companies
def save_companies(companies):
    lines = []
    for c in companies:
        line = '|'.join([
            c['company_id'],
            c['company_name'],
            c['industry'],
            c['location'],
            c['employee_count'],
            c['description']
        ])
        lines.append(line)
    write_file_lines(COMPANIES_FILE, lines)
def load_categories():
    categories = []
    lines = read_file_lines(CATEGORIES_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 3:
            continue
        category = {
            'category_id': parts[0],
            'category_name': parts[1],
            'description': parts[2]
        }
        categories.append(category)
    return categories
def load_applications():
    applications = []
    lines = read_file_lines(APPLICATIONS_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 7:
            continue
        application = {
            'application_id': parts[0],
            'job_id': parts[1],
            'applicant_name': parts[2],
            'applicant_email': parts[3],
            'status': parts[4],
            'applied_date': parts[5],
            'resume_id': parts[6]
        }
        applications.append(application)
    return applications
def save_applications(applications):
    lines = []
    for app in applications:
        line = '|'.join([
            app['application_id'],
            app['job_id'],
            app['applicant_name'],
            app['applicant_email'],
            app['status'],
            app['applied_date'],
            app['resume_id']
        ])
        lines.append(line)
    write_file_lines(APPLICATIONS_FILE, lines)
def load_resumes():
    resumes = []
    lines = read_file_lines(RESUMES_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 6:
            continue
        resume = {
            'resume_id': parts[0],
            'applicant_name': parts[1],
            'applicant_email': parts[2],
            'filename': parts[3],
            'upload_date': parts[4],
            'summary': parts[5]
        }
        resumes.append(resume)
    return resumes
def save_resumes(resumes):
    lines = []
    for res in resumes:
        line = '|'.join([
            res['resume_id'],
            res['applicant_name'],
            res['applicant_email'],
            res['filename'],
            res['upload_date'],
            res['summary']
        ])
        lines.append(line)
    write_file_lines(RESUMES_FILE, lines)
def load_job_categories():
    mappings = []
    lines = read_file_lines(JOB_CATEGORIES_FILE)
    for line in lines:
        parts = line.split('|')
        if len(parts) != 3:
            continue
        mapping = {
            'mapping_id': parts[0],
            'job_id': parts[1],
            'category_id': parts[2]
        }
        mappings.append(mapping)
    return mappings
# Helper functions
def get_company_by_id(company_id):
    companies = load_companies()
    for c in companies:
        if c['company_id'] == company_id:
            return c
    return None
def get_job_by_id(job_id):
    jobs = load_jobs()
    for job in jobs:
        if job['job_id'] == job_id:
            return job
    return None
def get_category_name(category_name):
    # Since category is stored as name in jobs.txt, just return it
    return category_name
def get_resume_by_id(resume_id):
    resumes = load_resumes()
    for res in resumes:
        if res['resume_id'] == resume_id:
            return res
    return None
def get_application_by_id(application_id):
    applications = load_applications()
    for app in applications:
        if app['application_id'] == application_id:
            return app
    return None
def get_jobs_by_company(company_id):
    jobs = load_jobs()
    company_jobs = [job for job in jobs if job['company_id'] == company_id]
    return company_jobs
def get_jobs_by_category(category_name):
    jobs = load_jobs()
    filtered = [job for job in jobs if job['category'].lower() == category_name.lower()]
    return filtered
def get_jobs_by_location(location):
    jobs = load_jobs()
    filtered = [job for job in jobs if job['location'].lower() == location.lower()]
    return filtered
def get_featured_jobs():
    # For simplicity, featured jobs are the 3 most recent posted jobs
    jobs = load_jobs()
    jobs_sorted = sorted(jobs, key=lambda j: j['posted_date'], reverse=True)
    featured = jobs_sorted[:3]
    # Add company_name for display
    for job in featured:
        company = get_company_by_id(job['company_id'])
        job['company_name'] = company['company_name'] if company else 'Unknown'
    return featured
def search_jobs(query):
    query = query.lower()
    jobs = load_jobs()
    companies = load_companies()
    company_dict = {c['company_id']: c['company_name'] for c in companies}
    results = []
    for job in jobs:
        company_name = company_dict.get(job['company_id'], '').lower()
        if (query in job['title'].lower() or
            query in company_name or
            query in job['location'].lower()):
            job_copy = job.copy()
            job_copy['company_name'] = company_dict.get(job['company_id'], 'Unknown')
            results.append(job_copy)
    return results
def search_companies(query):
    query = query.lower()
    companies = load_companies()
    results = []
    for c in companies:
        if query in c['company_name'].lower() or query in c['industry'].lower():
            results.append(c)
    return results
# Routes
@app.route('/')
def dashboard():
    featured_jobs = get_featured_jobs()
    return render_template('dashboard.html', featured_jobs=featured_jobs)
@app.route('/jobs')
def job_listings():
    jobs = load_jobs()
    companies = load_companies()
    categories = load_categories()
    # Build company dict for name lookup
    company_dict = {c['company_id']: c['company_name'] for c in companies}
    # Get filters from query parameters
    search_query = request.args.get('search', '').strip()
    category_filter = request.args.get('category', '').strip()
    location_filter = request.args.get('location', '').strip()
    filtered_jobs = []
    for job in jobs:
        # Add company_name for display
        job['company_name'] = company_dict.get(job['company_id'], 'Unknown')
        # Filter by search query
        if search_query:
            if (search_query.lower() not in job['title'].lower() and
                search_query.lower() not in job['company_name'].lower() and
                search_query.lower() not in job['location'].lower()):
                continue
        # Filter by category
        if category_filter and category_filter.lower() != 'all':
            if job['category'].lower() != category_filter.lower():
                continue
        # Filter by location
        if location_filter and location_filter.lower() != 'all':
            if job['location'].lower() != location_filter.lower():
                continue
        filtered_jobs.append(job)
    # Sort jobs by posted_date descending
    filtered_jobs.sort(key=lambda j: j['posted_date'], reverse=True)
    # Prepare category names for dropdown
    category_names = [c['category_name'] for c in categories]
    # Location options as per requirements
    location_options = ['Remote', 'On-site', 'Hybrid']
    return render_template('job_listings.html',
                           jobs=filtered_jobs,
                           categories=category_names,
                           selected_category=category_filter,
                           selected_location=location_filter,
                           location_options=location_options,
                           search_query=search_query)
@app.route('/jobs/<job_id>')
def job_details(job_id):
    job = get_job_by_id(job_id)
    if not job:
        flash('Job not found.')
        return redirect(url_for('job_listings'))
    company = get_company_by_id(job['company_id'])
    company_name = company['company_name'] if company else 'Unknown'
    return render_template('job_details.html',
                           job=job,
                           company_name=company_name)
@app.route('/apply/<job_id>', methods=['GET', 'POST'])
def application_form(job_id):
    job = get_job_by_id(job_id)
    if not job:
        flash('Job not found.')
        return redirect(url_for('job_listings'))
    if request.method == 'POST':
        applicant_name = request.form.get('applicant-name', '').strip()
        applicant_email = request.form.get('applicant-email', '').strip()
        cover_letter = request.form.get('cover-letter', '').strip()
        resume_file = request.files.get('resume-upload')
        if not applicant_name or not applicant_email or not resume_file:
            flash('Please fill in all required fields and upload a resume.')
            return render_template('application_form.html', job=job)
        # Save resume file
        filename = secure_filename(resume_file.filename)
        if filename == '':
            flash('Invalid resume file.')
            return render_template('application_form.html', job=job)
        # Avoid filename collisions
        base, ext = os.path.splitext(filename)
        counter = 1
        save_filename = filename
        while os.path.exists(os.path.join(UPLOADS_DIR, save_filename)):
            save_filename = f"{base}_{counter}{ext}"
            counter += 1
        save_path = os.path.join(UPLOADS_DIR, save_filename)
        resume_file.save(save_path)
        # Load resumes and add new resume entry
        resumes = load_resumes()
        resume_id = str(get_next_id(resumes, 'resume_id'))
        upload_date = datetime.now().strftime('%Y-%m-%d')
        summary = cover_letter[:100].replace('\n', ' ') if cover_letter else ''
        new_resume = {
            'resume_id': resume_id,
            'applicant_name': applicant_name,
            'applicant_email': applicant_email,
            'filename': save_filename,
            'upload_date': upload_date,
            'summary': summary
        }
        resumes.append(new_resume)
        save_resumes(resumes)
        # Load applications and add new application entry
        applications = load_applications()
        application_id = str(get_next_id(applications, 'application_id'))
        applied_date = datetime.now().strftime('%Y-%m-%d')
        new_application = {
            'application_id': application_id,
            'job_id': job_id,
            'applicant_name': applicant_name,
            'applicant_email': applicant_email,
            'status': 'Applied',
            'applied_date': applied_date,
            'resume_id': resume_id
        }
        applications.append(new_application)
        save_applications(applications)
        flash('Application submitted successfully!')
        return redirect(url_for('application_tracking'))
    return render_template('application_form.html', job=job)
@app.route('/applications')
def application_tracking():
    applications = load_applications()
    jobs = load_jobs()
    companies = load_companies()
    # Build lookup dicts
    job_dict = {job['job_id']: job for job in jobs}
    company_dict = {c['company_id']: c for c in companies}
    # Filter by status if provided
    status_filter = request.args.get('status', 'All').strip()
    filtered_apps = []
    for app in applications:
        if status_filter != 'All' and app['status'] != status_filter:
            continue
        job = job_dict.get(app['job_id'])
        if not job:
            continue
        company = company_dict.get(job['company_id'])
        company_name = company['company_name'] if company else 'Unknown'
        app_copy = app.copy()
        app_copy['job_title'] = job['title']
        app_copy['company_name'] = company_name
        filtered_apps.append(app_copy)
    # Sort by applied_date descending
    filtered_apps.sort(key=lambda a: a['applied_date'], reverse=True)
    status_options = ['All', 'Applied', 'Under Review', 'Interview', 'Rejected']
    return render_template('application_tracking.html',
                           applications=filtered_apps,
                           selected_status=status_filter,
                           status_options=status_options)
@app.route('/applications/<application_id>')
def application_details(application_id):
    app_data = get_application_by_id(application_id)
    if not app_data:
        flash('Application not found.')
        return redirect(url_for('application_tracking'))
    job = get_job_by_id(app_data['job_id'])
    company = get_company_by_id(job['company_id']) if job else None
    resume = get_resume_by_id(app_data['resume_id'])
    return render_template('application_details.html',
                           application=app_data,
                           job=job,
                           company=company,
                           resume=resume)
@app.route('/companies')
def companies_directory():
    companies = load_companies()
    search_query = request.args.get('search', '').strip()
    if search_query:
        filtered_companies = []
        for c in companies:
            if (search_query.lower() in c['company_name'].lower() or
                search_query.lower() in c['industry'].lower()):
                filtered_companies.append(c)
        companies = filtered_companies
    # Sort companies by name
    companies.sort(key=lambda c: c['company_name'].lower())
    return render_template('companies.html',
                           companies=companies,
                           search_query=search_query)
@app.route('/companies/<company_id>')
def company_profile(company_id):
    company = get_company_by_id(company_id)
    if not company:
        flash('Company not found.')
        return redirect(url_for('companies_directory'))
    company_jobs = get_jobs_by_company(company_id)
    # Sort jobs by posted_date descending
    company_jobs.sort(key=lambda j: j['posted_date'], reverse=True)
    return render_template('company_profile.html',
                           company=company,
                           company_jobs=company_jobs)
@app.route('/resumes')
def resume_management():
    resumes = load_resumes()
    # Sort resumes by upload_date descending
    resumes.sort(key=lambda r: r['upload_date'], reverse=True)
    return render_template('resume_management.html', resumes=resumes)
@app.route('/resumes/upload', methods=['POST'])
def upload_resume():
    applicant_name = request.form.get('applicant-name', '').strip()
    applicant_email = request.form.get('applicant-email', '').strip()
    resume_file = request.files.get('resume-file-input')
    summary = request.form.get('summary', '').strip()
    if not applicant_name or not applicant_email or not resume_file:
        flash('Please provide all required fields and upload a resume.')
        return redirect(url_for('resume_management'))
    filename = secure_filename(resume_file.filename)
    if filename == '':
        flash('Invalid resume file.')
        return redirect(url_for('resume_management'))
    # Avoid filename collisions
    base, ext = os.path.splitext(filename)
    counter = 1
    save_filename = filename
    while os.path.exists(os.path.join(UPLOADS_DIR, save_filename)):
        save_filename = f"{base}_{counter}{ext}"
        counter += 1
    save_path = os.path.join(UPLOADS_DIR, save_filename)
    resume_file.save(save_path)
    resumes = load_resumes()
    resume_id = str(get_next_id(resumes, 'resume_id'))
    upload_date = datetime.now().strftime('%Y-%m-%d')
    new_resume = {
        'resume_id': resume_id,
        'applicant_name': applicant_name,
        'applicant_email': applicant_email,
        'filename': save_filename,
        'upload_date': upload_date,
        'summary': summary
    }
    resumes.append(new_resume)
    save_resumes(resumes)
    flash('Resume uploaded successfully.')
    return redirect(url_for('resume_management'))
@app.route('/resumes/delete/<resume_id>', methods=['POST'])
def delete_resume(resume_id):
    resumes = load_resumes()
    resume_to_delete = None
    for res in resumes:
        if res['resume_id'] == resume_id:
            resume_to_delete = res
            break
    if not resume_to_delete:
        flash('Resume not found.')
        return redirect(url_for('resume_management'))
    # Delete resume file
    file_path = os.path.join(UPLOADS_DIR, resume_to_delete['filename'])
    if os.path.exists(file_path):
        os.remove(file_path)
    # Remove from resumes list and save
    resumes = [r for r in resumes if r['resume_id'] != resume_id]
    save_resumes(resumes)
    flash('Resume deleted successfully.')
    return redirect(url_for('resume_management'))
@app.route('/search')
def search_results():
    query = request.args.get('q', '').strip()
    if not query:
        flash('Please enter a search query.')
        return redirect(url_for('dashboard'))
    job_results = search_jobs(query)
    company_results = search_companies(query)
    return render_template('search_results.html',
                           search_query=query,
                           job_results=job_results,
                           company_results=company_results)
@app.route('/uploads/resumes/<filename>')
def uploaded_resume(filename):
    return send_from_directory(UPLOADS_DIR, filename)
# Run the app
if __name__ == '__main__':
    app.run(debug=True, port=5000)
