@app.route('/vehicle_search', methods=['GET', 'POST'])
def vehicle_search():
    vehicles = read_vehicles()
    locations = read_locations()
    filtered_vehicles = vehicles
    selected_location = None
    selected_vehicle_type = None
    date_range = None

    if request.method == 'POST':
        selected_location = request.form.get('location-filter')
        selected_vehicle_type = request.form.get('vehicle-type-filter')
        date_range = request.form.get('date-range-input')

        # Parse date range input: expected format "YYYY-MM-DD to YYYY-MM-DD"
        start_date = None
        end_date = None
        if date_range:
            parts = date_range.split('to')
            if len(parts) == 2:
                start_date = parts[0].strip()
                end_date = parts[1].strip()

        # Filter vehicles by type and status
        filtered_vehicles = filter_vehicles(
            vehicles, location_city=selected_location, vehicle_type=selected_vehicle_type, date_range=(start_date, end_date))

        # Further filter by availability in date range and location
        # We exclude vehicles that have rentals overlapping with requested date range and pickup location
        if start_date and end_date:
            rentals = read_rentals()
            filtered_vehicles_ids = set(v['vehicle_id'] for v in filtered_vehicles)
            available_vehicles = []
            for v in filtered_vehicles:
                vehicle_id = v['vehicle_id']
                # Check if vehicle is booked in the requested date range at the selected location
                conflict = False
                for r in rentals:
                    if r['vehicle_id'] != vehicle_id:
                        continue
                    # Check location match
                    if selected_location and r['pickup_location'].lower() != selected_location.lower():
                        continue
                    # Check date overlap
                    r_start = parse_date(r['pickup_date'])
                    r_end = parse_date(r['dropoff_date'])
                    req_start = parse_date(start_date)
                    req_end = parse_date(end_date)
                    if r_start and r_end and req_start and req_end:
                        if not (req_end < r_start or req_start > r_end):
                            # Overlapping rental found
                            if r['status'].lower() in ['active', 'confirmed']:
                                conflict = True
                                break
                if not conflict:
                    available_vehicles.append(v)
            filtered_vehicles = available_vehicles

    return render_template('vehicle_search.html',
                           vehicles=filtered_vehicles,
                           locations=locations,
                           selected_location=selected_location,
                           selected_vehicle_type=selected_vehicle_type,
                           date_range=date_range)


