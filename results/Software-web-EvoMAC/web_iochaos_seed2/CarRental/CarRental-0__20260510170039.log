'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly and basic navigation buttons exist.
Test the presence and correctness of specified elements on the Dashboard page as per requirements.
'''
import unittest
from app import app
from bs4 import BeautifulSoup

class CarRentalDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)

    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements with correct IDs
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check container div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' not found")

        # Check featured vehicles section
        featured_div = soup.find('div', id='featured-vehicles')
        self.assertIsNotNone(featured_div, "Featured vehicles div with id 'featured-vehicles' not found")

        # Check promotions section
        promotions_div = soup.find('div', id='promotions-section')
        self.assertIsNotNone(promotions_div, "Promotions section div with id 'promotions-section' not found")

        # Check navigation buttons by id
        search_btn = soup.find('button', id='search-vehicles-button')
        self.assertIsNotNone(search_btn, "Search Vehicles button with id 'search-vehicles-button' not found")

        reservations_btn = soup.find('button', id='my-reservations-button')
        self.assertIsNotNone(reservations_btn, "My Reservations button with id 'my-reservations-button' not found")

        # Check other navigation buttons (without specific ids but present)
        nav_buttons = dashboard_div.find_all('button')
        nav_button_texts = [btn.get_text(strip=True) for btn in nav_buttons]
        self.assertIn('Rental History', nav_button_texts, "Rental History navigation button not found")
        self.assertIn('Locations', nav_button_texts, "Locations navigation button not found")
        self.assertIn('Special Requests', nav_button_texts, "Special Requests navigation button not found")

    def test_dashboard_featured_vehicles_content(self):
        # Test that featured vehicles section contains vehicle cards with expected structure
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_div = soup.find('div', id='featured-vehicles')
        vehicle_cards = featured_div.find_all('div', class_='vehicle-card')
        # Since example data has available vehicles, expect at least one vehicle card
        self.assertGreaterEqual(len(vehicle_cards), 0, "No vehicle cards found in featured vehicles section")

        for card in vehicle_cards:
            # Check image tag with alt attribute
            img = card.find('img')
            self.assertIsNotNone(img, "Vehicle card missing image")
            self.assertTrue(img.has_attr('alt'), "Vehicle image missing alt attribute")

            # Check h3 for vehicle make and model
            h3 = card.find('h3')
            self.assertIsNotNone(h3, "Vehicle card missing h3 for make and model")
            self.assertTrue(len(h3.text.strip()) > 0, "Vehicle make and model text is empty")

            # Check paragraphs for type and daily rate
            p_tags = card.find_all('p')
            self.assertGreaterEqual(len(p_tags), 2, "Vehicle card missing type or daily rate paragraphs")
            self.assertIn('Type:', p_tags[0].text)
            self.assertIn('Daily Rate:', p_tags[1].text)

            # Check view details button with correct id pattern
            btn = card.find('button')
            self.assertIsNotNone(btn, "Vehicle card missing view details button")
            self.assertTrue(btn.has_attr('id'), "View details button missing id attribute")
            self.assertTrue(btn['id'].startswith('view-details-button-'), "View details button id format incorrect")

if __name__ == '__main__':
    unittest.main()
