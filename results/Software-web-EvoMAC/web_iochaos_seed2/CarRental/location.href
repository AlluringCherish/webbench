{
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
}
.vehicle-card {
    background-color: #e6f0ff;
    border-radius: 8px;
    width: 250px;
    box-shadow: 0 1px 5px rgba(0,0,0,0.1);
    padding: 15px;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
{
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 10px;
}
{
    font-size: 1.2rem;
    margin-bottom: 8px;
    color: #003366;
}
.vehicle-card p {
    font-size: 0.95rem;
    margin-bottom: 6px;
    color: #004080;
}
/* */
#promotions-section {
    list-style-type: disc;
    padding-left: 20px;
    color: #004d99;
}
p {
    font-style: italic;
    color: #666;
}
/* and Inputs */
input[type="date"],
select,
{
    width: 100%;
    padding: 8px 10px;
    margin: 8px 0 15px 0;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
}
select:focus,
{
    border-color: #007bff;
    outline: none;
}
Textarea
{
    resize: vertical;
    min-height: 80px;
}
