Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}
table th,
table td {
    border: 1px solid #ddd;
    padding: 10px 12px;
    text-align: left;
    font-size: 0.95rem;
}
th {
    background-color: #007bff;
    color: white;
}
