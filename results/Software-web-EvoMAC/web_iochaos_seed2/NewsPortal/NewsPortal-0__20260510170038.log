'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page, including presence of:
- Div with id "dashboard-page"
- Section with id "featured-articles" containing featured articles links
- Section with id "trending-articles" containing trending articles links
- Buttons with ids "browse-articles-button", "view-bookmarks-button", "trending-articles-button"
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class NewsPortalDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check div with id dashboard-page
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div not found")
        # Check featured-articles section
        featured_section = soup.find('section', id='featured-articles')
        self.assertIsNotNone(featured_section, "Featured articles section not found")
        # There should be at least one featured article link or a no articles message
        featured_links = featured_section.find_all('a')
        no_featured_msg = featured_section.find('p')
        self.assertTrue(len(featured_links) > 0 or (no_featured_msg and "No featured articles" in no_featured_msg.text),
                        "Featured articles section should have links or no articles message")
        # Check trending-articles section
        trending_section = soup.find('section', id='trending-articles')
        self.assertIsNotNone(trending_section, "Trending articles section not found")
        trending_links = trending_section.find_all('a')
        no_trending_msg = trending_section.find('p')
        self.assertTrue(len(trending_links) > 0 or (no_trending_msg and "No trending articles" in no_trending_msg.text),
                        "Trending articles section should have links or no articles message")
        # Check buttons by id
        browse_btn = soup.find('button', id='browse-articles-button')
        self.assertIsNotNone(browse_btn, "Browse Articles button not found")
        view_bookmarks_btn = soup.find('button', id='view-bookmarks-button')
        self.assertIsNotNone(view_bookmarks_btn, "View Bookmarks button not found")
        trending_btn = soup.find('button', id='trending-articles-button')
        self.assertIsNotNone(trending_btn, "Trending Articles button not found")
    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons have correct hrefs in onclick or form actions
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        browse_btn = soup.find('button', id='browse-articles-button')
        self.assertIn('/articles', browse_btn.get('onclick', ''), "Browse Articles button does not navigate to /articles")
        view_bookmarks_btn = soup.find('button', id='view-bookmarks-button')
        self.assertIn('/bookmarks', view_bookmarks_btn.get('onclick', ''), "View Bookmarks button does not navigate to /bookmarks")
        trending_btn = soup.find('button', id='trending-articles-button')
        self.assertIn('/trending', trending_btn.get('onclick', ''), "Trending Articles button does not navigate to /trending")
if __name__ == '__main__':
    unittest.main()

