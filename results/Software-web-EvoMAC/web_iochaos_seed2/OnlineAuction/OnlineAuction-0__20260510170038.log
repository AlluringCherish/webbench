templates/dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
<div id="dashboard-page">
    <h1>Auction Dashboard</h1>

    <section id="featured-auctions">
        <h2>Featured Auctions</h2>
        {% if featured_auctions %}
            <div class="featured-auctions-list">
                {% for auction in featured_auctions %}
                    <div class="auction-card" id="featured-auction-{{ auction.auction_id }}">
                        <img src="{{ url_for('static', filename='images/' + auction.image_url) }}" alt="{{ auction.item_name }}" class="auction-image" />
                        <h3>{{ auction.item_name }}</h3>
                        <p>Current Bid: ${{ '%.2f'|format(auction.current_bid) }}</p>
                        <p>Ends: {{ auction.end_time }}</p>
                        <form action="{{ url_for('auction_details', auction_id=auction.auction_id) }}" method="get">
                            <button type="submit" id="view-auction-button-{{ auction.auction_id }}">View Details</button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p>No featured auctions available.</p>
        {% endif %}
    </section>

    <section id="trending-auctions-section">
        <h2>Trending Auctions</h2>
        {% if trending_auctions %}
            <ul id="trending-auctions-list">
                {% for trend in trending_auctions %}
                    <li>
                        <strong>#{{ trend.trending_rank }}:</strong> {{ trend.item_name }} - Current Bid: ${{ '%.2f'|format(trend.current_bid) }} - Bids: {{ trend.bid_count }}
                        <form action="{{ url_for('auction_details', auction_id=trend.auction_id) }}" method="get" style="display:inline;">
                            <button type="submit" id="view-auction-button-{{ trend.auction_id }}">View Details</button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No trending auctions available.</p>
        {% endif %}
    </section>

    <nav id="dashboard-navigation">
        <button id="browse-auctions-button" onclick="location.href='{{ url_for('auction_catalog') }}'">Browse Auctions</button>
        <button id="view-bids-button" onclick="location.href='{{ url_for('bid_history') }}'">View Bid History</button>
        <button id="trending-auctions-button" onclick="location.href='{{ url_for('trending_auctions') }}'">Trending Auctions</button>
    </nav>
</div>
</body>
</html>
```
