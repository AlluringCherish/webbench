        self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")
    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements with correct IDs
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check dashboard-page div container
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' not found")
        # Check featured-auctions div
        featured_div = soup.find('div', id='featured-auctions')
        self.assertIsNotNone(featured_div, "Featured auctions div with id 'featured-auctions' not found")
        # Check browse-auctions-button button
        browse_btn = soup.find('button', id='browse-auctions-button')
        self.assertIsNotNone(browse_btn, "Browse auctions button with id 'browse-auctions-button' not found")
        # Check view-bids-button button
        view_bids_btn = soup.find('button', id='view-bids-button')
        self.assertIsNotNone(view_bids_btn, "View bids button with id 'view-bids-button' not found")
        # Check trending-auctions-button button
        trending_btn = soup.find('button', id='trending-auctions-button')
        self.assertIsNotNone(trending_btn, "Trending auctions button with id 'trending-auctions-button' not found")
    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons exist and have correct attributes (e.g. type=button)
