from bs4 import BeautifulSoup
class OnlineAuctionDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.testing = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible at '/'
