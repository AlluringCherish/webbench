'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of ALL pages, verifying presence and correctness of required elements on each page.
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class MovieTicketingTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_01_dashboard_accessible(self):
        # Test Task 1: Access dashboard page at '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check page title
        self.assertIn(b'Movie Ticketing Dashboard', response.data)
    def test_02_dashboard_elements(self):
        # Test Task 3: Check dashboard page elements
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check container div id
        self.assertIsNotNone(soup.find('div', id='dashboard-page'))
        # Check featured movies section
        self.assertIsNotNone(soup.find('section', id='featured-movies'))
        # Check upcoming releases section
        self.assertIsNotNone(soup.find('section', id='upcoming-releases'))
        # Check navigation buttons by id
        self.assertIsNotNone(soup.find('button', id='browse-movies-button'))
        self.assertIsNotNone(soup.find('button', id='view-bookings-button'))
        self.assertIsNotNone(soup.find('button', id='showtimes-button'))
    def test_03_movie_catalog_page_elements(self):
        # Access movie catalog page
        response = self.client.get('/movie_catalog')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='catalog-page'))
        self.assertIsNotNone(soup.find('input', id='search-input'))
        self.assertIsNotNone(soup.find('select', id='genre-filter'))
        self.assertIsNotNone(soup.find('div', id='movies-grid'))
        # Check at least one view movie button if movies exist
        buttons = soup.find_all('button')
        view_buttons = [b for b in buttons if b.get('id', '').startswith('view-movie-button-')]
        self.assertTrue(len(view_buttons) >= 0)  # zero or more allowed if no movies
    def test_04_movie_details_page_elements(self):
        # Use example movie_id=1 (The Matrix)
        response = self.client.get('/movie_details/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='movie-details-page'))
        self.assertIsNotNone(soup.find('h1', id='movie-title'))
        self.assertIsNotNone(soup.find('div', id='movie-director'))
        self.assertIsNotNone(soup.find('div', id='movie-rating'))
        self.assertIsNotNone(soup.find('div', id='movie-description'))
        self.assertIsNotNone(soup.find('button', id='select-showtime-button'))
    def test_05_showtime_selection_page_elements(self):
        # Use example movie_id=1
        response = self.client.get('/showtime_selection/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='showtime-page'))
        self.assertIsNotNone(soup.find('div', id='showtimes-list'))
        self.assertIsNotNone(soup.find('select', id='theater-filter'))
        self.assertIsNotNone(soup.find('input', id='date-filter'))
        # Check for at least one select showtime button if showtimes exist
        buttons = soup.find_all('button')
        select_buttons = [b for b in buttons if b.get('id', '').startswith('select-showtime-button-')]
        self.assertTrue(len(select_buttons) >= 0)
    def test_06_seat_selection_page_elements(self):
        # Use example showtime_id=1
        response = self.client.get('/seat_selection/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='seat-selection-page'))
        self.assertIsNotNone(soup.find('div', id='seat-map'))
        self.assertIsNotNone(soup.find('div', id='selected-seats-display'))
        # Check for at least one seat button with id pattern seat-{row}{col}
        seat_buttons = soup.find_all('button')
        seat_btns = [b for b in seat_buttons if b.get('id', '').startswith('seat-')]
        self.assertTrue(len(seat_btns) >= 0)
        self.assertIsNotNone(soup.find('button', id='proceed-booking-button'))
    def test_07_booking_confirmation_page_elements(self):
        # Use example showtime_id=1 and seats A1,A2 (simulate query string)
        response = self.client.get('/booking_confirmation/1?seats=A1,A2')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='confirmation-page'))
        self.assertIsNotNone(soup.find('div', id='booking-summary'))
        self.assertIsNotNone(soup.find('input', id='customer-name'))
        self.assertIsNotNone(soup.find('input', id='customer-email'))
        self.assertIsNotNone(soup.find('button', id='confirm-booking-button'))
    def test_08_booking_history_page_elements(self):
        response = self.client.get('/booking_history')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='bookings-page'))
        self.assertIsNotNone(soup.find('table', id='bookings-table'))
        # Check for status filter dropdown
        self.assertIsNotNone(soup.find('select', id='status-filter'))
        # Check for back to dashboard button
        self.assertIsNotNone(soup.find('button', id='back-to-dashboard'))
        # Check for at least one view booking button if bookings exist
        buttons = soup.find_all('button')
        view_buttons = [b for b in buttons if b.get('id', '').startswith('view-booking-button-')]
        self.assertTrue(len(view_buttons) >= 0)
    def test_09_theater_information_page_elements(self):
        response = self.client.get('/theater_information')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find('div', id='theater-page'))
        self.assertIsNotNone(soup.find('div', id='theaters-list'))
        self.assertIsNotNone(soup.find('select', id='theater-location-filter'))
        self.assertIsNotNone(soup.find('div', id='facilities-display'))
        self.assertIsNotNone(soup.find('button', id='back-to-dashboard'))
    def test_10_navigation_buttons(self):
        # Test navigation routes from dashboard buttons
        response = self.client.get('/navigate_to_catalog')
        self.assertEqual(response.status_code, 302)  # Redirect
        response = self.client.get('/navigate_to_bookings')
        self.assertEqual(response.status_code, 302)
        response = self.client.get('/navigate_to_showtimes')
        self.assertEqual(response.status_code, 302)
        response = self.client.get('/back_to_dashboard')
        self.assertEqual(response.status_code, 302)
if __name__ == '__main__':
    unittest.main()

