showtimes.html
```html
'''
Showtimes overview page template.
Displays all showtimes with filtering options by theater and date.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Showtimes</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
<div id="showtime-page">
    <h1>Showtimes</h1>
    <div id="filters">
        <label for="theater-filter">Filter by Theater:</label>
        <select id="theater-filter" name="theater">
            <option value="All" {% if theater_filter == 'All' %}selected{% endif %}>All</option>
            {% for theater in theaters %}
                <option value="{{ theater.theater_id }}" {% if theater_filter == theater.theater_id %}selected{% endif %}>{{ theater.theater_name }}</option>
            {% endfor %}
        </select>
        <label for="date-filter">Filter by Date:</label>
        <input type="date" id="date-filter" name="date" value="{{ date_filter }}">
    </div>
    <div id="showtimes-list">
        {% if showtimes %}
            <table>
                <thead>
                    <tr>
                        <th>Movie</th>
                        <th>Theater</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Price</th>
                        <th>Available Seats</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for showtime in showtimes %}
                        <tr>
                            <td>
                                {% set movie = None %}
                                {% for m in movies %}
                                    {% if m.movie_id == showtime.movie_id %}
                                        {% set movie = m %}
                                    {% endif %}
                                {% endfor %}
                                {{ movie.title if movie else 'Unknown' }}
                            </td>
                            <td>{{ showtime.theater_name }}</td>
                            <td>{{ showtime.showtime_date }}</td>
                            <td>{{ showtime.showtime_time }}</td>
                            <td>${{ "%.2f"|format(showtime.price) }}</td>
                            <td>{{ showtime.available_seats }}</td>
                            <td>
                                <form action="{{ url_for('seat_selection', showtime_id=showtime.showtime_id) }}" method="get">
                                    <button type="submit" id="select-showtime-button-{{ showtime.showtime_id }}">Select</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>No showtimes available for the selected filters.</p>
        {% endif %}
    </div>
    <button onclick="location.href='{{ url_for('back_to_dashboard') }}'">Back to Dashboard</button>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const theaterFilter = document.getElementById('theater-filter');
    const dateFilter = document.getElementById('date-filter');

    function applyShowtimeFilters() {
        const theater = theaterFilter ? encodeURIComponent(theaterFilter.value) : 'All';
        const date = dateFilter ? encodeURIComponent(dateFilter.value) : '';
        let url = '/showtimes?theater=' + theater;
        if (date) {
            url += '&date=' + date;
        }
        window.location.href = url;
    }

    if (theaterFilter) {
        theaterFilter.addEventListener('change', applyShowtimeFilters);
    }
    if (dateFilter) {
        dateFilter.addEventListener('change', applyShowtimeFilters);
    }
});
</script>
</body>
</html>
