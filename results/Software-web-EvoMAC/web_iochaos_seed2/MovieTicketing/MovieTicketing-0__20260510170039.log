        function submitFilterForm() {
            document.getElementById('filter-form').submit();
        }
    </script>
</head>
<body>
<div id="catalog-page">
    <h1>Movie Catalog</h1>
    <form id="filter-form" action="{{ url_for('movie_catalog') }}" method="get">
        <label for="search-input">Search:</label>
        <input type="text" id="search-input" name="search" value="{{ search_term }}" placeholder="Search by title or genre">
        <label for="genre-filter">Genre:</label>
        <select id="genre-filter" name="genre" onchange="submitFilterForm()">
            {% for genre in genres %}
                <option value="{{ genre }}" {% if genre == selected_genre %}selected{% endif %}>{{ genre }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="movies-grid" class="movies-grid">
        {% if movies %}
            {% for movie in movies %}
                <div class="movie-card">
                    <h3>{{ movie.title }}</h3>
                    <p><strong>Rating:</strong> {{ movie.rating }}</p>
                    <p><strong>Duration:</strong> {{ movie.duration }} min</p>
                    <p><strong>Genre:</strong> {{ movie.genre }}</p>
                    <form action="{{ url_for('movie_details', movie_id=movie.movie_id) }}" method="get">
