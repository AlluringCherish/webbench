/*
JavaScript for MovieTicketing web application.
Supports interactive elements such as seat selection,
dynamic filtering, and navigation.
*/

// Seat selection logic for seat_selection.html
document.addEventListener('DOMContentLoaded', function () {
    const seatMap = document.getElementById('seat-map');
    if (!seatMap) return;

    const selectedSeatsDisplay = document.getElementById('selected-seats-display');
    const proceedBookingButton = document.getElementById('proceed-booking-button');

    // Keep track of selected seats
    let selectedSeats = new Set();

    // Add click event listeners to all seat buttons
    const seatButtons = seatMap.querySelectorAll('button[id^="seat-"]');
    seatButtons.forEach(button => {
        if (button.classList.contains('booked')) {
            // Booked seats are not clickable
            button.disabled = true;
            return;
        }
        button.addEventListener('click', function () {
            const seatId = this.id.replace('seat-', '');
            if (selectedSeats.has(seatId)) {
                // Deselect seat
                selectedSeats.delete(seatId);
                this.classList.remove('selected');
            } else {
                // Select seat
                selectedSeats.add(seatId);
                this.classList.add('selected');
            }
            updateSelectedSeatsDisplay();
        });
    });

    function updateSelectedSeatsDisplay() {
        if (selectedSeats.size === 0) {
            selectedSeatsDisplay.textContent = 'No seats selected.';
            proceedBookingButton.disabled = true;
        } else {
            // Sort seats alphabetically by row and then column
            const sortedSeats = Array.from(selectedSeats).sort((a, b) => {
                const rowA = a.charAt(0);
                const rowB = b.charAt(0);
                if (rowA < rowB) return -1;
                if (rowA > rowB) return 1;
                // Compare numeric part
                const numA = parseInt(a.slice(1));
                const numB = parseInt(b.slice(1));
                return numA - numB;
            });
            selectedSeatsDisplay.textContent = 'Selected Seats: ' + sortedSeats.join(', ');
            proceedBookingButton.disabled = false;
        }
    }

    // Initialize display
    updateSelectedSeatsDisplay();

    // On form submission, add selected seats as hidden inputs
    const seatForm = document.getElementById('seat-selection-form');
    if (seatForm) {
        seatForm.addEventListener('submit', function (e) {
            if (selectedSeats.size === 0) {
                e.preventDefault();
                alert('Please select at least one seat before proceeding.');
                return false;
            }
            // Remove any existing hidden inputs for seats
            const existingInputs = seatForm.querySelectorAll('input[name="selected_seats"]');
            existingInputs.forEach(input => input.remove());
            // Add hidden inputs for each selected seat
            selectedSeats.forEach(seat => {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'selected_seats';
                hiddenInput.value = seat;
                seatForm.appendChild(hiddenInput);
            });
        });
    }
});

// Dynamic filtering for movie_catalog.html
document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('search-input');
    const genreFilter = document.getElementById('genre-filter');

    if (searchInput && genreFilter) {
        // On change or enter key, submit the form or reload page with query params
        function applyFilters() {
            const search = encodeURIComponent(searchInput.value.trim());
            const genre = encodeURIComponent(genreFilter.value);
            let url = '/movie_catalog?';
            if (search) {
                url += 'search=' + search + '&';
            }
            if (genre && genre !== 'All') {
                url += 'genre=' + genre;
            }
            window.location.href = url;
        }

        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                applyFilters();
            }
        });

        genreFilter.addEventListener('change', function () {
            applyFilters();
        });
    }
});

// Dynamic filtering for showtime_selection.html
document.addEventListener('DOMContentLoaded', function () {
    const theaterFilter = document.getElementById('theater-filter');
    const dateFilter = document.getElementById('date-filter');

    if (theaterFilter || dateFilter) {
        function applyShowtimeFilters() {
            const theater = theaterFilter ? encodeURIComponent(theaterFilter.value) : 'All';
            const date = dateFilter ? encodeURIComponent(dateFilter.value) : '';
            // The current URL path contains movie_id, keep it
            const pathParts = window.location.pathname.split('/');
            // Expected path: /showtime_selection/<movie_id>
            if (pathParts.length < 3) return;
            const movieId = pathParts[2];
            let url = `/showtime_selection/${movieId}?theater=${theater}`;
            if (date) {
                url += `&date=${date}`;
            }
            window.location.href = url;
        }

        if (theaterFilter) {
            theaterFilter.addEventListener('change', applyShowtimeFilters);
        }
        if (dateFilter) {
            dateFilter.addEventListener('change', applyShowtimeFilters);
        }
    }
});

// Dynamic filtering for booking_history.html
document.addEventListener('DOMContentLoaded', function () {
    const statusFilter = document.getElementById('status-filter');
    if (statusFilter) {
        statusFilter.addEventListener('change', function () {
            const status = encodeURIComponent(statusFilter.value);
            let url = '/booking_history?status=' + status;
            window.location.href = url;
        });
    }
});

// Dynamic filtering for theater_information.html
document.addEventListener('DOMContentLoaded', function () {
    const locationFilter = document.getElementById('theater-location-filter');
    if (locationFilter) {
        locationFilter.addEventListener('change', function () {
            const location = encodeURIComponent(locationFilter.value);
            let url = '/theater_information?location=' + location;
            window.location.href = url;
        });
    }
});
