<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Movie Ticketing Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="dashboard-page">
    <h1>Movie Ticketing Dashboard</h1>
    <section id="featured-movies">
        <h2>Featured Movies</h2>
        {% if featured_movies %}
            <div class="movies-list">
                {% for movie in featured_movies %}
                    <div class="movie-card">
                        <h3>{{ movie.title }}</h3>
                        <p><strong>Rating:</strong> {{ movie.rating }}</p>
                        <p><strong>Genre:</strong> {{ movie.genre }}</p>
                        <p><strong>Duration:</strong> {{ movie.duration }} min</p>
                        <form action="{{ url_for('movie_details', movie_id=movie.movie_id) }}" method="get">
                            <button type="submit" id="view-movie-button-{{ movie.movie_id }}">View Details</button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p>No featured movies available.</p>
        {% endif %}
    </section>
    <section id="upcoming-releases">
        <h2>Upcoming Releases</h2>
        {% if upcoming_releases %}
            <ul>
                {% for movie in upcoming_releases %}
                    <li>
                        <strong>{{ movie.title }}</strong> - Release Date: {{ movie.release_date }}
                        <form style="display:inline;" action="{{ url_for('movie_details', movie_id=movie.movie_id) }}" method="get">
                            <button type="submit" id="view-movie-button-{{ movie.movie_id }}">View Details</button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No upcoming releases.</p>
        {% endif %}
    </section>
    <nav id="dashboard-navigation">
        <button id="browse-movies-button" onclick="location.href='{{ url_for('navigate_to_catalog') }}'">Browse Movies</button>
        <button id="view-bookings-button" onclick="location.href='{{ url_for('navigate_to_bookings') }}'">View Bookings</button>
        <button id="showtimes-button" onclick="location.href='{{ url_for('navigate_to_showtimes') }}'">Showtimes</button>
    </nav>
</div>
</body>
</html>
