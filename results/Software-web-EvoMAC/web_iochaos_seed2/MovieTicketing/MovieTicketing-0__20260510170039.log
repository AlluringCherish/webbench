                <option value="{{ theater.theater_id }}" {% if theater.theater_id == theater_filter %}selected{% endif %}>{{ theater.theater_name }}</option>
            {% endfor %}
            <option value="All" {% if theater_filter == 'All' %}selected{% endif %}>All</option>
