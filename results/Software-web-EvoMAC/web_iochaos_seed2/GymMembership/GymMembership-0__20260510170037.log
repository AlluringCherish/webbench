<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <style>
        #dashboard-page {
            max-width: 900px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #member-welcome {
            background-color: #e0f7fa;
