'''
Personal Training Booking page template for GymMembership web application.
Includes form to book a session with a trainer.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>
<body>
<div id="booking-page">
    <h1>Book Personal Training</h1>
    {% if error %}
    <div class="error-message">{{ error }}</div>
    {% endif %}
    {% if success %}
    <div class="success-message">{{ success }}</div>
    {% endif %}
    <form method="post" action="{{ url_for('pt_booking') }}">
        <label for="member-name">Your Name</label>
        <input type="text" id="member-name" name="member_name" required
               value="{{ form_data.member_name if form_data and form_data.member_name else '' }}">
        
        <label for="select-trainer">Select Trainer</label>
        <select id="select-trainer" name="select_trainer" required>
            <option value="">-- Select Trainer --</option>
            {% for trainer in trainers %}
            <option value="{{ trainer.trainer_id }}"
                {% if form_data and form_data.select_trainer == trainer.trainer_id %}selected{% endif %}>
                {{ trainer.name }} ({{ trainer.specialty }})
            </option>
            {% endfor %}
        </select>
        
        <label for="session-date">Session Date</label>
        <input type="date" id="session-date" name="session_date" required
               value="{{ form_data.session_date if form_data and form_data.session_date else '' }}">
        
        <label for="session-time">Session Time</label>
        <select id="session-time" name="session_time" required>
            <option value="">-- Select Time --</option>
            {% set times = ['06:00', '07:00', '08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00', '19:00', '20:00'] %}
            {% for time in times %}
            <option value="{{ time }}" {% if form_data and form_data.session_time == time %}selected{% endif %}>{{ time }}</option>
            {% endfor %}
        </select>
        
        <label for="session-duration">Session Duration (minutes)</label>
        <select id="session-duration" name="session_duration" required>
            <option value="">-- Select Duration --</option>
            {% for duration in [30, 60, 90] %}
            <option value="{{ duration }}" {% if form_data and form_data.session_duration == duration|string %}selected{% endif %}>{{ duration }}</option>
            {% endfor %}
        </select>
        
        <button type="submit" id="confirm-booking-button">Confirm Booking</button>
    </form>
    <nav>
        <a href="{{ url_for('dashboard') }}">Dashboard</a> |
        <a href="{{ url_for('membership_plans') }}">Membership Plans</a> |
        <a href="{{ url_for('class_schedule') }}">Class Schedule</a> |
        <a href="{{ url_for('trainer_profiles') }}">Trainer Profiles</a> |
        <a href="{{ url_for('workout_records') }}">My Workout Records</a> |
        <a href="{{ url_for('log_workout') }}">Log Workout</a>
    </nav>
</div>
</body>
</html>
