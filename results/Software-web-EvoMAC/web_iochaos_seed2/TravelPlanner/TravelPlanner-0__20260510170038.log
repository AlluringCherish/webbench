'''
Main backend application for TravelPlanner web application.
Defines routes for all pages starting from the root '/' serving the Dashboard page.
All frontend navigation uses Flask routing URLs.
'''
from flask import Flask, render_template, request, url_for, redirect
import os

app = Flask(__name__)

DATA_DIR = 'data'

def read_destinations():
    destinations = []
    try:
        with open(os.path.join(DATA_DIR, 'destinations.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        destination = {
                            'dest_id': parts[0],
                            'name': parts[1],
                            'country': parts[2],
                            'region': parts[3],
                            'description': parts[4],
                            'attractions': parts[5],
                            'climate': parts[6]
                        }
                        destinations.append(destination)
    except FileNotFoundError:
        pass
    return destinations

def read_itineraries():
    itineraries = []
    try:
        with open(os.path.join(DATA_DIR, 'itineraries.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        itinerary = {
                            'itinerary_id': parts[0],
                            'itinerary_name': parts[1],
                            'destination': parts[2],
                            'start_date': parts[3],
                            'end_date': parts[4],
                            'activities': parts[5],
                            'status': parts[6]
                        }
                        itineraries.append(itinerary)
    except FileNotFoundError:
        pass
    return itineraries

def read_trips():
    trips = []
    try:
        with open(os.path.join(DATA_DIR, 'trips.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 8:
                        trip = {
                            'trip_id': parts[0],
                            'trip_name': parts[1],
                            'destination': parts[2],
                            'start_date': parts[3],
                            'end_date': parts[4],
                            'total_budget': parts[5],
                            'status': parts[6],
                            'created_date': parts[7]
                        }
                        trips.append(trip)
    except FileNotFoundError:
        pass
    return trips

@app.route('/')
def dashboard():
    '''
    Root route serving the Dashboard page.
    Loads featured destinations and upcoming trips with status Planned or In Progress.
    '''
    destinations = read_destinations()
    # For featured destinations, pick first 3
    featured_destinations = destinations[:3]

    trips = read_trips()
    # For upcoming trips, pick trips with status Planned or In Progress, sorted by start_date ascending, limit 3
    upcoming_trips = sorted(
        [trip for trip in trips if trip['status'] in ['Planned', 'In Progress']],
        key=lambda t: t['start_date']
    )[:3]

    return render_template('dashboard.html',
                           featured_destinations=featured_destinations,
                           upcoming_trips=upcoming_trips)

@app.route('/destinations')
def destinations():
    '''
    Destinations page.
    Supports search and region filter parameters.
    '''
    destinations = read_destinations()
    search_query = request.args.get('search', '').lower()
    region_filter = request.args.get('region', 'All')

    filtered = []
    for dest in destinations:
        if search_query and search_query not in dest['name'].lower() and search_query not in dest['country'].lower():
            continue
        if region_filter != 'All' and dest['region'] != region_filter:
            continue
        filtered.append(dest)

    return render_template('destinations.html',
                           destinations=filtered,
                           search_query=search_query,
                           region_filter=region_filter)

@app.route('/destination/<dest_id>')
def destination_details(dest_id):
    '''
    Destination Details page for a specific destination.
    '''
    destinations = read_destinations()
    destination = next((d for d in destinations if d['dest_id'] == dest_id), None)
    if not destination:
        return "Destination not found", 404
    return render_template('destination_details.html', destination=destination)

@app.route('/itinerary')
def itinerary():
    '''
    Itinerary Planning page.
    Displays all itineraries.
    '''
    itineraries = read_itineraries()
    return render_template('itinerary.html', itineraries=itineraries)

@app.route('/accommodations')
def accommodations():
    '''
    Accommodations page.
    Supports filtering by destination city and price category.
    '''
    hotels = []
    try:
        with open(os.path.join(DATA_DIR, 'hotels.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        hotel = {
                            'hotel_id': parts[0],
                            'name': parts[1],
                            'city': parts[2],
                            'rating': parts[3],
                            'price_per_night': parts[4],
                            'amenities': parts[5],
                            'category': parts[6]
                        }
                        hotels.append(hotel)
    except FileNotFoundError:
        pass

    destination_input = request.args.get('destination', '').lower()
    price_filter = request.args.get('price', 'All')

    filtered = []
    for hotel in hotels:
        if destination_input and destination_input not in hotel['city'].lower():
            continue
        if price_filter != 'All' and hotel['category'] != price_filter:
            continue
        filtered.append(hotel)

    return render_template('accommodations.html',
                           hotels=filtered,
                           destination_input=destination_input,
                           price_filter=price_filter)

@app.route('/transportation')
def transportation():
    '''
    Transportation page for booking flights.
    Supports filtering by departure city, arrival city, and flight class.
    '''
    flights = []
    try:
        with open(os.path.join(DATA_DIR, 'flights.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 9:
                        flight = {
                            'flight_id': parts[0],
                            'airline': parts[1],
                            'departure_city': parts[2],
                            'arrival_city': parts[3],
                            'departure_time': parts[4],
                            'arrival_time': parts[5],
                            'price': parts[6],
                            'class_type': parts[7],
                            'duration': parts[8]
                        }
                        flights.append(flight)
    except FileNotFoundError:
        pass

    departure_city = request.args.get('departure_city', '').lower()
    arrival_city = request.args.get('arrival_city', '').lower()
    flight_class = request.args.get('flight_class', 'All')

    filtered = []
    for flight in flights:
        if departure_city and departure_city not in flight['departure_city'].lower():
            continue
        if arrival_city and arrival_city not in flight['arrival_city'].lower():
            continue
        if flight_class != 'All' and flight['class_type'] != flight_class:
            continue
        filtered.append(flight)

    return render_template('transportation.html',
                           flights=filtered,
                           departure_city=departure_city,
                           arrival_city=arrival_city,
                           flight_class=flight_class)

@app.route('/packages')
def packages():
    '''
    Travel Packages page.
    Supports filtering by duration.
    '''
    packages = []
    try:
        with open(os.path.join(DATA_DIR, 'packages.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        package = {
                            'package_id': parts[0],
                            'package_name': parts[1],
                            'destination': parts[2],
                            'duration_days': parts[3],
                            'price': parts[4],
                            'included_items': parts[5],
                            'difficulty_level': parts[6]
                        }
                        packages.append(package)
    except FileNotFoundError:
        pass

    duration_filter = request.args.get('duration', 'All')

    filtered = []
    for pkg in packages:
        try:
            dur = int(pkg['duration_days'])
        except ValueError:
            continue
        if duration_filter == '3-5 days':
            if dur < 3 or dur > 5:
                continue
        elif duration_filter == '7-10 days':
            if dur < 7 or dur > 10:
                continue
        elif duration_filter == '14+ days':
            if dur < 14:
                continue
        filtered.append(pkg)

    return render_template('packages.html',
                           packages=filtered,
                           duration_filter=duration_filter)

@app.route('/trips')
def trips():
    '''
    Trip Management page.
    Displays all trips.
    '''
    trips = read_trips()
    return render_template('trips.html', trips=trips)

@app.route('/booking_confirmation/<booking_id>')
def booking_confirmation(booking_id):
    '''
    Booking Confirmation page.
    Displays booking details for a given booking ID.
    '''
    bookings = []
    try:
        with open(os.path.join(DATA_DIR, 'bookings.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        booking = {
                            'booking_id': parts[0],
                            'trip_id': parts[1],
                            'booking_type': parts[2],
                            'booking_date': parts[3],
                            'amount': parts[4],
                            'confirmation_number': parts[5],
                            'status': parts[6]
                        }
                        bookings.append(booking)
    except FileNotFoundError:
        pass

    booking = next((b for b in bookings if b['booking_id'] == booking_id), None)
    if not booking:
        return "Booking not found", 404

    return render_template('booking_confirmation.html', booking=booking)

@app.route('/recommendations')
def recommendations():
    '''
    Travel Recommendations page.
    Supports filtering by season and budget.
    '''
    destinations = read_destinations()
    # For demo, trending destinations sorted by name (popularity logic can be added)
    trending_destinations = sorted(destinations, key=lambda d: d['name'])

    season_filter = request.args.get('season', '')
    budget_filter = request.args.get('budget', '')

    # Filtering logic can be implemented here based on season and budget
    # For now, just pass all trending destinations

    return render_template('recommendations.html',
                           trending_destinations=trending_destinations,
                           season_filter=season_filter,
                           budget_filter=budget_filter)

if __name__ == '__main__':
    app.run(debug=True)
