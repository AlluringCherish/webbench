        # Test Task 1: Access root URL and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_title(self):
        # Test Task 2: Check page title in HTML content
        response = self.client.get('/')
        self.assertIn(b'<title>Travel Planner Dashboard</title>', response.data,
                      "Dashboard page should have correct page title")
    def test_dashboard_elements_presence(self):
        # Test Task 3: Check presence of main container and key elements by their IDs
        response = self.client.get('/')
