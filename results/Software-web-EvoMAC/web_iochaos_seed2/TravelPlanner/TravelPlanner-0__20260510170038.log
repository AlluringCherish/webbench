'''
Dashboard page template for TravelPlanner.
Displays featured destinations, upcoming trips, and navigation buttons.
Uses Flask url_for for navigation links.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Travel Planner Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Travel Planner Dashboard</h1>

        <div id="featured-destinations">
            <h2>Featured Destinations</h2>
            <ul>
                {% for dest in featured_destinations %}
                <li>
                    <strong>{{ dest.name }}</strong> - {{ dest.country }}
                    <a href="{{ url_for('destination_details', dest_id=dest.dest_id) }}">View Details</a>
                </li>
                {% endfor %}
            </ul>
        </div>

        <div id="upcoming-trips">
            <h2>Upcoming Trips</h2>
            <ul>
                {% for trip in upcoming_trips %}
                <li>
                    <strong>{{ trip.trip_name }}</strong> to {{ trip.destination }} from {{ trip.start_date }} to {{ trip.end_date }}
                </li>
                {% endfor %}
            </ul>
        </div>

        <div>
            <button id="browse-destinations-button" onclick="location.href='{{ url_for('destinations') }}'">Browse Destinations</button>
            <button id="plan-itinerary-button" onclick="location.href='{{ url_for('itinerary') }}'">Plan Itinerary</button>
        </div>
    </div>
</body>
</html>
