'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly and basic navigation buttons exist.
Test the presence and correctness of specified elements on the Dashboard page as per requirements.
'''

import unittest
from main import app

class TestOnlineLibraryDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test if the dashboard page is accessible via GET request
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test if the page title is "Library Dashboard"
        response = self.client.get('/')
        self.assertIn(b'<title>Library Dashboard</title>', response.data, "Dashboard page title should be 'Library Dashboard'")

    def test_dashboard_elements_presence(self):
        # Test presence of main container div with id 'dashboard-page'
        response = self.client.get('/')
        self.assertIn(b'id="dashboard-page"', response.data, "Dashboard page should contain div with id 'dashboard-page'")

        # Test presence of welcome message with id 'welcome-message'
        self.assertIn(b'id="welcome-message"', response.data, "Dashboard page should contain welcome message with id 'welcome-message'")

        # Test presence of browse books button with id 'browse-books-button'
        self.assertIn(b'id="browse-books-button"', response.data, "Dashboard page should contain 'browse-books-button'")

        # Test presence of my borrows button with id 'my-borrows-button'
        self.assertIn(b'id="my-borrows-button"', response.data, "Dashboard page should contain 'my-borrows-button'")

    def test_dashboard_navigation_buttons_functionality(self):
        # Since this is a unit test without browser, test that buttons link to correct routes in HTML
        response = self.client.get('/')
        html = response.data.decode('utf-8')

        # Check that browse-books-button navigates to book catalog page (assumed route '/catalog')
        self.assertIn("id=\"browse-books-button\"", html)
        self.assertIn("url_for('catalog')", html or "")  # url_for usage in template

        # Check that my-borrows-button navigates to my borrowings page (assumed route '/my-borrows')
        self.assertIn("id=\"my-borrows-button\"", html)
        self.assertIn("url_for('my_borrows')", html or "")

if __name__ == '__main__':
    unittest.main()
```
