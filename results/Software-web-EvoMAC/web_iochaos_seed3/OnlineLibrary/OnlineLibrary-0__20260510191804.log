'''
Main Flask application for OnlineLibrary web application.
Ensures root route '/' serves the Dashboard page as the first page.
All navigation uses Flask routing URLs via url_for for maintainability and correctness.
'''
from flask import Flask, render_template, request, redirect, url_for
import os
from datetime import datetime, timedelta

app = Flask(__name__)

DATA_DIR = 'data'

# Helper functions to load data from text files
def load_users():
    users = {}
    try:
        with open(os.path.join(DATA_DIR, 'users.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    username, email, phone, address = line.split('|')
                    users[username] = {
                        'email': email,
                        'phone': phone,
                        'address': address
                    }
    except FileNotFoundError:
        pass
    return users

def load_books():
    books = {}
    try:
        with open(os.path.join(DATA_DIR, 'books.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    book_id = parts[0]
                    books[book_id] = {
                        'book_id': book_id,
                        'title': parts[1],
                        'author': parts[2],
                        'isbn': parts[3],
                        'genre': parts[4],
                        'publisher': parts[5],
                        'year': parts[6],
                        'description': parts[7],
                        'status': parts[8],
                        'avg_rating': parts[9]
                    }
    except FileNotFoundError:
        pass
    return books

def load_borrowings():
    borrowings = []
    try:
        with open(os.path.join(DATA_DIR, 'borrowings.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    borrowings.append({
                        'borrow_id': parts[0],
                        'username': parts[1],
                        'book_id': parts[2],
                        'borrow_date': parts[3],
                        'due_date': parts[4],
                        'return_date': parts[5],
                        'status': parts[6],
                        'fine_amount': parts[7]
                    })
    except FileNotFoundError:
        pass
    return borrowings

def load_reservations():
    reservations = []
    try:
        with open(os.path.join(DATA_DIR, 'reservations.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    reservations.append({
                        'reservation_id': parts[0],
                        'username': parts[1],
                        'book_id': parts[2],
                        'reservation_date': parts[3],
                        'status': parts[4]
                    })
    except FileNotFoundError:
        pass
    return reservations

def load_reviews():
    reviews = []
    try:
        with open(os.path.join(DATA_DIR, 'reviews.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    reviews.append({
                        'review_id': parts[0],
                        'username': parts[1],
                        'book_id': parts[2],
                        'rating': parts[3],
                        'review_text': parts[4],
                        'review_date': parts[5]
                    })
    except FileNotFoundError:
        pass
    return reviews

def load_fines():
    fines = []
    try:
        with open(os.path.join(DATA_DIR, 'fines.txt'), 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    fines.append({
                        'fine_id': parts[0],
                        'username': parts[1],
                        'borrow_id': parts[2],
                        'amount': parts[3],
                        'status': parts[4],
                        'date_issued': parts[5]
                    })
    except FileNotFoundError:
        pass
    return fines

# For demonstration, we assume a logged-in user 'john_reader'
current_user = 'john_reader'

@app.route('/')
def dashboard():
    '''
    Route for the Dashboard page.
    Displays welcome message and navigation buttons.
    '''
    # For featured books, show first 3 available books
    books = load_books()
    featured_books = [b for b in books.values() if b['status'] == 'Available'][:3]
    return render_template('dashboard.html', username=current_user, featured_books=featured_books)

@app.route('/catalog')
def catalog():
    '''
    Route for the Book Catalog page.
    Displays all books with search and filter options.
    '''
    books = load_books()
    search_query = request.args.get('search', '').lower()
    filtered_books = []
    for book in books.values():
        if search_query in book['title'].lower() or search_query in book['author'].lower():
            filtered_books.append(book)
    if not search_query:
        filtered_books = list(books.values())
    return render_template('catalog.html', books=filtered_books, search_query=search_query)

@app.route('/book/<book_id>')
def book_details(book_id):
    '''
    Route for the Book Details page.
    Displays detailed info about a specific book.
    '''
    books = load_books()
    book = books.get(book_id)
    if not book:
        return "Book not found", 404
    reviews = load_reviews()
    book_reviews = [r for r in reviews if r['book_id'] == book_id]
    return render_template('book_details.html', book=book, reviews=book_reviews)

@app.route('/borrow-confirmation/<book_id>', methods=['GET', 'POST'])
def borrow_confirmation(book_id):
    '''
    Route for Borrow Confirmation page.
    GET: Show borrow details and due date.
    POST: Confirm or cancel borrowing.
    '''
    books = load_books()
    book = books.get(book_id)
    if not book:
        return "Book not found", 404

    if request.method == 'POST':
        if 'confirm' in request.form:
            # Process borrowing: add entry to borrowings.txt
            borrowings = load_borrowings()
            new_borrow_id = str(max([int(b['borrow_id']) for b in borrowings], default=0) + 1)
            borrow_date = datetime.now().strftime('%Y-%m-%d')
            due_date = (datetime.now() + timedelta(days=14)).strftime('%Y-%m-%d')
            new_borrow = f"{new_borrow_id}|{current_user}|{book_id}|{borrow_date}|{due_date}||Active|0"
            with open(os.path.join(DATA_DIR, 'borrowings.txt'), 'a', encoding='utf-8') as f:
                f.write(new_borrow + '\n')
            # Update book status to Borrowed
            # Reload books and rewrite file with updated status
            books[book_id]['status'] = 'Borrowed'
            with open(os.path.join(DATA_DIR, 'books.txt'), 'w', encoding='utf-8') as f:
                for b in books.values():
                    line = '|'.join([
                        b['book_id'], b['title'], b['author'], b['isbn'], b['genre'],
                        b['publisher'], b['year'], b['description'], b['status'], b['avg_rating']
                    ])
                    f.write(line + '\n')
            return redirect(url_for('my_borrows'))
        else:
            # Cancel borrow, redirect back to book details
            return redirect(url_for('book_details', book_id=book_id))

    due_date = (datetime.now() + timedelta(days=14)).strftime('%Y-%m-%d')
    return render_template('borrow_confirmation.html', book=book, due_date=due_date)

@app.route('/my-borrows')
def my_borrows():
    '''
    Route for My Borrowings page.
    Displays all books currently borrowed by the user with filter options.
    '''
    borrowings = load_borrowings()
    books = load_books()
    filter_status = request.args.get('filter', 'All')
    user_borrows = [b for b in borrowings if b['username'] == current_user]

    if filter_status != 'All':
        user_borrows = [b for b in user_borrows if b['status'] == filter_status]

    # Enrich borrowings with book title
    for b in user_borrows:
        b['title'] = books.get(b['book_id'], {}).get('title', 'Unknown')

    return render_template('my_borrows.html', borrows=user_borrows, filter_status=filter_status)

@app.route('/return-book/<borrow_id>', methods=['POST'])
def return_book(borrow_id):
    '''
    Route to return a borrowed book.
    Updates borrowings.txt and books.txt accordingly.
    '''
    borrowings = load_borrowings()
    books = load_books()
    updated = False
    for b in borrowings:
        if b['borrow_id'] == borrow_id and b['username'] == current_user and b['status'] == 'Active':
            b['return_date'] = datetime.now().strftime('%Y-%m-%d')
            b['status'] = 'Returned'
            # Update book status to Available
            book_id = b['book_id']
            if book_id in books:
                books[book_id]['status'] = 'Available'
            updated = True
            break
    if updated:
        # Rewrite borrowings.txt
        with open(os.path.join(DATA_DIR, 'borrowings.txt'), 'w', encoding='utf-8') as f:
            for b in borrowings:
                line = '|'.join([
                    b['borrow_id'], b['username'], b['book_id'], b['borrow_date'],
                    b['due_date'], b['return_date'], b['status'], b['fine_amount']
                ])
                f.write(line + '\n')
        # Rewrite books.txt
        with open(os.path.join(DATA_DIR, 'books.txt'), 'w', encoding='utf-8') as f:
            for b in books.values():
                line = '|'.join([
                    b['book_id'], b['title'], b['author'], b['isbn'], b['genre'],
                    b['publisher'], b['year'], b['description'], b['status'], b['avg_rating']
                ])
                f.write(line + '\n')
    return redirect(url_for('my_borrows'))

@app.route('/my-reservations')
def my_reservations():
    '''
    Route for My Reservations page.
    Displays all reservations made by the user.
    '''
    reservations = load_reservations()
    books = load_books()
    user_reservations = [r for r in reservations if r['username'] == current_user]
    for r in user_reservations:
        r['title'] = books.get(r['book_id'], {}).get('title', 'Unknown')
    return render_template('my_reservations.html', reservations=user_reservations)

@app.route('/cancel-reservation/<reservation_id>', methods=['POST'])
def cancel_reservation(reservation_id):
    '''
    Route to cancel a reservation.
    Updates reservations.txt accordingly.
    '''
    reservations = load_reservations()
    updated = False
    for r in reservations:
        if r['reservation_id'] == reservation_id and r['username'] == current_user and r['status'] == 'Active':
            r['status'] = 'Cancelled'
            updated = True
            break
    if updated:
        with open(os.path.join(DATA_DIR, 'reservations.txt'), 'w', encoding='utf-8') as f:
            for r in reservations:
                line = '|'.join([
                    r['reservation_id'], r['username'], r['book_id'], r['reservation_date'], r['status']
                ])
                f.write(line + '\n')
    return redirect(url_for('my_reservations'))

@app.route('/my-reviews')
def my_reviews():
    '''
    Route for My Reviews page.
    Displays all reviews written by the user.
    '''
    reviews = load_reviews()
    books = load_books()
    user_reviews = [r for r in reviews if r['username'] == current_user]
    for r in user_reviews:
        r['title'] = books.get(r['book_id'], {}).get('title', 'Unknown')
    return render_template('my_reviews.html', reviews=user_reviews)

@app.route('/write-review/<book_id>', methods=['GET', 'POST'])
def write_review(book_id):
    '''
    Route for Write Review page.
    GET: Show form to write or edit review.
    POST: Submit review.
    '''
    books = load_books()
    book = books.get(book_id)
    if not book:
        return "Book not found", 404

    reviews = load_reviews()
    existing_review = None
    for r in reviews:
        if r['username'] == current_user and r['book_id'] == book_id:
            existing_review = r
            break

    if request.method == 'POST':
        rating = request.form.get('rating')
        review_text = request.form.get('review_text')
        review_date = datetime.now().strftime('%Y-%m-%d')

        if existing_review:
            # Update existing review
            existing_review['rating'] = rating
            existing_review['review_text'] = review_text
            existing_review['review_date'] = review_date
        else:
            # Add new review
            new_review_id = str(max([int(r['review_id']) for r in reviews], default=0) + 1)
            new_review = {
                'review_id': new_review_id,
                'username': current_user,
                'book_id': book_id,
                'rating': rating,
                'review_text': review_text,
                'review_date': review_date
            }
            reviews.append(new_review)

        # Rewrite reviews.txt
        with open(os.path.join(DATA_DIR, 'reviews.txt'), 'w', encoding='utf-8') as f:
            for r in reviews:
                line = '|'.join([
                    r['review_id'], r['username'], r['book_id'], r['rating'], r['review_text'], r['review_date']
                ])
                f.write(line + '\n')

        return redirect(url_for('book_details', book_id=book_id))

    return render_template('write_review.html', book=book, review=existing_review)

@app.route('/edit-review/<review_id>', methods=['GET', 'POST'])
def edit_review(review_id):
    '''
    Route to edit a review.
    Redirects to write_review page with book_id.
    '''
    reviews = load_reviews()
    review = None
    for r in reviews:
        if r['review_id'] == review_id and r['username'] == current_user:
            review = r
            break
    if not review:
        return "Review not found", 404
    return redirect(url_for('write_review', book_id=review['book_id']))

@app.route('/delete-review/<review_id>', methods=['POST'])
def delete_review(review_id):
    '''
    Route to delete a review.
    Updates reviews.txt accordingly.
    '''
    reviews = load_reviews()
    reviews = [r for r in reviews if not (r['review_id'] == review_id and r['username'] == current_user)]
    with open(os.path.join(DATA_DIR, 'reviews.txt'), 'w', encoding='utf-8') as f:
        for r in reviews:
            line = '|'.join([
                r['review_id'], r['username'], r['book_id'], r['rating'], r['review_text'], r['review_date']
            ])
            f.write(line + '\n')
    return redirect(url_for('my_reviews'))

@app.route('/profile', methods=['GET', 'POST'])
def profile():
    '''
    Route for User Profile page.
    GET: Show profile info and borrow history.
    POST: Update email.
    '''
    users = load_users()
    user = users.get(current_user)
    if not user:
        return "User not found", 404

    borrowings = load_borrowings()
    books = load_books()
    borrow_history = [b for b in borrowings if b['username'] == current_user and b['status'] == 'Returned']
    for b in borrow_history:
        b['title'] = books.get(b['book_id'], {}).get('title', 'Unknown')

    if request.method == 'POST':
        new_email = request.form.get('email')
        if new_email:
            user['email'] = new_email
            # Rewrite users.txt
            with open(os.path.join(DATA_DIR, 'users.txt'), 'w', encoding='utf-8') as f:
                for username, u in users.items():
                    line = '|'.join([username, u['email'], u['phone'], u['address']])
                    f.write(line + '\n')
        return redirect(url_for('profile'))

    return render_template('profile.html', username=current_user, email=user['email'], borrow_history=borrow_history)

@app.route('/payment-confirmation/<fine_id>', methods=['GET', 'POST'])
def payment_confirmation(fine_id):
    '''
    Route for Payment Confirmation page.
    GET: Show fine amount.
    POST: Confirm payment.
    '''
    fines = load_fines()
    fine = None
    for f in fines:
        if f['fine_id'] == fine_id and f['username'] == current_user and f['status'] == 'Unpaid':
            fine = f
            break
    if not fine:
        return "Fine not found or already paid", 404

    if request.method == 'POST':
        # Mark fine as Paid
        fine['status'] = 'Paid'
        with open(os.path.join(DATA_DIR, 'fines.txt'), 'w', encoding='utf-8') as f:
            for fin in fines:
                line = '|'.join([fin['fine_id'], fin['username'], fin['borrow_id'], fin['amount'], fin['status'], fin['date_issued']])
                f.write(line + '\n')
        return redirect(url_for('profile'))

    return render_template('payment_confirmation.html', fine=fine)

if __name__ == '__main__':
    app.run(debug=True)
```

