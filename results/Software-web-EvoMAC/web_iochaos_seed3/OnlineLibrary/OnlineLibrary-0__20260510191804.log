'''
Book Catalog page template.
Displays all books with search input and navigation.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Catalog</title>
</head>
<body>
    <div id="catalog-page">
        <h1>Book Catalog</h1>
        <input id="search-input" type="text" placeholder="Search by title or author" value="{{ search_query }}" onkeydown="if(event.key==='Enter'){searchBooks();}">
        <button onclick="searchBooks()">Search</button>
        <div id="book-grid">
            {% for book in books %}
                <div class="book-card">
                    <h3>{{ book.title }}</h3>
                    <p>Author: {{ book.author }}</p>
                    <p>Status: {{ book.status }}</p>
                    <button id="view-book-button-{{ book.book_id }}" onclick="location.href='{{ url_for('book_details', book_id=book.book_id) }}'">View Details</button>
                </div>
            {% endfor %}
        </div>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
    <script>
        function searchBooks() {
            const query = document.getElementById('search-input').value;
            window.location.href = "{{ url_for('catalog') }}" + "?search=" + encodeURIComponent(query);
        }
    </script>
</body>
</html>
