'''
My Borrowings page template.
Displays user's borrowed books with filter and return buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Borrowings</title>
</head>
<body>
    <div id="my-borrows-page">
        <h1>My Borrowings</h1>
        <label for="filter-status">Filter by status:</label>
        <select id="filter-status" onchange="filterStatus()">
            <option value="All" {% if filter_status == 'All' %}selected{% endif %}>All</option>
            <option value="Active" {% if filter_status == 'Active' %}selected{% endif %}>Active</option>
            <option value="Returned" {% if filter_status == 'Returned' %}selected{% endif %}>Returned</option>
            <option value="Overdue" {% if filter_status == 'Overdue' %}selected{% endif %}>Overdue</option>
        </select>
        <table id="borrows-table" border="1">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for borrow in borrows %}
                <tr>
                    <td>{{ borrow.title }}</td>
                    <td>{{ borrow.borrow_date }}</td>
                    <td>{{ borrow.due_date }}</td>
                    <td>{{ borrow.status }}</td>
                    <td>
                        {% if borrow.status == 'Active' %}
                        <form method="post" action="{{ url_for('return_book', borrow_id=borrow.borrow_id) }}">
                            <button id="return-book-button-{{ borrow.borrow_id }}" type="submit">Return Book</button>
                        </form>
                        {% else %}
                        -
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
    <script>
        function filterStatus() {
            const filter = document.getElementById('filter-status').value;
            window.location.href = "{{ url_for('my_borrows') }}" + "?filter=" + encodeURIComponent(filter);
        }
    </script>
</body>
</html>
