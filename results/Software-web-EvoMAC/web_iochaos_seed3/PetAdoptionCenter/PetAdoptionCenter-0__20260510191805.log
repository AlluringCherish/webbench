'''
Main backend logic for PetAdoptionCenter web application.
Implements all routes and functionalities described in the requirements document.
Uses Flask framework and reads/writes data from/to local text files in the 'data' directory.
'''
import os
from flask import Flask, render_template, request, redirect, url_for, flash, session, jsonify
from datetime import datetime
app = Flask(__name__)
app.secret_key = 'supersecretkey'  # For session management and flash messages
DATA_DIR = 'data'
# Utility functions for file operations and data parsing
def read_file_lines(filename):
    path = os.path.join(DATA_DIR, filename)
    if not os.path.exists(path):
        return []
    with open(path, 'r', encoding='utf-8') as f:
        lines = [line.strip() for line in f if line.strip()]
    return lines
def write_file_lines(filename, lines):
    path = os.path.join(DATA_DIR, filename)
    with open(path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines) + '\n')
def parse_users():
    users = []
    for line in read_file_lines('users.txt'):
        parts = line.split('|')
        if len(parts) == 4:
            username, email, phone, address = parts
            users.append({
                'username': username,
                'email': email,
                'phone': phone,
                'address': address
            })
    return users
def get_user(username):
    users = parse_users()
    for user in users:
        if user['username'] == username:
            return user
    return None
def update_user(username, email):
    users = parse_users()
    updated = False
    for user in users:
        if user['username'] == username:
            user['email'] = email
            updated = True
            break
    if updated:
        lines = [f"{u['username']}|{u['email']}|{u['phone']}|{u['address']}" for u in users]
        write_file_lines('users.txt', lines)
    return updated
def parse_pets():
    pets = []
    for line in read_file_lines('pets.txt'):
        parts = line.split('|')
        if len(parts) == 11:
            pet_id, name, species, breed, age, gender, size, description, shelter_id, status, date_added = parts
            pets.append({
                'pet_id': pet_id,
                'name': name,
                'species': species,
                'breed': breed,
                'age': age,
                'gender': gender,
                'size': size,
                'description': description,
                'shelter_id': shelter_id,
                'status': status,
                'date_added': date_added
            })
    return pets
def get_pet(pet_id):
    pets = parse_pets()
    for pet in pets:
        if pet['pet_id'] == str(pet_id):
            return pet
    return None
def add_pet(pet_data):
    pets = parse_pets()
    max_id = 0
    for pet in pets:
        try:
            pid = int(pet['pet_id'])
            if pid > max_id:
                max_id = pid
        except:
            continue
    new_id = str(max_id + 1)
    pet_data['pet_id'] = new_id
    pets.append(pet_data)
    lines = []
    for pet in pets:
        line = '|'.join([
            pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
            pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
            pet['status'], pet['date_added']
        ])
        lines.append(line)
    write_file_lines('pets.txt', lines)
    return new_id
def update_pet(pet_id, pet_data):
    pets = parse_pets()
    updated = False
    for i, pet in enumerate(pets):
        if pet['pet_id'] == str(pet_id):
            pets[i].update(pet_data)
            updated = True
            break
    if updated:
        lines = []
        for pet in pets:
            line = '|'.join([
                pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
                pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
                pet['status'], pet['date_added']
            ])
            lines.append(line)
        write_file_lines('pets.txt', lines)
    return updated
def delete_pet(pet_id):
    pets = parse_pets()
    pets = [pet for pet in pets if pet['pet_id'] != str(pet_id)]
    lines = []
    for pet in pets:
        line = '|'.join([
            pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
            pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
            pet['status'], pet['date_added']
        ])
        lines.append(line)
    write_file_lines('pets.txt', lines)
def parse_applications():
    applications = []
    for line in read_file_lines('applications.txt'):
        parts = line.split('|')
        if len(parts) == 13:
            (application_id, username, pet_id, applicant_name, phone, address,
             housing_type, has_yard, other_pets, experience, reason, status, date_submitted) = parts
            applications.append({
                'application_id': application_id,
                'username': username,
                'pet_id': pet_id,
                'applicant_name': applicant_name,
                'phone': phone,
                'address': address,
                'housing_type': housing_type,
                'has_yard': has_yard,
                'other_pets': other_pets,
                'experience': experience,
                'reason': reason,
                'status': status,
                'date_submitted': date_submitted
            })
    return applications
def add_application(application_data):
    applications = parse_applications()
    max_id = 0
    for app in applications:
        try:
            aid = int(app['application_id'])
            if aid > max_id:
                max_id = aid
        except:
            continue
    new_id = str(max_id + 1)
    application_data['application_id'] = new_id
    applications.append(application_data)
    lines = []
    for app in applications:
        line = '|'.join([
            app['application_id'], app['username'], app['pet_id'], app['applicant_name'], app['phone'],
            app['address'], app['housing_type'], app['has_yard'], app['other_pets'], app['experience'],
            app['reason'], app['status'], app['date_submitted']
        ])
        lines.append(line)
    write_file_lines('applications.txt', lines)
    return new_id
def update_application_status(application_id, new_status):
    applications = parse_applications()
    updated = False
    for i, app in enumerate(applications):
        if app['application_id'] == str(application_id):
            applications[i]['status'] = new_status
            updated = True
            break
    if updated:
        lines = []
        for app in applications:
            line = '|'.join([
                app['application_id'], app['username'], app['pet_id'], app['applicant_name'], app['phone'],
                app['address'], app['housing_type'], app['has_yard'], app['other_pets'], app['experience'],
                app['reason'], app['status'], app['date_submitted']
            ])
            lines.append(line)
        write_file_lines('applications.txt', lines)
    return updated
def parse_favorites():
    favorites = []
    for line in read_file_lines('favorites.txt'):
        parts = line.split('|')
        if len(parts) == 3:
            username, pet_id, date_added = parts
            favorites.append({
                'username': username,
                'pet_id': pet_id,
                'date_added': date_added
            })
    return favorites
def add_favorite(username, pet_id):
    favorites = parse_favorites()
    for fav in favorites:
        if fav['username'] == username and fav['pet_id'] == str(pet_id):
            return False  # Already favorited
    date_added = datetime.now().strftime('%Y-%m-%d')
    favorites.append({'username': username, 'pet_id': str(pet_id), 'date_added': date_added})
    lines = [f"{fav['username']}|{fav['pet_id']}|{fav['date_added']}" for fav in favorites]
    write_file_lines('favorites.txt', lines)
    return True
def remove_favorite(username, pet_id):
    favorites = parse_favorites()
    new_favs = [fav for fav in favorites if not (fav['username'] == username and fav['pet_id'] == str(pet_id))]
    if len(new_favs) == len(favorites):
        return False  # Not found
    lines = [f"{fav['username']}|{fav['pet_id']}|{fav['date_added']}" for fav in new_favs]
    write_file_lines('favorites.txt', lines)
    return True
def parse_messages():
    messages = []
    for line in read_file_lines('messages.txt'):
        parts = line.split('|')
        if len(parts) == 7:
            message_id, sender_username, recipient_username, subject, content, timestamp, is_read = parts
            messages.append({
                'message_id': message_id,
                'sender_username': sender_username,
                'recipient_username': recipient_username,
                'subject': subject,
                'content': content,
                'timestamp': timestamp,
                'is_read': is_read.lower() == 'true'
            })
    return messages
def add_message(message_data):
    messages = parse_messages()
    max_id = 0
    for msg in messages:
        try:
            mid = int(msg['message_id'])
            if mid > max_id:
                max_id = mid
        except:
            continue
    new_id = str(max_id + 1)
    message_data['message_id'] = new_id
    messages.append(message_data)
    lines = []
    for msg in messages:
        line = '|'.join([
            msg['message_id'], msg['sender_username'], msg['recipient_username'], msg['subject'],
            msg['content'], msg['timestamp'], 'true' if msg['is_read'] else 'false'
        ])
        lines.append(line)
    write_file_lines('messages.txt', lines)
    return new_id
def mark_message_read(message_id):
    messages = parse_messages()
    updated = False
    for i, msg in enumerate(messages):
        if msg['message_id'] == str(message_id):
            if not messages[i]['is_read']:
                messages[i]['is_read'] = True
                updated = True
            break
    if updated:
        lines = []
        for msg in messages:
            line = '|'.join([
                msg['message_id'], msg['sender_username'], msg['recipient_username'], msg['subject'],
                msg['content'], msg['timestamp'], 'true' if msg['is_read'] else 'false'
            ])
            lines.append(line)
        write_file_lines('messages.txt', lines)
    return updated
def parse_shelters():
    shelters = []
    for line in read_file_lines('shelters.txt'):
        parts = line.split('|')
        if len(parts) == 5:
            shelter_id, name, address, phone, email = parts
            shelters.append({
                'shelter_id': shelter_id,
                'name': name,
                'address': address,
                'phone': phone,
                'email': email
            })
    return shelters
def get_shelter(shelter_id):
    shelters = parse_shelters()
    for shelter in shelters:
        if shelter['shelter_id'] == str(shelter_id):
            return shelter
