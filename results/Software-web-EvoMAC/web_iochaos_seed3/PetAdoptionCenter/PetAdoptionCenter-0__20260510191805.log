@app.route('/messages', methods=['GET', 'POST'])
def messages():
    username = get_current_username()
    if request.method == 'POST':
        recipient_username = request.form.get('recipient_username', '').strip()
        subject = request.form.get('subject', '').strip()
        content = request.form.get('message-input', '').strip()
        if not recipient_username or not subject or not content:
            flash('All fields are required to send a message.', 'error')
            return redirect(url_for('messages'))
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        message_data = {
            'sender_username': username,
            'recipient_username': recipient_username,
            'subject': subject,
            'content': content,
            'timestamp': timestamp,
            'is_read': False
        }
        add_message(message_data)
        flash('Message sent successfully.', 'success')
        return redirect(url_for('messages'))
    # GET: show conversations (messages where user is sender or recipient)
    messages_all = parse_messages()
    conversations = {}
    for msg in messages_all:
        if msg['sender_username'] == username or msg['recipient_username'] == username:
            # Conversation key: other party username
            other = msg['recipient_username'] if msg['sender_username'] == username else msg['sender_username']
            if other not in conversations:
                conversations[other] = []
            conversations[other].append(msg)
    # Sort messages in each conversation by timestamp ascending
    for conv in conversations.values():
        conv.sort(key=lambda m: m['timestamp'])
    return render_template('messages.html', conversations=conversations, username=username)
@app.route('/messages/mark_read/<message_id>', methods=['POST'])
