'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page by verifying the presence and correctness of the following elements:
- ID: dashboard-page (Div container)
- ID: featured-pets (Div container with up to 5 featured pets)
- Buttons with IDs: browse-pets-button, back-to-dashboard
- Featured pets display pet name, species, and age
- Recent activities section with recent adoption applications for the current user
'''
import unittest
from app import app
from bs4 import BeautifulSoup
class PetAdoptionCenterTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status 200")
    def test_dashboard_elements_presence(self):
        # Test that dashboard page contains required elements and structure
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check dashboard-page div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' should be present")
        # Check featured-pets div
        featured_pets_div = soup.find('section', id='featured-pets')
        self.assertIsNotNone(featured_pets_div, "Featured pets section with id 'featured-pets' should be present")
        # Check that featured pets are at most 5
        pet_cards = featured_pets_div.find_all('div', class_='pet-card')
        self.assertLessEqual(len(pet_cards), 5, "Featured pets should be limited to 5")
        # Check each pet card has pet name, species, and age
        for pet_card in pet_cards:
            pet_name = pet_card.find('div', class_='pet-name')
            self.assertIsNotNone(pet_name, "Each pet card should have a pet name element")
            self.assertTrue(pet_name.text.strip() != '', "Pet name should not be empty")
            pet_species_age = pet_card.find('div', class_='pet-species-age')
            self.assertIsNotNone(pet_species_age, "Each pet card should have a species and age element")
            self.assertTrue(',' in pet_species_age.text, "Pet species and age should be separated by a comma")
        # Check buttons: browse-pets-button and back-to-dashboard
        browse_button = soup.find('button', id='browse-pets-button')
        self.assertIsNotNone(browse_button, "Button with id 'browse-pets-button' should be present")
        back_button = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button, "Button with id 'back-to-dashboard' should be present")
        # Check recent activities section
        recent_activities_section = soup.find('section', id='recent-activities')
        self.assertIsNotNone(recent_activities_section, "Recent activities section with id 'recent-activities' should be present")
        # Check recent applications list or message
        recent_applications_list = recent_activities_section.find('ul', id='recent-applications-list')
        if recent_applications_list:
            # If list present, check each list item has pet link, status, and date submitted
            list_items = recent_applications_list.find_all('li')
            for li in list_items:
                pet_link = li.find('a', class_='pet-link')
                self.assertIsNotNone(pet_link, "Each recent application should have a pet link")
                self.assertTrue(pet_link.text.strip() != '', "Pet link text should not be empty")
                self.assertIn('Status:', li.text, "Recent application should display status")
                self.assertIn('Date Submitted:', li.text, "Recent application should display date submitted")
        else:
            # If no recent applications, check for no applications message
            no_apps_msg = recent_activities_section.find('p')
            self.assertIsNotNone(no_apps_msg, "If no recent applications, a message should be displayed")
    def test_dashboard_navigation_buttons(self):
        # Test that clicking buttons leads to correct URLs (simulate by checking href or onclick)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        browse_button = soup.find('button', id='browse-pets-button')
        self.assertIsNotNone(browse_button)
        # The button uses onclick with location.href to /pets
        onclick = browse_button.get('onclick', '')
        self.assertIn('/pets', onclick, "Browse Pets button should navigate to /pets")
        back_button = soup.find('button', id='back-to-dashboard')
        self.assertIsNotNone(back_button)
        onclick_back = back_button.get('onclick', '')
        self.assertIn('location.reload()', onclick_back, "Back to Dashboard button should reload the page")
if __name__ == '__main__':
    unittest.main()

