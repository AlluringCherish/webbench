<div id="dashboard-page">
    <h1>Pet Adoption Dashboard</h1>
    <section id="featured-pets">
        <h2>Featured Pets</h2>
        {% if featured_pets %}
            {% for pet in featured_pets %}
                <div class="pet-card">
                    <a href="{{ url_for('pet_details', pet_id=pet.pet_id) }}" class="pet-link">
                        <!-- Placeholder image, can be replaced with actual pet photo if available -->
                        <img src="{{ url_for('static', filename='images/pets/' + pet.pet_id + '.jpg') }}" alt="{{ pet.name }}" onerror="this.onerror=null;this.src='{{ url_for('static', filename='images/pets/default.jpg') }}';">
                        <div class="pet-name" id="pet-name-{{ pet.pet_id }}">{{ pet.name }}</div>
                        <div class="pet-species-age" id="pet-species-age-{{ pet.pet_id }}">{{ pet.species }}, {{ pet.age }}</div>
                    </a>
                </div>
            {% endfor %}
        {% else %}
            <p>No featured pets available at the moment.</p>
        {% endif %}
    </section>
    <section id="recent-activities">
        <h2>Recent Activities</h2>
        <h3>My Recent Adoption Applications</h3>
        {% if recent_applications %}
            <ul id="recent-applications-list">
                {% for app in recent_applications %}
                    <li>
                        <strong>Pet:</strong>
                        {% set pet = None %}
                        {% for p in featured_pets %}
                            {% if p.pet_id == app.pet_id %}
                                {% set pet = p %}
                            {% endif %}
                        {% endfor %}
                        {% if not pet %}
                            {% set pet = None %}
                            {% for p in parse_pets() %}
                                {% if p.pet_id == app.pet_id %}
                                    {% set pet = p %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        {% if pet %}
                            <a href="{{ url_for('pet_details', pet_id=pet.pet_id) }}" class="pet-link">{{ pet.name }}</a>
                        {% else %}
                            Unknown Pet
                        {% endif %}
                        <br>
                        <strong>Status:</strong> {{ app.status }}<br>
                        <strong>Date Submitted:</strong> {{ app.date_submitted }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You have no recent adoption applications.</p>
        {% endif %}
    </section>
    <div id="buttons-container">
        <button id="browse-pets-button" onclick="location.href='{{ url_for('pet_listings') }}'">Browse Pets</button>
        <button id="back-to-dashboard" onclick="location.reload()">Refresh Dashboard</button>
    </div>
</div>
</body>
</html>
