@app.route('/messages', methods=['GET', 'POST'])
def messages():
    username = get_current_username()
    if request.method == 'POST':
        recipient_username = request.form.get('recipient_username', '').strip()
        subject = request.form.get('subject', '').strip()
        content = request.form.get('message-input', '').strip()
        if not recipient_username or not subject or not content:
            flash('All fields are required to send a message.', 'error')
            return redirect(url_for('messages'))
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        message_data = {
            'sender_username': username,
            'recipient_username': recipient_username,
            'subject': subject,
            'content': content,
            'timestamp': timestamp,
            'is_read': False
        }
        add_message(message_data)
        flash('Message sent successfully.', 'success')
        return redirect(url_for('messages'))
    # GET: show conversations (messages where user is sender or recipient)
    messages_all = parse_messages()
    conversations = {}
    for msg in messages_all:
        if msg['sender_username'] == username or msg['recipient_username'] == username:
            # Conversation key: other party username
            other = msg['recipient_username'] if msg['sender_username'] == username else msg['sender_username']
            if other not in conversations:
                conversations[other] = []
            conversations[other].append(msg)
    # Sort messages in each conversation by timestamp ascending
    for conv in conversations.values():
        conv.sort(key=lambda m: m['timestamp'])
    return render_template('messages.html', conversations=conversations, username=username)
@app.route('/messages/mark_read/<message_id>', methods=['POST'])
def mark_message_read_route(message_id):
    mark_message_read(message_id)
    return ('', 204)
@app.route('/profile', methods=['GET', 'POST'])
def user_profile():
    username = get_current_username()
    user = get_user(username)
    if not user:
        flash('User not found.', 'error')
        return redirect(url_for('dashboard'))
    if request.method == 'POST':
        email = request.form.get('profile-email', '').strip()
        if not email:
            flash('Email cannot be empty.', 'error')
            return render_template('user_profile.html', user=user)
        update_user(username, email)
        flash('Profile updated successfully.', 'success')
        user = get_user(username)  # Refresh user data
    return render_template('user_profile.html', user=user)
@app.route('/admin', methods=['GET', 'POST'])
def admin_panel():
    # For simplicity, no authentication check for admin user
    pets = parse_pets()
    applications = parse_applications()
    pending_apps = [app for app in applications if app['status'].lower() == 'pending']
    if request.method == 'POST':
        # Handle application status update or pet delete/edit
        action = request.form.get('action')
        if action == 'update_application_status':
            application_id = request.form.get('application_id')
            new_status = request.form.get('new_status')
            if application_id and new_status:
                update_application_status(application_id, new_status)
                flash('Application status updated.', 'success')
            return redirect(url_for('admin_panel'))
        elif action == 'delete_pet':
            pet_id = request.form.get('pet_id')
            if pet_id:
                delete_pet(pet_id)
                flash('Pet deleted.', 'success')
            return redirect(url_for('admin_panel'))
        elif action == 'edit_pet':
            pet_id = request.form.get('pet_id')
            # For simplicity, redirect to add_pet page with prefilled data not implemented
            flash('Edit pet feature not implemented.', 'info')
            return redirect(url_for('admin_panel'))
    return render_template('admin_panel.html',
                           pending_applications=pending_apps,
                           all_pets=pets)
# Run the app
if __name__ == '__main__':
    # Ensure data directory exists
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)
    app.run(host='0.0.0.0', port=5000, debug=True)
