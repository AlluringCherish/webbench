'''
Main backend logic for PetAdoptionCenter web application.
Implements all routes and functionalities described in the requirements document.
Uses Flask framework and reads/writes data from/to local text files in the 'data' directory.
'''
import os
from flask import Flask, render_template, request, redirect, url_for, flash, session, jsonify
from datetime import datetime
app = Flask(__name__)
app.secret_key = 'supersecretkey'  # For session management and flash messages
DATA_DIR = 'data'
# Utility functions for file operations and data parsing
def read_file_lines(filename):
    path = os.path.join(DATA_DIR, filename)
    if not os.path.exists(path):
        return []
    with open(path, 'r', encoding='utf-8') as f:
        lines = [line.strip() for line in f if line.strip()]
    return lines
def write_file_lines(filename, lines):
    path = os.path.join(DATA_DIR, filename)
    with open(path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines) + '\n')
def parse_users():
    users = []
    for line in read_file_lines('users.txt'):
        parts = line.split('|')
        if len(parts) == 4:
            username, email, phone, address = parts
            users.append({
                'username': username,
                'email': email,
                'phone': phone,
                'address': address
            })
    return users
def get_user(username):
    users = parse_users()
    for user in users:
        if user['username'] == username:
            return user
    return None
def update_user(username, email):
    users = parse_users()
    updated = False
    for user in users:
        if user['username'] == username:
            user['email'] = email
            updated = True
            break
    if updated:
        lines = [f"{u['username']}|{u['email']}|{u['phone']}|{u['address']}" for u in users]
        write_file_lines('users.txt', lines)
    return updated
def parse_pets():
    pets = []
    for line in read_file_lines('pets.txt'):
        parts = line.split('|')
        if len(parts) == 11:
            pet_id, name, species, breed, age, gender, size, description, shelter_id, status, date_added = parts
            pets.append({
                'pet_id': pet_id,
                'name': name,
                'species': species,
                'breed': breed,
                'age': age,
                'gender': gender,
                'size': size,
                'description': description,
                'shelter_id': shelter_id,
                'status': status,
                'date_added': date_added
            })
    return pets
def get_pet(pet_id):
    pets = parse_pets()
    for pet in pets:
        if pet['pet_id'] == str(pet_id):
            return pet
    return None
def add_pet(pet_data):
    pets = parse_pets()
    max_id = 0
    for pet in pets:
        try:
            pid = int(pet['pet_id'])
            if pid > max_id:
                max_id = pid
        except:
            continue
    new_id = str(max_id + 1)
    pet_data['pet_id'] = new_id
    pets.append(pet_data)
    lines = []
    for pet in pets:
        line = '|'.join([
            pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
            pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
            pet['status'], pet['date_added']
        ])
        lines.append(line)
    write_file_lines('pets.txt', lines)
    return new_id
def update_pet(pet_id, pet_data):
    pets = parse_pets()
    updated = False
    for i, pet in enumerate(pets):
        if pet['pet_id'] == str(pet_id):
            pets[i].update(pet_data)
            updated = True
            break
    if updated:
        lines = []
        for pet in pets:
            line = '|'.join([
                pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
                pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
                pet['status'], pet['date_added']
            ])
            lines.append(line)
        write_file_lines('pets.txt', lines)
    return updated
def delete_pet(pet_id):
    pets = parse_pets()
    pets = [pet for pet in pets if pet['pet_id'] != str(pet_id)]
    lines = []
    for pet in pets:
        line = '|'.join([
            pet['pet_id'], pet['name'], pet['species'], pet['breed'], pet['age'],
            pet['gender'], pet['size'], pet['description'], pet['shelter_id'],
            pet['status'], pet['date_added']
        ])
        lines.append(line)
    write_file_lines('pets.txt', lines)
def parse_applications():
    applications = []
    for line in read_file_lines('applications.txt'):
        parts = line.split('|')
        if len(parts) == 13:
            (application_id, username, pet_id, applicant_name, phone, address,
             housing_type, has_yard, other_pets, experience, reason, status, date_submitted) = parts
            applications.append({
                'application_id': application_id,
                'username': username,
                'pet_id': pet_id,
                'applicant_name': applicant_name,
                'phone': phone,
                'address': address,
                'housing_type': housing_type,
                'has_yard': has_yard,
                'other_pets': other_pets,
                'experience': experience,
                'reason': reason,
                'status': status,
                'date_submitted': date_submitted
            })
    return applications
def add_application(application_data):
    applications = parse_applications()
    max_id = 0
    for app in applications:
        try:
            aid = int(app['application_id'])
            if aid > max_id:
                max_id = aid
        except:
            continue
    new_id = str(max_id + 1)
