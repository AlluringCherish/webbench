'''
Bestsellers page template for BookstoreOnline.
Displays top-selling books with time period filter.
Uses Flask url_for() for navigation and form actions.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bestsellers</title>
</head>
<body>
<div id="bestsellers-page">
    <h1>Bestsellers</h1>
    <form method="get" action="{{ url_for('bestsellers') }}">
        <label for="time-period-filter">Filter by Time Period:</label>
        <select id="time-period-filter" name="period" onchange="this.form.submit()">
            <option value="This Week" {% if selected_period == 'This Week' %}selected{% endif %}>This Week</option>
            <option value="This Month" {% if selected_period == 'This Month' %}selected{% endif %}>This Month</option>
            <option value="All Time" {% if selected_period == 'All Time' %}selected{% endif %}>All Time</option>
        </select>
    </form>
    <div id="bestsellers-list">
        <ol>
            {% for book in bestsellers %}
            <li>
                <strong>{{ book.title }}</strong> by {{ book.author }} - Sales: {{ book.sales_count }}
                <a href="{{ url_for('book_details', book_id=book.book_id) }}" id="view-book-button-{{ book.book_id }}">View Details</a>
            </li>
            {% endfor %}
        </ol>
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
