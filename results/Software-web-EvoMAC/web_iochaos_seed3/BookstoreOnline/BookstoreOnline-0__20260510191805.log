                    </td>
                    <td>${{ "%.2f"|format(item.price) }}</td>
                    <td>${{ "%.2f"|format(item.subtotal) }}</td>
                    <td>
                        <button type="submit" name="remove-item-button-{{ item.cart_id }}" id="remove-item-button-{{ item.cart_id }}">Remove</button>
