        # Check for dashboard-page div
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must contain div with id 'dashboard-page'")

        # Check for featured-books div inside dashboard-page
        featured_books_div = soup.find(id='featured-books')
