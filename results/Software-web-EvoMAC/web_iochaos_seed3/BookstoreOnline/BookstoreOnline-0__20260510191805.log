        self.assertIsNotNone(bestsellers_button, "Dashboard page must contain button with id 'bestsellers-button'")
        self.assertEqual(bestsellers_button.name, 'button', "bestsellers-button must be a button element")

    def test_navigation_buttons_functionality(self):
        # Test that navigation buttons link to correct pages (href or form action)
        response = self.client.get('/')
