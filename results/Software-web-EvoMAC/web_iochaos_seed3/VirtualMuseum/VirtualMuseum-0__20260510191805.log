<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Exhibition Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="exhibition-details-page">
        <h1 id="exhibition-title">{{ exhibition.title }}</h1>
        <div id="exhibition-description">{{ exhibition.description }}</div>
        <div id="exhibition-dates">From {{ exhibition.start_date }} to {{ exhibition.end_date }}</div>
        <table id="exhibition-artifacts" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Artifact ID</th>
                    <th>Name</th>
                    <th>Period</th>
                    <th>Origin</th>
                    <th>Description</th>
                    <th>Storage Location</th>
                    <th>Acquisition Date</th>
                </tr>
            </thead>
            <tbody>
                {% for artifact in artifacts %}
                <tr>
                    <td>{{ artifact.artifact_id }}</td>
                    <td>{{ artifact.artifact_name }}</td>
                    <td>{{ artifact.period }}</td>
                    <td>{{ artifact.origin }}</td>
                    <td>{{ artifact.description }}</td>
                    <td>{{ artifact.storage_location }}</td>
                    <td>{{ artifact.acquisition_date }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7">No artifacts found for this exhibition.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-exhibitions" onclick="location.href='{{ url_for('exhibitions') }}'">Back to Exhibitions</button>
    </div>
</body>
</html>
