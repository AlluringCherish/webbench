        self.assertIsNotNone(summary_div)
        self.assertIn('Total Exhibitions:', summary_div.text)
        self.assertIn('Active Exhibitions:', summary_div.text)
        # Check navigation buttons presence and correct IDs
        expected_buttons = [
            'artifact-catalog-button',
            'exhibitions-button',
            'visitor-tickets-button',
            'virtual-events-button',
            'audio-guides-button'
        ]
        for btn_id in expected_buttons:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' not found on dashboard")
    def test_02_navigation_links_from_dashboard(self):
        # Test Task 2: Check navigation buttons lead to correct pages
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # Extract URLs from buttons
        buttons = {
            'artifact-catalog-button': '/artifact_catalog',
            'exhibitions-button': '/exhibitions',
            'visitor-tickets-button': '/visitor_tickets',
            'virtual-events-button': '/virtual_events',
            'audio-guides-button': '/audio_guides'
        }
        for btn_id, expected_path in buttons.items():
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn)
            # The button uses onclick with location.href, extract URL from onclick attribute
            onclick = btn.get('onclick', '')
            self.assertIn(expected_path, onclick, f"Button {btn_id} does not link to {expected_path}")
