                <option value="{{ category.category_name }}" {% if selected_category.lower() == category.category_name.lower() %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="articles-grid">
        {% if articles %}
            <ul>
                {% for article in articles %}
                    <li>
                        <div class="article-card">
                            <!-- Thumbnail placeholder: no image data provided -->
                            <div class="thumbnail">
                                <img src="{{ url_for('static', filename='images/default_thumbnail.png') }}" alt="Thumbnail" width="100" height="75">
                            </div>
                            <div class="article-info">
                                <h3>{{ article.title }}</h3>
                                <p>By {{ article.author }} on {{ article.date }}</p>
                                <form method="get" action="{{ url_for('article_details', article_id=article.article_id) }}">
                                    <button type="submit" id="view-article-button-{{ article.article_id }}">View Article</button>
                                </form>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No articles found.</p>
        {% endif %}
    </div>
</div>
<script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</body>
</html>
```
