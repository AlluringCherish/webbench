                                <img src="{{ url_for('static', filename='images/default_thumbnail.png') }}" alt="Thumbnail" width="100" height="75">
                            </div>
                            <div class="article-info">
                                <h3>{{ article.title }}</h3>
                                <p>By {{ article.author }} on {{ article.date }}</p>
                                <form method="get" action="{{ url_for('article_details', article_id=article.article_id) }}">
