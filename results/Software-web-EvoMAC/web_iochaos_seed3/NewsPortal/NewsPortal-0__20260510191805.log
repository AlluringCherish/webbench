<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>News Portal</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
    <script>
        // Define URLs for frontend navigation to avoid hardcoding
        const URLS = {
            catalog: "{{ url_for('article_catalog') }}",
            bookmarks: "{{ url_for('bookmarks') }}",
            trending: "{{ url_for('trending') }}",
            articleDetailsBase: "{{ url_for('article_details', article_id='') }}"
        };
    </script>
