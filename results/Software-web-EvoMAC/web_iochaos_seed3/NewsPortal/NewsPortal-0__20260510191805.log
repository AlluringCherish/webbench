<body>
<div id="catalog-page">
    <h1>Article Catalog</h1>
    <form method="post" action="{{ url_for('article_catalog') }}">
        <input type="text" id="search-input" name="search-input" placeholder="Search articles..." value="{{ search_query }}">
        <select id="category-filter" name="category-filter">
            <option value="All" {% if selected_category == '' or selected_category.lower() == 'all' %}selected{% endif %}>All Categories</option>
