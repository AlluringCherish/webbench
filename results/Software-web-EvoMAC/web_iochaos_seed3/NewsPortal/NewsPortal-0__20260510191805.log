    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements with correct IDs
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check dashboard-page div
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page div with id 'dashboard-page' should be present")
        # Check featured-articles div
        featured_div = soup.find('section', id='featured-articles')
        self.assertIsNotNone(featured_div, "Featured articles section with id 'featured-articles' should be present")
        # Check browse-articles-button button
        browse_button = soup.find('button', id='browse-articles-button')
        self.assertIsNotNone(browse_button, "Button with id 'browse-articles-button' should be present")
        # Check view-bookmarks-button button
        bookmarks_button = soup.find('button', id='view-bookmarks-button')
        self.assertIsNotNone(bookmarks_button, "Button with id 'view-bookmarks-button' should be present")
        # Check trending-articles-button button
        trending_button = soup.find('button', id='trending-articles-button')
        self.assertIsNotNone(trending_button, "Button with id 'trending-articles-button' should be present")
    def test_dashboard_navigation_buttons(self):
        # Test that the navigation buttons lead to the correct pages by simulating GET requests
        # Browse Articles button leads to /catalog
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200, "Article Catalog page should be accessible at /catalog")
        # View Bookmarks button leads to /bookmarks
        response = self.client.get('/bookmarks')
        self.assertEqual(response.status_code, 200, "Bookmarks page should be accessible at /bookmarks")
        # Trending Articles button leads to /trending
        response = self.client.get('/trending')
        self.assertEqual(response.status_code, 200, "Trending Articles page should be accessible at /trending")
if __name__ == '__main__':
    unittest.main()

