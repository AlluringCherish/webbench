<body>
<div id="catalog-page">
    <h1>Article Catalog</h1>
    <form method="post" action="{{ url_for('article_catalog') }}">
        <input type="text" id="search-input" name="search-input" placeholder="Search articles..." value="{{ search_query }}">
        <select id="category-filter" name="category-filter">
            <option value="All" {% if selected_category == '' or selected_category.lower() == 'all' %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category.lower() == category.category_name.lower() %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="articles-grid">
        {% if articles %}
            <ul>
                {% for article in articles %}
                    <li>
                        <div class="article-card">
                            <!-- Thumbnail placeholder: no image data provided -->
