<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Restaurant Dashboard</title>
    <style>
        #dashboard-page {
            max-width: 900px;
            margin: 0 auto;
            font-family: Arial, sans-serif;
        }
        #welcome-message {
            margin-top: 20px;
            font-size: 2em;
            color: #333;
        }
        .button-group {
            margin: 20px 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
