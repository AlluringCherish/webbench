            padding: 10px 15px;
            font-size: 1em;
            cursor: pointer;
            border: none;
            background-color: #007bff;
            color: white;
            border-radius: 4px;
            transition: background-color 0.3s ease;
        }
        button:hover {
            background-color: #0056b3;
        }
        .section {
            margin-top: 30px;
        }
        .featured-dishes {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .dish-card {
            border: 1px solid #ccc;
            border-radius: 6px;
