<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Restaurant Dashboard</title>
    <style>
        #dashboard-page {
            max-width: 900px;
            margin: 0 auto;
            font-family: Arial, sans-serif;
        }
        #welcome-message {
            margin-top: 20px;
            font-size: 2em;
            color: #333;
        }
        .button-group {
            margin: 20px 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        button {
            padding: 10px 15px;
            font-size: 1em;
            cursor: pointer;
            border: none;
            background-color: #007bff;
            color: white;
            border-radius: 4px;
            transition: background-color 0.3s ease;
        }
        button:hover {
            background-color: #0056b3;
        }
        .section {
            margin-top: 30px;
        }
        .featured-dishes {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        .dish-card {
            border: 1px solid #ccc;
            border-radius: 6px;
            padding: 15px;
            width: 28%;
            box-sizing: border-box;
            background-color: #fafafa;
        }
        .dish-name {
            font-weight: bold;
            font-size: 1.2em;
            margin-bottom: 5px;
        }
        .dish-description {
            font-size: 0.9em;
            color: #555;
            margin-bottom: 10px;
        }
        .dish-price {
            font-weight: bold;
            color: #007bff;
        }
        .upcoming-reservations {
            border-collapse: collapse;
            width: 100%;
        }
        .upcoming-reservations th, .upcoming-reservations td {
            border: 1px solid #ddd;
            padding: 8px;
        }
        .upcoming-reservations th {
            background-color: #007bff;
            color: white;
            text-align: left;
        }
        .no-reservations {
            font-style: italic;
            color: #777;
        }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1 id="welcome-message">Welcome, {{ full_name if full_name else username }}!</h1>
    <div class="button-group">
        <button id="make-reservation-button" onclick="location.href='{{ url_for('make_reservation') }}'">Make Reservation</button>
        <button id="view-menu-button" onclick="location.href='{{ url_for('menu') }}'">View Menu</button>
        <button id="my-reservations-button" onclick="location.href='{{ url_for('my_reservations') }}'">My Reservations</button>
        <button id="my-reviews-button" onclick="location.href='{{ url_for('my_reviews') }}'">My Reviews</button>
        <button id="waitlist-button" onclick="location.href='{{ url_for('waitlist') }}'">Waitlist</button>
        <button id="profile-button" onclick="location.href='{{ url_for('profile') }}'">My Profile</button>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Refresh Dashboard</button>
    </div>
    <div class="section">
        <h2>Featured Dishes</h2>
        <div class="featured-dishes">
            {% for dish in featured_dishes %}
            <div class="dish-card">
                <div class="dish-name">{{ dish.name }}</div>
                <div class="dish-description">{{ dish.description }}</div>
                <div class="dish-price">${{ dish.price }}</div>
                <button id="view-dish-button-{{ dish.dish_id }}" onclick="location.href='{{ url_for('dish_details', dish_id=dish.dish_id) }}'">View Details</button>
            </div>
            {% else %}
            <p>No featured dishes available.</p>
            {% endfor %}
        </div>
    </div>
    <div class="section">
        <h2>Upcoming Reservations</h2>
        {% if upcoming_reservations %}
        <table class="upcoming-reservations">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Party Size</th>
                    <th>Special Requests</th>
                </tr>
            </thead>
            <tbody>
                {% for res in upcoming_reservations %}
                <tr>
                    <td>{{ res.date }}</td>
                    <td>{{ res.time }}</td>
                    <td>{{ res.party_size }}</td>
                    <td>{{ res.special_requests if res.special_requests else '-' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p class="no-reservations">You have no upcoming reservations.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
