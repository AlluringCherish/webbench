        <label for="reservation-time">Reservation Time:</label>
        <input type="time" id="reservation-time" name="reservation-time" required><br><br>

        <label for="special-requests">Special Requests:</label><br>
        <textarea id="special-requests" name="special-requests" rows="4" cols="50"></textarea><br><br>

        <button id="submit-reservation-button" type="submit">Submit Reservation</button>
