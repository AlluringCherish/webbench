import unittest
from main import app
from bs4 import BeautifulSoup

class TestDashboardPage(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access root '/' and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title_and_elements(self):
        # Test Task 2 & 3: Check page title and presence of required elements on Dashboard page
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check page title
        self.assertEqual(soup.title.string.strip(), "Restaurant Dashboard", "Page title should be 'Restaurant Dashboard'")

        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must have a div with id 'dashboard-page'")

        # Check welcome message h1 with id 'welcome-message' containing username
        welcome_h1 = soup.find('h1', id='welcome-message')
        self.assertIsNotNone(welcome_h1, "Dashboard page must have an h1 with id 'welcome-message'")
        self.assertIn('john_diner', welcome_h1.text.lower(), "Welcome message should contain the username 'john_diner'")

        # Check presence of all navigation buttons by id
        button_ids = [
            'make-reservation-button',
            'view-menu-button',
            'back-to-dashboard',
            'my-reservations-button',
            'my-reviews-button',
            'waitlist-button',
            'profile-button'
        ]
        for btn_id in button_ids:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Dashboard page must have a button with id '{btn_id}'")

        # Check featured dishes section: at least 1 featured dish displayed with name and avg_rating
        # We expect top 3 featured dishes, so check for at least one dish card or element
        # Since no specific container id for featured dishes is given, check if dish names appear in page
        featured_dish_names = [dish.text for dish in soup.find_all(string=True) if any(name in dish for name in ['Caesar Salad', 'Grilled Salmon', 'Chocolate Lava Cake', 'Green Tea'])]
        self.assertTrue(len(featured_dish_names) > 0, "Dashboard should display featured dishes from menu")

        # Check upcoming reservations section: check if upcoming reservations for user are displayed
        # Look for any text that matches date or 'Upcoming' status
        self.assertIn('Upcoming', response.get_data(as_text=True), "Dashboard should display upcoming reservations with status 'Upcoming'")

if __name__ == '__main__':
    unittest.main()
