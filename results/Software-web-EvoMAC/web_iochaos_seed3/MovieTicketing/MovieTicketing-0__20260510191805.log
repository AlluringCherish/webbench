            <p><strong>Seats:</strong> {{ selected_seats|join(', ') }}</p>
            <p><strong>Total Price:</strong> ${{ "%.2f"|format(total_price) }}</p>
        </div>
        <form method="post" action="{{ url_for('booking_confirmation', showtime_id=showtime.showtime_id) }}?seats={{ selected_seats|join(',') }}">
