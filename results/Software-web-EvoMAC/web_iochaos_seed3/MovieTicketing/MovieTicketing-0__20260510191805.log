'''
Dashboard page template for Movie Ticketing Dashboard.
Displays featured movies, upcoming releases, and navigation buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Movie Ticketing Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Movie Ticketing Dashboard</h1>
        <div id="featured-movies">
            <h2>Featured Movies</h2>
            <ul>
                {% for movie in featured_movies %}
                <li>
                    <strong>{{ movie.title }}</strong> (Rating: {{ movie.rating }})
                </li>
                {% endfor %}
            </ul>
        </div>
        <div id="upcoming-releases">
            <h2>Upcoming Releases</h2>
            <ul>
                {% for movie in upcoming_releases %}
                <li>
                    <strong>{{ movie.title }}</strong> - Release Date: {{ movie.release_date }}
                </li>
                {% endfor %}
            </ul>
        </div>
        <button id="browse-movies-button" onclick="location.href='{{ url_for('movie_catalog') }}'">Browse Movies</button>
        <button id="view-bookings-button" onclick="location.href='{{ url_for('booking_history') }}'">View Bookings</button>
        <button id="showtimes-button" onclick="location.href='{{ url_for('showtime_selection', movie_id=featured_movies[0].movie_id if featured_movies else 1) }}'">Showtimes</button>
        <button id="theater-info-button" onclick="location.href='{{ url_for('theater_information') }}'">Theater Information</button>
    </div>
</body>
</html>
