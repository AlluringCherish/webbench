'''
Movie Catalog page template.
Displays movies with search and genre filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Movie Catalog</title>
</head>
<body>
    <div id="catalog-page">
        <h1>Movie Catalog</h1>
        <form method="get" action="{{ url_for('movie_catalog') }}">
            <input type="text" id="search-input" name="search" placeholder="Search by title or genre" value="{{ search_query }}">
            <select id="genre-filter" name="genre">
                <option value="All" {% if selected_genre == 'All' or not selected_genre %}selected{% endif %}>All Genres</option>
                {% for genre in genres %}
                <option value="{{ genre.genre_name }}" {% if selected_genre == genre.genre_name %}selected{% endif %}>{{ genre.genre_name }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>
        <div id="movies-grid">
            {% for movie in movies %}
            <div class="movie-card">
                <h3>{{ movie.title }}</h3>
                <p>Rating: {{ movie.rating }}</p>
                <p>Duration: {{ movie.duration }} min</p>
                <button id="view-movie-button-{{ movie.movie_id }}" onclick="location.href='{{ url_for('movie_details', movie_id=movie.movie_id) }}'">View Details</button>
            </div>
            {% else %}
            <p>No movies found.</p>
            {% endfor %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
