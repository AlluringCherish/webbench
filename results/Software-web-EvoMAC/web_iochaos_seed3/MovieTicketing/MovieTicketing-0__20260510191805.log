                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No featured movies available.</p>
            {% endif %}
        </section>
        <section id="upcoming-releases">
            <h2>Upcoming Releases</h2>
            {% if upcoming_releases %}
                <ul>
                    {% for movie in upcoming_releases %}
                        <li>
                            <strong>{{ movie.title }}</strong> - Release Date: {{ movie.release_date }}
                            <a href="{{ url_for('movie_details', movie_id=movie.movie_id) }}">
                                <button id="view-movie-button-{{ movie.movie_id }}">View Details</button>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No upcoming releases available.</p>
            {% endif %}
        </section>
        <nav id="dashboard-navigation">
            <button id="browse-movies-button" onclick="location.href='{{ url_for('movie_catalog') }}'">Browse Movies</button>
            <button id="view-bookings-button" onclick="location.href='{{ url_for('booking_history') }}'">View Bookings</button>
            <button id="showtimes-button" onclick="location.href='{{ url_for('all_showtimes') }}'">Showtimes</button>
        </nav>
    </div>
</body>
</html>
```

all_showtimes.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>All Showtimes</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="showtime-page">
        <h1>All Showtimes</h1>
        <form method="get" action="{{ url_for('all_showtimes') }}">
            <label for="theater-filter">Filter by Theater:</label>
            <select id="theater-filter" name="theater">
                <option value="All" {% if theater_filter == 'All' or not theater_filter %}selected{% endif %}>All</option>
                {% for theater in theaters %}
                    <option value="{{ theater.theater_name }}" {% if theater_filter == theater.theater_name %}selected{% endif %}>{{ theater.theater_name }}</option>
                {% endfor %}
            </select>
            <label for="date-filter">Filter by Date:</label>
            <input type="date" id="date-filter" name="date" value="{{ date_filter }}">
            <button type="submit">Filter</button>
        </form>
        {% if showtimes %}
            <div id="showtimes-list">
                <table>
                    <thead>
                        <tr>
                            <th>Movie</th>
