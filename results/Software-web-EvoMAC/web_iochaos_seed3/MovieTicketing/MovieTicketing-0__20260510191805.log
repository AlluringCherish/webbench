from bs4 import BeautifulSoup

class MovieTicketingTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_access_and_elements(self):
        # Test access to dashboard page '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check page title
        self.assertIn('Movie Ticketing Dashboard', soup.title.string)
        # Check container div id=dashboard-page
        self.assertIsNotNone(soup.find('div', id='dashboard-page'))
        # Check featured movies div
        self.assertIsNotNone(soup.find('div', id='featured-movies'))
        # Check buttons for navigation
        self.assertIsNotNone(soup.find('button', id='browse-movies-button'))
        self.assertIsNotNone(soup.find('button', id='view-bookings-button'))
        self.assertIsNotNone(soup.find('button', id='showtimes-button'))

    def test_catalog_page_elements_and_filter(self):
        # Access catalog page without filters
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data.decode('utf-8'), 'html.parser')
        self.assertIsNotNone(soup.find('div', id='catalog-page'))
        self.assertIsNotNone(soup.find('input', id='search-input'))
        self.assertIsNotNone(soup.find('select', id='genre-filter'))
        self.assertIsNotNone(soup.find('div', id='movies-grid'))
        # Check that movie cards have view-movie-button-{movie_id}
        buttons = soup.find_all('button')
        self.assertTrue(any(btn['id'].startswith('view-movie-button-') for btn in buttons if btn.has_attr('id')))

    def test_movie_details_page_elements(self):
        # Use movie_id=1 from example data
