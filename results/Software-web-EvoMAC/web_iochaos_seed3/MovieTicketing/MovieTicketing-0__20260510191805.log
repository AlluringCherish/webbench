templates/booking_history.html
```html
'''
Booking History page template.
Displays all previous bookings with filters and navigation.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking History</title>
</head>
<body>
    <div id="bookings-page">
        <h1>Booking History</h1>
        <form method="get" action="{{ url_for('booking_history') }}">
            <label for="status-filter">Filter by Status:</label>
            <select id="status-filter" name="status">
                <option value="All" {% if status_filter == 'All' %}selected{% endif %}>All</option>
                <option value="Confirmed" {% if status_filter == 'Confirmed' %}selected{% endif %}>Confirmed</option>
                <option value="Cancelled" {% if status_filter == 'Cancelled' %}selected{% endif %}>Cancelled</option>
                <option value="Completed" {% if status_filter == 'Completed' %}selected{% endif %}>Completed</option>
            </select>
            <button type="submit">Filter</button>
        </form>
        <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Movie</th>
                    <th>Date</th>
                    <th>Seats</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for booking in bookings %}
                <tr>
                    <td>{{ booking.booking_id }}</td>
                    <td>{{ movie_dict.get(booking.showtime_id, 'Unknown') }}</td>
                    <td>{{ booking.booking_date }}</td>
                    <td>{{ booking.seats_booked|join(', ') }}</td>
                    <td>{{ booking.status }}</td>
                    <td><button id="view-booking-button-{{ booking.booking_id }}" onclick="location.href='{{ url_for('booking_details', booking_id=booking.booking_id) }}'">View</button></td>
                </tr>
                {% else %}
                <tr><td colspan="6">No bookings found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

