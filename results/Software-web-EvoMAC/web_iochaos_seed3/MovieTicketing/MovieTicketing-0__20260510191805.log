            <input type="text" id="customer-name" name="customer_name" required>
            <br>
            <label for="customer-email">Email:</label>
            <input type="email" id="customer-email" name="customer_email" required>
            <br>
            <button type="submit" id="confirm-booking-button">Confirm Booking</button>
        </form>
        <button onclick="location.href='{{ url_for('seat_selection', showtime_id=showtime.showtime_id) }}'">Back to Seat Selection</button>
    </div>
</body>
</html>
