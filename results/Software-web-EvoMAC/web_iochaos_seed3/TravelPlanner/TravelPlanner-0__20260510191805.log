'''
Main Flask application for TravelPlanner web application.
Starts from the Dashboard page and provides routing to all pages.
Data is loaded from local text files in the 'data' directory.
'''
from flask import Flask, render_template, request, redirect, url_for
import os
app = Flask(__name__)
DATA_DIR = 'data'
def load_destinations():
    destinations = []
    filepath = os.path.join(DATA_DIR, 'destinations.txt')
    if os.path.exists(filepath):
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    parts = line.split('|')
                    if len(parts) == 7:
                        dest = {
                            'dest_id': parts[0],
                            'name': parts[1],
                            'country': parts[2],
                            'region': parts[3],
                            'description': parts[4],
                            'attractions': parts[5],
                            'climate': parts[6]
                        }
                        destinations.append(dest)
    return destinations
