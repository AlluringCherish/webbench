<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Travel Planner Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Travel Planner Dashboard</h1>

        <div id="featured-destinations">
            <h2>Featured Destinations</h2>
            <ul>
                {% for dest in featured_destinations %}
                <li>
                    <strong>{{ dest.name }}</strong> - {{ dest.country }}
                    <button id="view-destination-button-{{ dest.dest_id }}" onclick="location.href='/destination/{{ dest.dest_id }}'">View Details</button>
                </li>
                {% endfor %}
            </ul>
        </div>

        <div id="upcoming-trips">
            <h2>Upcoming Trips</h2>
            <ul>
                {% for trip in upcoming_trips %}
                <li>
                    <strong>{{ trip.trip_name }}</strong> to {{ trip.destination }} from {{ trip.start_date }} to {{ trip.end_date }}
                </li>
                {% else %}
                <li>No upcoming trips.</li>
                {% endfor %}
            </ul>
        </div>

        <button id="browse-destinations-button" onclick="location.href='/destinations'">Browse Destinations</button>
        <button id="plan-itinerary-button" onclick="location.href='/itinerary'">Plan Your Itinerary</button>
    </div>
</body>
</html>
