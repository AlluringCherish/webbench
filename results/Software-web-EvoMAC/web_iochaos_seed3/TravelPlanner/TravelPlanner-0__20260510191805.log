'''
Travel Packages page template for TravelPlanner.
Displays pre-designed travel packages with filters.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Travel Packages</title>
</head>
<body>
    <div id="packages-page">
        <h1>Travel Packages</h1>

        <form method="get" action="/packages">
            <label for="duration-filter">Duration:</label>
            <select id="duration-filter" name="duration">
                {% for option in duration_options %}
                <option value="{{ option }}" {% if option == duration_filter %}selected{% endif %}>{{ option }}</option>
                {% endfor %}
            </select>
            <button type="submit">Filter</button>
        </form>

        <div id="packages-grid">
            {% for pkg in packages %}
            <div class="package-card">
                <h3>{{ pkg.package_name }}</h3>
                <p>Destination: {{ pkg.destination }}</p>
                <p>Duration: {{ pkg.duration_days }} days</p>
                <p>Price: ${{ pkg.price }}</p>
                <button id="view-package-details-button-{{ pkg.package_id }}" onclick="alert('View package details not implemented yet.')">View Details</button>
                <button id="book-package-button-{{ pkg.package_id }}" onclick="alert('Book package functionality not implemented yet.')">Book Package</button>
            </div>
            {% else %}
            <p>No packages found.</p>
            {% endfor %}
        </div>

        <button onclick="location.href='/'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/trips.html
```html
'''
Trip Management page template for TravelPlanner.
Displays all created trips with options to view, edit, or delete.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Trips</title>
</head>
<body>
    <div id="trips-page">
        <h1>My Trips</h1>

        <table id="trips-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Trip Name</th>
                    <th>Destination</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for trip in trips %}
                <tr>
                    <td>{{ trip.trip_name }}</td>
                    <td>{{ trip.destination }}</td>
                    <td>{{ trip.start_date }}</td>
                    <td>{{ trip.end_date }}</td>
                    <td>{{ trip.status }}</td>
                    <td>
                        <button id="view-trip-details-button-{{ trip.trip_id }}" onclick="alert('View trip details not implemented yet.')">View</button>
                        <button id="edit-trip-button-{{ trip.trip_id }}" onclick="alert('Edit trip not implemented yet.')">Edit</button>
                        <button id="delete-trip-button-{{ trip.trip_id }}" onclick="alert('Delete trip not implemented yet.')">Delete</button>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6">No trips found.</td></tr>
                {% endfor %}
            </tbody>
        </table>

        <button onclick="location.href='/'">Back to Dashboard</button>
    </div>
</body>
</html>
```

