templates/recommendations.html
```html
'''
Travel Recommendations page template for TravelPlanner.
Displays personalized travel recommendations and trending destinations.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Travel Recommendations</title>
</head>
<body>
    <div id="recommendations-page">
        <h1>Travel Recommendations</h1>

        <form method="get" action="/recommendations">
            <label for="recommendation-season-filter">Travel Season:</label>
            <select id="recommendation-season-filter" name="season">
                {% for season in seasons %}
                <option value="{{ season }}" {% if season == recommendation_season_filter %}selected{% endif %}>{{ season }}</option>
                {% endfor %}
            </select>

            <label for="budget-filter">Budget Range:</label>
            <select id="budget-filter" name="budget">
                {% for b in budgets %}
                <option value="{{ b }}" {% if b == budget_filter %}selected{% endif %}>{{ b }}</option>
                {% endfor %}
            </select>

            <button type="submit">Filter</button>
        </form>

        <div id="trending-destinations">
            <h2>Trending Destinations</h2>
            <ul>
                {% for dest in trending_destinations %}
                <li><strong>{{ dest.name }}</strong> - {{ dest.country }}</li>
                {% else %}
                <li>No trending destinations available.</li>
                {% endfor %}
            </ul>
        </div>

        <button id="back-to-dashboard" onclick="location.href='/'">Back to Dashboard</button>
    </div>
</body>
</html>
```
