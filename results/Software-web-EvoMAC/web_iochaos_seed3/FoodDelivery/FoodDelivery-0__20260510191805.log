dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Food Delivery Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="dashboard-page">
        <h1>Food Delivery Dashboard</h1>
        <div id="featured-restaurants">
            <h2>Featured Restaurants</h2>
            <ul>
                {% for restaurant in featured_restaurants %}
                <li>
                    <strong>{{ restaurant.name }}</strong> - {{ restaurant.cuisine }} - Rating: {{ restaurant.rating }} - Delivery Time: {{ restaurant.delivery_time }} mins
                </li>
                {% else %}
                <li>No featured restaurants available.</li>
                {% endfor %}
            </ul>
        </div>
        <div id="popular-cuisines">
            <h2>Popular Cuisines</h2>
            <ul>
                {% for cuisine in popular_cuisines %}
                <li>{{ cuisine }}</li>
                {% else %}
                <li>No cuisines available.</li>
                {% endfor %}
            </ul>
        </div>
        <div id="dashboard-buttons">
            <button id="browse-restaurants-button" onclick="location.href='{{ url_for('browse_restaurants') }}'">Browse Restaurants</button>
            <button id="view-cart-button" onclick="location.href='{{ url_for('view_cart') }}'">View Cart</button>
            <button id="active-orders-button" onclick="location.href='{{ url_for('active_orders') }}'">Active Orders</button>
        </div>
    </div>
</body>
</html>
```

restaurants.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Browse Restaurants</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="restaurants-page">
        <h1>Browse Restaurants</h1>
        <form method="get" action="{{ url_for('browse_restaurants') }}">
            <input type="text" id="search-input" name="search" placeholder="Search by name or cuisine" value="{{ search_query|default('') }}">
            <select id="cuisine-filter" name="cuisine">
                <option value="">All Cuisines</option>
                {% for cuisine in cuisines %}
                <option value="{{ cuisine }}" {% if cuisine == selected_cuisine %}selected{% endif %}>{{ cuisine }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>
        <div id="restaurants-grid">
            {% if restaurants %}
                {% for restaurant in restaurants %}
                <div class="restaurant-card">
                    <div class="restaurant-logo">
                        <!-- Placeholder for logo, can be replaced with actual images -->
                        <img src="{{ url_for('static', filename='images/restaurant_' ~ restaurant.restaurant_id ~ '.jpg') }}" alt="{{ restaurant.name }} Logo" onerror="this.style.display='none'">
                    </div>
                    <div class="restaurant-info">
                        <h3>{{ restaurant.name }}</h3>
                        <p>Cuisine: {{ restaurant.cuisine }}</p>
                        <p>Rating: {{ restaurant.rating }}</p>
                        <p>Delivery Time: {{ restaurant.delivery_time }} mins</p>
                        <button id="view-restaurant-button-{{ restaurant.restaurant_id }}" onclick="location.href='{{ url_for('restaurant_menu', restaurant_id=restaurant.restaurant_id) }}'">View Menu</button>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p>No restaurants found.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

menu.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Restaurant Menu</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="menu-page">
        <h1 id="restaurant-name">{{ restaurant.name }}</h1>
        <div id="restaurant-info">
            <p>Address: {{ restaurant.address }}</p>
            <p>Phone: {{ restaurant.phone }}</p>
            <p>Rating: {{ restaurant.rating }}</p>
        </div>
        <div id="menu-items-grid">
            {% if menu_items %}
                {% for item in menu_items %}
                <div class="menu-item-card">
                    <div class="menu-item-photo">
                        <img src="{{ url_for('static', filename='images/item_' ~ item.item_id ~ '.jpg') }}" alt="{{ item.item_name }}" onerror="this.style.display='none'">
                    </div>
                    <div class="menu-item-info">
                        <h3>{{ item.item_name }}</h3>
                        <p>{{ item.description }}</p>
                        <p>Price: ${{ "%.2f"|format(item.price) }}</p>
                        <button id="add-to-cart-button-{{ item.item_id }}" onclick="location.href='{{ url_for('add_to_cart', item_id=item.item_id) }}'">Add to Cart</button>
                        <button id="view-item-details-{{ item.item_id }}" onclick="location.href='{{ url_for('item_details', item_id=item.item_id) }}'">View Details</button>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p>No menu items available.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('browse_restaurants') }}'">Back to Restaurants</button>
    </div>
</body>
</html>
```

item_details.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Item Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="item-details-page">
        <h1 id="item-name">{{ item.item_name }}</h1>
        <div id="item-description">
            <p>{{ item.description }}</p>
            {% if item.ingredients %}
            <p><strong>Ingredients:</strong> {{ item.ingredients }}</p>
            {% endif %}
            {% if item.nutritional_info %}
            <p><strong>Nutritional Info:</strong> {{ item.nutritional_info }}</p>
            {% endif %}
        </div>
        <div id="item-price">
            <p>Price: ${{ "%.2f"|format(item.price) }}</p>
        </div>
        <form method="post" action="{{ url_for('add_to_cart_with_quantity', item_id=item.item_id) }}">
            <label for="quantity-input">Quantity:</label>
            <input type="number" id="quantity-input" name="quantity" value="1" min="1" required>
            <button type="submit" id="add-to-cart-button">Add to Cart</button>
        </form>
        <button onclick="location.href='{{ url_for('restaurant_menu', restaurant_id=item.restaurant_id) }}'">Back to Menu</button>
    </div>
</body>
</html>
```

cart.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="cart-page">
        <h1>Shopping Cart</h1>
        {% if cart_items %}
        <form method="post" action="{{ url_for('update_cart_quantities') }}">
            <table id="cart-items-table" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Subtotal</th>
                        <th>Remove</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart_items %}
                    <tr>
                        <td>{{ item.item_name }}</td>
                        <td>
                            <input type="number" id="update-quantity-{{ item.item_id }}" name="quantity_{{ item.item_id }}" value="{{ item.quantity }}" min="1" required>
                        </td>
                        <td>${{ "%.2f"|format(item.price) }}</td>
                        <td>${{ "%.2f"|format(item.subtotal) }}</td>
                        <td>
                            <button type="submit" formaction="{{ url_for('remove_cart_item', item_id=item.item_id) }}" formmethod="post" id="remove-item-button-{{ item.item_id }}">Remove</button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div id="total-amount">
                <strong>Total Amount: ${{ "%.2f"|format(total_amount) }}</strong>
            </div>
            <button type="submit" id="update-cart-button">Update Quantities</button>
        </form>
        <button id="proceed-checkout-button" onclick="location.href='{{ url_for('checkout') }}'">Proceed to Checkout</button>
        {% else %}
        <p>Your cart is empty.</p>
        {% endif %}
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

checkout.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Checkout</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="checkout-page">
        <h1>Checkout</h1>
        <form method="post" action="{{ url_for('checkout') }}">
            <label for="customer-name">Customer Name:</label><br>
            <input type="text" id="customer-name" name="customer_name" value="{{ customer_name|default('') }}" required><br><br>
            <label for="delivery-address">Delivery Address:</label><br>
            <textarea id="delivery-address" name="delivery_address" rows="4" cols="50" required>{{ delivery_address|default('') }}</textarea><br><br>
            <label for="phone-number">Phone Number:</label><br>
            <input type="text" id="phone-number" name="phone_number" value="{{ phone_number|default('') }}" required><br><br>
            <label for="payment-method">Payment Method:</label><br>
            <select id="payment-method" name="payment_method" required>
                <option value="Credit Card" {% if payment_method == 'Credit Card' %}selected{% endif %}>Credit Card</option>
                <option value="Cash" {% if payment_method == 'Cash' %}selected{% endif %}>Cash</option>
                <option value="PayPal" {% if payment_method == 'PayPal' %}selected{% endif %}>PayPal</option>
            </select><br><br>
            <button type="submit" id="place-order-button">Place Order</button>
        </form>
        <button onclick="location.href='{{ url_for('view_cart') }}'">Back to Cart</button>
    </div>
</body>
</html>
```

