<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="cart-page">
        <h1>Shopping Cart</h1>
        {% if cart_items %}
        <form method="post" action="{{ url_for('update_cart_quantities') }}">
            <table id="cart-items-table" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Subtotal</th>
                        <th>Remove</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart_items %}
                    <tr>
                        <td>{{ item.item_name }}</td>
                        <td>
                            <input type="number" id="update-quantity-{{ item.item_id }}" name="quantity_{{ item.item_id }}" value="{{ item.quantity }}" min="1" required>
                        </td>
                        <td>${{ "%.2f"|format(item.price) }}</td>
                        <td>${{ "%.2f"|format(item.subtotal) }}</td>
                        <td>
                            <button type="submit" formaction="{{ url_for('remove_cart_item', item_id=item.item_id) }}" formmethod="post" id="remove-item-button-{{ item.item_id }}">Remove</button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div id="total-amount">
                <strong>Total Amount: ${{ "%.2f"|format(total_amount) }}</strong>
            </div>
            <button type="submit" id="update-cart-button">Update Quantities</button>
        </form>
        <button id="proceed-checkout-button" onclick="location.href='{{ url_for('checkout') }}'">Proceed to Checkout</button>
        {% else %}
        <p>Your cart is empty.</p>
        {% endif %}
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
