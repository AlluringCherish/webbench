```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Item Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="item-details-page">
        <h1 id="item-name">{{ item.item_name }}</h1>
        <div id="item-description">
            <p>{{ item.description }}</p>
            {% if item.ingredients %}
            <p><strong>Ingredients:</strong> {{ item.ingredients }}</p>
            {% endif %}
            {% if item.nutritional_info %}
            <p><strong>Nutritional Info:</strong> {{ item.nutritional_info }}</p>
            {% endif %}
        </div>
        <div id="item-price">
            <p>Price: ${{ "%.2f"|format(item.price) }}</p>
        </div>
        <form method="post" action="{{ url_for('add_to_cart_with_quantity', item_id=item.item_id) }}">
            <label for="quantity-input">Quantity:</label>
            <input type="number" id="quantity-input" name="quantity" value="1" min="1" required>
            <button type="submit" id="add-to-cart-button">Add to Cart</button>
        </form>
        <button onclick="location.href='{{ url_for('restaurant_menu', restaurant_id=item.restaurant_id) }}'">Back to Menu</button>
    </div>
</body>
</html>
