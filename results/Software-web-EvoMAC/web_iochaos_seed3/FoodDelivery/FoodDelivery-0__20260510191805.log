checkout.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Checkout</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="checkout-page">
        <h1>Checkout</h1>
        <form method="post" action="{{ url_for('checkout') }}">
            <label for="customer-name">Customer Name:</label><br>
            <input type="text" id="customer-name" name="customer_name" value="{{ customer_name|default('') }}" required><br><br>
            <label for="delivery-address">Delivery Address:</label><br>
            <textarea id="delivery-address" name="delivery_address" rows="4" cols="50" required>{{ delivery_address|default('') }}</textarea><br><br>
            <label for="phone-number">Phone Number:</label><br>
            <input type="text" id="phone-number" name="phone_number" value="{{ phone_number|default('') }}" required><br><br>
            <label for="payment-method">Payment Method:</label><br>
            <select id="payment-method" name="payment_method" required>
                <option value="Credit Card" {% if payment_method == 'Credit Card' %}selected{% endif %}>Credit Card</option>
                <option value="Cash" {% if payment_method == 'Cash' %}selected{% endif %}>Cash</option>
                <option value="PayPal" {% if payment_method == 'PayPal' %}selected{% endif %}>PayPal</option>
            </select><br><br>
            <button type="submit" id="place-order-button">Place Order</button>
        </form>
        <button onclick="location.href='{{ url_for('view_cart') }}'">Back to Cart</button>
    </div>
</body>
</html>
```

