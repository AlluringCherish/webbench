                <option value="">All Cuisines</option>
                {% for cuisine in cuisines %}
                <option value="{{ cuisine }}" {% if cuisine == selected_cuisine %}selected{% endif %}>{{ cuisine }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>
        <div id="restaurants-grid">
            {% if restaurants %}
                {% for restaurant in restaurants %}
                <div class="restaurant-card">
                    <div class="restaurant-logo">
                        <!-- Placeholder for logo, can be replaced with actual images -->
                        <img src="{{ url_for('static', filename='images/restaurant_' ~ restaurant.restaurant_id ~ '.jpg') }}" alt="{{ restaurant.name }} Logo" onerror="this.style.display='none'">
                    </div>
                    <div class="restaurant-info">
                        <h3>{{ restaurant.name }}</h3>
                        <p>Cuisine: {{ restaurant.cuisine }}</p>
                        <p>Rating: {{ restaurant.rating }}</p>
                        <p>Delivery Time: {{ restaurant.delivery_time }} mins</p>
                        <button id="view-restaurant-button-{{ restaurant.restaurant_id }}" onclick="location.href='{{ url_for('restaurant_menu', restaurant_id=restaurant.restaurant_id) }}'">View Menu</button>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p>No restaurants found.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
