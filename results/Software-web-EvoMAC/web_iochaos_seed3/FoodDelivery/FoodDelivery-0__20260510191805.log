<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order Reviews</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="reviews-page">
        <h1>Order Reviews</h1>
        <form method="get" action="{{ url_for('reviews') }}">
            <label for="filter-by-rating">Filter by Rating:</label>
            <select id="filter-by-rating" name="rating">
                <option value="All" {% if filter_rating == 'All' %}selected{% endif %}>All</option>
                <option value="5" {% if filter_rating == '5' %}selected{% endif %}>5 stars</option>
                <option value="4" {% if filter_rating == '4' %}selected{% endif %}>4 stars</option>
                <option value="3" {% if filter_rating == '3' %}selected{% endif %}>3 stars</option>
                <option value="2" {% if filter_rating == '2' %}selected{% endif %}>2 stars</option>
                <option value="1" {% if filter_rating == '1' %}selected{% endif %}>1 star</option>
            </select>
            <button type="submit">Filter</button>
        </form>
        <div id="reviews-list">
            {% if reviews %}
                <ul>
                {% for review in reviews %}
                    <li>
                        <strong>{{ review.restaurant_name }}</strong> - Rating: {{ review.rating }}<br>
                        {{ review.review_text }}<br>
                        <em>By {{ review.customer_name }} on {{ review.review_date }}</em>
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No reviews found.</p>
            {% endif %}
        </div>
        <button id="write-review-button" onclick="location.href='{{ url_for('write_review') }}'">Write a Review</button>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
