import unittest
from app import app

class FoodDeliveryDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access root URL and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_elements(self):
        # Test Task 2 & 3: Check presence of main container and key elements on dashboard page
        response = self.client.get('/')
        html = response.get_data(as_text=True)

        # Check container div id
        self.assertIn('id="dashboard-page"', html, "Dashboard container div with id 'dashboard-page' should be present")

        # Check featured restaurants section
        self.assertIn('id="featured-restaurants"', html, "Featured restaurants div with id 'featured-restaurants' should be present")
        self.assertIn('<h2>Featured Restaurants</h2>', html, "Featured restaurants header should be present")

        # Check popular cuisines section
        self.assertIn('id="popular-cuisines"', html, "Popular cuisines div with id 'popular-cuisines' should be present")
        self.assertIn('<h2>Popular Cuisines</h2>', html, "Popular cuisines header should be present")

        # Check dashboard buttons container
        self.assertIn('id="dashboard-buttons"', html, "Dashboard buttons container div with id 'dashboard-buttons' should be present")

        # Check buttons by id and their labels
        self.assertIn('id="browse-restaurants-button"', html, "Browse Restaurants button with id 'browse-restaurants-button' should be present")
        self.assertIn('Browse Restaurants', html, "Browse Restaurants button text should be present")

        self.assertIn('id="view-cart-button"', html, "View Cart button with id 'view-cart-button' should be present")
        self.assertIn('View Cart', html, "View Cart button text should be present")

        self.assertIn('id="active-orders-button"', html, "Active Orders button with id 'active-orders-button' should be present")
        self.assertIn('Active Orders', html, "Active Orders button text should be present")

    def test_dashboard_navigation_buttons(self):
        # Test Task 2: Check that navigation buttons link to correct URLs
        response = self.client.get('/')
        html = response.get_data(as_text=True)

        # The buttons use onclick with location.href, check URLs for correctness
        self.assertIn("location.href='/restaurants'", html, "Browse Restaurants button should link to /restaurants")
        self.assertIn("location.href='/cart'", html, "View Cart button should link to /cart")
        self.assertIn("location.href='/active_orders'", html, "Active Orders button should link to /active_orders")

if __name__ == '__main__':
    unittest.main()
