                        <button id="track-order-button-{{ order.order_id }}" onclick="location.href='{{ url_for('track_order', order_id=order.order_id) }}'">Track Order</button>
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No active orders found.</p>
            {% endif %}
        </div>
