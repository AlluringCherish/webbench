<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Active Orders</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script src="{{ url_for('static', filename='js/scripts.js') }}"></script>
</head>
<body>
    <div id="active-orders-page">
        <h1>Active Orders</h1>
        <form method="get" action="{{ url_for('active_orders') }}">
            <label for="status-filter">Filter by Status:</label>
            <select id="status-filter" name="status">
                {% for status_option in statuses %}
                <option value="{{ status_option }}" {% if status_option == status_filter %}selected{% endif %}>{{ status_option }}</option>
                {% endfor %}
            </select>
            <button type="submit">Filter</button>
        </form>
        <div id="orders-list">
            {% if orders %}
                <ul>
                {% for order in orders %}
                    <li>
                        Order ID: {{ order.order_id }} - Restaurant: {{ order.restaurant_name }} - Status: {{ order.status }} - ETA: {{ order.eta }}
                        <button id="track-order-button-{{ order.order_id }}" onclick="location.href='{{ url_for('track_order', order_id=order.order_id) }}'">Track Order</button>
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No active orders found.</p>
            {% endif %}
        </div>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
