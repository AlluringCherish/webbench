'''
Auction Catalog page template for OnlineAuction.
Displays all auctions with search and category filter.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Catalog</title>
</head>
<body>
    <div id="catalog-page">
        <h1>Auction Catalog</h1>

        <form method="get" action="{{ url_for('auction_catalog') }}">
            <input id="search-input" type="text" name="search" placeholder="Search auctions..." value="{{ search_query }}">
            <select id="category-filter" name="category">
                <option value="all" {% if selected_category == 'all' or not selected_category %}selected{% endif %}>All Categories</option>
                {% for category in categories %}
                    <option value="{{ category.category_name|lower }}" {% if selected_category == category.category_name|lower %}selected{% endif %}>{{ category.category_name }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>

        <div id="auctions-grid">
            {% if auctions %}
                <ul>
                {% for auction in auctions %}
                    <li>
                        <img src="{{ url_for('static', filename=auction.image_url) }}" alt="{{ auction.item_name }}" width="100">
                        <strong>{{ auction.item_name }}</strong><br>
                        Current Bid: ${{ '%.2f'|format(auction.current_bid) }}<br>
                        Time Remaining: {{ auction.end_time }}<br>
                        <button id="view-auction-button-{{ auction.auction_id }}" onclick="location.href='{{ url_for('auction_details', auction_id=auction.auction_id) }}'">View Details</button>
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No auctions found.</p>
            {% endif %}
        </div>

        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
