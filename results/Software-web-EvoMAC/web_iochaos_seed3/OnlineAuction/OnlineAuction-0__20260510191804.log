                        </a>
                    </div>
                {% endfor %}
            {% else %}
                <p>No auctions found matching your criteria.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
