            <div id="auction-name">Auction Item: {{ auction.item_name }}</div>
            <div id="minimum-bid">Minimum Acceptable Bid: ${{ '%.2f'|format(minimum_bid + 0.01) }}</div><br>

            <button id="submit-bid-button" type="submit">Submit Bid</button>
        </form>

        <button onclick="location.href='{{ url_for('auction_details', auction_id=auction.auction_id) }}'">Back to Auction Details</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
