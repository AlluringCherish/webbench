```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Place Bid</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="place-bid-page">
        <h1>Place Bid</h1>

        <div id="auction-name">
            <strong>Auction Item:</strong> {{ auction.item_name }}
        </div>
        <div id="minimum-bid">
            <strong>Minimum Acceptable Bid:</strong> ${{ '%.2f'|format(minimum_bid) }}
        </div>

        {% if error %}
            <p style="color:red;">{{ error }}</p>
        {% endif %}

        <form method="post" action="{{ url_for('place_bid', auction_id=auction.auction_id) }}">
            <label for="bidder-name">Bidder Name:</label><br>
            <input type="text" id="bidder-name" name="bidder_name" required><br><br>

            <label for="bid-amount">Bid Amount:</label><br>
            <input type="number" id="bid-amount" name="bid_amount" step="0.01" min="{{ minimum_bid + 0.01 }}" required><br><br>

            <button type="submit" id="submit-bid-button">Submit Bid</button>
        </form>

        <button onclick="location.href='{{ url_for('auction_details', auction_id=auction.auction_id) }}'">Back to Auction Details</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
