}
/* Remove song button in playlist details */
button[id^="remove-song-button-"] {
    background-color: #dc3545;
}
button[id^="remove-song-button-"]:hover {
    background-color: #a71d2a;
}
/* Delete playlist button */
#delete-playlist-button {
    background-color: #dc3545;
    padding: 10px 18px;
    font-weight: 600;
}
#delete-playlist-button:hover {
