                           songs=songs,
                           albums=albums)

@app.route('/genres')
def genres():
    genres = read_genres()
    selected_genre = request.args.get('genre', '').strip()
    genre_songs = []
    genre_artists = []
    if selected_genre:
        genre_songs = get_songs_by_genre(selected_genre)
