<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Music Streaming Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="dashboard-page">
        <h1>Music Streaming Dashboard</h1>
        <section id="featured-songs">
            <h2>Featured Songs</h2>
            <ul>
                {% for song in featured_songs %}
                <li>
                    <a href="{{ url_for('song_details', song_id=song.song_id) }}">{{ song.title }}</a> by 
                    <a href="{{ url_for('artist_profile', artist_id=song.artist_id) }}">{{ song.artist_name }}</a>
                </li>
                {% else %}
                <li>No featured songs available.</li>
                {% endfor %}
            </ul>
        </section>
        <section id="trending-artists">
            <h2>Trending Artists</h2>
            <ul>
                {% for artist in trending_artists %}
                <li>
                    <a href="{{ url_for('artist_profile', artist_id=artist.artist_id) }}">{{ artist.name }}</a>
                </li>
                {% else %}
                <li>No trending artists available.</li>
                {% endfor %}
            </ul>
        </section>
        <nav>
            <button id="browse-songs-button" onclick="location.href='{{ url_for('song_catalog') }}'">Browse Songs</button>
            <button id="my-playlists-button" onclick="location.href='{{ url_for('playlists') }}'">My Playlists</button>
            <button id="trending-artists-button" onclick="location.href='{{ url_for('artists') }}'">Trending Artists</button>
        </nav>
    </div>
</body>
</html>
