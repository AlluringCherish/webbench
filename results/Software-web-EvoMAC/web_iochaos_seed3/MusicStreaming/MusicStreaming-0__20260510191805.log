}
/* Responsive adjustments */
@media (max-width: 768px) {
    #songs-grid,
    #albums-grid,
    #artists-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
}
@media (max-width: 480px) {
    nav button,
    button {
        width: 100%;
        margin-bottom: 10px;
    }
}
