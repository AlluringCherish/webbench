/*
Stylesheet for ContentPublishingHub
Provides consistent UI design across all pages
*/

/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f9fafb;
    color: #333;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.page-container {
    max-width: 960px;
    margin: 2rem auto;
    padding: 1.5rem 2rem;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* Header */
header h1#welcome-message {
    font-size: 1.8rem;
    color: #2c3e50;
    margin-bottom: 1rem;
}

/* Sections */
.stats-section, .activity-feed, .actions-section {
    margin-bottom: 2rem;
}

.stats-section h2, .activity-feed h2 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
    color: #34495e;
    border-bottom: 2px solid #3498db;
    padding-bottom: 0.3rem;
}

.stats-section ul {
    list-style: none;
    padding-left: 0;
}

.stats-section ul li {
    font-size: 1.1rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid #e1e4e8;
}

.actions-section {
    text-align: right;
}

button#create-article-button {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    font-size: 1.1rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

button#create-article-button:hover,
button#create-article-button:focus {
    background-color: #2980b9;
    outline: none;
}

/* Recent Activity Feed */
.activity-feed ul {
    list-style: none;
    padding-left: 0;
}

.activity-feed ul li {
    background-color: #f4f6f8;
    border-radius: 5px;
    padding: 0.8rem 1rem;
    margin-bottom: 0.8rem;
    font-size: 0.95rem;
    color: #2c3e50;
    box-shadow: inset 0 0 3px rgba(0,0,0,0.05);
}

.activity-feed ul li strong {
    color: #2980b9;
}

.activity-feed ul li em {
    font-style: italic;
    color: #7f8c8d;
}

.activity-feed p {
    font-style: italic;
    color: #7f8c8d;
}

/* Links and buttons */
a, button {
    text-decoration: none;
}

button {
    font-family: inherit;
}

/* Responsive */
@media (max-width: 600px) {
    .page-container {
        margin: 1rem;
        padding: 1rem;
    }

    header h1#welcome-message {
        font-size: 1.4rem;
    }

    .stats-section h2, .activity-feed h2 {
        font-size: 1.2rem;
    }

    button#create-article-button {
        width: 100%;
        padding: 0.8rem;
        font-size: 1.2rem;
    }
}
```

