import unittest
from app import app
class ContentPublishingHubTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_root_redirects_to_dashboard(self):
        # Test root URL redirects to /dashboard
        response = self.client.get('/')
        self.assertEqual(response.status_code, 302)
        self.assertIn('/dashboard', response.headers['Location'])
    def test_dashboard_accessible(self):
        # Test /dashboard page is accessible and returns 200
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
    def test_dashboard_contains_required_elements(self):
        # Test that dashboard page contains required elements by id and content
        response = self.client.get('/dashboard')
        html = response.get_data(as_text=True)
        # Check page container id
        self.assertIn('id="dashboard-page"', html)
        # Check welcome message with username (default user is 'john' with fullname 'John Doe')
        self.assertIn('id="welcome-message"', html)
        self.assertIn('Welcome, John Doe!', html)
        # Check quick stats section
        self.assertIn('id="quick-stats"', html)
        self.assertIn('Total Articles:', html)
        self.assertIn('Published Articles:', html)
        self.assertIn('Drafts:', html)
        self.assertIn('Pending Review:', html)
        # Check Create Article button
        self.assertIn('id="create-article-button"', html)
        self.assertIn('Create Article', html)
        # Check recent activity feed
        self.assertIn('id="recent-activity"', html)
        self.assertIn('Recent Activity', html)
    def test_create_article_button_navigation(self):
        # Test that clicking Create Article button leads to /article/create page
        # Since we cannot click button in unittest, test the URL linked in button onclick
        response = self.client.get('/dashboard')
        html = response.get_data(as_text=True)
        self.assertIn("location.href='/article/create'", html)
        # Test /article/create page is accessible
        response_create = self.client.get('/article/create')
        self.assertEqual(response_create.status_code, 200)
        self.assertIn('id="create-article-page"', response_create.get_data(as_text=True))
if __name__ == '__main__':
    unittest.main()

