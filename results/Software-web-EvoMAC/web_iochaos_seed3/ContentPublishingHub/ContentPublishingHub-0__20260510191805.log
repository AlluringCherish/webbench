        stages.append({
            'stage_id': parts[0],
            'category': parts[1],
            'stage_name': parts[2],
            'stage_order': int(parts[3]),
            'is_required': parts[4].lower() == 'yes'
        })
    return stages
# Load comments from comments.txt
def load_comments():
    comments = []
    lines = read_file_lines('comments.txt')
    for line in lines:
        parts = line.split('|')
        if len(parts) < 6:
            continue
        comments.append({
            'comment_id': parts[0],
            'article_id': parts[1],
            'version_id': parts[2],
            'user': parts[3],
            'comment_text': parts[4],
            'timestamp': parts[5]
        })
    return comments
def save_comments(comments):
    lines = []
    for c in comments:
        line = '|'.join([
            c['comment_id'],
            c['article_id'],
            c['version_id'],
            c['user'],
            c['comment_text'],
