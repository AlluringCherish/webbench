/*
for ContentPublishingHub
Provides consistent UI all
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f9fafb;
    color: #333;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}
{
    max-width: 960px;
    margin: 2rem auto;
    padding: 1.5rem 2rem;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
{
    font-size: 1.8rem;
    color: #2c3e50;
    margin-bottom: 1rem;
}
*/
.activity-feed, {
    margin-bottom: 2rem;
}
{
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
    color: #34495e;
    border-bottom: 2px solid #3498db;
    padding-bottom: 0.3rem;
}
ul {
    list-style: none;
    padding-left: 0;
}
li {
    font-size: 1.1rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid #e1e4e8;
}
{
    text-align: right;
}
{
    background-color: #3498db;
