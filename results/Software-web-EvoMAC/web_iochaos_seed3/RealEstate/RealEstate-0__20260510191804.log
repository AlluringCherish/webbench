        <h2>Featured Properties</h2>
        {% if featured_properties %}
            {% for property in featured_properties %}
                <div class="property-card">
                    <h3>{{ property.address }}</h3>
                    <div class="property-info">
                        Location: {{ property.location }}<br>
                        Price: ${{ "{:,}".format(property.price) }}<br>
                        Beds: {{ property.bedrooms }} | Baths: {{ property.bathrooms }}
                    </div>
                    <form action="{{ url_for('property_details', property_id=property.property_id) }}" method="get" style="margin-top: 5px;">
                        <button type="submit" id="view-property-button-{{ property.property_id }}">View Details</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No featured properties available.</p>
        {% endif %}
    </section>
    <section id="recent-listings">
        <h2>Recent Listings</h2>
        {% if recent_listings %}
            {% for property in recent_listings %}
                <div class="property-card">
                    <h3>{{ property.address }}</h3>
                    <div class="property-info">
                        Location: {{ property.location }}<br>
                        Price: ${{ "{:,}".format(property.price) }}<br>
