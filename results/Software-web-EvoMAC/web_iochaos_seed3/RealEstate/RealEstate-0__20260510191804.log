    margin-bottom: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    align-items: center;
}
.filters label {
    font-weight: 600;
    margin-right: 6px;
    white-space: nowrap;
}
.filters input[type="text"],
.filters input[type="number"],
.filters select {
    width: 150px;
}
/* Error message */
.error-message {
    color: #e74c3c;
    font-weight: 600;
    margin-bottom: 15px;
}
/* Navigation buttons container */
#dashboard-buttons,
#back-to-dashboard-container {
    text-align: center;
    margin-top: 30px;
}
#dashboard-buttons button,
#back-to-dashboard-container button {
    margin: 0 10px;
    padding: 12px 25px;
    font-size: 1.1em;
    border-radius: 6px;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    .filters {
        flex-direction: column;
        align-items: stretch;
    }
    .filters input[type="text"],
    .filters input[type="number"],
    .filters select {
        width: 100%;
    }
    #properties-grid,
    #agents-list,
    #locations-list {
        grid-template-columns: 1fr;
    }
}
