property_search.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Property Search</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="search-page">
    <h1>Property Search</h1>
    <form method="get" action="{{ url_for('property_search') }}" class="filters" id="search-filters">
        <label for="location-input">Location:</label>
        <input type="text" id="location-input" name="location" value="{{ location_input }}" placeholder="Enter location or city">
        <label for="price-range-min">Min Price:</label>
        <input type="number" id="price-range-min" name="price_min" min="0" value="{{ price_range_min }}">
        <label for="price-range-max">Max Price:</label>
        <input type="number" id="price-range-max" name="price_max" min="0" value="{{ price_range_max }}">
        <label for="property-type-filter">Property Type:</label>
        <select id="property-type-filter" name="property_type">
            <option value="">All</option>
            {% for ptype in property_types %}
                <option value="{{ ptype }}" {% if property_type_filter == ptype %}selected{% endif %}>{{ ptype }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="properties-grid">
        {% if properties %}
            {% for property in properties %}
                <div class="property-card">
                    <h3>{{ property.address }}</h3>
                    <div class="property-info">
                        Location: {{ property.location }}<br>
                        Price: ${{ "{:,}".format(property.price) }}<br>
                        Beds: {{ property.bedrooms }} | Baths: {{ property.bathrooms }}
                    </div>
                    <form action="{{ url_for('property_details', property_id=property.property_id) }}" method="get" style="margin-top: 5px;">
                        <button type="submit" id="view-property-button-{{ property.property_id }}">View Details</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No properties found matching your criteria.</p>
        {% endif %}
    </div>
    <div id="back-to-dashboard-container">
        <form action="{{ url_for('back_to_dashboard') }}" method="get">
            <button type="submit" id="back-to-dashboard">Back to Dashboard</button>
        </form>
    </div>
</div>
</body>
</html>
