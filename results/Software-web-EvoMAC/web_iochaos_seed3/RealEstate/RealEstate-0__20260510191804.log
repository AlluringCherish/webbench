'''
Test whether the website can be accessed through local port 5000.
In this test, you only need to test whether the first page of the website can be accessed through the local 5000 port.
'''
import unittest
from main import app

class TestRealEstateApp(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test GET request to root URL '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check that the response contains the dashboard page title
        self.assertIn(b'Real Estate Dashboard', response.data)

if __name__ == '__main__':
    unittest.main()
