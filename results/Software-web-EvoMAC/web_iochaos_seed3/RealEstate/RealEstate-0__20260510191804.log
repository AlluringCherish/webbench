/*
Stylesheet for consistent styling across all pages of the RealEstate web application.
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
/* Body and general font */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    min-height: 100vh;
}
/* Container for pages */
#dashboard-page,
#search-page,
#property-details-page,
#inquiry-page,
#inquiries-page,
#favorites-page,
#agents-page,
#locations-page {
    max-width: 1000px;
    margin: 20px auto 40px auto;
    padding: 20px;
    background-color: #fff;
