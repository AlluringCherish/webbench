'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page as the first page.
'''

import unittest
from app import app
from bs4 import BeautifulSoup

class TestJobBoardDashboard(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test that the dashboard page has correct title
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string.strip()
        self.assertEqual(title, "Job Board Dashboard", "Dashboard page title should be 'Job Board Dashboard'")

    def test_dashboard_page_elements(self):
        # Test presence of main container div with id 'dashboard-page'
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page should contain div with id 'dashboard-page'")

        # Test presence of featured jobs section with id 'featured-jobs'
        featured_jobs_section = soup.find('section', id='featured-jobs')
        self.assertIsNotNone(featured_jobs_section, "Dashboard page should contain section with id 'featured-jobs'")

        # Test presence of buttons with correct ids and their text
        browse_jobs_button = soup.find('button', id='browse-jobs-button')
        self.assertIsNotNone(browse_jobs_button, "Dashboard page should have button with id 'browse-jobs-button'")
        self.assertIn("Browse Jobs", browse_jobs_button.text)

        my_applications_button = soup.find('button', id='my-applications-button')
        self.assertIsNotNone(my_applications_button, "Dashboard page should have button with id 'my-applications-button'")
        self.assertIn("My Applications", my_applications_button.text)

        companies_button = soup.find('button', id='companies-button')
        self.assertIsNotNone(companies_button, "Dashboard page should have button with id 'companies-button'")
        self.assertIn("Companies", companies_button.text)

    def test_featured_jobs_content(self):
        # Test that featured jobs are displayed with required info: title, company, location, salary range, and view details button
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        job_cards = soup.select('#featured-jobs .job-card')
        self.assertTrue(len(job_cards) > 0, "There should be at least one featured job displayed")

        for job_card in job_cards:
            # Check job title
            h3 = job_card.find('h3')
            self.assertIsNotNone(h3, "Job card should have an h3 element for job title")
            self.assertTrue(len(h3.text.strip()) > 0, "Job title should not be empty")

            # Check company name
            company_div = job_card.find('div', string=lambda text: text and "Company:" in text)
            self.assertIsNotNone(company_div, "Job card should display company name")

            # Check location
            location_div = job_card.find('div', string=lambda text: text and "Location:" in text)
            self.assertIsNotNone(location_div, "Job card should display location")

            # Check salary range
            salary_div = job_card.find('div', string=lambda text: text and "Salary:" in text)
            self.assertIsNotNone(salary_div, "Job card should display salary range")

            # Check view details button with correct id pattern
            view_button = job_card.find('button', id=lambda x: x and x.startswith('view-job-button-'))
            self.assertIsNotNone(view_button, "Job card should have a 'View Details' button with id starting with 'view-job-button-'")

if __name__ == '__main__':
    unittest.main()
