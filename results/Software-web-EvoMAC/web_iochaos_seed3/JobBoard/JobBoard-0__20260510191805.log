def back_to_dashboard():
    return redirect(url_for('dashboard'))
@app.route('/back-to-companies')
def back_to_companies():
    return redirect(url_for('companies_directory'))
# Run the app
if __name__ == '__main__':
    app.run(port=5000, debug=True)
