'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page including presence of featured vehicles, promotions, and navigation buttons.
'''
import unittest
from main import app
from bs4 import BeautifulSoup

class CarRentalDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access root URL and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_title(self):
        # Test Task 2: Check page title contains "Car Rental Dashboard"
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string if soup.title else ''
        self.assertIn("Car Rental Dashboard", title, "Dashboard page title should contain 'Car Rental Dashboard'")

    def test_dashboard_elements_presence(self):
        # Test Task 3: Check presence of required elements by ID on Dashboard page
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container with id 'dashboard-page' should be present")

        # Check featured vehicles div
        featured_div = soup.find(id='featured-vehicles')
        self.assertIsNotNone(featured_div, "Featured vehicles div with id 'featured-vehicles' should be present")

        # Check promotions section div
        promotions_div = soup.find(id='promotions-section')
        self.assertIsNotNone(promotions_div, "Promotions section div with id 'promotions-section' should be present")

        # Check search vehicles button
        search_button = soup.find(id='search-vehicles-button')
        self.assertIsNotNone(search_button, "Search vehicles button with id 'search-vehicles-button' should be present")
        self.assertEqual(search_button.name, 'button', "Search vehicles element should be a button")

        # Check my reservations button
        reservations_button = soup.find(id='my-reservations-button')
        self.assertIsNotNone(reservations_button, "My reservations button with id 'my-reservations-button' should be present")
        self.assertEqual(reservations_button.name, 'button', "My reservations element should be a button")

    def test_dashboard_navigation_buttons(self):
        # Test Task 2: Check that navigation buttons have correct href or onclick to navigate
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')

        # For buttons, check if they have form or javascript or link to navigate
        # Since buttons may use JS or form, we check if they have attributes or are inside forms
        search_button = soup.find(id='search-vehicles-button')
        self.assertIsNotNone(search_button)
        # Check if button has onclick or form action or is inside a form
        has_navigation = False
        if search_button.has_attr('onclick'):
            has_navigation = True
        else:
            parent_form = search_button.find_parent('form')
            if parent_form and parent_form.has_attr('action'):
                has_navigation = True
        self.assertTrue(has_navigation, "Search vehicles button should have navigation action")

        reservations_button = soup.find(id='my-reservations-button')
        self.assertIsNotNone(reservations_button)
        has_navigation = False
        if reservations_button.has_attr('onclick'):
            has_navigation = True
        else:
            parent_form = reservations_button.find_parent('form')
            if parent_form and parent_form.has_attr('action'):
                has_navigation = True
        self.assertTrue(has_navigation, "My reservations button should have navigation action")

if __name__ == '__main__':
    unittest.main()
