    <div id="locations-page">
        <h1>Pickup and Dropoff Locations</h1>
        <form method="get" action="{{ url_for('locations') }}">
            <label for="hours-filter">Operating Hours:</label>
            <select id="hours-filter" name="hours" onchange="this.form.submit()">
                <option value="All" {% if hours_filter == 'All' or not hours_filter %}selected{% endif %}>All</option>
                <option value="24/7" {% if hours_filter == '24/7' %}selected{% endif %}>24/7</option>
                <option value="Business Hours" {% if hours_filter == 'Business Hours' %}selected{% endif %}>Business Hours</option>
                <option value="Weekend" {% if hours_filter == 'Weekend' %}selected{% endif %}>Weekend</option>
            </select>
            <label for="search-location-input">Search:</label>
            <input type="text" id="search-location-input" name="search" value="{{ search_query }}">
            <button type="submit">Search</button>
        </form>
        <div id="locations-list">
            <ul>
                {% for loc in locations %}
                <li>
                    <strong>{{ loc.city }}</strong> - {{ loc.address }} - Phone: {{ loc.phone }} - Hours: {{ loc.hours }}
                    <button id="location-detail-button-{{ loc.location_id }}" onclick="alert('Location details for {{ loc.city }}')">View Details</button>
                </li>
                {% endfor %}
            </ul>
        </div>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
