                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No featured vehicles available.</p>
            {% endif %}
        </section>

        <section id="promotions-section">
            <h2>Current Promotions</h2>
            {% if promotions %}
                <ul>
                    {% for promo in promotions %}
                        <li><strong>{{ promo.title }}:</strong> {{ promo.description }}</li>
                    {% endfor %}
                </ul>
            {% else %}
                <p>No promotions available at this time.</p>
            {% endif %}
        </section>

        <nav>
            <button id="search-vehicles-button" onclick="location.href='{{ url_for('search_vehicles') }}'">Search Vehicles</button>
            <button id="my-reservations-button" onclick="location.href='{{ url_for('my_reservations') }}'">My Reservations</button>
        </nav>
    </div>
</body>
</html>
```
