'''
Vehicle Search page template for CarRental.
Displays vehicles with filters and navigation.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Vehicles</title>
</head>
<body>
    <div id="search-page">
        <h1>Search Vehicles</h1>
        <label for="location-filter">Pickup Location:</label>
        <select id="location-filter" name="location-filter">
            <option value="">All</option>
            {% for loc in locations %}
            <option value="{{ loc.city }}">{{ loc.city }}</option>
            {% endfor %}
        </select>

        <label for="vehicle-type-filter">Vehicle Type:</label>
        <select id="vehicle-type-filter" name="vehicle-type-filter">
            <option value="">All</option>
            <option value="Economy">Economy</option>
            <option value="Compact">Compact</option>
            <option value="Sedan">Sedan</option>
            <option value="SUV">SUV</option>
            <option value="Luxury">Luxury</option>
        </select>

        <label for="date-range-input">Rental Date Range:</label>
        <input type="text" id="date-range-input" name="date-range-input" placeholder="YYYY-MM-DD to YYYY-MM-DD">

        <div id="vehicles-grid">
            <h2>Available Vehicles</h2>
            <ul>
                {% for vehicle in vehicles %}
                {% if vehicle.status == 'Available' %}
                <li>
                    <img src="/static/images/{{ vehicle.make|lower }}_{{ vehicle.model|lower }}.jpg" alt="{{ vehicle.make }} {{ vehicle.model }}" width="100" height="60">
                    <div>{{ vehicle.make }} {{ vehicle.model }}</div>
                    <div>${{ vehicle.daily_rate }} per day</div>
                    <button id="view-details-button-{{ vehicle.vehicle_id }}" onclick="location.href='{{ url_for('vehicle_details', vehicle_id=vehicle.vehicle_id) }}'">View Details</button>
                </li>
                {% endif %}
                {% endfor %}
            </ul>
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'" id="back-to-dashboard">Back to Dashboard</button>
    </div>
</body>
</html>
