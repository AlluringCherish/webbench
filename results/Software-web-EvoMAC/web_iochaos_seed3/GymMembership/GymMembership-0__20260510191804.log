import unittest
from main import app

class GymMembershipTestCase(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Task 1: Test that the Dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        # Check page title in response data
        self.assertIn(b'Gym Membership Dashboard', response.data)

    def test_dashboard_elements(self):
        # Task 2: Test that Dashboard page contains required elements
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        # Check for dashboard-page div
        self.assertIn('id="dashboard-page"', html)
        # Check for member-welcome div
        self.assertIn('id="member-welcome"', html)
        # Check for welcome message text
        self.assertIn('Welcome, Guest!', html)
        # Check for featured classes section
        self.assertIn('Featured Classes', html)
        # Check for buttons with correct IDs and labels
        self.assertIn('id="browse-membership-button"', html)
        self.assertIn('Browse Membership Plans', html)
        self.assertIn('id="view-schedule-button"', html)
        self.assertIn('View Class Schedule', html)
        self.assertIn('id="book-trainer-button"', html)
        self.assertIn('Book Personal Training', html)

    def test_dashboard_navigation_buttons(self):
        # Task 3: Test navigation buttons on Dashboard redirect correctly
        # Since buttons use JS location.href, simulate by requesting target URLs

        # Membership Plans page
        response = self.client.get('/membership_plans')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Membership Plans', response.data)

        # Class Schedule page
        response = self.client.get('/class_schedule')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Class Schedule', response.data)

        # PT Booking page
        response = self.client.get('/pt_booking')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Book Personal Training', response.data)

if __name__ == '__main__':
    unittest.main()
