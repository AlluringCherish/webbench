dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="dashboard-page">
    <h1>Event Planning Dashboard</h1>
    <section id="featured-events">
        <h2>Featured Events</h2>
        {% if events %}
            <ul>
                {% for event in events %}
                    <li>
                        <strong>{{ event.event_name }}</strong><br>
                        {{ event.date }} {{ event.time }}<br>
                        {{ event.location }}<br>
                        <a href="{{ url_for('event_details', event_id=event.event_id) }}">View Details</a>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No upcoming events available.</p>
        {% endif %}
    </section>
    <section id="featured-venues">
        <h2>Featured Venues</h2>
        {% if venues %}
            <ul>
                {% for venue in venues %}
                    <li>
                        <strong>{{ venue.venue_name }}</strong><br>
                        Location: {{ venue.location }}<br>
                        Capacity: {{ venue.capacity }}<br>
                        Amenities: {{ venue.amenities }}<br>
                        Contact: {{ venue.contact }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No featured venues available.</p>
        {% endif %}
    </section>
    <nav>
        <button id="browse-events-button" onclick="location.href='{{ url_for('events_listing') }}'">Browse Events</button>
        <button id="view-tickets-button" onclick="location.href='{{ url_for('ticket_booking') }}'">Book Tickets</button>
        <button id="venues-button" onclick="location.href='{{ url_for('venues') }}'">View Venues</button>
    </nav>
</div>
</body>
</html>
```

events_listing.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="events-page">
    <h1>Events Catalog</h1>
    <form method="get" action="{{ url_for('events_listing') }}">
        <input type="text" id="event-search-input" name="search" placeholder="Search by name, location, or date" value="{{ search_query }}">
        <select id="event-category-filter" name="category">
            <option value="All" {% if category_filter == 'All' or not category_filter %}selected{% endif %}>All Categories</option>
            <option value="Conference" {% if category_filter == 'Conference' %}selected{% endif %}>Conference</option>
            <option value="Concert" {% if category_filter == 'Concert' %}selected{% endif %}>Concert</option>
            <option value="Sports" {% if category_filter == 'Sports' %}selected{% endif %}>Sports</option>
            <option value="Workshop" {% if category_filter == 'Workshop' %}selected{% endif %}>Workshop</option>
            <option value="Social" {% if category_filter == 'Social' %}selected{% endif %}>Social</option>
        </select>
        <button type="submit">Filter</button>
    </form>
    <div id="events-grid">
        {% if events %}
            <ul>
                {% for event in events %}
                    <li>
                        <div class="event-card">
                            <!-- Placeholder for event image if available -->
                            <h3>{{ event.event_name }}</h3>
                            <p>Date: {{ event.date }} {{ event.time }}</p>
                            <p>Location: {{ event.location }}</p>
                            <button id="view-event-button-{{ event.event_id }}" onclick="location.href='{{ url_for('event_details', event_id=event.event_id) }}'">View Details</button>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No events found.</p>
        {% endif %}
    </div>
    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
```

