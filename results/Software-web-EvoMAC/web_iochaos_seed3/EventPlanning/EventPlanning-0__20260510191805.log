<div id="event-details-page">
    <h1 id="event-title">{{ event.event_name }}</h1>
    <div id="event-date">Date & Time: {{ event.date }} {{ event.time }}</div>
    <div id="event-location">Location: {{ event.location }}</div>
    <div id="event-description">{{ event.description }}</div>

    <button id="book-ticket-button" onclick="location.href='{{ url_for('ticket_booking') }}?event_id={{ event.event_id }}'">Book Ticket</button>

    <p><a href="{{ url_for('events_listing') }}">Back to Events Catalog</a></p>
</div>
</body>
</html>
```

templates/ticket_booking.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="ticket-booking-page">
    <h1>Book Your Tickets</h1>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <ul class="flashes">
          {% for category, message in messages %}
            <li class="{{ category }}">{{ message }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endwith %}

    {% if booking_confirmation %}
        <div id="booking-confirmation">
            <h2>Booking Confirmation</h2>
            <p>Booking ID: {{ booking_confirmation.booking_id }}</p>
            <p>Event ID: {{ booking_confirmation.event_id }}</p>
            <p>Customer Name: {{ booking_confirmation.customer_name }}</p>
            <p>Booking Date: {{ booking_confirmation.booking_date }}</p>
            <p>Ticket Count: {{ booking_confirmation.ticket_count }}</p>
            <p>Ticket Type: {{ booking_confirmation.ticket_type }}</p>
            <p>Total Amount: ${{ "%.2f"|format(booking_confirmation.total_amount) }}</p>
            <p>Status: {{ booking_confirmation.status }}</p>
            <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
        </div>
    {% else %}
        <form method="post" action="{{ url_for('ticket_booking') }}">
            <label for="select-event-dropdown">Select Event:</label>
            <select id="select-event-dropdown" name="select-event-dropdown" required>
                <option value="">-- Select an Event --</option>
                {% for event in events %}
                    <option value="{{ event.event_id }}"
                    {% if request.args.get('event_id') == event.event_id %}selected{% endif %}>
                        {{ event.event_name }} ({{ event.date }})
                    </option>
                {% endfor %}
            </select><br><br>

            <label for="ticket-quantity-input">Ticket Quantity:</label>
            <input type="number" id="ticket-quantity-input" name="ticket-quantity-input" min="1" required><br><br>

            <label for="ticket-type-select">Ticket Type:</label>
            <select id="ticket-type-select" name="ticket-type-select" required>
                <option value="">-- Select Ticket Type --</option>
                <option value="General">General</option>
                <option value="VIP">VIP</option>
                <option value="Early Bird">Early Bird</option>
            </select><br><br>

            <label for="customer-name-input">Your Name:</label>
            <input type="text" id="customer-name-input" name="customer-name-input" required><br><br>

            <button type="submit" id="book-now-button">Book Now</button>
        </form>
    {% endif %}

    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
```

templates/participants_management.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="participants-page">
    <h1>Participants Management</h1>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <ul class="flashes">
          {% for category, message in messages %}
            <li class="{{ category }}">{{ message }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endwith %}

    <form method="get" action="{{ url_for('participants_management') }}">
        <input type="text" id="search-participant-input" name="search" placeholder="Search by name or email" value="{{ search_query }}">
        <select id="participant-status-filter" name="status">
            <option value="All" {% if status_filter == 'All' or not status_filter %}selected{% endif %}>All Statuses</option>
            <option value="Registered" {% if status_filter == 'Registered' %}selected{% endif %}>Registered</option>
            <option value="Confirmed" {% if status_filter == 'Confirmed' %}selected{% endif %}>Confirmed</option>
            <option value="Attended" {% if status_filter == 'Attended' %}selected{% endif %}>Attended</option>
        </select>
        <button type="submit">Filter</button>
    </form>

    <table id="participants-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Participant ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Event</th>
                <th>Status</th>
                <th>Registration Date</th>
            </tr>
        </thead>
        <tbody>
            {% if participants %}
                {% for participant in participants %}
                    <tr>
                        <td>{{ participant.participant_id }}</td>
                        <td>{{ participant.name }}</td>
                        <td>{{ participant.email }}</td>
                        <td>
                            {% set event = events | selectattr('event_id', 'equalto', participant.event_id) | list | first %}
                            {{ event.event_name if event else 'Unknown' }}
                        </td>
                        <td>{{ participant.status }}</td>
                        <td>{{ participant.registration_date }}</td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr><td colspan="6">No participants found.</td></tr>
            {% endif %}
        </tbody>
    </table>

    <h2>Add New Participant</h2>
    <form method="post" action="{{ url_for('participants_management') }}">
        <label for="participant-name">Name:</label>
        <input type="text" id="participant-name" name="participant-name" required><br><br>

        <label for="participant-email">Email:</label>
        <input type="email" id="participant-email" name="participant-email" required><br><br>

        <label for="participant-event-id">Event:</label>
        <select id="participant-event-id" name="participant-event-id" required>
            <option value="">-- Select Event --</option>
            {% for event in events %}
                <option value="{{ event.event_id }}">{{ event.event_name }}</option>
            {% endfor %}
        </select><br><br>

        <label for="participant-booking-id">Booking ID:</label>
        <input type="text" id="participant-booking-id" name="participant-booking-id" required><br><br>

        <label for="participant-status">Status:</label>
        <select id="participant-status" name="participant-status" required>
            <option value="Registered">Registered</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Attended">Attended</option>
        </select><br><br>

        <button type="submit" id="add-participant-button">Add Participant</button>
    </form>

    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
```

templates/venues.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="venues-page">
    <h1>Venues</h1>

    <form method="get" action="{{ url_for('venues') }}">
        <input type="text" id="venue-search-input" name="search" placeholder="Search by name or location" value="{{ search_query }}">
        <select id="venue-capacity-filter" name="capacity">
            <option value="All" {% if capacity_filter == 'All' or not capacity_filter %}selected{% endif %}>All Capacities</option>
            <option value="Small" {% if capacity_filter == 'Small' %}selected{% endif %}>Small (≤ 500)</option>
            <option value="Medium" {% if capacity_filter == 'Medium' %}selected{% endif %}>Medium (501 - 2000)</option>
            <option value="Large" {% if capacity_filter == 'Large' %}selected{% endif %}>Large (> 2000)</option>
        </select>
        <button type="submit">Filter</button>
    </form>

    <div id="venues-grid">
        {% if venues %}
            <ul>
                {% for venue in venues %}
                    <li>
                        <div class="venue-card">
                            <h3>{{ venue.venue_name }}</h3>
                            <p>Capacity: {{ venue.capacity }}</p>
                            <p>Amenities: {{ venue.amenities }}</p>
                            <button id="view-venue-details-{{ venue.venue_id }}" onclick="alert('Venue Details:\\nName: {{ venue.venue_name }}\\nLocation: {{ venue.location }}\\nCapacity: {{ venue.capacity }}\\nAmenities: {{ venue.amenities }}\\nContact: {{ venue.contact }}')">View Details</button>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No venues found.</p>
        {% endif %}
    </div>

    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
```

templates/event_schedules.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="schedules-page">
    <h1>Event Schedules</h1>

    <form method="get" action="{{ url_for('event_schedules') }}">
        <label for="schedule-filter-date">Filter by Date:</label>
        <input type="date" id="schedule-filter-date" name="date" value="{{ filter_date }}">
        <label for="schedule-filter-event">Filter by Event:</label>
        <select id="schedule-filter-event" name="event">
            <option value="All" {% if filter_event == 'All' or not filter_event %}selected{% endif %}>All Events</option>
            {% for event in events %}
                <option value="{{ event.event_id }}" {% if filter_event == event.event_id %}selected{% endif %}>{{ event.event_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Filter</button>
    </form>

    <div id="schedules-timeline">
        {% if schedules %}
            <ul>
                {% for schedule in schedules %}
                    <li>
                        <strong>{{ schedule.session_title }}</strong><br>
                        Time: {{ schedule.session_time }}<br>
                        Duration: {{ schedule.duration_minutes }} minutes<br>
                        Speaker: {{ schedule.speaker }}<br>
                        Venue:
                        {% set venue = (venues | selectattr('venue_id', 'equalto', schedule.venue_id) | list | first) %}
                        {{ venue.venue_name if venue else 'Unknown' }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No schedules found.</p>
        {% endif %}
    </div>

    <button id="export-schedule-button" onclick="location.href='{{ url_for('export_schedule') }}'">Export Schedule Data</button>

    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
```

templates/bookings_summary.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="bookings-page">
    <h1>My Bookings</h1>

    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <ul class="flashes">
          {% for category, message in messages %}
            <li class="{{ category }}">{{ message }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    {% endwith %}

    <form method="get" action="{{ url_for('bookings_summary') }}">
        <input type="text" id="booking-search-input" name="search" placeholder="Search by event name or booking ID" value="{{ search_query }}">
        <button type="submit">Search</button>
    </form>

    <form method="post" action="{{ url_for('bookings_summary') }}">
        <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Ticket Count</th>
                    <th>Ticket Type</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% if bookings %}
                    {% for booking in bookings %}
                        <tr>
                            <td>{{ booking.booking_id }}</td>
                            <td>
                                {% set event = events | selectattr('event_id', 'equalto', booking.event_id) | list | first %}
                                {{ event.event_name if event else 'Unknown' }}
                            </td>
                            <td>{{ booking.booking_date }}</td>
                            <td>{{ booking.ticket_count }}</td>
                            <td>{{ booking.ticket_type }}</td>
                            <td>${{ "%.2f"|format(booking.total_amount) }}</td>
                            <td>{{ booking.status }}</td>
                            <td>
                                {% if booking.status.lower() != 'cancelled' %}
                                    <button type="submit" name="cancel-booking-id" value="{{ booking.booking_id }}" id="cancel-booking-button-{{ booking.booking_id }}">Cancel</button>
                                {% else %}
                                    <em>Cancelled</em>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="8">No bookings found.</td></tr>
                {% endif %}
            </tbody>
        </table>
    </form>

    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
