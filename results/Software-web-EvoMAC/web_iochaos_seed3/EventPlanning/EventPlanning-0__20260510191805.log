<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="dashboard-page">
    <h1>Event Planning Dashboard</h1>
    <section id="featured-events">
        <h2>Featured Events</h2>
        {% if events %}
            <ul>
                {% for event in events %}
                    <li>
                        <strong>{{ event.event_name }}</strong><br>
                        {{ event.date }} {{ event.time }}<br>
                        {{ event.location }}<br>
                        <a href="{{ url_for('event_details', event_id=event.event_id) }}">View Details</a>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No upcoming events available.</p>
        {% endif %}
    </section>
    <section id="featured-venues">
        <h2>Featured Venues</h2>
        {% if venues %}
            <ul>
                {% for venue in venues %}
                    <li>
                        <strong>{{ venue.venue_name }}</strong><br>
                        Location: {{ venue.location }}<br>
                        Capacity: {{ venue.capacity }}<br>
                        Amenities: {{ venue.amenities }}<br>
                        Contact: {{ venue.contact }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No featured venues available.</p>
        {% endif %}
