'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) loads correctly.
Test basic navigation from Dashboard to Events Listing, Ticket Booking, and Venues pages.
Test presence and correctness of key elements on the Dashboard page.
'''

import unittest
from main import app

class TestEventPlanningApp(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Event Planning Dashboard', response.data)
        # Check presence of dashboard container div
        self.assertIn(b'id="dashboard-page"', response.data)
        # Check presence of featured-events section
        self.assertIn(b'id="featured-events"', response.data)
        # Check presence of featured-venues section
        self.assertIn(b'id="featured-venues"', response.data)
        # Check presence of navigation buttons with correct IDs
        self.assertIn(b'id="browse-events-button"', response.data)
        self.assertIn(b'id="view-tickets-button"', response.data)
        self.assertIn(b'id="venues-button"', response.data)

    def test_navigation_buttons(self):
        # Test navigation buttons on dashboard lead to correct pages

        # Browse Events button leads to /events
        response = self.client.get('/events')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Events Catalog', response.data)
        self.assertIn(b'id="events-page"', response.data)

        # Book Tickets button leads to /book-tickets
        response = self.client.get('/book-tickets')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Book Your Tickets', response.data)
        self.assertIn(b'id="ticket-booking-page"', response.data)

        # Venues button leads to /venues
        response = self.client.get('/venues')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Venues', response.data)
        self.assertIn(b'id="venues-page"', response.data)

if __name__ == '__main__':
    unittest.main()
