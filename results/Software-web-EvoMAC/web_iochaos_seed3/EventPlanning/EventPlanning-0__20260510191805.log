                            <p>Amenities: {{ venue.amenities }}</p>
                            <button id="view-venue-details-{{ venue.venue_id }}" onclick="alert('Venue Details:\\nName: {{ venue.venue_name }}\\nLocation: {{ venue.location }}\\nCapacity: {{ venue.capacity }}\\nAmenities: {{ venue.amenities }}\\nContact: {{ venue.contact }}')">View Details</button>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No venues found.</p>
        {% endif %}
    </div>
    <p><a href="{{ url_for('dashboard') }}">Back to Dashboard</a></p>
</div>
</body>
</html>
