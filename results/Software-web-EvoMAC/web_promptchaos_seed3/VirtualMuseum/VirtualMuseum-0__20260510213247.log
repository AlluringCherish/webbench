│   ├── artifact_catalog.html
│   ├── exhibitions.html
│   ├── exhibition_details.html
│   ├── visitor_tickets.html
│   ├── virtual_events.html
│   └── audio_guides.html
│
├── static/
│   ├── css/
│   │   └── styles.css
│   ├── js/
│   │   └── scripts.js
│   └── audio/
│       └── (audio guide files, if any)
│
└── data/
    ├── users.txt
    ├── galleries.txt
    ├── exhibitions.txt
