        <h1>Exhibitions</h1>
        <form method="post" action="{{ url_for('exhibitions', username=username) if username else url_for('exhibitions') }}">
            <label for="filter-exhibition-type">Filter by Exhibition Type:</label>
            <select id="filter-exhibition-type" name="filter-exhibition-type">
                <option value="" {% if filter_type == '' %}selected{% endif %}>All</option>
                <option value="Permanent" {% if filter_type == 'Permanent' %}selected{% endif %}>Permanent</option>
                <option value="Temporary" {% if filter_type == 'Temporary' %}selected{% endif %}>Temporary</option>
                <option value="Virtual" {% if filter_type == 'Virtual' %}selected{% endif %}>Virtual</option>
            </select>
            <button type="submit" id="apply-exhibition-filter">Apply Filter</button>
        </form>
        <table id="exhibition-list" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Dates</th>
                    <th>Gallery</th>
                    <th>Status</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for exhibition in exhibitions %}
                <tr>
                    <td>{{ exhibition.title }}</td>
                    <td>{{ exhibition.exhibition_type }}</td>
                    <td>{{ exhibition.start_date }} to {{ exhibition.end_date }}</td>
                    <td>{{ exhibition.gallery_name }}</td>
                    <td>{{ exhibition.status }}</td>
                    <td>
                        <form method="get" action="{{ url_for('exhibition_details', exhibition_id=exhibition.exhibition_id) }}">
                            {% if username %}
                            <input type="hidden" name="username" value="{{ username }}">
                            {% endif %}
                            <button type="submit" id="view-exhibition-button-{{ exhibition.exhibition_id }}">View</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6">No exhibitions found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard', username=username) if username else url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

exhibition_details.html
```html
'''
Exhibition Details page showing detailed info and artifacts in the exhibition.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Exhibition Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="exhibition-details-page">
        <h1 id="exhibition-title">{{ exhibition_title }}</h1>
        <div id="exhibition-description">
            <p>{{ exhibition_description }}</p>
        </div>
        <div id="exhibition-dates">
            <p><strong>Dates:</strong> {{ exhibition_dates }}</p>
        </div>
        <h2>Artifacts in this Exhibition</h2>
        <table id="exhibition-artifacts" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Period</th>
                    <th>Origin</th>
                    <th>Description</th>
                    <th>Storage Location</th>
                    <th>Acquisition Date</th>
                    <th>Added By</th>
                </tr>
            </thead>
            <tbody>
                {% for artifact in artifacts %}
                <tr>
                    <td>{{ artifact.artifact_id }}</td>
                    <td>{{ artifact.artifact_name }}</td>
                    <td>{{ artifact.period }}</td>
                    <td>{{ artifact.origin }}</td>
                    <td>{{ artifact.description }}</td>
                    <td>{{ artifact.storage_location }}</td>
                    <td>{{ artifact.acquisition_date }}</td>
                    <td>{{ artifact.added_by }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8">No artifacts found for this exhibition.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-exhibitions" onclick="location.href='{{ url_for('exhibitions', username=username) if username else url_for('exhibitions') }}'">Back to Exhibitions</button>
    </div>
</body>
</html>
```

visitor_tickets.html
```html
'''
Visitor Tickets page for purchasing tickets and viewing user's tickets.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Visitor Tickets</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="visitor-tickets-page">
        <h1>Visitor Tickets</h1>
        <form method="post" action="{{ url_for('visitor_tickets', username=username) }}">
            <label for="ticket-type">Ticket Type:</label>
            <select id="ticket-type" name="ticket-type" required>
                {% for ttype in ticket_types %}
                <option value="{{ ttype }}">{{ ttype }}</option>
                {% endfor %}
            </select><br><br>
            <label for="number-of-tickets">Number of Tickets:</label>
            <input type="number" id="number-of-tickets" name="number-of-tickets" min="1" required><br><br>
            <label for="visitor-name">Visitor Name:</label>
            <input type="text" id="visitor-name" name="visitor-name" required><br><br>
            <label for="visitor-email">Visitor Email:</label>
            <input type="email" id="visitor-email" name="visitor-email" required><br><br>
            <label for="visit-date">Visit Date:</label>
            <input type="date" id="visit-date" name="visit-date" required><br><br>
            <label for="visit-time">Visit Time:</label>
            <input type="time" id="visit-time" name="visit-time" required><br><br>
            <button type="submit" id="purchase-ticket-button">Purchase Tickets</button>
        </form>
        <h2>My Tickets</h2>
        <table id="my-tickets-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Type</th>
                    <th>Visit Date</th>
                    <th>Visit Time</th>
                    <th>Number</th>
                    <th>Price</th>
                    <th>Visitor Name</th>
                    <th>Visitor Email</th>
                    <th>Purchase Date</th>
                </tr>
            </thead>
            <tbody>
                {% for ticket in user_tickets %}
                <tr>
                    <td>{{ ticket.ticket_id }}</td>
                    <td>{{ ticket.ticket_type }}</td>
                    <td>{{ ticket.visit_date }}</td>
                    <td>{{ ticket.visit_time }}</td>
                    <td>{{ ticket.number_of_tickets }}</td>
                    <td>${{ ticket.price }}</td>
                    <td>{{ ticket.visitor_name }}</td>
                    <td>{{ ticket.visitor_email }}</td>
                    <td>{{ ticket.purchase_date }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9">No tickets purchased yet.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard', username=username) if username else url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

virtual_events.html
```html
'''
Virtual Events page to view and manage event registrations.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Virtual Events</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="virtual-events-page">
        <h1>Virtual Events</h1>
        <table id="event-list" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Type</th>
                    <th>Speaker</th>
                    <th>Capacity</th>
                    <th>Description</th>
                    <th>Registration Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for event in events %}
                <tr>
                    <td>{{ event.title }}</td>
                    <td>{{ event.date }}</td>
                    <td>{{ event.time }}</td>
                    <td>{{ event.event_type }}</td>
                    <td>{{ event.speaker }}</td>
                    <td>{{ event.capacity }}</td>
                    <td>{{ event.description }}</td>
                    <td>
                        {% if event.registered %}
                            Registered
                        {% else %}
                            Not Registered
                        {% endif %}
                    </td>
                    <td>
                        {% if event.registered %}
                        <form method="post" action="{{ url_for('virtual_events', username=username) }}">
                            <input type="hidden" name="action" value="cancel">
                            <input type="hidden" name="registration_id" value="{{ event.registration_id }}">
                            <button type="submit" id="cancel-registration-button-{{ event.registration_id }}">Cancel Registration</button>
                        </form>
                        {% else %}
                        <form method="post" action="{{ url_for('virtual_events', username=username) }}">
                            <input type="hidden" name="action" value="register">
                            <input type="hidden" name="event_id" value="{{ event.event_id }}">
                            <button type="submit" id="register-event-button-{{ event.event_id }}">Register</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9">No events available.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard', username=username) if username else url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

