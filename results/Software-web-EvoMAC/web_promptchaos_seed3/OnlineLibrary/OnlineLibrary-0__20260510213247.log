def calculate_avg_rating(book_id, reviews):
    ratings = [r['rating'] for r in reviews.values() if r['book_id'] == book_id]
    if not ratings:
        return 0.0
    return round(sum(ratings) / len(ratings), 1)
def update_book_avg_rating(book_id):
    books = read_books()
