templates/dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bookstore Dashboard</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="dashboard-page">
    <h1>Bookstore Dashboard</h1>

    <section id="featured-books">
        <h2>Featured Books</h2>
        {% if featured_books %}
            <div class="books-list">
                {% for book in featured_books %}
                    <div class="book-card">
                        <h3>{{ book.title }}</h3>
                        <p><strong>Author:</strong> {{ book.author }}</p>
                        <p><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</p>
                        <a href="{{ url_for('book_details', book_id=book.book_id) }}">
                            <button id="view-book-button-{{ book.book_id }}">View Details</button>
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p>No featured books available.</p>
        {% endif %}
    </section>

    <section id="bestsellers-section">
        <h2>Bestsellers This Month</h2>
        {% if bestsellers %}
            <ol>
                {% for book in bestsellers %}
                    <li>
                        <strong>{{ book.title }}</strong> by {{ book.author }} - Sales: {{ book.sales_count }}
                        <a href="{{ url_for('book_details', book_id=book.book_id) }}">
                            <button id="view-book-button-{{ book.book_id }}">View Details</button>
                        </a>
                    </li>
                {% endfor %}
            </ol>
        {% else %}
            <p>No bestsellers data available.</p>
        {% endif %}
    </section>

    <nav id="dashboard-navigation">
        <button id="browse-catalog-button" onclick="location.href='{{ url_for('catalog') }}'">Browse Catalog</button>
        <button id="view-cart-button" onclick="location.href='{{ url_for('cart') }}'">View Cart</button>
        <button id="bestsellers-button" onclick="location.href='{{ url_for('bestsellers') }}'">Bestsellers</button>
    </nav>
</div>
</body>
</html>
```
templates/catalog.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Catalog</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="catalog-page">
    <h1>Book Catalog</h1>

    <form method="get" action="{{ url_for('catalog') }}">
        <input type="text" id="search-input" name="search" placeholder="Search by title, author, or ISBN" value="{{ search_query }}">
        <select id="category-filter" name="category">
            <option value="All" {% if selected_category == 'All' or not selected_category %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category == category.category_name %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>

    <div id="books-grid" class="books-grid">
        {% if books %}
            {% for book in books %}
                <div class="book-card">
                    <h3>{{ book.title }}</h3>
                    <p><strong>Author:</strong> {{ book.author }}</p>
                    <p><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</p>
                    <a href="{{ url_for('book_details', book_id=book.book_id) }}">
                        <button id="view-book-button-{{ book.book_id }}">View Details</button>
                    </a>
                </div>
            {% endfor %}
        {% else %}
            <p>No books found.</p>
        {% endif %}
    </div>

    <nav>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
```
templates/book_details.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Details</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="book-details-page">
    <h1 id="book-title">{{ book.title }}</h1>
    <div id="book-author"><strong>Author:</strong> {{ book.author }}</div>
    <div id="book-price"><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</div>
    <div id="book-description"><strong>Description:</strong> {{ book.description }}</div>

    <form method="post" action="{{ url_for('book_details', book_id=book.book_id) }}">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" value="1" min="1" max="{{ book.stock }}">
        <button type="submit" id="add-to-cart-button">Add to Cart</button>
    </form>

    <section id="book-reviews">
        <h2>Customer Reviews</h2>
        {% if reviews %}
            <ul>
                {% for review in reviews %}
                    <li>
                        <strong>{{ review.customer_name }}</strong> ({{ review.review_date }}) - Rating: {{ review.rating }} / 5
                        <p>{{ review.review_text }}</p>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No reviews yet.</p>
        {% endif %}
    </section>

    <nav>
        <button onclick="location.href='{{ url_for('catalog') }}'">Back to Catalog</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
```
templates/cart.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="cart-page">
    <h1>Shopping Cart</h1>

    {% if cart_items %}
    <form method="post" action="{{ url_for('cart') }}">
        <table id="cart-items-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart_items %}
                <tr>
                    <td>{{ item.title }}</td>
                    <td>
                        <input type="number" id="update-quantity-{{ item.cart_id }}" name="update-quantity-{{ item.cart_id }}" value="{{ item.quantity }}" min="1">
                    </td>
                    <td>${{ "%.2f"|format(item.price) }}</td>
                    <td>${{ "%.2f"|format(item.subtotal) }}</td>
                    <td>
                        <button type="submit" name="remove-item-button-{{ item.cart_id }}" id="remove-item-button-{{ item.cart_id }}">Remove</button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div id="total-amount"><strong>Total Amount:</strong> ${{ "%.2f"|format(total_amount) }}</div>
        <button type="submit" id="update-cart-button">Update Cart</button>
    </form>
    <button id="proceed-checkout-button" onclick="location.href='{{ url_for('checkout') }}'">Proceed to Checkout</button>
    {% else %}
        <p>Your cart is empty.</p>
        <button onclick="location.href='{{ url_for('catalog') }}'">Browse Books</button>
    {% endif %}

    <nav>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
```
templates/checkout.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Checkout</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="checkout-page">
    <h1>Checkout</h1>

    {% if error %}
        <p style="color: red;">{{ error }}</p>
    {% endif %}

    <p><strong>Total Amount:</strong> ${{ "%.2f"|format(total_amount) }}</p>

    <form method="post" action="{{ url_for('checkout') }}">
        <label for="customer-name">Customer Name:</label><br>
        <input type="text" id="customer-name" name="customer-name" value="{{ customer_name|default('') }}" required><br><br>

        <label for="shipping-address">Shipping Address:</label><br>
        <textarea id="shipping-address" name="shipping-address" rows="4" cols="50" required>{{ shipping_address|default('') }}</textarea><br><br>

        <label for="payment-method">Payment Method:</label><br>
        <select id="payment-method" name="payment-method" required>
            <option value="" disabled {% if not payment_method %}selected{% endif %}>Select payment method</option>
            <option value="Credit Card" {% if payment_method == 'Credit Card' %}selected{% endif %}>Credit Card</option>
            <option value="PayPal" {% if payment_method == 'PayPal' %}selected{% endif %}>PayPal</option>
            <option value="Bank Transfer" {% if payment_method == 'Bank Transfer' %}selected{% endif %}>Bank Transfer</option>
        </select><br><br>

        <button type="submit" id="place-order-button">Place Order</button>
    </form>

    <nav>
        <button onclick="location.href='{{ url_for('cart') }}'">Back to Cart</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
