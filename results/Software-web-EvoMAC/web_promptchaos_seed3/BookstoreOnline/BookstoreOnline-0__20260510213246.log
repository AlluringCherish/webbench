        <select id="order-status-filter" name="status" onchange="this.form.submit()">
            <option value="All" {% if selected_status == 'All' %}selected{% endif %}>All</option>
            <option value="Pending" {% if selected_status == 'Pending' %}selected{% endif %}>Pending</option>
            <option value="Shipped" {% if selected_status == 'Shipped' %}selected{% endif %}>Shipped</option>
            <option value="Delivered" {% if selected_status == 'Delivered' %}selected{% endif %}>Delivered</option>
        </select>
    </form>
    {% if orders %}
    <table id="orders-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Shipping Address</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td>{{ order.order_id }}</td>
                <td>{{ order.order_date }}</td>
                <td>${{ "%.2f"|format(order.total_amount) }}</td>
                <td>{{ order.status }}</td>
                <td>{{ order.shipping_address }}</td>
                <td>
                    <a href="{{ url_for('order_details', order_id=order.order_id) }}">
                        <button id="view-order-button-{{ order.order_id }}">View Details</button>
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
        <p>No orders found.</p>
    {% endif %}
    <nav>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
```

reviews.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Reviews</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="reviews-page">
    <h1>Customer Reviews</h1>
    <form method="get" action="{{ url_for('reviews') }}">
        <label for="filter-by-rating">Filter by Rating:</label>
        <select id="filter-by-rating" name="rating" onchange="this.form.submit()">
            <option value="All" {% if selected_rating == 'All' %}selected{% endif %}>All</option>
            <option value="5 stars" {% if selected_rating == '5 stars' %}selected{% endif %}>5 stars</option>
            <option value="4 stars" {% if selected_rating == '4 stars' %}selected{% endif %}>4 stars</option>
            <option value="3 stars" {% if selected_rating == '3 stars' %}selected{% endif %}>3 stars</option>
            <option value="2 stars" {% if selected_rating == '2 stars' %}selected{% endif %}>2 stars</option>
            <option value="1 star" {% if selected_rating == '1 star' %}selected{% endif %}>1 star</option>
        </select>
    </form>
    <div id="reviews-list">
        {% if reviews %}
            <ul>
                {% for review in reviews %}
                    <li>
                        <strong>{{ review.book_title }}</strong> - Rating: {{ review.rating }} / 5<br>
                        <em>by {{ review.customer_name }} on {{ review.review_date }}</em><br>
                        <p>{{ review.review_text }}</p>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No reviews found.</p>
        {% endif %}
    </div>
    <button id="write-review-button" onclick="location.href='{{ url_for('write_review') }}'">Write a Review</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

write_review.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write a Review</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="write-review-page">
    <h1>Write a Review</h1>
    {% if error %}
        <p style="color: red;">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ url_for('write_review') }}">
        <label for="select-book">Select Book:</label><br>
        <select id="select-book" name="select-book" required>
            <option value="" disabled {% if not selected_book %}selected{% endif %}>-- Select a book --</option>
            {% for book in books %}
                <option value="{{ book.book_id }}" {% if selected_book == book.book_id %}selected{% endif %}>{{ book.title }}</option>
            {% endfor %}
        </select><br><br>
        <label for="rating-select">Rating:</label><br>
        <select id="rating-select" name="rating-select" required>
            <option value="" disabled {% if not selected_rating %}selected{% endif %}>-- Select rating --</option>
            {% for i in range(1,6) %}
                <option value="{{ i }}" {% if selected_rating == i|string %}selected{% endif %}>{{ i }} star{% if i > 1 %}s{% endif %}</option>
            {% endfor %}
        </select><br><br>
        <label for="review-text">Review:</label><br>
        <textarea id="review-text" name="review-text" rows="5" cols="50" required>{{ review_text|default('') }}</textarea><br><br>
        <button type="submit" id="submit-review-button">Submit Review</button>
    </form>
    <nav>
        <button onclick="location.href='{{ url_for('reviews') }}'">Back to Reviews</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
```

bestsellers.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bestsellers</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="bestsellers-page">
    <h1>Bestsellers</h1>
    <form method="get" action="{{ url_for('bestsellers') }}">
        <label for="time-period-filter">Filter by Time Period:</label>
        <select id="time-period-filter" name="time_period" onchange="this.form.submit()">
            <option value="This Week" {% if selected_period == 'This Week' %}selected{% endif %}>This Week</option>
            <option value="This Month" {% if selected_period == 'This Month' %}selected{% endif %}>This Month</option>
            <option value="All Time" {% if selected_period == 'All Time' %}selected{% endif %}>All Time</option>
        </select>
    </form>
    <div id="bestsellers-list">
        {% if bestsellers %}
            <ol>
                {% for book in bestsellers %}
                    <li>
                        <strong>{{ book.title }}</strong> by {{ book.author }} - Sales: {{ book.sales_count }}
                        <a href="{{ url_for('book_details', book_id=book.book_id) }}">
                            <button id="view-book-button-{{ book.book_id }}">View Details</button>
                        </a>
                    </li>
                {% endfor %}
            </ol>
        {% else %}
            <p>No bestsellers data available for selected period.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
