<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Energy Report</title>
</head>
<body>
    <div id="energy-page">
        <h1>Energy Report</h1>
        <div id="energy-summary">
            <p>Total Energy Consumption: {{ total_consumption }} kWh</p>
            <p>Estimated Cost: ${{ "%.2f"|format(total_cost) }}</p>
        </div>
        <form method="post" action="{{ url_for('energy_report') }}">
            <label for="date-filter">Filter by Date:</label>
            <input type="date" id="date-filter" name="date_filter" value="{{ filter_date or '' }}">
            <button type="submit" id="apply-filter-button">Apply Filter</button>
        </form>
        <table id="energy-table" border="1" cellpadding="5" cellspacing="0">
