        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_access_and_elements(self):
        # Test access to root '/' (Dashboard)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check presence of required IDs on dashboard page
        self.assertIsNotNone(soup.find(id='dashboard-page'))
        self.assertIsNotNone(soup.find(id='device-summary'))
        self.assertIsNotNone(soup.find(id='device-list-button'))
        self.assertIsNotNone(soup.find(id='add-device-button'))
        self.assertIsNotNone(soup.find(id='automation-button'))
        self.assertIsNotNone(soup.find(id='energy-button'))
        self.assertIsNotNone(soup.find(id='activity-button'))
        self.assertIsNotNone(soup.find(id='room-list'))
    def test_device_list_access_and_elements(self):
        response = self.client.get('/devices')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='device-list-page'))
        self.assertIsNotNone(soup.find(id='device-table'))
        self.assertIsNotNone(soup.find(id='back-to-dashboard'))
        # Check for at least one control-device-button with any device_id pattern
        control_buttons = soup.find_all('button')
        found = False
        for btn in control_buttons:
            if btn.has_attr('id') and btn['id'].startswith('control-device-button-'):
                found = True
                break
        self.assertTrue(found, "No control-device-button-{device_id} found")
    def test_add_device_access_and_elements(self):
        response = self.client.get('/devices/add')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='add-device-page'))
        self.assertIsNotNone(soup.find(id='device-name'))
        self.assertIsNotNone(soup.find(id='device-type'))
        self.assertIsNotNone(soup.find(id='device-room'))
        self.assertIsNotNone(soup.find(id='submit-device-button'))
        self.assertIsNotNone(soup.find(id='back-to-dashboard'))
    def test_device_control_access_and_elements(self):
        # Use example device_id '1' from example data
        response = self.client.get('/devices/control/1')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='device-control-page'))
        self.assertIsNotNone(soup.find(id='device-name-display'))
        self.assertIsNotNone(soup.find(id='device-status-display'))
        self.assertIsNotNone(soup.find(id='power-toggle'))
        self.assertIsNotNone(soup.find(id='save-settings-button'))
        self.assertIsNotNone(soup.find(id='back-to-devices'))
    def test_automation_rules_access_and_elements(self):
        response = self.client.get('/automation')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='automation-page'))
        self.assertIsNotNone(soup.find(id='rules-table'))
        self.assertIsNotNone(soup.find(id='rule-name'))
        self.assertIsNotNone(soup.find(id='trigger-type'))
        self.assertIsNotNone(soup.find(id='trigger-value'))
        self.assertIsNotNone(soup.find(id='action-device'))
        self.assertIsNotNone(soup.find(id='action-type'))
        self.assertIsNotNone(soup.find(id='add-rule-button'))
        self.assertIsNotNone(soup.find(id='back-to-dashboard'))
    def test_energy_report_access_and_elements(self):
        response = self.client.get('/energy')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='energy-page'))
        self.assertIsNotNone(soup.find(id='energy-summary'))
        self.assertIsNotNone(soup.find(id='energy-table'))
        self.assertIsNotNone(soup.find(id='date-filter'))
        self.assertIsNotNone(soup.find(id='apply-filter-button'))
        self.assertIsNotNone(soup.find(id='back-to-dashboard'))
    def test_activity_logs_access_and_elements(self):
        response = self.client.get('/activity')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        self.assertIsNotNone(soup.find(id='activity-page'))
        self.assertIsNotNone(soup.find(id='activity-table'))
        self.assertIsNotNone(soup.find(id='search-activity'))
        self.assertIsNotNone(soup.find(id='apply-search-button'))
        self.assertIsNotNone(soup.find(id='back-to-dashboard'))
if __name__ == '__main__':
    unittest.main()

