templates/dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Smart Home Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Smart Home Dashboard</h1>

        <div id="device-summary">
            <p>Total Devices: {{ total_devices }}</p>
            <p>Active Devices: {{ online_devices }}</p>
            <p>Offline Devices: {{ offline_devices }}</p>
        </div>

        <button id="device-list-button" onclick="location.href='{{ url_for('device_list') }}'">Device List</button>
        <button id="add-device-button" onclick="location.href='{{ url_for('add_device') }}'">Add Device</button>
        <button id="automation-button" onclick="location.href='{{ url_for('automation_rules') }}'">Automation Rules</button>
        <button id="energy-button" onclick="location.href='{{ url_for('energy_report') }}'">Energy Report</button>
        <button id="activity-button" onclick="location.href='{{ url_for('activity_logs') }}'">Activity Logs</button>

        <div id="room-list">
            <h2>Rooms</h2>
            {% if rooms %}
                <ul>
                {% for room in rooms %}
                    <li>{{ room.room_name }} ({{ room.device_count }} devices)</li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No rooms found.</p>
            {% endif %}
        </div>
    </div>
</body>
</html>
```

templates/device_list.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Devices</title>
</head>
<body>
    <div id="device-list-page">
        <h1>My Devices</h1>

        <table id="device-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Room</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if devices %}
                    {% for device in devices %}
                    <tr>
                        <td>{{ device.device_name }}</td>
                        <td>{{ device.device_type }}</td>
                        <td>{{ device.room }}</td>
                        <td>{{ device.status }}</td>
                        <td>
                            <button id="control-device-button-{{ device.device_id }}" onclick="location.href='{{ url_for('device_control', device_id=device.device_id) }}'">Control</button>
                        </td>
                    </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="5">No devices found.</td></tr>
                {% endif %}
            </tbody>
        </table>

        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

templates/add_device.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add New Device</title>
</head>
<body>
    <div id="add-device-page">
        <h1>Add New Device</h1>

        <form method="post" action="{{ url_for('add_device') }}">
            <label for="device-name">Device Name:</label><br>
            <input type="text" id="device-name" name="device_name" required><br><br>

            <label for="device-type">Device Type:</label><br>
            <select id="device-type" name="device_type" required>
                <option value="">--Select Type--</option>
                <option value="Light">Light</option>
                <option value="Thermostat">Thermostat</option>
                <option value="Camera">Camera</option>
                <option value="Lock">Lock</option>
                <option value="Sensor">Sensor</option>
                <option value="Appliance">Appliance</option>
            </select><br><br>

            <label for="device-room">Room:</label><br>
            <select id="device-room" name="device_room" required>
                <option value="">--Select Room--</option>
                {% for room in rooms %}
                <option value="{{ room.room_name }}">{{ room.room_name }}</option>
                {% endfor %}
            </select><br><br>

            <button type="submit" id="submit-device-button">Add Device</button>
            <button type="button" id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/device_control.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Device Control</title>
</head>
<body>
    <div id="device-control-page">
        <h1>Device Control</h1>

        <h2 id="device-name-display">{{ device.device_name }}</h2>
        <div id="device-status-display">Status: {{ device.status }}</div>

        <form method="post" action="{{ url_for('device_control', device_id=device.device_id) }}">
            <button type="submit" name="power_toggle" id="power-toggle">
                {% if device.power == 'on' %}
                    Turn Off
                {% else %}
                    Turn On
                {% endif %}
            </button>
            <br><br>

            {% if device.device_type == 'Light' %}
                <label for="brightness">Brightness (0-100):</label><br>
                <input type="number" id="brightness" name="brightness" min="0" max="100" value="{{ device.brightness or '' }}"><br><br>
            {% elif device.device_type == 'Thermostat' %}
                <label for="temperature">Temperature:</label><br>
                <input type="number" id="temperature" name="temperature" value="{{ device.temperature or '' }}"><br><br>
            {% endif %}

            <button type="submit" id="save-settings-button">Save Settings</button>
            <button type="button" id="back-to-devices" onclick="location.href='{{ url_for('device_list') }}'">Back to Device List</button>
        </form>
    </div>
</body>
</html>
```

templates/automation_rules.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Automation Rules</title>
</head>
<body>
    <div id="automation-page">
        <h1>Automation Rules</h1>

        <table id="rules-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Trigger</th>
                    <th>Action</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% if rules %}
                    {% for rule in rules %}
                    <tr>
                        <td>{{ rule.rule_name }}</td>
                        <td>{{ rule.trigger_type }}: {{ rule.trigger_value }}</td>
                        <td>
                            {% set action_val = rule.action_value if rule.action_value else '' %}
                            {% if rule.action_type in ['Turn On', 'Turn Off'] %}
                                {{ rule.action_type }}
                            {% elif rule.action_type == 'Set Brightness' %}
                                Set Brightness to {{ action_val }}
                            {% elif rule.action_type == 'Set Temperature' %}
                                Set Temperature to {{ action_val }}
                            {% else %}
                                {{ rule.action_type }} {{ action_val }}
                            {% endif %}
                        </td>
                        <td>{{ 'Enabled' if rule.enabled|lower == 'true' else 'Disabled' }}</td>
                    </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="4">No automation rules found.</td></tr>
                {% endif %}
            </tbody>
        </table>

        <h2>Add New Rule</h2>
        <form method="post" action="{{ url_for('automation_rules') }}">
            <label for="rule-name">Rule Name:</label><br>
            <input type="text" id="rule-name" name="rule_name" required><br><br>

            <label for="trigger-type">Trigger Type:</label><br>
            <select id="trigger-type" name="trigger_type" required>
                <option value="">--Select Trigger--</option>
                <option value="Time">Time</option>
                <option value="Motion">Motion</option>
                <option value="Temperature">Temperature</option>
            </select><br><br>

            <label for="trigger-value">Trigger Value:</label><br>
            <input type="text" id="trigger-value" name="trigger_value" required><br><br>

            <label for="action-device">Action Device:</label><br>
            <select id="action-device" name="action_device" required>
                <option value="">--Select Device--</option>
                {% for device in devices %}
                <option value="{{ device.device_id }}">{{ device.device_name }}</option>
                {% endfor %}
            </select><br><br>

            <label for="action-type">Action Type:</label><br>
            <select id="action-type" name="action_type" required>
                <option value="">--Select Action--</option>
                <option value="Turn On">Turn On</option>
                <option value="Turn Off">Turn Off</option>
                <option value="Set Brightness">Set Brightness</option>
                <option value="Set Temperature">Set Temperature</option>
            </select><br><br>

            <button type="submit" id="add-rule-button">Add Rule</button>
            <button type="button" id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
```

templates/energy_report.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Energy Report</title>
</head>
<body>
    <div id="energy-page">
        <h1>Energy Report</h1>

        <div id="energy-summary">
            <p>Total Energy Consumption: {{ total_consumption }} kWh</p>
            <p>Estimated Cost: ${{ "%.2f"|format(total_cost) }}</p>
        </div>

        <form method="post" action="{{ url_for('energy_report') }}">
            <label for="date-filter">Filter by Date:</label>
            <input type="date" id="date-filter" name="date_filter" value="{{ filter_date or '' }}">
            <button type="submit" id="apply-filter-button">Apply Filter</button>
        </form>

        <table id="energy-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Device</th>
                    <th>Date</th>
                    <th>Consumption (kWh)</th>
                </tr>
            </thead>
            <tbody>
                {% if energy_logs %}
                    {% for log in energy_logs %}
                    <tr>
                        <td>{{ log.device_name }}</td>
                        <td>{{ log.date }}</td>
                        <td>{{ log.consumption_kwh }}</td>
                    </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="3">No energy consumption data found.</td></tr>
                {% endif %}
            </tbody>
        </table>

        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

