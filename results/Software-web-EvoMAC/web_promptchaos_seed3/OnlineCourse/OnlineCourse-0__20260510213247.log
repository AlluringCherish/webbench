                    e.preventDefault();
                    alert('Please enter a search term.');
                    searchInput.focus();
                }
            });
        }
    }

    // Course Details Page: Enroll button confirmation
    const courseDetailsPage = document.getElementById('course-details-page');
    if (courseDetailsPage) {
