    <div id="learning-page">
        <h1>{{ course.title }} - Learning</h1>
        <div id="lessons-list">
            <h2>Lessons</h2>
            <ul>
                {% for lesson in lessons_list %}
                    <li>
                        Lesson {{ lesson.lesson_number }} - 
                        {% if lesson.completed %}
                            Completed
                        {% else %}
                            Pending
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
        <div id="lesson-content">
            <p>{{ lesson_content }}</p>
        </div>
        <form method="post" action="{{ url_for('course_learning', course_id=course.course_id) }}">
            {% if current_lesson_index < total_lessons %}
                <button id="mark-complete-button" type="submit">Mark Complete</button>
            {% else %}
                <button id="mark-complete-button" type="submit" disabled>All Lessons Completed</button>
            {% endif %}
        </form>
        <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
    </div>
</body>
</html>
```

my_assignments.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Assignments</title>
</head>
<body>
    <div id="assignments-page">
        <h1>My Assignments</h1>
        <table id="assignments-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Max Points</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% if assignments %}
                    {% for assignment in assignments %}
                        <tr>
                            <td>{{ assignment.title }}</td>
                            <td>{{ assignment.description }}</td>
                            <td>{{ assignment.due_date }}</td>
                            <td>{{ assignment.max_points }}</td>
                            <td>{{ assignment.status }}</td>
                            <td>
                                {% if assignment.status == 'Pending' %}
                                    <button id="submit-assignment-button-{{ assignment.assignment_id }}" onclick="location.href='{{ url_for('submit_assignment', assignment_id=assignment.assignment_id) }}'">Submit</button>
                                {% else %}
                                    Submitted
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr><td colspan="6">No assignments found.</td></tr>
                {% endif %}
            </tbody>
        </table>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
