                <button id="mark-complete-button" type="submit">Mark Complete</button>
            {% else %}
                <button id="mark-complete-button" type="submit" disabled>All Lessons Completed</button>
            {% endif %}
        </form>
        <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
    </div>
</body>
