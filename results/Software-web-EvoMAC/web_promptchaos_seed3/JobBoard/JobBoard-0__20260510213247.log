        <h1 id="job-title">{{ job.title }}</h1>
        <div id="company-name">{{ job.company_name }}</div>
        <div id="location">{{ job.location }}</div>
        <div id="salary-range">${{ "{:,}".format(job.salary_min) }} - ${{ "{:,}".format(job.salary_max) }}</div>
