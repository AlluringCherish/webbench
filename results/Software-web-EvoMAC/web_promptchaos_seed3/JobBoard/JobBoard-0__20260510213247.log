    <meta charset="UTF-8" />
    <title>{{ job.title }} - Job Details - JobBoard</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; max-width: 800px; margin-left: auto; margin-right: auto; }
        #job-details-page { border: 1px solid #ccc; padding: 20px; border-radius: 5px; }
        h1 { margin-bottom: 5px; }
        #company-name { font-weight: bold; color: #555; margin-bottom: 15px; }
        #description { margin-bottom: 15px; white-space: pre-wrap; }
