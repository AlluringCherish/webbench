import unittest
from main import app
class TestDashboardPage(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code 200
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_title(self):
        # Test Task 2 & 3: Check if page title is correct in the HTML
        response = self.client.get('/')
        self.assertIn(b'<title>Movie Ticketing Dashboard</title>', response.data,
                      "Dashboard page should contain correct page title")
    def test_dashboard_elements_presence(self):
        # Test Task 3: Check presence of required elements by their IDs
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        # Check container div with id 'dashboard-page'
        self.assertIn('id="dashboard-page"', html, "Dashboard page should contain div with id 'dashboard-page'")
        # Check featured movies div
        self.assertIn('id="featured-movies"', html, "Dashboard page should contain div with id 'featured-movies'")
        # Check browse movies button
        self.assertIn('id="browse-movies-button"', html, "Dashboard page should contain button with id 'browse-movies-button'")
        # Check view bookings button
        self.assertIn('id="view-bookings-button"', html, "Dashboard page should contain button with id 'view-bookings-button'")
        # Check showtimes button
        self.assertIn('id="showtimes-button"', html, "Dashboard page should contain button with id 'showtimes-button'")
    def test_dashboard_navigation_buttons_functionality(self):
