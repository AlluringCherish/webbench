# Utility functions to load data from files
def load_movies():
    movies = []
    with open('movies.txt', newline='', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            movie = {
                'movie_id': int(row[0]),
                'title': row[1],
                'director': row[2],
                'genre': row[3],
                'rating': float(row[4]),
                'duration': int(row[5]),
                'description': row[6],
                'release_date': row[7]
            }
            movies.append(movie)
    return movies

def load_theaters():
    theaters = []
    with open('theaters.txt', newline='', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            theater = {
                'theater_id': int(row[0]),
                'theater_name': row[1],
                'location': row[2],
                'city': row[3],
                'screens': int(row[4]),
                'facilities': row[5].split(',')
            }
            theaters.append(theater)
    return theaters

def load_showtimes():
    showtimes = []
    with open('showtimes.txt', newline='', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            showtime = {
                'showtime_id': int(row[0]),
                'movie_id': int(row[1]),
                'theater_id': int(row[2]),
                'showtime_date': row[3],
                'showtime_time': row[4],
                'price': float(row[5]),
                'available_seats': int(row[6])
            }
            showtimes.append(showtime)
    return showtimes

def load_seats():
    seats = []
    with open('seats.txt', newline='', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            seat = {
                'seat_id': int(row[0]),
                'theater_id': int(row[1]),
                'screen_id': int(row[2]),
                'row': row[3],
                'column': int(row[4]),
                'seat_type': row[5],
                'status': row[6]
            }
            seats.append(seat)
    return seats

def load_bookings():
    bookings = []
    with open('bookings.txt', newline='', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            booking = {
                'booking_id': int(row[0]),
                'showtime_id': int(row[1]),
                'customer_name': row[2],
                'customer_email': row[3],
                'booking_date': row[4],
                'total_price': float(row[5]),
                'status': row[6],
                'seats_booked': row[7].split(',') if row[7] else []
            }
            bookings.append(booking)
    return bookings

# Route: Dashboard page
@app.route('/')
def dashboard():
    """
    Dashboard page showing navigation buttons to browse movies, theaters, and bookings.
    """
    return render_template('dashboard.html')

# Route: Movie catalog page with optional genre and rating filters
@app.route('/catalog')
def movie_catalog():
    """
    Displays a catalog of movies with optional filtering by genre and minimum rating.
    """
    genre_filter = request.args.get('genre', 'All')
    min_rating = request.args.get('min_rating', 0, type=float)

    movies = load_movies()
    genres = set(movie['genre'] for movie in movies)
    genres = sorted(genres)

    filtered_movies = []
    for movie in movies:
        if (genre_filter == 'All' or movie['genre'] == genre_filter) and movie['rating'] >= min_rating:
            filtered_movies.append(movie)

    return render_template('catalog.html',
                           movies=filtered_movies,
                           genres=genres,
                           selected_genre=genre_filter,
                           min_rating=min_rating)

# Route: Movie details page
@app.route('/movie/<int:movie_id>')
def movie_details(movie_id):
    """
    Displays detailed information about a specific movie, including showtimes.
    """
    movies = load_movies()
    movie = next((m for m in movies if m['movie_id'] == movie_id), None)
    if not movie:
        return "Movie not found", 404

    showtimes = load_showtimes()
    theaters = load_theaters()

    # Filter showtimes for this movie and upcoming dates
    today = datetime.today().date()
    movie_showtimes = []
    for st in showtimes:
        if st['movie_id'] == movie_id:
            showtime_date = datetime.strptime(st['showtime_date'], '%Y-%m-%d').date()
            if showtime_date >= today:
                theater = next((t for t in theaters if t['theater_id'] == st['theater_id']), None)
                if theater:
                    st_copy = st.copy()
                    st_copy['theater_name'] = theater['theater_name']
                    st_copy['location'] = theater['location']
                    movie_showtimes.append(st_copy)

    return render_template('movie_details.html',
                           movie=movie,
                           showtimes=movie_showtimes)

# Route: Theater list page with city filter
@app.route('/theaters')
def theaters_list():
    """
    Displays a list of theaters with optional city filter.
    """
    city_filter = request.args.get('city', 'All')
    theaters = load_theaters()
    cities = set(t['city'] for t in theaters)
    cities = sorted(cities)

    filtered_theaters = []
    for theater in theaters:
        if city_filter == 'All' or theater['city'] == city_filter:
            filtered_theaters.append(theater)

    return render_template('theaters.html',
                           theaters=filtered_theaters,
                           cities=cities,
                           selected_city=city_filter)

# Route: Showtimes page for a specific theater
@app.route('/theater/<int:theater_id>/showtimes')
def theater_showtimes(theater_id):
    """
    Displays showtimes for a specific theater.
    """
    theaters = load_theaters()
    theater = next((t for t in theaters if t['theater_id'] == theater_id), None)
    if not theater:
        return "Theater not found", 404

    showtimes = load_showtimes()
    movies = load_movies()

    today = datetime.today().date()
    theater_showtimes = []
    for st in showtimes:
        if st['theater_id'] == theater_id:
            showtime_date = datetime.strptime(st['showtime_date'], '%Y-%m-%d').date()
            if showtime_date >= today:
                movie = next((m for m in movies if m['movie_id'] == st['movie_id']), None)
                if movie:
                    st_copy = st.copy()
                    st_copy['movie_title'] = movie['title']
                    theater_showtimes.append(st_copy)

    return render_template('theater_showtimes.html',
                           theater=theater,
                           showtimes=theater_showtimes)

# Route: Seat selection page for a showtime
@app.route('/showtime/<int:showtime_id>/seats')
def seat_selection(showtime_id):
    """
    Displays seat map for a showtime to allow seat selection.
    """
    showtimes = load_showtimes()
    showtime = next((st for st in showtimes if st['showtime_id'] == showtime_id), None)
    if not showtime:
        return "Showtime not found", 404

    theaters = load_theaters()
    theater = next((t for t in theaters if t['theater_id'] == showtime['theater_id']), None)
    if not theater:
        return "Theater not found", 404

    seats = load_seats()
    # Filter seats for this theater and screen (assuming screen_id is known)
    # Here we assume screen_id = 1 for simplicity; adjust as needed
    screen_id = 1
    theater_seats = [s for s in seats if s['theater_id'] == theater['theater_id'] and s['screen_id'] == screen_id]

    # Organize seats by row and column for display
    seat_map = {}
    for seat in theater_seats:
        row = seat['row']
        if row not in seat_map:
            seat_map[row] = []
        seat_map[row].append(seat)
    # Sort seats in each row by column
    for row in seat_map:
        seat_map[row].sort(key=lambda s: s['column'])

    return render_template('seat_selection.html',
                           showtime=showtime,
                           theater=theater,
                           seat_map=seat_map)

# Route: Bookings page showing user's bookings (filter by email)
@app.route('/bookings')
def bookings_page():
    """
    Displays bookings filtered by customer email query parameter.
    """
    email = request.args.get('email', '').strip().lower()
    bookings = load_bookings()
    showtimes = load_showtimes()
    movies = load_movies()
    theaters = load_theaters()

    filtered_bookings = []
    if email:
        for booking in bookings:
            if booking['customer_email'].lower() == email:
                # Enrich booking with showtime, movie, theater info
                st = next((s for s in showtimes if s['showtime_id'] == booking['showtime_id']), None)
                if st:
                    movie = next((m for m in movies if m['movie_id'] == st['movie_id']), None)
                    theater = next((t for t in theaters if t['theater_id'] == st['theater_id']), None)
                    booking_copy = booking.copy()
                    booking_copy['movie_title'] = movie['title'] if movie else 'Unknown'
                    booking_copy['theater_name'] = theater['theater_name'] if theater else 'Unknown'
                    booking_copy['showtime_date'] = st['showtime_date']
                    booking_copy['showtime_time'] = st['showtime_time']
                    filtered_bookings.append(booking_copy)

    return render_template('bookings.html',
                           bookings=filtered_bookings,
                           email=email)

# Run the app
if __name__ == '__main__':
    app.run(debug=True)
```

---

### Explanation

- The Flask app provides routes for the main dashboard, movie catalog with filters, movie details with showtimes, theater list with city filter, theater showtimes, seat selection for a showtime, and bookings filtered by customer email.
- Data is loaded from the provided text files (`movies.txt`, `theaters.txt`, `showtimes.txt`, `seats.txt`, `bookings.txt`) using CSV reader with pipe delimiter.
- Templates (not included here) should be created for each route (`dashboard.html`, `catalog.html`, `movie_details.html`, `theaters.html`, `theater_showtimes.html`, `seat_selection.html`, `bookings.html`) and use the passed data to render the UI.
- Filtering and sorting are done in Python before passing data to templates.
- The seat selection page organizes seats by row and column for display.
- Bookings page allows filtering by customer email to show their bookings.
- The code uses standard Flask patterns and is designed to be accessible and navigable with buttons and dropdowns as described.

This code is a solid backend foundation for the described "MovieTicketing" web application with the specified pages, filters, and navigation.
