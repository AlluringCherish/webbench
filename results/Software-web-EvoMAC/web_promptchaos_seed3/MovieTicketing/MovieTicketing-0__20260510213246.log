```app.py
"""
Flask backend application for MovieTicketing web app.
Handles data loading from local files, business logic for browsing movies,
showtimes, seat selection, booking, booking history, and theater information.
"""

import csv
from datetime import datetime
from flask import Flask, render_template, request, redirect, url_for

app = Flask(__name__)

DATA_DIR = './data/'

def load_movies():
    movies = []
    with open(DATA_DIR + 'movies.txt', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            if len(row) < 8:
                continue
            movie = {
                'movie_id': int(row[0]),
                'title': row[1],
                'director': row[2],
                'genre': row[3],
                'rating': float(row[4]),
                'duration': int(row[5]),
                'description': row[6],
                'release_date': row[7]
            }
            movies.append(movie)
    return movies

def load_theaters():
    theaters = []
    with open(DATA_DIR + 'theaters.txt', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            if len(row) < 6:
                continue
            theater = {
                'theater_id': int(row[0]),
                'theater_name': row[1],
                'location': row[2],
                'city': row[3],
                'screens': int(row[4]),
                'facilities': [fac.strip() for fac in row[5].split(',')] if row[5].strip() else []
            }
            theaters.append(theater)
    return theaters

def load_showtimes():
    showtimes = []
    with open(DATA_DIR + 'showtimes.txt', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            if len(row) < 7:
                continue
            showtime = {
                'showtime_id': int(row[0]),
                'movie_id': int(row[1]),
                'theater_id': int(row[2]),
                'showtime_date': row[3],
                'showtime_time': row[4],
                'price': float(row[5]),
                'available_seats': int(row[6])
            }
            showtimes.append(showtime)
    return showtimes

def load_seats():
    seats = []
    with open(DATA_DIR + 'seats.txt', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            if len(row) < 7:
                continue
            seat = {
                'seat_id': int(row[0]),
                'theater_id': int(row[1]),
                'screen_id': int(row[2]),
                'row': row[3],
                'column': int(row[4]),
                'seat_type': row[5],
                'status': row[6]
            }
            seats.append(seat)
    return seats

def load_bookings():
    bookings = []
    try:
        with open(DATA_DIR + 'bookings.txt', encoding='utf-8', newline='') as f:
            reader = csv.reader(f, delimiter='|')
            for row in reader:
                if len(row) < 8:
                    continue
                booking = {
                    'booking_id': int(row[0]),
                    'showtime_id': int(row[1]),
                    'customer_name': row[2],
                    'customer_email': row[3],
                    'booking_date': row[4],
                    'total_price': float(row[5]),
                    'status': row[6],
                    'seats_booked': row[7].split(',') if row[7].strip() else []
                }
                bookings.append(booking)
    except FileNotFoundError:
        # No bookings yet
        pass
    return bookings

def load_genres():
    genres = []
    with open(DATA_DIR + 'genres.txt', encoding='utf-8') as f:
        reader = csv.reader(f, delimiter='|')
        for row in reader:
            if len(row) < 3:
                continue
            genre = {
                'genre_id': int(row[0]),
                'genre_name': row[1],
                'description': row[2]
            }
            genres.append(genre)
    return genres

@app.route('/')
def dashboard():
    """
    Dashboard page showing featured movies, navigation buttons to catalog and booking history.
    """
    movies = load_movies()
    today = datetime.today().date()
    # Featured movies: top rated and already released
    featured_movies = [m for m in movies if m['rating'] >= 8.0 and datetime.strptime(m['release_date'], '%Y-%m-%d').date() <= today]
    featured_movies = sorted(featured_movies, key=lambda m: m['rating'], reverse=True)[:5]
    return render_template('dashboard.html', featured_movies=featured_movies)

@app.route('/catalog')
def movie_catalog():
    """
    Movie catalog page with search and genre filter.
    """
    search_query = request.args.get('search', '').strip().lower()
    genre_filter = request.args.get('genre', 'All')
    movies = load_movies()
    genres = load_genres()
    genres = sorted(genres, key=lambda g: g['genre_name'])
    filtered_movies = []
    for movie in movies:
        matches_search = search_query in movie['title'].lower() or search_query in movie['director'].lower()
        matches_genre = (genre_filter == 'All' or movie['genre'] == genre_filter)
        if (not search_query or matches_search) and matches_genre:
            filtered_movies.append(movie)
    return render_template('movie_catalog.html', movies=filtered_movies, genres=genres, search_query=search_query, selected_genre=genre_filter)

@app.route('/movie/<int:movie_id>')
def movie_details(movie_id):
    """
    Movie details page showing detailed info and button to showtime selection.
    """
    movies = load_movies()
    movie = next((m for m in movies if m['movie_id'] == movie_id), None)
    if not movie:
        return "Movie not found", 404
    return render_template('movie_details.html', movie=movie)

@app.route('/showtimes/<int:movie_id>')
def showtime_selection(movie_id):
    """
    Showtime selection page for a movie with filters by theater and date.
    """
    movies = load_movies()
    theaters = load_theaters()
    showtimes = load_showtimes()
    movie = next((m for m in movies if m['movie_id'] == movie_id), None)
    if not movie:
        return "Movie not found", 404

    theater_filter = request.args.get('theater', 'All')
    date_filter = request.args.get('date', '').strip()

    filtered_showtimes = []
    for st in showtimes:
        if st['movie_id'] != movie_id:
            continue
        st_date_obj = datetime.strptime(st['showtime_date'], '%Y-%m-%d').date()
        if date_filter and st['showtime_date'] != date_filter:
            continue
        if theater_filter != 'All' and str(st['theater_id']) != theater_filter:
            continue
        st_copy = st.copy()
        theater = next((t for t in theaters if t['theater_id'] == st['theater_id']), None)
        st_copy['theater_name'] = theater['theater_name'] if theater else 'Unknown'
        filtered_showtimes.append(st_copy)

    theater_options = [('All', 'All Theaters')] + [(str(t['theater_id']), t['theater_name']) for t in theaters]

    return render_template('showtime_selection.html',
                           movie=movie,
                           showtimes=filtered_showtimes,
                           theater_options=theater_options,
                           selected_theater=theater_filter,
                           selected_date=date_filter)

@app.route('/seats/<int:showtime_id>')
def seat_selection(showtime_id):
    """
    Seat selection page for a showtime.
    """
    showtimes = load_showtimes()
    theaters = load_theaters()
    seats = load_seats()
    showtime = next((st for st in showtimes if st['showtime_id'] == showtime_id), None)
    if not showtime:
        return "Showtime not found", 404
    movie = next((m for m in load_movies() if m['movie_id'] == showtime['movie_id']), None)
    theater = next((t for t in theaters if t['theater_id'] == showtime['theater_id']), None)
    if not theater:
        return "Theater not found", 404

    # Filter seats for this theater and screen (assuming screen_id=1 for simplicity)
    theater_seats = [s for s in seats if s['theater_id'] == theater['theater_id'] and s['screen_id'] == 1]

    # Organize seats by row
    seat_map = {}
    for seat in theater_seats:
        row = seat['row']
        if row not in seat_map:
            seat_map[row] = []
        seat_map[row].append(seat)
    # Sort seats in each row by column
    for row in seat_map:
        seat_map[row] = sorted(seat_map[row], key=lambda s: s['column'])

    return render_template('seat_selection.html',
                           showtime=showtime,
                           movie=movie,
                           theater=theater,
                           seat_map=seat_map)

@app.route('/booking/<int:showtime_id>', methods=['GET', 'POST'])
def booking_confirmation(showtime_id):
    """
    Booking confirmation page to complete booking and purchase.
    """
    showtimes = load_showtimes()
    theaters = load_theaters()
    seats = load_seats()
    bookings = load_bookings()

    showtime = next((st for st in showtimes if st['showtime_id'] == showtime_id), None)
    if not showtime:
        return "Showtime not found", 404
    movie = next((m for m in load_movies() if m['movie_id'] == showtime['movie_id']), None)
    theater = next((t for t in theaters if t['theater_id'] == showtime['theater_id']), None)
    if not theater:
        return "Theater not found", 404

    seats_selected = request.args.get('seats', '')
    seats_selected_list = [s.strip() for s in seats_selected.split(',') if s.strip()]

    error = None
    if request.method == 'POST':
        customer_name = request.form.get('customer_name', '').strip()
        customer_email = request.form.get('customer_email', '').strip()
        if not customer_name or not customer_email:
            error = "Customer name and email are required."
        elif not seats_selected_list:
            error = "No seats selected."
        else:
            # Calculate total price
            total_price = showtime['price'] * len(seats_selected_list)
            # Generate new booking_id
            max_booking_id = max([b['booking_id'] for b in bookings], default=0)
            new_booking_id = max_booking_id + 1
            booking_date = datetime.today().strftime('%Y-%m-%d')
            # Append booking to bookings.txt
            with open(DATA_DIR + 'bookings.txt', 'a', encoding='utf-8', newline='') as f:
                writer = csv.writer(f, delimiter='|')
                writer.writerow([
                    new_booking_id,
                    showtime_id,
                    customer_name,
                    customer_email,
                    booking_date,
                    f"{total_price:.2f}",
                    'Confirmed',
                    ','.join(seats_selected_list)
                ])
            # Update seat status to Booked in seats.txt
            all_seats = load_seats()
            for seat in all_seats:
                seat_code = f"{seat['row']}{seat['column']}"
                if seat_code in seats_selected_list and seat['theater_id'] == theater['theater_id'] and seat['screen_id'] == 1:
                    seat['status'] = 'Booked'
            with open(DATA_DIR + 'seats.txt', 'w', encoding='utf-8', newline='') as f:
                writer = csv.writer(f, delimiter='|')
                for seat in all_seats:
                    writer.writerow([
                        seat['seat_id'],
                        seat['theater_id'],
                        seat['screen_id'],
                        seat['row'],
                        seat['column'],
                        seat['seat_type'],
                        seat['status']
                    ])
            # Update available seats in showtimes.txt
            for st in showtimes:
                if st['showtime_id'] == showtime_id:
                    st['available_seats'] -= len(seats_selected_list)
            with open(DATA_DIR + 'showtimes.txt', 'w', encoding='utf-8', newline='') as f:
                writer = csv.writer(f, delimiter='|')
                for st in showtimes:
                    writer.writerow([
                        st['showtime_id'],
                        st['movie_id'],
                        st['theater_id'],
                        st['showtime_date'],
                        st['showtime_time'],
                        f"{st['price']:.2f}",
                        st['available_seats']
                    ])
            return redirect(url_for('booking_history'))

    return render_template('booking_confirmation.html',
                           showtime=showtime,
                           movie=movie,
                           theater=theater,
                           seats_selected=seats_selected_list,
                           error=error)

@app.route('/bookings')
def booking_history():
    """
    Booking history page displaying all bookings with status filter.
    """
    status_filter = request.args.get('status', 'All')
    bookings = load_bookings()
    showtimes = load_showtimes()
    movies = load_movies()
    theaters = load_theaters()

    filtered_bookings = []
    for booking in bookings:
        if status_filter != 'All' and booking['status'] != status_filter:
            continue
        st = next((s for s in showtimes if s['showtime_id'] == booking['showtime_id']), None)
        if not st:
            continue
        movie = next((m for m in movies if m['movie_id'] == st['movie_id']), None)
        theater = next((t for t in theaters if t['theater_id'] == st['theater_id']), None)
        booking_copy = booking.copy()
        booking_copy['movie_title'] = movie['title'] if movie else 'Unknown'
        booking_copy['theater_name'] = theater['theater_name'] if theater else 'Unknown'
        booking_copy['showtime_date'] = st['showtime_date']
        booking_copy['showtime_time'] = st['showtime_time']
        filtered_bookings.append(booking_copy)

    statuses = ['All', 'Confirmed', 'Cancelled', 'Completed']

    return render_template('booking_history.html',
                           bookings=filtered_bookings,
                           statuses=statuses,
                           selected_status=status_filter)

@app.route('/booking/<int:booking_id>/details')
def booking_details(booking_id):
    """
    Booking details page showing detailed info about a booking.
    """
    bookings = load_bookings()
    booking = next((b for b in bookings if b['booking_id'] == booking_id), None)
    if not booking:
        return "Booking not found", 404
    showtimes = load_showtimes()
    movies = load_movies()
    theaters = load_theaters()
    st = next((s for s in showtimes if s['showtime_id'] == booking['showtime_id']), None)
    if not st:
        return "Showtime not found", 404
    movie = next((m for m in movies if m['movie_id'] == st['movie_id']), None)
    theater = next((t for t in theaters if t['theater_id'] == st['theater_id']), None)
    return render_template('booking_details.html',
                           booking=booking,
                           showtime=st,
                           movie=movie,
                           theater=theater)

@app.route('/theaters')
def theater_information():
    """
    Theater information page with filter by location.
    """
    theaters = load_theaters()
    location_filter = request.args.get('location', 'All')
    filtered_theaters = []
    locations = sorted(set(t['location'] for t in theaters))
    if location_filter == 'All':
        filtered_theaters = theaters
    else:
        filtered_theaters = [t for t in theaters if t['location'] == location_filter]
    return render_template('theater_information.html',
                           theaters=filtered_theaters,
                           locations=['All'] + locations,
                           selected_location=location_filter)

@app.route('/navigate')
def navigate():
    """
    Helper route for dashboard navigation buttons.
    """
    page = request.args.get('page', '')
    if page == 'catalog':
        return redirect(url_for('movie_catalog'))
    elif page == 'bookings':
        return redirect(url_for('booking_history'))
    elif page == 'theaters':
        return redirect(url_for('theater_information'))
    else:
        return redirect(url_for('dashboard'))

if __name__ == '__main__':
    app.run(debug=True)
```
