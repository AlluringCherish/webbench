'''
Property Search page template for RealEstate application.
Uses Flask url_for for navigation and form submission.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Property Search</title>
</head>
<body>
<div id="search-page">
    <h1>Property Search</h1>
    <form method="get" action="{{ url_for('property_search') }}">
        <label for="location-input">Location:</label>
        <input type="text" id="location-input" name="location" value="{{ location_filter }}">
        <label for="price-range-min">Min Price:</label>
        <input type="number" id="price-range-min" name="price_min" value="{{ price_min }}">
        <label for="price-range-max">Max Price:</label>
        <input type="number" id="price-range-max" name="price_max" value="{{ price_max }}">
        <label for="property-type-filter">Property Type:</label>
        <select id="property-type-filter" name="property_type">
            <option value="">All</option>
            {% for pt in property_types %}
            <option value="{{ pt }}" {% if pt == property_type_filter %}selected{% endif %}>{{ pt }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="properties-grid">
        {% if properties %}
        <ul>
            {% for property in properties %}
            <li>
                <img src="/static/images/property_placeholder.png" alt="Property Image" width="150" height="100">
                <div>{{ property.address }}, {{ property.location }}</div>
                <div>Price: ${{ property.price }}</div>
                <div>Beds: {{ property.bedrooms }}, Baths: {{ property.bathrooms }}</div>
                <button id="view-property-button-{{ property.property_id }}" onclick="location.href='{{ url_for('property_details', property_id=property.property_id) }}'">View Details</button>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p>No properties found matching your criteria.</p>
        {% endif %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
