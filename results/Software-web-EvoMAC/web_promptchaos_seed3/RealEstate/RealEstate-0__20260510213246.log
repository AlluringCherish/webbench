'''
My Inquiries page template for RealEstate application.
Uses Flask url_for for navigation and actions.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Inquiries</title>
</head>
<body>
<div id="inquiries-page">
    <h1>My Inquiries</h1>
    <form method="get" action="{{ url_for('my_inquiries') }}">
        <label for="inquiry-status-filter">Filter by Status:</label>
        <select id="inquiry-status-filter" name="status" onchange="this.form.submit()">
            <option value="All" {% if status_filter == 'All' %}selected{% endif %}>All</option>
            <option value="Pending" {% if status_filter == 'Pending' %}selected{% endif %}>Pending</option>
            <option value="Contacted" {% if status_filter == 'Contacted' %}selected{% endif %}>Contacted</option>
            <option value="Resolved" {% if status_filter == 'Resolved' %}selected{% endif %}>Resolved</option>
        </select>
    </form>
    <table id="inquiries-table" border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>Property</th>
                <th>Date</th>
                <th>Status</th>
                <th>Contact Info</th>
                <th>Message</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for inquiry in inquiries %}
            <tr>
                <td>
                    {% if inquiry.property_id in properties %}
                    {{ properties[inquiry.property_id].address }}
                    {% else %}
                    Unknown Property
                    {% endif %}
                </td>
                <td>{{ inquiry.inquiry_date }}</td>
                <td>{{ inquiry.status }}</td>
                <td>
                    {{ inquiry.customer_name }}<br>
                    {{ inquiry.customer_email }}<br>
                    {{ inquiry.customer_phone }}
                </td>
                <td>{{ inquiry.message }}</td>
                <td>
                    <form method="post" action="{{ url_for('delete_inquiry', inquiry_id=inquiry.inquiry_id) }}" onsubmit="return confirm('Are you sure you want to delete this inquiry?');">
                        <button id="delete-inquiry-button-{{ inquiry.inquiry_id }}" type="submit">Delete</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6">No inquiries found.</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
