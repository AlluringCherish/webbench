                <option value="">-- Select an Event --</option>
                {% for event in events %}
                    <option value="{{ event.event_id }}"
                    {% if request.args.get('event_id') == event.event_id %}selected{% endif %}
                    >{{ event.event_name }} ({{ event.date }})</option>
                {% endfor %}
            </select><br><br>
            <label for="ticket-quantity-input">Number of Tickets:</label>
            <input type="number" id="ticket-quantity-input" name="ticket-quantity-input" min="1" required><br><br>
            <label for="ticket-type-select">Ticket Type:</label>
            <select id="ticket-type-select" name="ticket-type-select" required>
                <option value="">-- Select Ticket Type --</option>
                <option value="General">General</option>
                <option value="VIP">VIP</option>
                <option value="Early Bird">Early Bird</option>
            </select><br><br>
            <label for="customer-name-input">Your Name:</label>
            <input type="text" id="customer-name-input" name="customer-name-input" placeholder="Guest"><br><br>
            <button id="book-now-button" type="submit">Book Now</button>
            <button type="button" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        </form>
    </div>
</body>
</html>
