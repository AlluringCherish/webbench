                        <th>Total Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% if bookings %}
                        {% for b in bookings %}
                            <tr>
                                <td>{{ b.booking_id }}</td>
                                <td>{{ b.event_name }}</td>
                                <td>{{ b.booking_date }}</td>
                                <td>{{ b.ticket_count }}</td>
                                <td>{{ b.ticket_type }}</td>
                                <td>${{ "%.2f"|format(b.total_amount) }}</td>
                                <td>{{ b.status }}</td>
                                <td>
                                    {% if b.status != 'Cancelled' %}
                                        <button type="submit" name="cancel_booking_id" value="{{ b.booking_id }}" id="cancel-booking-button-{{ b.booking_id }}">Cancel</button>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr><td colspan="8">No bookings found.</td></tr>
                    {% endif %}
                </tbody>
            </table>
        </form>
    </div>
</body>
</html>
