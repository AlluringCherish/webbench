<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Schedules</title>
</head>
<body>
    <div id="schedules-page">
        <h1>Event Schedules</h1>
        <form method="get" action="{{ url_for('schedules_page') }}">
            <label for="schedule-filter-date">Filter by Date:</label>
            <input id="schedule-filter-date" name="date" type="date" value="{{ filter_date }}">
            <label for="schedule-filter-event">Filter by Event:</label>
            <select id="schedule-filter-event" name="event">
                <option value="">All Events</option>
                {% for event in events %}
                <option value="{{ event.event_id }}" {% if filter_event == event.event_id %}selected{% endif %}>{{ event.event_name }}</option>
                {% endfor %}
            </select>
            <button type="submit">Filter</button>
        </form>
        <div id="schedules-timeline">
            {% for schedule in schedules %}
            <div class="schedule-item">
                <h3>{{ schedule.session_title }}</h3>
                <p>Event: {{ schedule.event_name }}</p>
                <p>Time: {{ schedule.session_time }}</p>
                <p>Duration: {{ schedule.duration_minutes }} minutes</p>
                <p>Speaker: {{ schedule.speaker }}</p>
            </div>
            {% else %}
            <p>No schedules found.</p>
            {% endfor %}
        </div>
        <button id="export-schedule-button" onclick="alert('Export schedule functionality not implemented.')">Export Schedule</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

