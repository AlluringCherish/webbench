'''
Bookings Summary page template for EventPlanning.
Uses Flask url_for() for navigation buttons and form submission.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings</title>
</head>
<body>
    <div id="bookings-page">
        <h1>My Bookings</h1>
        <form method="get" action="{{ url_for('bookings_summary') }}">
            <input id="booking-search-input" name="search" type="text" placeholder="Search bookings" value="{{ search_query }}">
            <button type="submit">Search</button>
        </form>
        <form method="post" action="{{ url_for('bookings_summary') }}">
            <table id="bookings-table" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>Booking ID</th>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Ticket Count</th>
                        <th>Ticket Type</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for booking in bookings %}
                    <tr>
                        <td>{{ booking.booking_id }}</td>
                        <td>{{ booking.event_name }}</td>
                        <td>{{ booking.booking_date }}</td>
                        <td>{{ booking.ticket_count }}</td>
                        <td>{{ booking.ticket_type }}</td>
                        <td>{{ booking.status }}</td>
                        <td>
                            {% if booking.status != 'Cancelled' %}
                            <button id="cancel-booking-button-{{ booking.booking_id }}" name="cancel_booking_id" value="{{ booking.booking_id }}" type="submit">Cancel Booking</button>
                            {% else %}
                            N/A
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="7">No bookings found.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </form>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
