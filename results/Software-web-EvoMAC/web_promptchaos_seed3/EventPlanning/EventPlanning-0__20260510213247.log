'''
Dashboard page template for EventPlanning.
Uses Flask url_for() for navigation buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Planning Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Event Planning Dashboard</h1>
        <div id="featured-events">
            <h2>Featured Events</h2>
            <ul>
                {% for event in events %}
                <li>
                    <strong>{{ event.event_name }}</strong> - {{ event.date }} {{ event.time }} at {{ event.location }}
                    <button id="view-event-button-{{ event.event_id }}" onclick="location.href='{{ url_for('event_details', event_id=event.event_id) }}'">View Details</button>
                </li>
                {% endfor %}
            </ul>
        </div>
        <div id="featured-venues">
            <h2>Featured Venues</h2>
            <ul>
                {% for venue in venues %}
                <li>{{ venue.venue_name }} - {{ venue.location }}</li>
                {% endfor %}
            </ul>
        </div>
        <button id="browse-events-button" onclick="location.href='{{ url_for('events_listing') }}'">Browse Events</button>
        <button id="view-tickets-button" onclick="location.href='{{ url_for('ticket_booking') }}'">View Tickets</button>
        <button id="venues-button" onclick="location.href='{{ url_for('venues_page') }}'">Venues</button>
        <button id="participants-button" onclick="location.href='{{ url_for('participants_management') }}'">Participants</button>
        <button id="schedules-button" onclick="location.href='{{ url_for('schedules_page') }}'">Schedules</button>
        <button id="bookings-button" onclick="location.href='{{ url_for('bookings_summary') }}'">My Bookings</button>
    </div>
</body>
</html>
