class ContentPublishingHubTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_index_redirects_to_dashboard(self):
        # Test that accessing '/' redirects to '/dashboard'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 302)
        self.assertIn('/dashboard', response.headers['Location'])
    def test_dashboard_page_accessible(self):
        # Test that /dashboard page is accessible and returns 200
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        # Check content type is HTML
        self.assertIn('text/html', response.content_type)
    def test_dashboard_page_elements(self):
        # Test presence of required elements on dashboard page
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check page container with id 'dashboard-page'
        container = soup.find(id='dashboard-page')
        self.assertIsNotNone(container, "Dashboard page container with id 'dashboard-page' not found")
        # Check welcome message with id 'welcome-message'
        welcome = soup.find(id='welcome-message')
        self.assertIsNotNone(welcome, "Welcome message with id 'welcome-message' not found")
        self.assertTrue(len(welcome.text.strip()) > 0, "Welcome message is empty")
        # Check quick stats section with id 'quick-stats'
        quick_stats = soup.find(id='quick-stats')
        self.assertIsNotNone(quick_stats, "Quick stats section with id 'quick-stats' not found")
        # Check Create Article button with id 'create-article-button'
        create_btn = soup.find(id='create-article-button')
        self.assertIsNotNone(create_btn, "Create Article button with id 'create-article-button' not found")
        self.assertEqual(create_btn.name, 'button', "Create Article element is not a button")
        # Check recent activity feed with id 'recent-activity'
        recent_activity = soup.find(id='recent-activity')
        self.assertIsNotNone(recent_activity, "Recent activity feed with id 'recent-activity' not found")
    def test_create_article_button_navigation(self):
        # Test that clicking Create Article button leads to /article/create
        # Since this is backend test, simulate GET /article/create
        response = self.client.get('/article/create')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        self.assertIn('create-article-page', html, "Create Article page container not found")
if __name__ == '__main__':
    unittest.main()

