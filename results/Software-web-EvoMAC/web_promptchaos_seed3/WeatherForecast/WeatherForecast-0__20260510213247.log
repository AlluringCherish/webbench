<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Alerts</title>
</head>
<body>
    <div id="alerts-page">
        <h1>Weather Alerts</h1>

        <form method="get" action="{{ url_for('alerts') }}">
            <label for="severity-filter">Filter by Severity:</label>
            <select id="severity-filter" name="severity" onchange="this.form.submit()">
                {% set severities = ['All', 'Critical', 'High', 'Medium', 'Low'] %}
                {% for sev in severities %}
                    <option value="{{ sev }}" {% if severity_filter == sev %}selected{% endif %}>{{ sev }}</option>
                {% endfor %}
            </select>

            <label for="location-filter-alerts">Filter by Location:</label>
            <select id="location-filter-alerts" name="location_id" onchange="this.form.submit()">
                <option value="" {% if not location_filter %}selected{% endif %}>All Locations</option>
                {% for loc_id, loc in locations.items() %}
                    <option value="{{ loc_id }}" {% if location_filter == loc_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>

        <div id="alerts-list">
            {% if alerts %}
                <ul>
                {% for alert in alerts %}
                    <li>
                        <strong>{{ alert.alert_type }}</strong> - Severity: {{ alert.severity }}<br>
                        Location: {{ locations[alert.location_id].location_name if alert.location_id in locations else 'Unknown' }}<br>
                        Description: {{ alert.description }}<br>
                        Start: {{ alert.start_time }} - End: {{ alert.end_time }}<br>
                        Acknowledged: {{ 'Yes' if alert.is_acknowledged == '1' else 'No' }}<br>
                        {% if alert.is_acknowledged == '0' %}
                            <form method="post" action="{{ url_for('acknowledge_alert', alert_id=alert.alert_id) }}" style="display:inline;">
                                <button id="acknowledge-alert-button-{{ alert.alert_id }}" type="submit">Acknowledge</button>
                            </form>
                        {% endif %}
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No active alerts.</p>
            {% endif %}
        </div>

        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

