settings.html
```html
'''
Settings page template.
Allows users to configure temperature units, default location, and alert notifications.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Settings</title>
</head>
<body>
    <div id="settings-page">
        <h1>Settings</h1>
        <form method="post" action="{{ url_for('settings') }}">
            <label for="temperature-unit-select">Temperature Unit:</label>
            <select id="temperature-unit-select" name="temperature_unit">
                <option value="Celsius">Celsius</option>
                <option value="Fahrenheit">Fahrenheit</option>
                <option value="Kelvin">Kelvin</option>
            </select>
            <br><br>
            <label for="default-location-select">Default Location:</label>
            <select id="default-location-select" name="default_location">
                {% for loc_id, loc in locations.items() %}
                    <option value="{{ loc_id }}">{{ loc.location_name }}</option>
                {% endfor %}
            </select>
            <br><br>
            <label for="alert-notifications-toggle">Alert Notifications:</label>
            <input type="checkbox" id="alert-notifications-toggle" name="alert_notifications" checked>
            <br><br>
            <button id="save-settings-button" type="submit">Save Settings</button>
        </form>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
