        <div id="saved-locations-list">
            {% if saved_locations %}
                <ul>
                {% for loc in saved_locations %}
                    <li>{{ loc.location_name }}</li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No saved locations.</p>
            {% endif %}
        </div>
