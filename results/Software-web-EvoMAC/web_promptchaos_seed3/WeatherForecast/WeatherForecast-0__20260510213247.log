location_search.html
```html
'''
Location Search page template.
Allows users to search and select different locations,
and view previously saved locations.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Locations</title>
</head>
<body>
    <div id="search-page">
        <h1>Search Locations</h1>
        <form method="get" action="{{ url_for('locations_page') }}">
            <input type="text" id="location-search-input" name="q" placeholder="Search by city name or coordinates" value="{{ request.args.get('q', '') }}">
            <button type="submit">Search</button>
        </form>
        <div id="search-results">
            {% if locations %}
                <ul>
                {% for loc_id, loc in locations.items() %}
                    {% if not request.args.get('q') or request.args.get('q').lower() in loc.location_name.lower() %}
                    <li>
                        {{ loc.location_name }} ({{ loc.country }})
                        <button id="select-location-button-{{ loc.location_id }}" onclick="location.href='{{ url_for('weather', location_id=loc.location_id) }}'">Select</button>
                    </li>
                    {% endif %}
                {% endfor %}
                </ul>
            {% else %}
                <p>No locations found.</p>
            {% endif %}
        </div>
        <h3>Saved Locations</h3>
        <div id="saved-locations-list">
            {% if saved_locations %}
                <ul>
                {% for loc in saved_locations %}
                    <li>{{ loc.location_name }}</li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No saved locations.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

weather_alerts.html
```html
'''
Weather Alerts page template.
Displays active weather alerts with filtering and acknowledgement.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Alerts</title>
</head>
<body>
    <div id="alerts-page">
        <h1>Weather Alerts</h1>
        <form method="get" action="{{ url_for('alerts') }}">
            <label for="severity-filter">Filter by Severity:</label>
            <select id="severity-filter" name="severity" onchange="this.form.submit()">
                {% set severities = ['All', 'Critical', 'High', 'Medium', 'Low'] %}
                {% for sev in severities %}
                    <option value="{{ sev }}" {% if severity_filter == sev %}selected{% endif %}>{{ sev }}</option>
                {% endfor %}
            </select>
            <label for="location-filter-alerts">Filter by Location:</label>
            <select id="location-filter-alerts" name="location_id" onchange="this.form.submit()">
                <option value="" {% if not location_filter %}selected{% endif %}>All Locations</option>
                {% for loc_id, loc in locations.items() %}
                    <option value="{{ loc_id }}" {% if location_filter == loc_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>
        <div id="alerts-list">
            {% if alerts %}
                <ul>
                {% for alert in alerts %}
                    <li>
                        <strong>{{ alert.alert_type }}</strong> - Severity: {{ alert.severity }}<br>
                        Location: {{ locations[alert.location_id].location_name if alert.location_id in locations else 'Unknown' }}<br>
                        Description: {{ alert.description }}<br>
                        Start: {{ alert.start_time }} - End: {{ alert.end_time }}<br>
                        Acknowledged: {{ 'Yes' if alert.is_acknowledged == '1' else 'No' }}<br>
                        {% if alert.is_acknowledged == '0' %}
                            <form method="post" action="{{ url_for('acknowledge_alert', alert_id=alert.alert_id) }}" style="display:inline;">
                                <button id="acknowledge-alert-button-{{ alert.alert_id }}" type="submit">Acknowledge</button>
                            </form>
                        {% endif %}
                    </li>
                {% endfor %}
                </ul>
            {% else %}
                <p>No active alerts.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

air_quality.html
```html
'''
Air Quality page template.
Displays air quality index and pollution details for selected location.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Air Quality Index</title>
</head>
<body>
    <div id="air-quality-page">
        <h1>Air Quality Index</h1>
        <form method="get" action="{{ url_for('air_quality') }}">
            <label for="location-aqi-filter">Filter by Location:</label>
            <select id="location-aqi-filter" name="location_id" onchange="this.form.submit()">
                <option value="" {% if not selected_location %}selected{% endif %}>Select Location</option>
                {% for loc_id, loc in locations.items() %}
                    <option value="{{ loc_id }}" {% if selected_location == loc_id %}selected{% endif %}>{{ loc.location_name }}</option>
                {% endfor %}
            </select>
        </form>
        {% if air_quality %}
            <div id="aqi-display">AQI Index: {{ air_quality.aqi_index }}</div>
            <div id="aqi-description">
                {% set aqi_val = air_quality.aqi_index|int %}
                {% if aqi_val <= 50 %}
                    Good
                {% elif aqi_val <= 100 %}
                    Moderate
                {% elif aqi_val <= 150 %}
                    Unhealthy for Sensitive Groups
                {% elif aqi_val <= 200 %}
                    Unhealthy
                {% elif aqi_val <= 300 %}
                    Very Unhealthy
                {% else %}
                    Hazardous
                {% endif %}
            </div>
            <table id="pollution-details" border="1" cellpadding="5" cellspacing="0">
                <thead>
                    <tr>
                        <th>PM2.5</th>
                        <th>PM10</th>
                        <th>NO2</th>
                        <th>O3</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>{{ air_quality.pm25 }}</td>
                        <td>{{ air_quality.pm10 }}</td>
                        <td>{{ air_quality.no2 }}</td>
                        <td>{{ air_quality.o3 }}</td>
                    </tr>
                </tbody>
            </table>
            <div id="health-recommendation">
                {% if aqi_val <= 50 %}
                    Air quality is considered satisfactory, and air pollution poses little or no risk.
                {% elif aqi_val <= 100 %}
                    Air quality is acceptable; however, some pollutants may be a moderate health concern for a very small number of people.
                {% elif aqi_val <= 150 %}
                    Members of sensitive groups may experience health effects. The general public is not likely to be affected.
                {% elif aqi_val <= 200 %}
                    Everyone may begin to experience health effects; members of sensitive groups may experience more serious health effects.
                {% elif aqi_val <= 300 %}
                    Health alert: everyone may experience more serious health effects.
                {% else %}
                    Health warnings of emergency conditions. The entire population is more likely to be affected.
                {% endif %}
            </div>
        {% else %}
            <p>No air quality data available for selected location.</p>
        {% endif %}
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
```

saved_locations.html
```html
'''
Saved Locations page template.
Displays all saved locations with current temperature and weather condition,
and allows viewing or removing locations.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Saved Locations</title>
</head>
<body>
    <div id="saved-locations-page">
        <h1>Saved Locations</h1>
        <table id="locations-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Location Name</th>
                    <th>Current Temperature</th>
                    <th>Weather Condition</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for loc in saved_locations %}
                    <tr>
                        <td>{{ loc.location_name }}</td>
                        <td>
                            {% if current_weather[loc.location_id] is defined %}
                                {{ current_weather[loc.location_id].temperature }}°
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if current_weather[loc.location_id] is defined %}
                                {{ current_weather[loc.location_id].condition }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            <button id="view-location-weather-{{ loc.location_id }}" onclick="location.href='{{ url_for('weather', location_id=loc.location_id) }}'">View Weather</button>
                            <form method="post" action="{{ url_for('remove_saved_location', location_id=loc.location_id) }}" style="display:inline;">
                                <button id="remove-location-button-{{ loc.location_id }}" type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">No saved locations.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        <button id="add-new-location-button" onclick="location.href='{{ url_for('locations_page') }}'">Add New Location</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
