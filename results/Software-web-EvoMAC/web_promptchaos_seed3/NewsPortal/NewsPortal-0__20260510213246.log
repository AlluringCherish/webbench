        <button id="trending-articles-button" onclick="location.href='{{ url_for('trending') }}'">Trending Articles</button>
    </div>
    <div id="trending-articles">
        <h2>Trending This Week</h2>
        {% if trending_articles %}
            {% for idx, article in enumerate(trending_articles, start=1) %}
                <div class="article-card">
                    <a href="{{ url_for('article_details', article_id=article.article_id) }}" class="article-link">
                        <div class="article-title" id="trending-article-title-{{ article.article_id }}">
                            {{ idx }}. {{ article.article_title }}
                        </div>
                    </a>
                    <div class="article-meta">Category: {{ article.category }} | Views: {{ article.view_count }}</div>
                </div>
            {% endfor %}
        {% else %}
            <p>No trending articles available for this week.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
