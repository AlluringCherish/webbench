styles.css
```css
/*
Stylesheet for consistent styling across all NewsPortal pages.
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
/* Body and general layout */
body {
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
    padding: 20px;
    min-height: 100vh;
}
/* Container for pages */
#dashboard-page,
#catalog-page,
#article-details-page,
#bookmarks-page,
#comments-page,
#write-comment-page,
#trending-page,
#category-page,
#search-results-page {
    max-width: 1000px;
    margin: 0 auto;
    background-color: #fff;
    padding: 20px 30px;
    border-radius: 6px;
    box-shadow: 0 0 8px rgba(0,0,0,0.1);
}
/* Headings */
h1, h2, h3 {
    color: #007BFF;
    margin-bottom: 15px;
}
h1 {
    text-align: center;
    margin-bottom: 30px;
}
h2 {
    border-bottom: 2px solid #007BFF;
    padding-bottom: 5px;
}
/* Buttons */
button {
    background-color: #007BFF;
    color: white;
    border: none;
    padding: 12px 20px;
    margin: 5px 10px 5px 0;
    font-size: 1em;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.3s ease;
}
button:hover,
button:focus {
    background-color: #0056b3;
    outline: none;
}
/* Links */
a {
    color: #007BFF;
    text-decoration: none;
}
a:hover,
a:focus {
    text-decoration: underline;
}
/* Article cards and lists */
.article-card,
.bookmark-item,
.comment-item,
.trending-item,
.category-article-item,
.search-result-item {
    border-bottom: 1px solid #ddd;
    padding: 10px 0;
}
.article-card:last-child,
.bookmark-item:last-child,
.comment-item:last-child,
.trending-item:last-child,
.category-article-item:last-child,
.search-result-item:last-child {
    border-bottom: none;
}
/* Article title styling */
.article-title,
.bookmark-title,
.comment-article-title,
.trending-title,
.category-article-title,
.search-result-title {
    font-weight: bold;
    font-size: 1.1em;
    margin-bottom: 5px;
}
/* Article meta info */
.article-meta,
.bookmark-date,
.comment-meta,
.trending-meta,
.category-article-meta,
.search-result-excerpt {
    font-size: 0.9em;
    color: #666;
}
/* Input fields and dropdowns */
input[type="text"],
input[type="search"],
select,
textarea {
    width: 100%;
    padding: 8px 10px;
    margin: 8px 0 15px 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1em;
    resize: vertical;
}
textarea {
    min-height: 100px;
}
/* Form labels */
label {
    font-weight: bold;
    display: block;
    margin-bottom: 5px;
}
/* Buttons container for center alignment */
#buttons-container,
#navigation-buttons {
    text-align: center;
    margin-bottom: 30px;
}
/* Grid for articles in catalog */
#articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
}
/* Article card inside grid */
.article-card {
    background-color: #fafafa;
    padding: 15px;
    border-radius: 5px;
    box-shadow: 0 0 5px #ccc;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
/* Thumbnail placeholder (optional) */
.article-thumbnail {
    width: 100%;
    height: 150px;
    background-color: #ddd;
    border-radius: 4px;
    margin-bottom: 10px;
    object-fit: cover;
}
/* Buttons inside article cards */
.article-card button,
.bookmark-item button,
.trending-item button,
.category-article-item button,
.search-result-item button {
    margin-top: 10px;
    align-self: flex-start;
}
/* Error message styling */
.error-message {
    color: #d9534f;
    font-weight: bold;
    margin-bottom: 15px;
}
/* No results or empty message */
.no-results-message {
    font-style: italic;
    color: #999;
    margin-top: 15px;
}
/* Comments list */
#comments-list {
    max-height: 400px;
    overflow-y: auto;
    padding-right: 10px;
}
/* Comment item */
.comment-item {
    background-color: #f5f5f5;
    border-radius: 4px;
    padding: 10px;
    margin-bottom: 10px;
}
/* Commenter name and date */
.comment-meta {
    font-size: 0.85em;
    color: #555;
    margin-bottom: 5px;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    #articles-grid {
        grid-template-columns: 1fr;
    }
    button {
        width: 100%;
        margin: 8px 0;
    }
}
