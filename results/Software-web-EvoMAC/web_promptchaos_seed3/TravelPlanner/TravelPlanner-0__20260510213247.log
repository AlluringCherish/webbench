@app.route('/navigate/back_to_dashboard')
def navigate_back_to_dashboard():
    return redirect(url_for('dashboard'))
if __name__ == '__main__':
    if not os.path.exists(DATA_DIR):
        os.makedirs(DATA_DIR)
    app.run(debug=True)
