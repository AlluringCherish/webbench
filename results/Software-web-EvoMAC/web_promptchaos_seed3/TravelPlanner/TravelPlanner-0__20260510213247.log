        season = recommendation_season_filter.lower()
        if season == 'summer':
            filtered_destinations = [d for d in filtered_destinations if d['climate'].lower() in ['tropical', 'warm']]
        elif season == 'winter':
            filtered_destinations = [d for d in filtered_destinations if d['climate'].lower() in ['temperate', 'cold']]
    # Budget filter is ignored here as no budget data in destinations
    return render_template('recommendations.html',
                           destinations=filtered_destinations,
                           recommendation_season_filter=recommendation_season_filter,
                           budget_filter=budget_filter)
