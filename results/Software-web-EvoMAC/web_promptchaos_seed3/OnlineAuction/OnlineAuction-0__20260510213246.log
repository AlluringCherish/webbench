                'item_name': parts[1],
                'bid_count': int(parts[2]),
                'current_bid': float(parts[3]),
                'trending_rank': int(parts[4]),
                'time_period': parts[5]
            }
            trending.append(item)
    return trending
def read_items():
    path = os.path.join(DATA_DIR, 'items.txt')
    items = []
    if not os.path.exists(path):
        return items
    with open(path, encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 7:
                continue
            item = {
                'item_id': parts[0],
                'auction_id': parts[1],
                'item_name': parts[2],
                'starting_price': float(parts[3]),
                'category': parts[4],
                'condition': parts[5],
                'seller_name': parts[6]
            }
            items.append(item)
    return items
def format_datetime(dt):
    return dt.strftime('%Y-%m-%d %H:%M')
def time_remaining(end_time_str):
    try:
        end_time = datetime.datetime.strptime(end_time_str, '%Y-%m-%d %H:%M')
    except ValueError:
        return "Unknown"
    now = datetime.datetime.now()
    if end_time < now:
        return "Ended"
    delta = end_time - now
    days = delta.days
    hours, remainder = divmod(delta.seconds, 3600)
    minutes = remainder // 60
    parts = []
    if days > 0:
        parts.append(f"{days}d")
    if hours > 0:
        parts.append(f"{hours}h")
    if minutes > 0:
        parts.append(f"{minutes}m")
    return ' '.join(parts) if parts else "Less than 1m"
@app.route('/')
def dashboard():
    auctions = read_auctions()
    # Filter active auctions for featured
    active_auctions = [a for a in auctions if a['status'].lower() == 'active']
    # Sort by end_time ascending
    active_auctions.sort(key=lambda x: x['end_time'])
    featured_auctions = active_auctions[:5]  # Show top 5 featured
    trending_auctions = read_trending()
    trending_this_week = [t for t in trending_auctions if t['time_period'].lower() == 'week']
    trending_this_week.sort(key=lambda x: x['trending_rank'])
    return render_template('auction_dashboard.html',
                           featured_auctions=featured_auctions,
                           trending_auctions=trending_this_week)
@app.route('/catalog')
def catalog():
    auctions = read_auctions()
    categories = read_categories()
    search_query = request.args.get('search', '').strip().lower()
    category_filter = request.args.get('category', '').strip().lower()
    filtered_auctions = auctions
    if category_filter:
        filtered_auctions = [a for a in filtered_auctions if a['category'].lower() == category_filter]
    if search_query:
        filtered_auctions = [a for a in filtered_auctions if search_query in a['item_name'].lower() or search_query in a['description'].lower()]
    # Sort by end_time ascending
    filtered_auctions.sort(key=lambda x: x['end_time'])
    return render_template('auction_catalog.html',
                           auctions=filtered_auctions,
                           categories=categories,
                           search_query=search_query,
                           category_filter=category_filter)
@app.route('/auction/<auction_id>')
def auction_details(auction_id):
    auctions = read_auctions()
    auction = next((a for a in auctions if a['auction_id'] == auction_id), None)
    if not auction:
        flash("Auction not found.", "error")
        return redirect(url_for('catalog'))
    bids = read_bids()
    auction_bid_history = [b for b in bids if b['auction_id'] == auction_id]
    auction_bid_history.sort(key=lambda x: x['bid_timestamp'], reverse=True)
    min_bid = max(auction['current_bid'], auction['starting_bid']) + 0.01
    return render_template('auction_details.html',
                           auction=auction,
                           bid_history=auction_bid_history,
                           minimum_bid=min_bid)
@app.route('/place_bid/<auction_id>', methods=['POST'])
def place_bid(auction_id):
    auctions = read_auctions()
    auction = next((a for a in auctions if a['auction_id'] == auction_id), None)
    if not auction:
        flash("Auction not found.", "error")
        return redirect(url_for('catalog'))
    if auction['status'].lower() != 'active':
        flash("Cannot place bid on inactive auction.", "error")
        return redirect(url_for('auction_details', auction_id=auction_id))
    bidder_name = request.form.get('bidder-name', '').strip()
    bid_amount_str = request.form.get('bid-amount', '').strip()
    if not bidder_name:
        flash("Bidder name is required.", "error")
        return redirect(url_for('auction_details', auction_id=auction_id))
    if not bid_amount_str:
        flash("Bid amount is required.", "error")
        return redirect(url_for('auction_details', auction_id=auction_id))
    try:
        bid_amount = float(bid_amount_str)
    except ValueError:
        flash("Invalid bid amount.", "error")
        return redirect(url_for('auction_details', auction_id=auction_id))
    min_bid = max(auction['current_bid'], auction['starting_bid']) + 0.01
    if bid_amount < min_bid:
        flash(f"Bid must be at least ${min_bid:.2f}.", "error")
        return redirect(url_for('auction_details', auction_id=auction_id))
    bids = read_bids()
    new_bid_id = str(max([int(b['bid_id']) for b in bids], default=0) + 1)
    now_str = datetime.datetime.now().strftime('%Y-%m-%d %H:%M')
    new_bid = {
        'bid_id': new_bid_id,
        'auction_id': auction_id,
        'bidder_name': bidder_name,
        'bid_amount': bid_amount,
        'bid_timestamp': now_str
    }
    bids.append(new_bid)
    write_bids(bids)
    # Update auction current bid
    for a in auctions:
        if a['auction_id'] == auction_id:
            a['current_bid'] = bid_amount
            break
    write_auctions(auctions)
    # Update bid history
    history = read_bid_history()
    new_history_id = str(max([int(h['history_id']) for h in history], default=0) + 1)
    new_history = {
        'history_id': new_history_id,
        'auction_id': auction_id,
        'auction_name': auction['item_name'],
        'bidder_name': bidder_name,
        'bid_amount': bid_amount,
        'bid_timestamp': now_str
    }
    history.append(new_history)
    write_bid_history(history)
    flash("Bid placed successfully.", "success")
    return redirect(url_for('auction_details', auction_id=auction_id))
@app.route('/bid_history')
def bid_history():
    bids = read_bids()
    auctions = read_auctions()
    auction_dict = {a['auction_id']: a['item_name'] for a in auctions}
    filter_auction = request.args.get('filter_auction', '').strip()
    sort_by = request.args.get('sort_by', '').strip().lower()
    filtered_bids = bids
    if filter_auction:
        filtered_bids = [b for b in filtered_bids if b['auction_id'] == filter_auction]
    if sort_by == 'amount':
        filtered_bids.sort(key=lambda x: x['bid_amount'], reverse=True)
    else:
        filtered_bids.sort(key=lambda x: x['bid_timestamp'], reverse=True)
    return render_template('bid_history.html',
                           bids=filtered_bids,
                           auction_dict=auction_dict,
                           filter_auction=filter_auction,
                           sort_by=sort_by)
@app.route('/categories')
def categories():
    categories = read_categories()
    auctions = read_auctions()
    # Calculate item counts dynamically
    category_counts = {}
    for c in categories:
        category_counts[c['category_name'].lower()] = 0
    for a in auctions:
        cat = a['category'].lower()
        if cat in category_counts:
            category_counts[cat] += 1
    for c in categories:
        c['item_count'] = category_counts.get(c['category_name'].lower(), 0)
    return render_template('categories.html', categories=categories)
@app.route('/winners')
def winners():
    winners = read_winners()
    filter_winner = request.args.get('filter_winner', '').strip().lower()
    if filter_winner:
        winners = [w for w in winners if filter_winner in w['winner_name'].lower()]
    winners.sort(key=lambda x: x['win_date'], reverse=True)
    return render_template('winners.html', winners=winners, filter_winner=filter_winner)
@app.route('/trending')
def trending():
    trending = read_trending()
    time_range = request.args.get('time_range', 'week').lower()
    filtered_trending = [t for t in trending if t['time_period'].lower() == time_range]
    filtered_trending.sort(key=lambda x: x['trending_rank'])
    return render_template('trending.html', trending_auctions=filtered_trending, selected_time_range=time_range)
@app.route('/status')
def status():
    auctions = read_auctions()
    status_filter = request.args.get('status', 'all').lower()
    if status_filter != 'all':
        filtered_auctions = [a for a in auctions if a['status'].lower() == status_filter]
    else:
        filtered_auctions = auctions
    # Add time_remaining field
    for a in filtered_auctions:
        a['time_remaining'] = time_remaining(a['end_time'])
    filtered_auctions.sort(key=lambda x: x['end_time'])
    return render_template('status.html', auctions=filtered_auctions, status_filter=status_filter)
@app.route('/back_to_dashboard')
def back_to_dashboard():
    return redirect(url_for('dashboard'))
@app.errorhandler(404)
def page_not_found(e):
    return render_template('404.html'), 404
@app.errorhandler(500)
def internal_error(e):
    return render_template('500.html'), 500
if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
