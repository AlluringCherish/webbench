        <input type="text" id="filter-by-winner" name="filter_by_winner" value="{{ filter_winner }}" placeholder="Enter winner name" oninput="filterWinners()">
    </div>
    <div id="winners-list">
        {% if winners %}
            {% for winner in winners %}
                <div class="winner-card" id="winner-card-{{ winner.auction_id }}">
                    <h3>{{ winner.item_name }}</h3>
                    <p><strong>Winner:</strong> {{ winner.winner_name }}</p>
                    <p><strong>Winning Bid:</strong> ${{ '%.2f'|format(winner.winning_bid) }}</p>
                    <p><strong>Win Date:</strong> {{ winner.win_date }}</p>
                </div>
            {% endfor %}
        {% else %}
            <p>No winning items found.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
<script>
function filterWinners() {
    const input = document.getElementById('filter-by-winner');
    const filter = input.value.toLowerCase();
    const winnerCards = document.querySelectorAll('.winner-card');
    winnerCards.forEach(card => {
        const winnerName = card.querySelector('p strong + text, p:nth-child(2)').textContent || card.querySelector('p:nth-child(2)').textContent;
        // The winner name is in the second <p> element, after <strong>Winner:</strong>
        const winnerText = card.querySelector('p:nth-child(2)').textContent.toLowerCase();
        if (winnerText.indexOf(filter) > -1) {
            card.style.display = "";
        } else {
            card.style.display = "none";
        }
    });
}
</script>
</body>
</html>
