            }
            bids.append(bid)
    return bids
def write_bids(bids):
    path = os.path.join(DATA_DIR, 'bids.txt')
    with open(path, 'w', encoding='utf-8') as f:
        for b in bids:
            line = '|'.join([
                b['bid_id'],
                b['auction_id'],
                b['bidder_name'],
                f"{b['bid_amount']:.2f}",
