            }
            trending.append(trend)
    return trending
def read_items():
    items = []
    path = os.path.join(DATA_DIR, 'items.txt')
    if not os.path.exists(path):
        return items
    with open(path, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split('|')
            if len(parts) != 7:
                continue
            item = {
                'item_id': parts[0],
                'auction_id': parts[1],
                'item_name': parts[2],
