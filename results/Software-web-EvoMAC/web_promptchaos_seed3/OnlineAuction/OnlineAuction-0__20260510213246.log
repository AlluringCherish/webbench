        for b in bids:
            line = '|'.join([
                b['bid_id'],
                b['auction_id'],
                b['bidder_name'],
                f"{b['bid_amount']:.2f}",
                b['bid_timestamp']
            ])
            f.write(line + '\n')
def read_bid_history():
