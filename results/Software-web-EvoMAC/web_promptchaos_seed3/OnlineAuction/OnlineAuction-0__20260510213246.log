                continue
            parts = line.split('|')
            if len(parts) != 4:
                continue
            category = {
                'category_id': parts[0],
                'category_name': parts[1],
                'description': parts[2],
                'item_count': int(parts[3])
            }
            categories.append(category)
    return categories
def read_bids():
    path = os.path.join(DATA_DIR, 'bids.txt')
    bids = []
