<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Select Insurance Coverage</title>
    <style>
        #insurance-page {
            max-width: 800px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #insurance-options {
            border: 1px solid #ccc;
            padding: 15px;
