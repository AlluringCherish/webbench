<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Car Rental Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
        }
        #dashboard-page {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        h1 {
            margin-bottom: 20px;
            color: #343a40;
        }
        #featured-vehicles {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        .vehicle-card {
            flex: 1;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            padding: 15px;
            background-color: #ffffff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .vehicle-image {
            width: 100%;
            max-width: 250px;
            height: 140px;
            background-color: #e9ecef;
            border-radius: 4px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            font-size: 14px;
        }
        .vehicle-name {
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 5px;
            color: #212529;
        }
        .vehicle-type {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 8px;
        }
        .vehicle-rate {
            font-size: 16px;
            color: #28a745;
            margin-bottom: 10px;
        }
        .view-details-link {
            margin-top: auto;
            text-decoration: none;
            color: #007bff;
            font-weight: 600;
            border: 1px solid #007bff;
            padding: 6px 12px;
            border-radius: 4px;
            transition: background-color 0.2s ease, color 0.2s ease;
        }
        .view-details-link:hover {
            background-color: #007bff;
            color: white;
        }
        #promotions-section {
            background-color: #fff3cd;
            border: 1px solid #ffeeba;
            border-radius: 6px;
            padding: 15px 20px;
            margin-bottom: 30px;
            color: #856404;
        }
        #promotions-section h2 {
            margin-top: 0;
            margin-bottom: 10px;
        }
        #promotions-list {
            list-style-type: disc;
            padding-left: 20px;
            margin: 0;
        }
        #buttons-container {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-bottom: 10px;
        }
        button {
            background-color: #007bff;
            border: none;
            color: white;
            padding: 12px 25px;
            font-size: 16px;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }
        button:hover {
            background-color: #0056b3;
        }
        @media (max-width: 768px) {
            #featured-vehicles {
                flex-direction: column;
            }
            .vehicle-card {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1>Car Rental Dashboard</h1>

    <div id="featured-vehicles">
        {% if featured_vehicles %}
            {% for vehicle in featured_vehicles %}
            <div class="vehicle-card">
                <div class="vehicle-image" aria-label="Image of {{ vehicle.make }} {{ vehicle.model }}">
                    <!-- Placeholder for vehicle image -->
                    <span>No Image</span>
                </div>
                <div class="vehicle-name">{{ vehicle.make }} {{ vehicle.model }}</div>
                <div class="vehicle-type">{{ vehicle.vehicle_type }}</div>
                <div class="vehicle-rate">${{ "%.2f"|format(vehicle.daily_rate) }} per day</div>
                <a href="{{ url_for('vehicle_details', vehicle_id=vehicle.vehicle_id) }}" class="view-details-link" id="view-details-button-{{ vehicle.vehicle_id }}">View Details</a>
            </div>
            {% endfor %}
        {% else %}
            <p>No featured vehicles available at the moment.</p>
        {% endif %}
    </div>

    <div id="promotions-section">
        <h2>Current Promotions</h2>
        {% if promotions %}
        <ul id="promotions-list">
            {% for promo in promotions %}
            <li>{{ promo }}</li>
            {% endfor %}
        </ul>
        {% else %}
        <p>No promotions available currently.</p>
        {% endif %}
    </div>

    <div id="buttons-container">
        <button id="search-vehicles-button" onclick="location.href='{{ url_for('vehicle_search') }}'">Search Vehicles</button>
        <button id="my-reservations-button" onclick="location.href='{{ url_for('reservations_page') }}'">My Reservations</button>
    </div>
</div>
</body>
</html>
