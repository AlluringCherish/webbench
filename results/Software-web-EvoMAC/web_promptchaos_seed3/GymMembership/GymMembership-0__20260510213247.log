'''
Class Schedule page template.
Displays fitness classes with search and filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Class Schedule</title>
</head>
<body>
    <div id="schedule-page">
        <h1>Class Schedule</h1>
        <input id="schedule-search" type="text" placeholder="Search classes or trainers" value="{{ search }}" oninput="searchClasses(this.value)">
        <select id="schedule-filter" onchange="filterClasses(this.value)">
            <option value="" {% if not filter_type %}selected{% endif %}>All Types</option>
            <option value="Yoga" {% if filter_type == 'Yoga' %}selected{% endif %}>Yoga</option>
            <option value="CrossFit" {% if filter_type == 'CrossFit' %}selected{% endif %}>CrossFit</option>
            <option value="Pilates" {% if filter_type == 'Pilates' %}selected{% endif %}>Pilates</option>
            <option value="Boxing" {% if filter_type == 'Boxing' %}selected{% endif %}>Boxing</option>
        </select>
        <div id="classes-grid">
            {% for c in classes %}
            <div class="class-card">
                <h3>{{ c.class_name }}</h3>
                <p>Type: {{ c.class_type }}</p>
                <p>Schedule: {{ c.schedule_day }} at {{ c.schedule_time }}</p>
                <p>Duration: {{ c.duration }} minutes</p>
                <p>Trainer: {{ trainer_dict.get(c.trainer_id, 'Unknown') }}</p>
                <p>Capacity: {{ c.capacity }}</p>
                <button id="enroll-class-button-{{ c.class_id }}" onclick="alert('Enrolled in {{ c.class_name }}!')">Enroll</button>
            </div>
            {% else %}
            <p>No classes found.</p>
            {% endfor %}
        </div>
        <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
    <script>
        function searchClasses(value) {
            const url = new URL(window.location.href);
            url.searchParams.set('search', value);
            window.location.href = url.toString();
        }
        function filterClasses(value) {
            const url = new URL(window.location.href);
            if(value) {
                url.searchParams.set('filter', value);
            } else {
                url.searchParams.delete('filter');
            }
            window.location.href = url.toString();
        }
    </script>
</body>
</html>
