templates/inquiry.html
```html
'''
Property Inquiry page template.
Allows users to submit inquiries for properties.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Submit Property Inquiry</title>
    <style>
        #inquiry-page { padding: 20px; font-family: Arial, sans-serif; }
        label { display: block; margin-top: 10px; }
        input, select, textarea { width: 300px; padding: 5px; }
        textarea { height: 100px; }
        button { margin-top: 15px; padding: 10px 15px; }
        .error { color: red; }
    </style>
</head>
<body>
<div id="inquiry-page">
    <h1>Submit Property Inquiry</h1>
    {% if error %}
        <p class="error">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ url_for('property_inquiry') }}">
        <label for="select-property">Select Property:</label>
        <select id="select-property" name="select_property" required>
            <option value="">-- Select a Property --</option>
            {% for prop in properties %}
                <option value="{{ prop.property_id }}"
                    {% if form_data and form_data.get('select_property') == prop.property_id %}selected{% endif %}>
                    {{ prop.address }} ({{ prop.location }})
                </option>
            {% endfor %}
        </select>

        <label for="inquiry-name">Name:</label>
        <input type="text" id="inquiry-name" name="inquiry_name" required value="{{ form_data.get('inquiry_name') if form_data else '' }}">

        <label for="inquiry-email">Email:</label>
        <input type="email" id="inquiry-email" name="inquiry_email" required value="{{ form_data.get('inquiry_email') if form_data else '' }}">

        <label for="inquiry-phone">Phone:</label>
        <input type="tel" id="inquiry-phone" name="inquiry_phone" value="{{ form_data.get('inquiry_phone') if form_data else '' }}">

        <label for="inquiry-message">Message:</label>
        <textarea id="inquiry-message" name="inquiry_message" required>{{ form_data.get('inquiry_message') if form_data else '' }}</textarea>

        <button type="submit" id="submit-inquiry-button">Submit Inquiry</button>
        <button type="button" onclick="window.location='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </form>
</div>
</body>
</html>
```

templates/my_inquiries.html
```html
'''
My Inquiries page template.
Displays all submitted inquiries with filtering and deletion options.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Inquiries</title>
    <style>
        #inquiries-page { padding: 20px; font-family: Arial, sans-serif; }
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        select { margin-bottom: 10px; }
        button { padding: 5px 10px; }
        form.inline { display: inline; }
    </style>
</head>
<body>
<div id="inquiries-page">
    <h1>My Inquiries</h1>
    <form method="get" action="{{ url_for('my_inquiries') }}">
        <label for="inquiry-status-filter">Filter by Status:</label>
        <select id="inquiry-status-filter" name="status" onchange="this.form.submit()">
            <option value="All" {% if status_filter == 'All' %}selected{% endif %}>All</option>
            <option value="Pending" {% if status_filter == 'Pending' %}selected{% endif %}>Pending</option>
            <option value="Contacted" {% if status_filter == 'Contacted' %}selected{% endif %}>Contacted</option>
            <option value="Resolved" {% if status_filter == 'Resolved' %}selected{% endif %}>Resolved</option>
        </select>
    </form>

    {% if inquiries %}
        <table id="inquiries-table">
            <thead>
                <tr>
                    <th>Property</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Customer Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Message</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for inq in inquiries %}
                    <tr>
                        <td>{{ properties[inq.property_id].address if inq.property_id in properties else 'Unknown' }}</td>
                        <td>{{ inq.inquiry_date }}</td>
                        <td>{{ inq.status }}</td>
                        <td>{{ inq.customer_name }}</td>
                        <td>{{ inq.customer_email }}</td>
                        <td>{{ inq.customer_phone }}</td>
                        <td>{{ inq.message }}</td>
                        <td>
                            <form method="post" class="inline" action="{{ url_for('my_inquiries', status=status_filter) }}">
                                <input type="hidden" name="delete_inquiry_id" value="{{ inq.inquiry_id }}">
                                <button type="submit" id="delete-inquiry-button-{{ inq.inquiry_id }}" onclick="return confirm('Are you sure you want to delete this inquiry?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No inquiries found.</p>
    {% endif %}

    <button id="back-to-dashboard" onclick="window.location='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

