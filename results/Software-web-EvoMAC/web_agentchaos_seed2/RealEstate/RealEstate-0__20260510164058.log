        self.assertIsNotNone(browse_button, "Button with id 'browse-properties-button' should be present")

        inquiries_button = soup.find('button', id='my-inquiries-button')
        self.assertIsNotNone(inquiries_button, "Button with id 'my-inquiries-button' should be present")

        favorites_button = soup.find('button', id='my-favorites-button')
        self.assertIsNotNone(favorites_button, "Button with id 'my-favorites-button' should be present")

    def test_dashboard_featured_properties_content(self):
        # Test that featured properties shown are available and limited to 3
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        featured_div = soup.find('div', id='featured-properties')
        self.assertIsNotNone(featured_div, "Featured properties div should be present")

        # Check that there are at most 3 featured property entries (assuming each property is in a child div or similar)
        # We look for child elements inside featured-properties div
        children = [child for child in featured_div.find_all(recursive=False) if child.name is not None]
        self.assertLessEqual(len(children), 3, "Featured properties should show at most 3 properties")

