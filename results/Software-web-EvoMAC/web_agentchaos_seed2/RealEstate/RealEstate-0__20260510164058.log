templates/search.html
```html
'''
Property Search page template.
Displays search filters and property cards matching criteria.
'''

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Property Search</title>
    <style>
        #search-page { padding: 20px; font-family: Arial, sans-serif; }
        #properties-grid { margin-top: 20px; }
        .property-card { border: 1px solid #ccc; padding: 10px; margin: 5px; display: inline-block; width: 30%; vertical-align: top; }
        label { display: inline-block; width: 120px; }
        input, select { margin-bottom: 10px; }
        button { padding: 5px 10px; }
    </style>
</head>
<body>
<div id="search-page">
    <h1>Property Search</h1>
    <form method="get" action="{{ url_for('property_search') }}">
        <label for="location-input">Location:</label>
        <input type="text" id="location-input" name="location" value="{{ location_filter }}">
        <br>
        <label for="price-range-min">Min Price:</label>
        <input type="number" id="price-range-min" name="price_min" min="0" value="{{ price_min }}">
        <br>
        <label for="price-range-max">Max Price:</label>
        <input type="number" id="price-range-max" name="price_max" min="0" value="{{ price_max }}">
        <br>
        <label for="property-type-filter">Property Type:</label>
        <select id="property-type-filter" name="property_type">
            <option value="">All</option>
            {% for pt in property_types %}
                <option value="{{ pt }}" {% if pt == property_type_filter %}selected{% endif %}>{{ pt }}</option>
            {% endfor %}
        </select>
        <br>
        <button type="submit">Search</button>
        <button type="button" onclick="window.location='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </form>

    <div id="properties-grid">
        {% if properties %}
            {% for prop in properties %}
                <div class="property-card">
                    <h3>{{ prop.address }}</h3>
                    <p>Location: {{ prop.location }}</p>
                    <p>Price: ${{ "{:,}".format(prop.price) }}</p>
                    <p>{{ prop.bedrooms }} beds, {{ prop.bathrooms }} baths</p>
                    <form action="{{ url_for('property_details', property_id=prop.property_id) }}" method="get">
                        <button type="submit" id="view-property-button-{{ prop.property_id }}">View Details</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No properties found matching your criteria.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
```

