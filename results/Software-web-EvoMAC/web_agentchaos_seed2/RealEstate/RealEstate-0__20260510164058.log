<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Real Estate Dashboard</title>
    <style>
        #dashboard-page { padding: 20px; font-family: Arial, sans-serif; }
        #featured-properties, #recent-listings { margin-bottom: 20px; }
        .property-card { border: 1px solid #ccc; padding: 10px; margin: 5px; display: inline-block; width: 30%; vertical-align: top; }
        button { margin: 5px; padding: 10px 15px; font-size: 16px; }
    </style>
</head>
<body>
<div id="dashboard-page">
    <h1>Real Estate Dashboard</h1>

    <div id="featured-properties">
        <h2>Featured Properties</h2>
        {% if featured_properties %}
            {% for prop in featured_properties %}
                <div class="property-card">
                    <h3>{{ prop.address }}</h3>
                    <p>Location: {{ prop.location }}</p>
                    <p>Price: ${{ "{:,}".format(prop.price) }}</p>
                    <p>{{ prop.bedrooms }} beds, {{ prop.bathrooms }} baths</p>
                    <form action="{{ url_for('property_details', property_id=prop.property_id) }}" method="get">
                        <button type="submit" id="view-property-button-{{ prop.property_id }}">View Details</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No featured properties available.</p>
        {% endif %}
    </div>

    <div id="recent-listings">
        <h2>Recent Listings</h2>
        {% if recent_listings %}
            <ul>
                {% for prop in recent_listings %}
                    <li>{{ prop.address }} - ${{ "{:,}".format(prop.price) }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No recent listings available.</p>
        {% endif %}
    </div>

    <div id="navigation-buttons">
        <form action="{{ url_for('property_search') }}" method="get" style="display:inline;">
            <button type="submit" id="browse-properties-button">Browse Properties</button>
        </form>
        <form action="{{ url_for('my_inquiries') }}" method="get" style="display:inline;">
            <button type="submit" id="my-inquiries-button">My Inquiries</button>
        </form>
        <form action="{{ url_for('my_favorites') }}" method="get" style="display:inline;">
            <button type="submit" id="my-favorites-button">My Favorites</button>
        </form>
    </div>
</div>
</body>
</html>
