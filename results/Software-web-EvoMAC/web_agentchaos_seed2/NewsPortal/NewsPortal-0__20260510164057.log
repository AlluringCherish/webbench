                        </div>
                        <form method="post" action="{{ url_for('remove_bookmark', bookmark_id=bookmark.bookmark_id) }}" style="display:inline;">
                            <button type="submit" id="remove-bookmark-button-{{ bookmark.bookmark_id }}">Remove</button>
                        </form>
                        <button id="read-bookmark-button-{{ bookmark.bookmark_id }}" onclick="location.href='{{ url_for('read_bookmarked_article', bookmark_id=bookmark.bookmark_id) }}'">Read</button>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No bookmarks found.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
