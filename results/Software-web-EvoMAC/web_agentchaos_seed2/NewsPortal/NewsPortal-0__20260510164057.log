        <br><br>
        <label for="comment-text">Comment:</label><br>
        <textarea id="comment-text" name="comment-text" rows="5" cols="50" required>{{ comment_text|default('') }}</textarea>
        <br><br>
        <button type="submit" id="submit-comment-button">Submit Comment</button>
    </form>
    <button onclick="location.href='{{ url_for('comments_page') }}'">Back to Comments</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
