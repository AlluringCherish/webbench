'''
Search Results page template for NewsPortal.
Displays search results based on user query.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Results</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="search-results-page">
    <h1>Search Results</h1>
    <div id="search-query-display">
        {% if search_query %}
            <p>Search query: <strong>{{ search_query }}</strong></p>
        {% else %}
            <p>No search query provided.</p>
        {% endif %}
    </div>
    <div id="results-list">
        {% if results %}
            <ul>
                {% for article in results %}
                    <li>
                        <a href="{{ url_for('article_details', article_id=article.article_id) }}">{{ article.title }}</a>
                        <p>{{ article.content[:150] }}{% if article.content|length > 150 %}...{% endif %}</p>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <div id="no-results-message">
                <p>No results found.</p>
            </div>
        {% endif %}
    </div>
