</head>
<body>
<div id="catalog-page">
    <h1>Article Catalog</h1>
    <form method="get" action="{{ url_for('article_catalog') }}">
        <input type="text" id="search-input" name="search" placeholder="Search articles..." value="{{ search_query }}">
        <select id="category-filter" name="category">
            <option value="All" {% if selected_category == 'All' or not selected_category %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category == category.category_name %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
