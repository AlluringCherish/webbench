                            <div class="thumbnail" style="width:100px; height:60px; background:#ccc; display:inline-block; vertical-align:middle;"></div>
                            <div style="display:inline-block; vertical-align:middle; margin-left:10px;">
                                <h3>{{ article.title }}</h3>
                                <div>By {{ article.author }} | {{ article.date }}</div>
