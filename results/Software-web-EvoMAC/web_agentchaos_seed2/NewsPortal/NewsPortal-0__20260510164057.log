comments.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Article Comments</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="comments-page">
    <h1>Article Comments</h1>
    <form method="get" action="{{ url_for('comments_page') }}">
        <label for="filter-by-article">Filter by Article:</label>
        <select id="filter-by-article" name="article_id" onchange="this.form.submit()">
            <option value="" {% if not selected_article_id %}selected{% endif %}>All Articles</option>
            {% for article in articles %}
                <option value="{{ article.article_id }}" {% if selected_article_id == article.article_id %}selected{% endif %}>{{ article.title }}</option>
            {% endfor %}
        </select>
    </form>
    <div id="comments-list">
        {% if comments %}
            <ul>
                {% for comment in comments %}
                    <li>
                        <div><strong>{{ comment.article_title }}</strong></div>
                        <div><em>{{ comment.commenter_name }}</em> on {{ comment.comment_date }}</div>
                        <div>{{ comment.comment_text }}</div>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No comments found.</p>
        {% endif %}
    </div>
    <button id="write-comment-button" onclick="location.href='{{ url_for('write_comment') }}'">Write a Comment</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
