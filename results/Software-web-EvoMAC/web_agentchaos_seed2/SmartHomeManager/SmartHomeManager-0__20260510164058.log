    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
}
button:hover, input[type="submit"]:hover {
    background-color: #0056b3;
}
button:disabled, button[disabled] {
    background-color: #a0a0a0;
