}
/* Flash Messages */
.flash-message {
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 5px;
    font-weight: 600;
    font-size: 1rem;
}
.flash-message.success {
    background-color: #d1e7dd;
