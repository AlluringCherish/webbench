        <label for="device-name">Device Name</label>
        <input type="text" id="device-name" name="device_name" value="{{ device_name|default('') }}" required>
        <label for="device-type">Device Type</label>
        <select id="device-type" name="device_type" required>
            <option value="" disabled selected>Select device type</option>
            {% for dtype in device_types %}
            <option value="{{ dtype }}" {% if dtype == device_type %}selected{% endif %}>{{ dtype }}</option>
            {% endfor %}
        </select>
        <label for="device-room">Room</label>
        <select id="device-room" name="device_room" required>
            <option value="" disabled selected>Select room</option>
            {% for room in room_names %}
            <option value="{{ room }}" {% if room == device_room %}selected{% endif %}>{{ room }}</option>
            {% endfor %}
        </select>
        <label for="brand">Brand</label>
        <input type="text" id="brand" name="brand" value="{{ brand|default('') }}">
        <label for="model">Model</label>
        <input type="text" id="model" name="model" value="{{ model|default('') }}">
        <button id="submit-device-button" type="submit">Add Device</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
