}
/* Device Control Page Specific */
#device-control-page h2#device-name-display {
    margin-bottom: 10px;
    color: #222;
}
#device-status-display {
    font-weight: 600;
    margin-bottom: 20px;
    padding: 10px 15px;
    border-radius: 4px;
    display: inline-block;
}
#device-status-display.online {
    background-color: #d1e7dd;
    color: #0f5132;
}
#device-status-display.offline {
    background-color: #f8d7da;
    color: #842029;
}
/* Power Toggle Button */
.power-toggle {
    background-color: #198754;
    margin-right: 10px;
}
.power-toggle.off {
    background-color: #dc3545;
}
.power-toggle:hover {
    opacity: 0.9;
}
/* Responsive Design */
@media (max-width: 768px) {
    #device-summary,
    #energy-summary {
        flex-direction: column;
    }
    #device-summary > div,
