    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ page_id }}">
    <h1>{{ page_title }}</h1>
    <table id="device-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Room</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
