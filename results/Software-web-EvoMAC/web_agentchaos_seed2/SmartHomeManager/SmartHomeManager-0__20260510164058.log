    border-radius: 6px;
    flex: 1 1 150px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    text-align: center;
    cursor: default;
    user-select: none;
}
#room-list .room-card h4 {
    margin-bottom: 8px;
    color: #0f5132;
}
#room-list .room-card p {
    font-size: 1.2rem;
    font-weight: 600;
    color: #14532d;
}
/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 25px;
}
th, td {
    padding: 12px 15px;
    border-bottom: 1px solid #ddd;
    text-align: left;
    vertical-align: middle;
}
th {
    background-color: #007bff;
    color: white;
    font-weight: 600;
    user-select: none;
}
tr:hover {
    background-color: #f1f5f9;
}
td button {
    padding: 6px 12px;
    font-size: 0.9rem;
}
/* Form Elements */
input[type="text"],
input[type="number"],
input[type="date"],
select {
    width: 100%;
    padding: 8px 10px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
}
input[type="text"]:focus,
input[type="number"]:focus,
input[type="date"]:focus,
select:focus {
    border-color: #007bff;
    outline: none;
}
/* Form Labels */
label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
    color: #333;
}
/* Flash Messages */
.flash-message {
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 5px;
    font-weight: 600;
    font-size: 1rem;
}
.flash-message.success {
    background-color: #d1e7dd;
    color: #0f5132;
    border: 1px solid #badbcc;
}
.flash-message.error {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
}
/* Device Control Page Specific */
#device-control-page h2#device-name-display {
    margin-bottom: 10px;
    color: #222;
}
#device-status-display {
    font-weight: 600;
    margin-bottom: 20px;
    padding: 10px 15px;
    border-radius: 4px;
    display: inline-block;
}
#device-status-display.online {
    background-color: #d1e7dd;
    color: #0f5132;
}
#device-status-display.offline {
    background-color: #f8d7da;
    color: #842029;
}
/* Power Toggle Button */
.power-toggle {
    background-color: #198754;
    margin-right: 10px;
}
.power-toggle.off {
    background-color: #dc3545;
}
.power-toggle:hover {
    opacity: 0.9;
}
/* Responsive Design */
@media (max-width: 768px) {
    #device-summary,
    #energy-summary {
        flex-direction: column;
    }
    #device-summary > div,
    #energy-summary > div {
        margin: 10px 0;
    }
    #room-list {
        flex-direction: column;
    }
    #room-list .room-card {
        flex: 1 1 100%;
    }
}
```

dashboard.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="{{ page_id }}">
    <h1>{{ page_title }}</h1>
    <!-- Device Summary -->
    <div id="device-summary">
        <div>
            <h3>Total Devices</h3>
            <p>{{ total_devices }}</p>
        </div>
        <div>
            <h3>Active Devices</h3>
            <p>{{ active_devices }}</p>
        </div>
        <div>
            <h3>Offline Devices</h3>
            <p>{{ offline_devices }}</p>
        </div>
    </div>
    <!-- Navigation Buttons -->
    <div>
        <button id="device-list-button" onclick="location.href='{{ url_for('device_list') }}'">Device List</button>
        <button id="add-device-button" onclick="location.href='{{ url_for('add_device') }}'">Add Device</button>
        <button id="automation-button" onclick="location.href='{{ url_for('automation_rules') }}'">Automation Rules</button>
        <button id="energy-button" onclick="location.href='{{ url_for('energy_report') }}'">Energy Report</button>
        <button id="activity-button" onclick="location.href='{{ url_for('activity_logs') }}'">Activity Logs</button>
    </div>
    <!-- Room List -->
    <div id="room-list">
        {% for room_name, count in room_device_counts.items() %}
        <div class="room-card">
            <h4>{{ room_name }}</h4>
            <p>{{ count }} device{{ 's' if count != 1 else '' }}</p>
        </div>
        {% else %}
        <p>No rooms found.</p>
        {% endfor %}
    </div>
</div>
</body>
</html>
