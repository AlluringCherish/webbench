/*
styles.css
Contains all CSS styles for the SmartHomeManager web application to ensure consistent and user-friendly UI design.
*/
/* Reset some default styles */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f6f8;
    color: #333;
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}
a {
    color: #007bff;
    text-decoration: none;
}
a:hover {
    text-decoration: underline;
}
/* Container for all pages */
#dashboard-page,
#device-list-page,
#add-device-page,
#device-control-page,
#automation-page,
#energy-page,
#activity-page {
    max-width: 1100px;
    margin: 20px auto 40px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
/* Page Titles */
h1, h2, h3 {
    margin-bottom: 20px;
    color: #222;
}
/* Buttons */
button, input[type="submit"] {
    background-color: #007bff;
    color: white;
    border: none;
    padding: 10px 18px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
}
button:hover, input[type="submit"]:hover {
    background-color: #0056b3;
}
button:disabled, button[disabled] {
    background-color: #a0a0a0;
    cursor: not-allowed;
}
/* Navigation Buttons */
#device-list-button,
#add-device-button,
#automation-button,
#energy-button,
#activity-button,
#back-to-dashboard,
#back-to-devices,
#apply-filter-button,
#apply-search-button,
#submit-device-button,
#add-rule-button,
.power-toggle,
.save-settings-button {
    margin: 5px 5px 15px 0;
}
/* Summary Boxes */
#device-summary,
#energy-summary {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30px;
}
#device-summary > div,
#energy-summary > div {
    background-color: #e9f0ff;
    padding: 15px 25px;
    border-radius: 6px;
    text-align: center;
    flex: 1;
    margin: 0 10px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
}
#device-summary > div h3,
#energy-summary > div h3 {
    font-size: 1.2rem;
    margin-bottom: 8px;
    color: #004085;
}
#device-summary > div p,
#energy-summary > div p {
    font-size: 1.5rem;
    font-weight: bold;
    color: #002752;
}
/* Room List on Dashboard */
#room-list {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
}
#room-list .room-card {
    background-color: #d1e7dd;
    padding: 15px 20px;
    border-radius: 6px;
    flex: 1 1 150px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    text-align: center;
    cursor: default;
    user-select: none;
}
#room-list .room-card h4 {
    margin-bottom: 8px;
    color: #0f5132;
}
#room-list .room-card p {
    font-size: 1.2rem;
    font-weight: 600;
    color: #14532d;
}
/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 25px;
}
th, td {
    padding: 12px 15px;
    border-bottom: 1px solid #ddd;
    text-align: left;
    vertical-align: middle;
}
th {
    background-color: #007bff;
    color: white;
    font-weight: 600;
    user-select: none;
}
tr:hover {
    background-color: #f1f5f9;
}
td button {
    padding: 6px 12px;
    font-size: 0.9rem;
}
/* Form Elements */
input[type="text"],
input[type="number"],
input[type="date"],
select {
    width: 100%;
    padding: 8px 10px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
}
input[type="text"]:focus,
input[type="number"]:focus,
input[type="date"]:focus,
select:focus {
    border-color: #007bff;
    outline: none;
}
/* Form Labels */
label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
    color: #333;
}
/* Flash Messages */
.flash-message {
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 5px;
    font-weight: 600;
    font-size: 1rem;
}
.flash-message.success {
    background-color: #d1e7dd;
    color: #0f5132;
    border: 1px solid #badbcc;
}
.flash-message.error {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
}
/* Device Control Page Specific */
#device-control-page h2#device-name-display {
    margin-bottom: 10px;
    color: #222;
}
#device-status-display {
    font-weight: 600;
    margin-bottom: 20px;
    padding: 10px 15px;
    border-radius: 4px;
    display: inline-block;
}
#device-status-display.online {
    background-color: #d1e7dd;
    color: #0f5132;
}
#device-status-display.offline {
    background-color: #f8d7da;
    color: #842029;
}
/* Power Toggle Button */
.power-toggle {
    background-color: #198754;
    margin-right: 10px;
}
.power-toggle.off {
    background-color: #dc3545;
}
.power-toggle:hover {
    opacity: 0.9;
}
/* Responsive Design */
@media (max-width: 768px) {
    #device-summary,
    #energy-summary {
        flex-direction: column;
    }
    #device-summary > div,
    #energy-summary > div {
        margin: 10px 0;
    }
    #room-list {
        flex-direction: column;
    }
    #room-list .room-card {
        flex: 1 1 100%;
    }
}
