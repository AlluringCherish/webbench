'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page, verifying the presence and correctness of all specified elements as per the requirements.
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class SmartHomeManagerTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_elements(self):
        # Test Task 2 & 3: Check the Dashboard page loads correctly and contains required elements
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Check page container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' should be present")

        # Check device summary div with id 'device-summary'
        device_summary = soup.find('div', id='device-summary')
        self.assertIsNotNone(device_summary, "Device summary div with id 'device-summary' should be present")

        # Check buttons for navigation with specified ids
        button_ids = [
            'device-list-button',
            'add-device-button',
            'automation-button',
            'energy-button',
            'activity-button'
        ]
        for btn_id in button_ids:
            btn = soup.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Button with id '{btn_id}' should be present on dashboard")

        # Check room list div with id 'room-list'
        room_list = soup.find('div', id='room-list')
        self.assertIsNotNone(room_list, "Room list div with id 'room-list' should be present on dashboard")

        # Check that room list contains at least one room card with class 'room-card'
        room_cards = room_list.find_all(class_='room-card') if room_list else []
        self.assertTrue(len(room_cards) > 0, "Room list should contain at least one room card with class 'room-card'")

    def test_dashboard_device_counts_consistency(self):
        # Additional check: device counts in device-summary should be integers and consistent with room device counts
        response = self.client.get('/')
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Extract counts from device-summary div children
        device_summary = soup.find('div', id='device-summary')
        self.assertIsNotNone(device_summary)
        counts = []
        for div in device_summary.find_all('div', recursive=False):
            p = div.find('p')
            self.assertIsNotNone(p)
            try:
                count = int(p.text.strip())
                counts.append(count)
            except ValueError:
                self.fail("Device summary counts should be integers")

        self.assertEqual(len(counts), 3, "Device summary should show exactly three counts: total, active, offline")
        total, active, offline = counts
        self.assertEqual(total, active + offline, "Total devices count should equal active + offline devices count")

if __name__ == '__main__':
    unittest.main()
