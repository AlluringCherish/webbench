    text-decoration: underline;
}
/* Container for all pages */
#dashboard-page,
#device-list-page,
#add-device-page,
#device-control-page,
#automation-page,
#energy-page,
#activity-page {
    max-width: 1100px;
    margin: 20px auto 40px auto;
    padding: 20px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
