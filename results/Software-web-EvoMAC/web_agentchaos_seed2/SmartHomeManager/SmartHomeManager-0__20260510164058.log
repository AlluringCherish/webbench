}
/* Navigation Buttons */
#device-list-button,
#add-device-button,
#automation-button,
#energy-button,
#activity-button,
#back-to-dashboard,
#back-to-devices,
#apply-filter-button,
#apply-search-button,
#submit-device-button,
#add-rule-button,
.power-toggle,
.save-settings-button {
    margin: 5px 5px 15px 0;
}
/* Summary Boxes */
#device-summary,
#energy-summary {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30px;
}
#device-summary > div,
