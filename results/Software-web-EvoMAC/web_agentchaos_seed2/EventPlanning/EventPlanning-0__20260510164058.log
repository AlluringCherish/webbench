'''
Ticket Booking page template for EventPlanning web application.
Allows users to select event, ticket type, quantity, and enter customer name to book tickets.
Displays booking confirmation on successful booking.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Your Tickets</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
    <div id="ticket-booking-page">
        <h1>Book Your Tickets</h1>
        {% with messages = get_flashed_messages(with_categories=true) %}
          {% if messages %}
            <ul class="flashes">
              {% for category, message in messages %}
                <li class="{{ category }}">{{ message }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endwith %}
        {% if confirmation %}
            <div id="booking-confirmation">
                <h2>Booking Confirmation</h2>
                <p>Booking ID: {{ confirmation.booking_id }}</p>
                <p>Event ID: {{ confirmation.event_id }}</p>
                <p>Customer Name: {{ confirmation.customer_name }}</p>
                <p>Ticket Count: {{ confirmation.ticket_count }}</p>
                <p>Ticket Type: {{ confirmation.ticket_type }}</p>
                <p>Total Amount: ${{ "%.2f"|format(confirmation.total_amount) }}</p>
                <p>Status: {{ confirmation.status }}</p>
                <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
            </div>
        {% else %}
            <form method="post" action="{{ url_for('ticket_booking') }}">
                <label for="select-event-dropdown">Select Event:</label>
                <select id="select-event-dropdown" name="select-event-dropdown" required>
                    <option value="" disabled selected>Select an event</option>
                    {% for event in events %}
                        <option value="{{ event.event_id }}">{{ event.event_name }} - {{ event.date }}</option>
                    {% endfor %}
                </select><br><br>

                <label for="ticket-type-select">Ticket Type:</label>
                <select id="ticket-type-select" name="ticket-type-select" required>
                    <option value="" disabled selected>Select ticket type</option>
                    <option value="General">General</option>
                    <option value="VIP">VIP</option>
                    <option value="Early Bird">Early Bird</option>
                </select><br><br>

                <label for="ticket-quantity-input">Ticket Quantity:</label>
                <input type="number" id="ticket-quantity-input" name="ticket-quantity-input" min="1" required><br><br>

                <label for="customer-name">Customer Name:</label>
                <input type="text" id="customer-name" name="customer-name" required><br><br>

                <button type="submit" id="book-now-button">Book Now</button>
            </form>
            <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        {% endif %}
    </div>
</body>
</html>
