'''
Testing Task 1 and Task 2:
- Test whether the website can be accessed through local port 5000 (Dashboard page).
- Test whether the first page (Dashboard) loads correctly and basic navigation buttons exist.
- Verify presence of key elements on the Dashboard page:
  - ID: dashboard-page (Div container)
  - ID: featured-events (Div container)
  - ID: browse-events-button (Button)
  - ID: view-tickets-button (Button)
  - ID: venues-button (Button)
'''
import unittest
from main import app
from bs4 import BeautifulSoup
class TestDashboardPage(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via GET /
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_elements(self):
        # Test that the dashboard page contains required elements by ID
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Check for div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page must contain div with id 'dashboard-page'")
        # Check for div with id 'featured-events'
        featured_events_div = soup.find('div', id='featured-events')
        self.assertIsNotNone(featured_events_div, "Dashboard page must contain div with id 'featured-events'")
        # Check for button with id 'browse-events-button'
        browse_events_button = soup.find('button', id='browse-events-button')
        self.assertIsNotNone(browse_events_button, "Dashboard page must contain button with id 'browse-events-button'")
        # Check for button with id 'view-tickets-button'
        view_tickets_button = soup.find('button', id='view-tickets-button')
        self.assertIsNotNone(view_tickets_button, "Dashboard page must contain button with id 'view-tickets-button'")
        # Check for button with id 'venues-button'
        venues_button = soup.find('button', id='venues-button')
        self.assertIsNotNone(venues_button, "Dashboard page must contain button with id 'venues-button'")
    def test_dashboard_navigation_buttons(self):
        # Test that navigation buttons have correct links or form actions (if applicable)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')
        # Buttons might be inside forms or have onclick or href attributes
        # Check browse-events-button navigates to /events
        browse_button = soup.find('button', id='browse-events-button')
        self.assertIsNotNone(browse_button)
        # Check if button is inside a form or has onclick or data-href attribute
        # We accept either a form with action or a button with onclick or data-href attribute
        browse_parent_form = browse_button.find_parent('form')
        if browse_parent_form:
            self.assertIn('/events', browse_parent_form.get('action', ''), "Browse Events button form action should be /events")
        else:
            # Check onclick or data-href attribute
            onclick = browse_button.get('onclick', '')
            data_href = browse_button.get('data-href', '')
            self.assertTrue('/events' in onclick or '/events' in data_href, "Browse Events button should navigate to /events")
        # Check view-tickets-button navigates to /book_ticket
        tickets_button = soup.find('button', id='view-tickets-button')
        self.assertIsNotNone(tickets_button)
        tickets_parent_form = tickets_button.find_parent('form')
        if tickets_parent_form:
            self.assertIn('/book_ticket', tickets_parent_form.get('action', ''), "View Tickets button form action should be /book_ticket")
        else:
            onclick = tickets_button.get('onclick', '')
            data_href = tickets_button.get('data-href', '')
            self.assertTrue('/book_ticket' in onclick or '/book_ticket' in data_href, "View Tickets button should navigate to /book_ticket")
        # Check venues-button navigates to /venues
        venues_button = soup.find('button', id='venues-button')
        self.assertIsNotNone(venues_button)
        venues_parent_form = venues_button.find_parent('form')
        if venues_parent_form:
            self.assertIn('/venues', venues_parent_form.get('action', ''), "Venues button form action should be /venues")
        else:
            onclick = venues_button.get('onclick', '')
            data_href = venues_button.get('data-href', '')
            self.assertTrue('/venues' in onclick or '/venues' in data_href, "Venues button should navigate to /venues")
if __name__ == '__main__':
    unittest.main()

