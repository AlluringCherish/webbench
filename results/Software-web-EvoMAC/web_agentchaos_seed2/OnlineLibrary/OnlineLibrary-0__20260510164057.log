}
/* Flash messages */
.flash-message {
    padding: 12px 15px;
    margin-bottom: 20px;
    border-radius: 5px;
    font-weight: 600;
}
.flash-success {
    background-color: #2ecc71;
    color: white;
}
.flash-warning {
    background-color: #f39c12;
    color: white;
}
.flash-danger {
    background-color: #e74c3c;
    color: white;
}
.flash-info {
    background-color: #3498db;
    color: white;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    .book-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
    button {
        font-size: 0.9rem;
        padding: 8px 14px;
    }
    h1#welcome-message {
        font-size: 1.6rem;
    }
}
