'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website (Dashboard) can be accessed after login.
Test whether the first page loads correctly with required elements:
- ID: dashboard-page (Div container)
- ID: welcome-message (H1 with username)
- ID: browse-books-button (Button to navigate to book catalog)
- ID: my-borrows-button (Button to navigate to my borrowings)
Test basic navigation from Dashboard to Book Catalog and My Borrowings pages.
'''
import unittest
from main import app
from flask import url_for
class OnlineLibraryBasicAccessTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
        self.username = 'john_reader'  # From example data
    def login(self):
        # Perform login with valid username
        return self.client.post('/login', data={'username': self.username}, follow_redirects=True)
    def test_access_dashboard_requires_login(self):
        # Access dashboard without login should redirect to login page
        response = self.client.get('/', follow_redirects=False)
        self.assertEqual(response.status_code, 302)
        self.assertIn('/login', response.headers['Location'])
    def test_login_and_access_dashboard(self):
        # Login and access dashboard page
        response = self.login()
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'Welcome, john_reader!', response.data)
        # Check presence of dashboard page container
        self.assertIn(b'id="dashboard-page"', response.data)
        # Check presence of welcome message H1
        self.assertIn(b'id="welcome-message"', response.data)
        # Check presence of browse books button
        self.assertIn(b'id="browse-books-button"', response.data)
        # Check presence of my borrowings button
        self.assertIn(b'id="my-borrows-button"', response.data)
    def test_navigation_from_dashboard_to_catalog(self):
        # Login first
        self.login()
        # Navigate to catalog page via button form submission
        response = self.client.get('/catalog')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'id="catalog-page"', response.data)
    def test_navigation_from_dashboard_to_my_borrowings(self):
        # Login first
        self.login()
        # Navigate to my borrowings page
        response = self.client.get('/my_borrowings')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b'id="my-borrows-page"', response.data)
if __name__ == '__main__':
    unittest.main()

