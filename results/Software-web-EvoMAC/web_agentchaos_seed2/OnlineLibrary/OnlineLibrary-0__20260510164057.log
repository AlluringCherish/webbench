}
.flash-danger {
    background-color: #e74c3c;
    color: white;
}
.flash-info {
    background-color: #3498db;
    color: white;
}
/* Responsive adjustments */
@media (max-width: 600px) {
    .book-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
    button {
        font-size: 0.9rem;
        padding: 8px 14px;
    }
    h1#welcome-message {
        font-size: 1.6rem;
    }
}
