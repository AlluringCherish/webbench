}
/* Responsive adjustments */
@media (max-width: 768px) {
    .vehicle-cards, #vehicles-grid {
        flex-direction: column;
        grid-template-columns: 1fr;
    }
    nav button {
        margin-bottom: 10px;
        width: 100%;
    }
}
