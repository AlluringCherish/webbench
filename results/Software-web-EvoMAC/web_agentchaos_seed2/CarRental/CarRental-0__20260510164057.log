}
/* Special Requests checkboxes */
#driver-assistance-checkbox,
#gps-option-checkbox {
    margin-right: 8px;
}
/* Messages */
.flash-message {
    padding: 12px 15px;
    margin-bottom: 20px;
    border-radius: 6px;
    font-weight: bold;
}
.flash-message.success {
    background-color: #2ecc71;
