<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Vehicles</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <script>
        // Simple script to set date range input placeholder and format
        function setDateRangePlaceholder() {
            const input = document.getElementById('date-range-input');
            input.placeholder = "YYYY-MM-DD to YYYY-MM-DD";
        }
        window.onload = setDateRangePlaceholder;
    </script>
</head>
<body>
<div id="search-page">
    <h1>Search Vehicles</h1>
    <form method="get" action="{{ url_for('vehicle_search') }}">
        <label for="location-filter">Pickup Location:</label>
        <select id="location-filter" name="location_filter">
            <option value="">-- All Locations --</option>
            {% for loc in locations %}
                <option value="{{ loc }}" {% if loc == location_filter %}selected{% endif %}>{{ loc }}</option>
            {% endfor %}
        </select>
        <label for="vehicle-type-filter">Vehicle Type:</label>
        <select id="vehicle-type-filter" name="vehicle_type_filter">
            <option value="">-- All Types --</option>
            {% for vt in vehicle_types %}
                <option value="{{ vt }}" {% if vt == vehicle_type_filter %}selected{% endif %}>{{ vt }}</option>
            {% endfor %}
        </select>
        <label for="date-range-input">Rental Date Range:</label>
        <input type="text" id="date-range-input" name="date_range_input" value="{{ date_range_input }}" placeholder="YYYY-MM-DD to YYYY-MM-DD" autocomplete="off">
        <button type="submit">Search</button>
        <button type="button" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </form>
    <div id="vehicles-grid">
        {% if vehicles %}
            {% for vehicle in vehicles %}
                <div class="vehicle-card">
                    <h3>{{ vehicle.make }} {{ vehicle.model }}</h3>
                    <p>Type: {{ vehicle.vehicle_type }}</p>
                    <p>Seats: {{ vehicle.seats }}</p>
                    <p>Transmission: {{ vehicle.transmission }}</p>
                    <p>Fuel: {{ vehicle.fuel_type }}</p>
                    <p>Daily Rate: ${{ "%.2f"|format(vehicle.daily_rate) }}</p>
                    <a href="{{ url_for('vehicle_details', vehicle_id=vehicle.vehicle_id) }}">
                        <button id="view-details-button-{{ vehicle.vehicle_id }}">View Details</button>
                    </a>
                </div>
            {% endfor %}
        {% else %}
            <p>No vehicles found matching your criteria.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
