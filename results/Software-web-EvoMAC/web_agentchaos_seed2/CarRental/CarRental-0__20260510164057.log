'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided in the Task.
Test the elements and integrity of the Dashboard page including presence and correctness of all specified elements as per the requirements.
'''
import unittest
from app import app
from bs4 import BeautifulSoup

class CarRentalDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test Task 1: Access the root URL and check status code
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")

    def test_dashboard_page_elements(self):
        # Test Task 2 & 3: Check page title and main elements presence and correctness
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        html = response.data.decode('utf-8')
        soup = BeautifulSoup(html, 'html.parser')

        # Check page container div with id dashboard-page
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' should be present")

        # Check page title in <title> tag
        title_tag = soup.find('title')
        self.assertIsNotNone(title_tag, "Page should have a <title> tag")
        self.assertEqual(title_tag.text.strip(), "Car Rental Dashboard", "Page title should be 'Car Rental Dashboard'")

        # Check featured vehicles section
        featured_section = soup.find('section', id='featured-vehicles')
        self.assertIsNotNone(featured_section, "Featured vehicles section with id 'featured-vehicles' should be present")
        # There should be at least one featured vehicle card if example data is present
        vehicle_cards = featured_section.find_all('div', class_='vehicle-card')
        self.assertTrue(len(vehicle_cards) > 0, "There should be at least one featured vehicle card")

        # Check each vehicle card has required info and button with correct id
        for card in vehicle_cards:
            # Check vehicle name h3
            h3 = card.find('h3')
            self.assertIsNotNone(h3, "Vehicle card should have an h3 with vehicle make and model")
            # Check vehicle type and daily rate paragraphs
            p_tags = card.find_all('p')
            self.assertTrue(any('Type:' in p.text for p in p_tags), "Vehicle card should display vehicle type")
            self.assertTrue(any('Daily Rate:' in p.text for p in p_tags), "Vehicle card should display daily rate")
            # Check view details button with correct id pattern
            button = card.find('button')
            self.assertIsNotNone(button, "Vehicle card should have a 'View Details' button")
            self.assertTrue(button['id'].startswith('view-details-button-'), "View Details button id should start with 'view-details-button-'")

        # Check promotions section
        promotions_section = soup.find('section', id='promotions-section')
        self.assertIsNotNone(promotions_section, "Promotions section with id 'promotions-section' should be present")
        promo_list_items = promotions_section.find_all('li')
        self.assertTrue(len(promo_list_items) >= 1, "Promotions section should list at least one promotion")

        # Check navigation buttons presence and correct ids
        nav = soup.find('nav')
        self.assertIsNotNone(nav, "Navigation section should be present")
        search_button = nav.find('button', id='search-vehicles-button')
        self.assertIsNotNone(search_button, "Search Vehicles button with id 'search-vehicles-button' should be present")
        reservations_button = nav.find('button', id='my-reservations-button')
        self.assertIsNotNone(reservations_button, "My Reservations button with id 'my-reservations-button' should be present")

        # Check other navigation buttons exist (Rental History, Special Requests, Locations)
        nav_buttons_texts = [btn.text.strip() for btn in nav.find_all('button')]
        self.assertIn('Rental History', nav_buttons_texts, "Navigation should include 'Rental History' button")
        self.assertIn('Special Requests', nav_buttons_texts, "Navigation should include 'Special Requests' button")
        self.assertIn('Locations', nav_buttons_texts, "Navigation should include 'Locations' button")

if __name__ == '__main__':
    unittest.main()
