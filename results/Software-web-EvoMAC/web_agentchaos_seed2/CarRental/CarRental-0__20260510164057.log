    text-decoration: underline;
}
button {
    background-color: #2980b9;
    color: white;
    border: none;
    padding: 10px 16px;
    margin: 5px 0;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
