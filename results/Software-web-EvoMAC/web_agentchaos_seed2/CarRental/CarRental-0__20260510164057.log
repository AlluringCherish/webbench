}
tr:nth-child(even) {
    background-color: #f9f9f9;
}
/* Dropdowns and filters */
#location-filter,
#vehicle-type-filter,
#date-range-input,
#status-filter,
#hours-filter,
#search-location-input,
#select-reservation {
    max-width: 300px;
}
/* Radio buttons for insurance */
#insurance-options {
    margin-top: 15px;
}
.insurance-plan {
    border: 1px solid #bdc3c7;
    border-radius: 6px;
    padding: 12px 15px;
