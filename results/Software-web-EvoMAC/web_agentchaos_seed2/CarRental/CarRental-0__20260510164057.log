    cursor: pointer;
    transition: border-color 0.3s ease;
    display: flex;
    align-items: center;
}
.insurance-plan:hover {
    border-color: #2980b9;
}
.insurance-plan input[type="radio"] {
    margin-right: 15px;
    transform: scale(1.2);
}
/* Special Requests checkboxes */
#driver-assistance-checkbox,
#gps-option-checkbox {
    margin-right: 8px;
}
/* Messages */
.flash-message {
    padding: 12px 15px;
    margin-bottom: 20px;
    border-radius: 6px;
    font-weight: bold;
}
.flash-message.success {
    background-color: #2ecc71;
    color: white;
}
.flash-message.error {
    background-color: #e74c3c;
    color: white;
}
/* Responsive adjustments */
@media (max-width: 768px) {
    .vehicle-cards, #vehicles-grid {
        flex-direction: column;
        grid-template-columns: 1fr;
    }
    nav button {
        margin-bottom: 10px;
        width: 100%;
    }
}
