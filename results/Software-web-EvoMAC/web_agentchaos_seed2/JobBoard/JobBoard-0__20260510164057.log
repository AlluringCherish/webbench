            margin: 5px 0;
        }
        a.resume-link {
            color: #007BFF;
            text-decoration: none;
        }
        a.resume-link:hover {
            text-decoration: underline;
        }
        button {
            margin-top: 20px;
            padding: 8px 15px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #6c757d;
            background-color: #6c757d;
            color: white;
