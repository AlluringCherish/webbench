    </div>
    <div id="company-jobs">
        <h2>Open Jobs</h2>
        <div id="jobs-list">
            {% if company_jobs %}
                {% for job in company_jobs %}
                    <div class="job-card">
                        <div class="job-title">{{ job.title }}</div>
                        <div class="job-status">Posted on {{ job.posted_date }}</div>
                        <form action="{{ url_for('job_details', job_id=job.job_id) }}" method="get">
                            <button type="submit" id="view-job-button-{{ job.job_id }}">View Details</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No open jobs available for this company.</p>
            {% endif %}
        </div>
    </div>
    <button id="back-to-companies" onclick="location.href='{{ url_for('companies_directory') }}'">Back to Companies Directory</button>
</div>
</body>
</html>
```

templates/resume_management.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Resumes</title>
    <style>
        #resume-page {
            max-width: 800px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #resumes-list {
            margin-top: 20px;
        }
        .resume-card {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .resume-info {
            max-width: 70%;
        }
        .resume-info p {
            margin: 3px 0;
        }
        button {
            padding: 6px 12px;
            font-size: 0.9em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #dc3545;
            background-color: #dc3545;
            color: white;
        }
        button:hover {
            background-color: #c82333;
            border-color: #bd2130;
        }
        #upload-resume-button {
            margin-top: 15px;
            padding: 10px 20px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 5px;
            border: 1px solid #007BFF;
            background-color: #007BFF;
            color: white;
        }
        #upload-resume-button:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }
        #back-to-dashboard {
            margin-top: 20px;
            padding: 8px 15px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #6c757d;
            background-color: #6c757d;
            color: white;
        }
        #back-to-dashboard:hover {
            background-color: #5a6268;
            border-color: #5a6268;
        }
        #resume-upload-form {
            margin-top: 20px;
            border: 1px solid #ccc;
            padding: 15px;
            border-radius: 5px;
            max-width: 600px;
        }
        #resume-upload-form label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
        }
        #resume-upload-form input[type="text"],
        #resume-upload-form input[type="email"],
        #resume-upload-form textarea {
            width: 100%;
            padding: 8px;
            font-size: 1em;
            margin-top: 5px;
            border-radius: 4px;
            border: 1px solid #ccc;
            resize: vertical;
        }
        #resume-upload-form textarea {
            min-height: 80px;
        }
        #resume-file-input {
            display: none;
        }
        #select-file-label {
            margin-top: 10px;
            display: inline-block;
            padding: 8px 15px;
            background-color: #007BFF;
            color: white;
            border-radius: 4px;
            cursor: pointer;
        }
        #select-file-label:hover {
            background-color: #0056b3;
        }
        #submit-upload-button {
            margin-top: 15px;
            padding: 10px 20px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 5px;
            border: 1px solid #28a745;
            background-color: #28a745;
            color: white;
        }
        #submit-upload-button:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }
        .flash-message {
            color: red;
            margin-top: 10px;
        }
        h1 {
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
    <script>
        function triggerFileInput() {
            document.getElementById('resume-file-input').click();
        }
        function updateFileName() {
            var input = document.getElementById('resume-file-input');
            var label = document.getElementById('file-name-label');
            if (input.files.length > 0) {
                label.textContent = input.files[0].name;
            } else {
                label.textContent = "No file selected";
            }
        }
    </script>
</head>
<body>
<div id="resume-page">
    <h1>My Resumes</h1>
    {% with messages = get_flashed_messages() %}
      {% if messages %}
        <div class="flash-message">
          {% for message in messages %}
            <p>{{ message }}</p>
          {% endfor %}
        </div>
      {% endif %}
    {% endwith %}
    <div id="resumes-list">
        {% if resumes %}
            {% for resume in resumes %}
                <div class="resume-card">
                    <div class="resume-info">
                        <p><strong>Name:</strong> {{ resume.applicant_name }}</p>
                        <p><strong>Email:</strong> {{ resume.applicant_email }}</p>
                        <p><strong>Filename:</strong> <a href="{{ url_for('uploaded_file', filename=resume.filename) }}" target="_blank">{{ resume.filename }}</a></p>
                        <p><strong>Upload Date:</strong> {{ resume.upload_date }}</p>
                        <p><strong>Summary:</strong> {{ resume.summary }}</p>
                    </div>
                    <form action="{{ url_for('delete_resume', resume_id=resume.resume_id) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this resume?');">
                        <button type="submit" id="delete-resume-button-{{ resume.resume_id }}">Delete</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No resumes uploaded yet.</p>
        {% endif %}
    </div>
    <form id="resume-upload-form" method="post" enctype="multipart/form-data">
        <label for="applicant-name">Applicant Name:</label>
        <input type="text" id="applicant-name" name="applicant-name" required>

        <label for="applicant-email">Applicant Email:</label>
        <input type="email" id="applicant-email" name="applicant-email" required>

        <label for="summary">Summary:</label>
        <textarea id="summary" name="summary" placeholder="Brief summary or description"></textarea>

        <label id="select-file-label" for="resume-file-input" onclick="triggerFileInput()">Select Resume File</label>
        <span id="file-name-label" style="margin-left:10px;">No file selected</span>
        <input type="file" id="resume-file-input" name="resume-file-input" accept=".pdf,.doc,.docx" onchange="updateFileName()" required>

        <button type="submit" id="upload-resume-button">Upload Resume</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/search_results.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Results</title>
    <style>
        #search-results-page {
            max-width: 900px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #search-query-display {
            font-size: 1.2em;
            margin-bottom: 20px;
        }
        #results-tabs {
            display: flex;
            margin-bottom: 15px;
            border-bottom: 2px solid #007BFF;
        }
        .tab {
            padding: 10px 20px;
            cursor: pointer;
            border: 1px solid #007BFF;
            border-bottom: none;
            border-radius: 5px 5px 0 0;
            margin-right: 5px;
            background-color: #f0f8ff;
            font-weight: bold;
        }
        .tab.active {
            background-color: white;
            color: #007BFF;
            border-bottom: 2px solid white;
        }
        #job-results, #company-results {
            border: 1px solid #007BFF;
            padding: 15px;
            border-radius: 0 5px 5px 5px;
            background-color: white;
        }
        .result-card {
            border: 1px solid #ccc;
            padding: 12px;
            margin-bottom: 10px;
            border-radius: 5px;
        }
        .job-title, .company-name {
            font-weight: bold;
            font-size: 1.1em;
        }
        .job-company, .company-industry {
            color: #555;
        }
        button {
            margin-top: 8px;
            padding: 6px 12px;
            font-size: 0.9em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #007BFF;
            background-color: #007BFF;
            color: white;
        }
        button:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }
        #no-results-message {
            font-style: italic;
            color: #666;
        }
        #back-to-dashboard {
            margin-top: 20px;
            padding: 8px 15px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #6c757d;
            background-color: #6c757d;
            color: white;
        }
        #back-to-dashboard:hover {
            background-color: #5a6268;
            border-color: #5a6268;
        }
        h1 {
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
    <script>
        function showTab(tabName) {
            var jobResults = document.getElementById('job-results');
            var companyResults = document.getElementById('company-results');
            var jobTab = document.getElementById('tab-jobs');
            var companyTab = document.getElementById('tab-companies');
            if (tabName === 'jobs') {
                jobResults.style.display = 'block';
                companyResults.style.display = 'none';
                jobTab.classList.add('active');
                companyTab.classList.remove('active');
            } else {
                jobResults.style.display = 'none';
                companyResults.style.display = 'block';
                jobTab.classList.remove('active');
                companyTab.classList.add('active');
            }
        }
        window.onload = function() {
            showTab('jobs');
        };
    </script>
</head>
<body>
<div id="search-results-page">
    <h1>Search Results</h1>
    <div id="search-query-display">Search query: "{{ query }}"</div>
    <div id="results-tabs">
        <div class="tab active" id="tab-jobs" onclick="showTab('jobs')">Jobs ({{ job_results|length }})</div>
        <div class="tab" id="tab-companies" onclick="showTab('companies')">Companies ({{ company_results|length }})</div>
    </div>
    {% if no_results %}
        <div id="no-results-message">No results found for your search.</div>
    {% else %}
        <div id="job-results">
            {% if job_results %}
                {% for job in job_results %}
                    <div class="result-card">
                        <div class="job-title">{{ job.title }}</div>
                        <div class="job-company">{{ job.location }}</div>
                        <div>Salary: ${{ job.salary_min }} - ${{ job.salary_max }}</div>
                        <form action="{{ url_for('job_details', job_id=job.job_id) }}" method="get" style="margin-top: 8px;">
                            <button type="submit" id="view-job-button-{{ job.job_id }}">View Details</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No job results found.</p>
            {% endif %}
        </div>
        <div id="company-results" style="display:none;">
            {% if company_results %}
                {% for company in company_results %}
                    <div class="result-card">
                        <div class="company-name">{{ company.company_name }}</div>
                        <div class="company-industry">{{ company.industry }} - {{ company.location }}</div>
                        <form action="{{ url_for('company_profile', company_id=company.company_id) }}" method="get" style="margin-top: 8px;">
                            <button type="submit" id="view-company-button-{{ company.company_id }}">View Profile</button>
                        </form>
                    </div>
                {% endfor %}
            {% else %}
                <p>No company results found.</p>
            {% endif %}
        </div>
    {% endif %}
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```
