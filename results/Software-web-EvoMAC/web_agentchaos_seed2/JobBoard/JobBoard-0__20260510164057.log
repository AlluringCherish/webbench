            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #007BFF;
            background-color: #007BFF;
            color: white;
        }
        button:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }
        #back-to-dashboard {
            margin-top: 20px;
            padding: 8px 15px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #6c757d;
            background-color: #6c757d;
            color: white;
        }
        #back-to-dashboard:hover {
            background-color: #5a6268;
