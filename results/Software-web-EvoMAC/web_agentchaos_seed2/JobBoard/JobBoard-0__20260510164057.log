<div id="tracking-page">
    <h1>My Applications</h1>
    <form method="get" action="{{ url_for('application_tracking') }}">
        <label for="status-filter">Filter by Status:</label>
        <select id="status-filter" name="status" onchange="this.form.submit()">
            <option value="All" {% if selected_status == 'All' %}selected{% endif %}>All</option>
            <option value="Applied" {% if selected_status == 'Applied' %}selected{% endif %}>Applied</option>
            <option value="Under Review" {% if selected_status == 'Under Review' %}selected{% endif %}>Under Review</option>
            <option value="Interview" {% if selected_status == 'Interview' %}selected{% endif %}>Interview</option>
            <option value="Rejected" {% if selected_status == 'Rejected' %}selected{% endif %}>Rejected</option>
        </select>
    </form>
    <table id="applications-table">
        <thead>
            <tr>
                <th>Job Title</th>
                <th>Company</th>
                <th>Status</th>
                <th>Date Applied</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            {% if applications %}
                {% for app in applications %}
                    <tr>
                        <td>{{ app.job_title }}</td>
                        <td>{{ app.company_name }}</td>
                        <td>{{ app.status }}</td>
                        <td>{{ app.applied_date }}</td>
                        <td>
                            <form action="{{ url_for('application_details', application_id=app.application_id) }}" method="get">
                                <button type="submit" id="view-application-button-{{ app.application_id }}">View</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="5" style="text-align:center;">No applications found.</td>
                </tr>
            {% endif %}
        </tbody>
    </table>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

