<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Job Board Dashboard</title>
    <style>
        #dashboard-page {
            max-width: 900px;
            margin: 20px auto;
            font-family: Arial, sans-serif;
        }
        #featured-jobs {
            margin-bottom: 30px;
        }
        .job-card {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
        }
        .job-title {
            font-weight: bold;
            font-size: 1.2em;
        }
        .job-company {
            color: #555;
        }
        button {
            margin-right: 10px;
            padding: 10px 15px;
            font-size: 1em;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #007BFF;
            background-color: #007BFF;
            color: white;
        }
        button:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }
        h1 {
            text-align: center;
            margin-bottom: 30px;
