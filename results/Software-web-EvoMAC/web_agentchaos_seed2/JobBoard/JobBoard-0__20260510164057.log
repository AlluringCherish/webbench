        <label for="cover-letter">Cover Letter:</label>
        <textarea id="cover-letter" name="cover-letter" placeholder="Write your cover letter here..."></textarea>
        <button type="submit" id="submit-application-button">Submit Application</button>
    </form>
    <button id="back-to-job-details" onclick="location.href='{{ url_for('job_details', job_id=job.job_id) }}'">Back to Job Details</button>
</div>
</body>
</html>
