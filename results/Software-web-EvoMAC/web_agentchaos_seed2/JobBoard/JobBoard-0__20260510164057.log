<body>
<div id="listings-page">
    <h1>Job Listings</h1>
    <form method="get" action="{{ url_for('job_listings') }}">
        <input type="text" id="search-input" name="search" placeholder="Search jobs..." value="{{ search_query }}">
        <select id="category-filter" name="category">
            <option value="All" {% if selected_category == 'All' or selected_category == '' %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
                <option value="{{ category.category_name }}" {% if selected_category == category.category_name %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <select id="location-filter" name="location">
            <option value="All" {% if selected_location == 'All' or selected_location == '' %}selected{% endif %}>All Locations</option>
            <option value="Remote" {% if selected_location == 'Remote' %}selected{% endif %}>Remote</option>
            <option value="On-site" {% if selected_location == 'On-site' %}selected{% endif %}>On-site</option>
            <option value="Hybrid" {% if selected_location == 'Hybrid' %}selected{% endif %}>Hybrid</option>
        </select>
        <button type="submit">Filter</button>
    </form>
    <div id="jobs-grid">
        {% if jobs %}
            {% for job in jobs %}
                <div class="job-card">
                    <div class="job-title">{{ job.title }}</div>
                    <div class="job-company">{{ job.company_name }} - {{ job.location }}</div>
                    <div>Salary: ${{ job.salary_min }} - ${{ job.salary_max }}</div>
                    <form action="{{ url_for('job_details', job_id=job.job_id) }}" method="get" style="margin-top: 8px;">
                        <button type="submit" id="view-job-button-{{ job.job_id }}">View Details</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No jobs found matching your criteria.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
