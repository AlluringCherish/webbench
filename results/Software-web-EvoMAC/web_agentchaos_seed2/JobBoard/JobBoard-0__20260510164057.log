    <script>
        function triggerFileInput() {
            document.getElementById('resume-file-input').click();
        }
        function updateFileName() {
            var input = document.getElementById('resume-file-input');
            var label = document.getElementById('file-name-label');
            if (input.files.length > 0) {
                label.textContent = input.files[0].name;
            } else {
                label.textContent = "No file selected";
            }
        }
    </script>
</head>
<body>
<div id="resume-page">
    <h1>My Resumes</h1>
    {% with messages = get_flashed_messages() %}
      {% if messages %}
        <div class="flash-message">
          {% for message in messages %}
            <p>{{ message }}</p>
          {% endfor %}
        </div>
      {% endif %}
    {% endwith %}
    <div id="resumes-list">
        {% if resumes %}
            {% for resume in resumes %}
                <div class="resume-card">
                    <div class="resume-info">
                        <p><strong>Name:</strong> {{ resume.applicant_name }}</p>
                        <p><strong>Email:</strong> {{ resume.applicant_email }}</p>
                        <p><strong>Filename:</strong> <a href="{{ url_for('uploaded_file', filename=resume.filename) }}" target="_blank">{{ resume.filename }}</a></p>
                        <p><strong>Upload Date:</strong> {{ resume.upload_date }}</p>
                        <p><strong>Summary:</strong> {{ resume.summary }}</p>
                    </div>
                    <form action="{{ url_for('delete_resume', resume_id=resume.resume_id) }}" method="post" onsubmit="return confirm('Are you sure you want to delete this resume?');">
                        <button type="submit" id="delete-resume-button-{{ resume.resume_id }}">Delete</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No resumes uploaded yet.</p>
        {% endif %}
    </div>
    <form id="resume-upload-form" method="post" enctype="multipart/form-data">
        <label for="applicant-name">Applicant Name:</label>
        <input type="text" id="applicant-name" name="applicant-name" required>
        <label for="applicant-email">Applicant Email:</label>
        <input type="email" id="applicant-email" name="applicant-email" required>
        <label for="summary">Summary:</label>
        <textarea id="summary" name="summary" placeholder="Brief summary or description"></textarea>
        <label id="select-file-label" for="resume-file-input" onclick="triggerFileInput()">Select Resume File</label>
        <span id="file-name-label" style="margin-left:10px;">No file selected</span>
        <input type="file" id="resume-file-input" name="resume-file-input" accept=".pdf,.doc,.docx" onchange="updateFileName()" required>
        <button type="submit" id="upload-resume-button">Upload Resume</button>
    </form>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
