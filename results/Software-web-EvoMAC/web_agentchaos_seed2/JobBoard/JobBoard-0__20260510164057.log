</head>
<body>
<div id="companies-page">
    <h1>Company Directory</h1>
    <form method="get" action="{{ url_for('companies_directory') }}">
        <input type="text" id="search-company-input" name="search" placeholder="Search companies..." value="{{ search_query }}">
        <button type="submit">Search</button>
    </form>
    <div id="companies-list">
        {% if companies %}
            {% for company in companies %}
                <div class="company-card">
                    <div class="company-name">{{ company.company_name }}</div>
                    <div class="company-info">{{ company.industry }} - {{ company.employee_count }} employees</div>
                    <form action="{{ url_for('company_profile', company_id=company.company_id) }}" method="get">
                        <button type="submit" id="view-company-button-{{ company.company_id }}">View Profile</button>
                    </form>
                </div>
            {% endfor %}
        {% else %}
            <p>No companies found matching your criteria.</p>
        {% endif %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
