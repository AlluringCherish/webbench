    </style>
    <script>
        function changeView() {
            const view = document.getElementById('calendar-view').value;
            const url = new URL(window.location.href);
            url.searchParams.set('view', view);
            window.location.href = url.toString();
        }
        // For simplicity, this calendar shows scheduled articles by publish_date grouped by day.
        // A real calendar would be more interactive.
    </script>
</head>
<body>
<div id="calendar-page">
    <h1>Content Calendar</h1>
    <label for="calendar-view">View:</label>
    <select id="calendar-view" onchange="changeView()">
        <option value="month" {% if calendar_view == 'month' %}selected{% endif %}>Month</option>
        <option value="week" {% if calendar_view == 'week' %}selected{% endif %}>Week</option>
    </select>
    <div id="calendar-grid">
        {% set days = [] %}
        {% if calendar_view == 'month' %}
            {% set days = range(1, 32) %}
        {% elif calendar_view == 'week' %}
            {% set days = range(1, 8) %}
        {% endif %}
        {% for day in days %}
            <div class="calendar-day">
                <div class="calendar-day-header">Day {{ day }}</div>
                {% for article in articles %}
                    {% if article.publish_date and article.publish_date.startswith('2024-01-') %}
                        {% set pub_day = article.publish_date[8:10]|int %}
                        {% if pub_day == day %}
                            <div class="scheduled-article" title="{{ article.title }}">{{ article.title }}</div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>
        {% endfor %}
    </div>
    <button id="schedule-button" onclick="alert('Schedule functionality not implemented yet.')">Schedule</button>
    <button id="back-to-dashboard-calendar" onclick="window.location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
