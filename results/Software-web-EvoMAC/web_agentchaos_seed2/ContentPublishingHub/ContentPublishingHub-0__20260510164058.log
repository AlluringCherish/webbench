<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Published Articles - ContentPublishingHub</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        #published-articles-page { max-width: 1000px; margin: auto; }
        label { font-weight: bold; }
        #filter-published-category, #sort-published {
            margin-left: 10px; padding: 5px; margin-right: 20px;
        }
        #published-articles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .article-card {
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 15px;
            background: #fafafa;
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        .article-image {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 3px;
            margin-bottom: 10px;
        }
        .article-title {
            font-weight: bold;
            font-size: 1.1em;
            margin-bottom: 5px;
            color: #007bff;
            text-decoration: none;
        }
        .article-meta {
            font-size: 0.9em;
            color: #555;
            margin-bottom: 10px;
        }
        .article-description {
            flex-grow: 1;
            font-size: 0.95em;
            margin-bottom: 10px;
        }
        #back-to-dashboard-published {
            margin-top: 20px;
            padding: 10px 20px;
            font-size: 1em;
            cursor: pointer;
            background-color: #6c757d;
            color: white;
            border: none;
        }
    </style>
    <script>
        function filterOrSortChanged() {
            const category = document.getElementById('filter-published-category').value;
            const sort = document.getElementById('sort-published').value;
            const url = new URL(window.location.href);
            if (category) {
                url.searchParams.set('category', category);
            } else {
                url.searchParams.delete('category');
            }
            if (sort) {
                url.searchParams.set('sort', sort);
            } else {
                url.searchParams.delete('sort');
            }
            window.location.href = url.toString();
        }
    </script>
</head>
<body>
<div id="published-articles-page">
    <h1>Published Articles</h1>
    <label for="filter-published-category">Filter by category:</label>
    <select id="filter-published-category" onchange="filterOrSortChanged()">
        <option value="" {% if not filter_category %}selected{% endif %}>All</option>
        <option value="news" {% if filter_category == 'news' %}selected{% endif %}>News</option>
        <option value="blog" {% if filter_category == 'blog' %}selected{% endif %}>Blog</option>
        <option value="tutorial" {% if filter_category == 'tutorial' %}selected{% endif %}>Tutorial</option>
        <option value="announcement" {% if filter_category == 'announcement' %}selected{% endif %}>Announcement</option>
        <option value="press_release" {% if filter_category == 'press_release' %}selected{% endif %}>Press Release</option>
    </select>

    <label for="sort-published">Sort by:</label>
    <select id="sort-published" onchange="filterOrSortChanged()">
        <option value="publish_date" {% if sort_by == 'publish_date' %}selected{% endif %}>Publish Date</option>
        <option value="title" {% if sort_by == 'title' %}selected{% endif %}>Title</option>
    </select>

    <div id="published-articles-grid">
        {% if articles %}
            {% for article in articles %}
            <div class="article-card">
                {% if article.featured_image %}
                    <img src="{{ article.featured_image }}" alt="Featured Image" class="article-image">
                {% else %}
                    <div class="article-image" style="background-color:#ddd; display:flex; align-items:center; justify-content:center; color:#666;">No Image</div>
                {% endif %}
                <a href="{{ url_for('article_analytics', article_id=article.article_id) }}" class="article-title">{{ article.title }}</a>
                <div class="article-meta">Category: {{ article.category }} | Published: {{ article.publish_date }}</div>
                <div class="article-description">{{ article.meta_description }}</div>
            </div>
            {% endfor %}
        {% else %}
            <p>No published articles found.</p>
        {% endif %}
    </div>

    <button id="back-to-dashboard-published" onclick="window.location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
