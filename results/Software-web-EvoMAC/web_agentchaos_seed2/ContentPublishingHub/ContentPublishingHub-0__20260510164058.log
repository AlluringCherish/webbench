            background-color: #007bff;
            color: white;
            padding: 3px 5px;
            border-radius: 3px;
            margin-bottom: 3px;
            font-size: 0.85em;
            cursor: default;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
