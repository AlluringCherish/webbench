            margin-top: 20px;
            padding: 10px 20px;
            font-size: 1em;
            cursor: pointer;
            margin-right: 10px;
        }
        #schedule-button { background-color: #28a745; color: white; border: none; }
        #back-to-dashboard-calendar { background-color: #6c757d; color: white; border: none; }
    </style>
    <script>
        function changeView() {
            const view = document.getElementById('calendar-view').value;
            const url = new URL(window.location.href);
            url.searchParams.set('view', view);
            window.location.href = url.toString();
        }
        // For simplicity, this calendar shows scheduled articles by publish_date grouped by day.
        // A real calendar would be more interactive.
    </script>
</head>
<body>
<div id="calendar-page">
    <h1>Content Calendar</h1>
    <label for="calendar-view">View:</label>
