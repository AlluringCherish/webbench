            margin-bottom: 10px;
        }
        .article-title {
            font-weight: bold;
            font-size: 1.1em;
            margin-bottom: 5px;
            color: #007bff;
            text-decoration: none;
        }
        .article-meta {
            font-size: 0.9em;
            color: #555;
            margin-bottom: 10px;
        }
        .article-description {
            flex-grow: 1;
            font-size: 0.95em;
            margin-bottom: 10px;
        }
        #back-to-dashboard-published {
            margin-top: 20px;
            padding: 10px 20px;
            font-size: 1em;
            cursor: pointer;
            background-color: #6c757d;
            color: white;
            border: none;
        }
    </style>
    <script>
        function filterOrSortChanged() {
            const category = document.getElementById('filter-published-category').value;
            const sort = document.getElementById('sort-published').value;
            const url = new URL(window.location.href);
            if (category) {
                url.searchParams.set('category', category);
            } else {
                url.searchParams.delete('category');
            }
            if (sort) {
                url.searchParams.set('sort', sort);
            } else {
                url.searchParams.delete('sort');
            }
            window.location.href = url.toString();
        }
    </script>
