"test_requirement_0.py:
'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page (/dashboard) including:
- Presence of page container with id 'dashboard-page'
- Presence of welcome message with id 'welcome-message' containing username/fullname
- Presence of quick stats section with id 'quick-stats' and correct status counts
- Presence of Create Article button with id 'create-article-button'
- Presence of recent activity feed with id 'recent-activity' and correct activity items
'''
import unittest
from app import app
from bs4 import BeautifulSoup
class ContentPublishingHubDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_server_running_and_dashboard_accessible(self):
        # Test if the root redirects to /dashboard and /dashboard loads successfully
        response_root = self.client.get('/')
        self.assertEqual(response_root.status_code, 302)
        self.assertIn('/dashboard', response_root.headers['Location'])
        response_dashboard = self.client.get('/dashboard')
        self.assertEqual(response_dashboard.status_code, 200)
        self.assertIn(b'ContentPublishingHub', response_dashboard.data)
    def test_dashboard_page_elements(self):
        response = self.client.get('/dashboard')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check page container
        dashboard_page = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_page, "Dashboard page container with id 'dashboard-page' not found")
        # Check welcome message
        welcome_message = soup.find(id='welcome-message')
        self.assertIsNotNone(welcome_message, "Welcome message with id 'welcome-message' not found")
        self.assertTrue(len(welcome_message.text.strip()) > 0, "Welcome message is empty")
        # Check quick stats section
        quick_stats = soup.find(id='quick-stats')
        self.assertIsNotNone(quick_stats, "Quick stats section with id 'quick-stats' not found")
        # Check presence of all status categories in quick stats
        expected_statuses = ['Draft', 'Pending Review', 'Under Review', 'Approved', 'Published', 'Rejected', 'Archived']
        quick_stats_text = quick_stats.get_text()
        for status in expected_statuses:
            self.assertIn(status, quick_stats_text, f"Status '{status}' not found in quick stats")
        # Check Create Article button
        create_article_button = soup.find(id='create-article-button')
        self.assertIsNotNone(create_article_button, "Create Article button with id 'create-article-button' not found")
        self.assertEqual(create_article_button.name, 'button', "Create Article element is not a button")
        self.assertIn('Create Article', create_article_button.text)
        # Check recent activity feed
        recent_activity = soup.find(id='recent-activity')
        self.assertIsNotNone(recent_activity, "Recent activity feed with id 'recent-activity' not found")
        # It should have a heading
        heading = recent_activity.find('h3')
        self.assertIsNotNone(heading, "Recent activity feed missing heading")
        self.assertIn('Recent Activity', heading.text)
        # Check at least the container for activity items exists
        activity_items = recent_activity.find_all(class_='activity-item')
        # It can be empty if no recent activity, but container must exist
        self.assertIsNotNone(activity_items, "No activity items container found in recent activity feed")
if __name__ == '__main__':
    unittest.main()

