<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Article Analytics - ContentPublishingHub</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        #analytics-page { max-width: 700px; margin: auto; }
        #analytics-overview { background: #f0f0f0; padding: 20px; border-radius: 5px; }
        #analytics-overview div { margin-bottom: 10px; font-size: 1.1em; }
        #back-to-article-analytics {
            margin-top: 20px; padding: 10px 20px; font-size: 1em; cursor: pointer;
            background-color: #6c757d; color: white; border: none;
        }
    </style>
</head>
<body>
<div id="analytics-page">
    <h1>Analytics for Article: {{ article.title }}</h1>
    <div id="analytics-overview">
        <div id="analytics-total-views">Total Views: {{ total_views }}</div>
        <div id="analytics-unique-visitors">Unique Visitors: {{ unique_visitors }}</div>
        <div id="analytics-avg-time">Average Time Spent (seconds): {{ avg_time_seconds }}</div>
