        a { color: #007bff; text-decoration: none; }
        a:hover { text-decoration: underline; }
    </style>
    <script>
        function filterStatusChanged() {
            const status = document.getElementById('filter-article-status').value;
            const url = new URL(window.location.href);
            if (status) {
                url.searchParams.set('status', status);
            } else {
                url.searchParams.delete('status');
            }
            window.location.href = url.toString();
        }
    </script>
</head>
<body>
<div id="my-articles-page">
    <h1>My Articles</h1>
    <label for="filter-article-status">Filter by status:</label>
    <select id="filter-article-status" onchange="filterStatusChanged()">
        <option value="" {% if not filter_status %}selected{% endif %}>All</option>
        <option value="draft" {% if filter_status == 'draft' %}selected{% endif %}>Draft</option>
        <option value="pending_review" {% if filter_status == 'pending_review' %}selected{% endif %}>Pending Review</option>
        <option value="under_review" {% if filter_status == 'under_review' %}selected{% endif %}>Under Review</option>
        <option value="approved" {% if filter_status == 'approved' %}selected{% endif %}>Approved</option>
        <option value="published" {% if filter_status == 'published' %}selected{% endif %}>Published</option>
        <option value="rejected" {% if filter_status == 'rejected' %}selected{% endif %}>Rejected</option>
        <option value="archived" {% if filter_status == 'archived' %}selected{% endif %}>Archived</option>
    </select>

    <table id="articles-table">
        <thead>
            <tr>
                <th>Article ID</th>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Publish Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if articles %}
                {% for article in articles %}
                <tr>
                    <td>{{ article.article_id }}</td>
                    <td><a href="{{ url_for('edit_article', article_id=article.article_id) }}">{{ article.title }}</a></td>
                    <td>{{ article.category }}</td>
                    <td>{{ article.status }}</td>
                    <td>{{ article.created_date }}</td>
                    <td>{{ article.publish_date if article.publish_date else '-' }}</td>
                    <td>
                        <a href="{{ url_for('edit_article', article_id=article.article_id) }}">Edit</a> |
                        <a href="{{ url_for('version_history', article_id=article.article_id) }}">Versions</a> |
                        <a href="{{ url_for('article_analytics', article_id=article.article_id) }}">Analytics</a>
                    </td>
                </tr>
                {% endfor %}
            {% else %}
                <tr><td colspan="7">No articles found.</td></tr>
            {% endif %}
        </tbody>
    </table>

    <button id="create-new-article" onclick="window.location.href='{{ url_for('create_article') }}'">Create New Article</button>
    <button id="back-to-dashboard" onclick="window.location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

templates/published_articles.html
