            parts = line.split('|')
            if len(parts) != 5:
                continue
            cart_item = {
                'cart_id': parts[0],
                'item_id': parts[1],
                'restaurant_id': parts[2],
                'quantity': int(parts[3]),
                'added_date': parts[4]
            }
