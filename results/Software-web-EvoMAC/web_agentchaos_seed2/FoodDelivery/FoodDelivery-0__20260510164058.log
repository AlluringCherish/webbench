            max-width: 700px;
            margin: auto;
            font-family: Arial, sans-serif;
        }
        #order-details, #delivery-driver-info, #order-items-list {
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 15px;
            border-radius: 5px;
        }
        #order-items-list ul {
            list-style-type: none;
            padding-left: 0;
        }
        #order-items-list li {
            margin-bottom: 5px;
        }
        #estimated-time {
            font-weight: bold;
            margin-bottom: 15px;
        }
        #back-to-orders {
            padding: 10px 15px;
            cursor: pointer;
        }
        .timeline {
            margin-bottom: 15px;
        }
        .timeline span {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 15px;
            background-color: #ddd;
            margin-right: 5px;
        }
        .timeline .current {
            background-color: #4CAF50;
            color: white;
        }
    </style>
</head>
<body>
<div id="tracking-page">
    <h1>Track Order #{{ order.order_id }}</h1>
    <div id="order-details">
        <h3>Order Details</h3>
        <div><strong>Restaurant:</strong> {{ restaurant.name if restaurant else 'Unknown' }}</div>
        <div><strong>Status:</strong> {{ order.status }}</div>
        <div class="timeline">
            {% for step in timeline %}
                {% if step == order.status %}
                    <span class="current">{{ step }}</span>
                {% else %}
                    <span>{{ step }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
    <div id="delivery-driver-info">
        <h3>Delivery Driver Info</h3>
        {% if delivery %}
            <div><strong>Name:</strong> {{ delivery.driver_name }}</div>
            <div><strong>Phone:</strong> {{ delivery.driver_phone }}</div>
            <div><strong>Vehicle:</strong> {{ delivery.vehicle_info }}</div>
            <div id="estimated-time"><strong>Estimated Delivery Time:</strong> {{ delivery.estimated_time }}</div>
        {% else %}
            <p>No delivery information available.</p>
        {% endif %}
    </div>
    <div id="order-items-list">
        <h3>Order Items</h3>
        {% if order_items %}
            <ul>
                {% for item in order_items %}
                    <li>{{ item.item_name }} - Quantity: {{ item.quantity }} - Price: ${{ "%.2f"|format(item.price) }}</li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No items found for this order.</p>
        {% endif %}
    </div>
    <button id="back-to-orders" onclick="location.href='{{ url_for('active_orders_page') }}'">Back to Active Orders</button>
</div>
</body>
</html>
```

reviews.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order Reviews</title>
    <style>
        #reviews-page {
            max-width: 900px;
            margin: auto;
            font-family: Arial, sans-serif;
        }
        #reviews-list {
            margin-top: 20px;
        }
        .review-card {
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 5px;
        }
        .review-card h4 {
            margin: 0 0 5px 0;
        }
        #filter-by-rating {
            margin-bottom: 15px;
            padding: 5px;
        }
        #write-review-button, #back-to-dashboard {
            margin-top: 15px;
            padding: 10px 15px;
            cursor: pointer;
        }
    </style>
</head>
<body>
<div id="reviews-page">
    <h1>Order Reviews</h1>
    <form method="get" action="{{ url_for('reviews_page') }}">
        <label for="filter-by-rating">Filter by Rating:</label>
        <select id="filter-by-rating" name="rating" onchange="this.form.submit()">
            {% for option in ratings_options %}
                <option value="{{ option }}" {% if option == selected_rating %}selected{% endif %}>{{ option }}</option>
            {% endfor %}
        </select>
    </form>
    <div id="reviews-list">
        {% if reviews %}
            {% for review in reviews %}
                <div class="review-card">
                    <h4>{{ review.restaurant_name }} - {{ review.rating }} Stars</h4>
                    <div><strong>By:</strong> {{ review.customer_name }} on {{ review.review_date }}</div>
                    <p>{{ review.review_text }}</p>
                </div>
            {% endfor %}
        {% else %}
            <p>No reviews found.</p>
        {% endif %}
    </div>
    <button id="write-review-button" onclick="location.href='{{ url_for('write_review_page') }}'">Write a Review</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

write_review.html
```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Write Review</title>
    <style>
        #write-review-page {
            max-width: 600px;
            margin: auto;
            font-family: Arial, sans-serif;
        }
        label {
            display: block;
            margin-top: 15px;
            margin-bottom: 5px;
        }
        select, input[type="text"], textarea {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }
        textarea {
            resize: vertical;
            height: 100px;
        }
        button {
            margin-top: 20px;
            padding: 10px 15px;
            cursor: pointer;
        }
        .error-list {
            color: red;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
<div id="write-review-page">
    <h1>Write a Review</h1>
    {% if errors %}
        <div class="error-list">
            <ul>
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    <form method="post" action="{{ url_for('write_review_page') }}">
        <label for="restaurant_id">Select Restaurant:</label>
        <select id="restaurant_id" name="restaurant_id" required>
            <option value="">-- Select --</option>
            {% for r in restaurants %}
                <option value="{{ r.restaurant_id }}" {% if form_data.restaurant_id == r.restaurant_id %}selected{% endif %}>{{ r.name }}</option>
            {% endfor %}
        </select>
        <label for="customer_name">Your Name:</label>
        <input type="text" id="customer_name" name="customer_name" value="{{ form_data.customer_name or '' }}" required>
        <label for="rating">Rating:</label>
        <select id="rating" name="rating" required>
            <option value="">-- Select --</option>
            {% for i in range(1,6) %}
                <option value="{{ i }}" {% if form_data.rating == i|string %}selected{% endif %}>{{ i }}</option>
            {% endfor %}
        </select>
        <label for="review_text">Review:</label>
        <textarea id="review_text" name="review_text" required>{{ form_data.review_text or '' }}</textarea>
        <button type="submit">Submit Review</button>
    </form>
</div>
</body>
</html>
```

