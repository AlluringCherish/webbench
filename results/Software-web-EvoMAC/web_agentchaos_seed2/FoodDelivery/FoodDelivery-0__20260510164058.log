        items = ul.find_all('li')
        self.assertTrue(len(items) > 0, "Popular cuisines list should have at least one cuisine")

    def test_dashboard_navigation_buttons_functionality(self):
        # Test that navigation buttons have correct href links
        response = self.client.get('/')
