                    <div><strong>By:</strong> {{ review.customer_name }} on {{ review.review_date }}</div>
                    <p>{{ review.review_text }}</p>
                </div>
            {% endfor %}
        {% else %}
            <p>No reviews found.</p>
        {% endif %}
    </div>
    <button id="write-review-button" onclick="location.href='{{ url_for('write_review_page') }}'">Write a Review</button>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
