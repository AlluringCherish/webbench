            margin: auto;
            font-family: Arial, sans-serif;
        }
        #restaurants-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(250px,1fr));
            gap: 15px;
        }
        .restaurant-card {
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 5px;
        }
        .restaurant-card h3 {
            margin: 0 0 5px 0;
        }
        button {
            margin-top: 10px;
            padding: 7px 12px;
            cursor: pointer;
        }
        #filters {
            margin-bottom: 20px;
        }
