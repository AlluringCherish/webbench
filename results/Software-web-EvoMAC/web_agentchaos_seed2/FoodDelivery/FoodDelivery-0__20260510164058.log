'''
Test whether the website can be accessed through local port 5000.
Test whether the first page of the website loads correctly and whether basic navigation works based on the example data provided.
Test the elements and integrity of the Dashboard page as it is the first page and main hub.
'''
import unittest
from app import app
from bs4 import BeautifulSoup
class FoodDeliveryDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible via '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200, "Dashboard page should be accessible with status code 200")
    def test_dashboard_page_title(self):
        # Test that the page title is correct
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        title = soup.title.string.strip()
        self.assertEqual(title, "Food Delivery Dashboard", "Dashboard page title should be 'Food Delivery Dashboard'")
    def test_dashboard_elements_presence(self):
        # Test presence of main container and key elements by ID
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' should be present")
        featured_div = soup.find(id='featured-restaurants')
        self.assertIsNotNone(featured_div, "Featured restaurants div with id 'featured-restaurants' should be present")
        browse_btn = soup.find(id='browse-restaurants-button')
        self.assertIsNotNone(browse_btn, "Browse Restaurants button with id 'browse-restaurants-button' should be present")
        self.assertEqual(browse_btn.name, 'button', "Browse Restaurants element should be a button")
        cart_btn = soup.find(id='view-cart-button')
        self.assertIsNotNone(cart_btn, "View Cart button with id 'view-cart-button' should be present")
        self.assertEqual(cart_btn.name, 'button', "View Cart element should be a button")
        active_orders_btn = soup.find(id='active-orders-button')
        self.assertIsNotNone(active_orders_btn, "Active Orders button with id 'active-orders-button' should be present")
        self.assertEqual(active_orders_btn.name, 'button', "Active Orders element should be a button")
    def test_dashboard_featured_restaurants_content(self):
        # Test that featured restaurants are displayed and contain expected fields
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        featured_div = soup.find(id='featured-restaurants')
        restaurant_cards = featured_div.find_all(class_='restaurant-card')
        self.assertTrue(len(restaurant_cards) > 0, "There should be at least one featured restaurant displayed")
        for card in restaurant_cards:
            text = card.get_text()
            self.assertRegex(text, r'.+', "Restaurant card should contain text")
            self.assertRegex(text, r'Rating:', "Restaurant card should display rating")
            self.assertRegex(text, r'Delivery Time:', "Restaurant card should display delivery time")
    def test_dashboard_popular_cuisines_content(self):
        # Test that popular cuisines list is present and has list items
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        popular_div = soup.find(id='popular-cuisines')
        ul = popular_div.find('ul')
        self.assertIsNotNone(ul, "Popular cuisines should have a <ul> list")
        items = ul.find_all('li')
        self.assertTrue(len(items) > 0, "Popular cuisines list should have at least one cuisine")
    def test_dashboard_navigation_buttons_functionality(self):
        # Test that navigation buttons have correct href links
        response = self.client.get('/')
        soup = BeautifulSoup(response.data, 'html.parser')
        browse_btn = soup.find(id='browse-restaurants-button')
        self.assertIn('/restaurants', browse_btn['onclick'], "Browse Restaurants button should navigate to /restaurants")
        cart_btn = soup.find(id='view-cart-button')
        self.assertIn('/cart', cart_btn['onclick'], "View Cart button should navigate to /cart")
        active_orders_btn = soup.find(id='active-orders-button')
        self.assertIn('/active_orders', active_orders_btn['onclick'], "Active Orders button should navigate to /active_orders")
if __name__ == '__main__':
    unittest.main()

