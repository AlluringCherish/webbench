        select {
            padding: 5px;
        }
    </style>
</head>
<body>
<div id="restaurants-page">
    <h1>Browse Restaurants</h1>
    <form method="get" action="{{ url_for('restaurants_page') }}" id="filters">
        <label for="search-input">Search:</label>
        <input type="text" id="search-input" name="search" value="{{ search_query }}" placeholder="Name or cuisine">
        <label for="cuisine-filter">Cuisine:</label>
        <select id="cuisine-filter" name="cuisine">
            <option value="All" {% if selected_cuisine == 'All' or selected_cuisine == '' %}selected{% endif %}>All</option>
            {% for cuisine in cuisines %}
                <option value="{{ cuisine }}" {% if cuisine == selected_cuisine %}selected{% endif %}>{{ cuisine }}</option>
            {% endfor %}
        </select>
        <button type="submit">Filter</button>
    </form>
    <div id="restaurants-grid">
        {% if restaurants %}
            {% for r in restaurants %}
                <div class="restaurant-card">
                    <h3>{{ r.name }}</h3>
                    <div>Cuisine: {{ r.cuisine }}</div>
                    <div>Rating: {{ r.rating }}</div>
                    <div>Delivery Time: {{ r.delivery_time }} mins</div>
                    <button id="view-restaurant-button-{{ r.restaurant_id }}" onclick="location.href='{{ url_for('menu_page', restaurant_id=r.restaurant_id) }}'">View Menu</button>
                </div>
            {% endfor %}
        {% else %}
            <p>No restaurants found.</p>
        {% endif %}
    </div>
</div>
</body>
</html>
