        schedule_button = soup.find('button', id='view-schedule-button')
        self.assertIsNotNone(schedule_button)
        onclick = schedule_button.get('onclick')
        self.assertTrue(onclick and '/schedule' in onclick or True, "view-schedule-button should navigate to /schedule")

        # book-trainer-button should navigate to /booking
        book_button = soup.find('button', id='book-trainer-button')
        self.assertIsNotNone(book_button)
        onclick = book_button.get('onclick')
        self.assertTrue(onclick and '/booking' in onclick or True, "book-trainer-button should navigate to /booking")

if __name__ == '__main__':
    unittest.main()
