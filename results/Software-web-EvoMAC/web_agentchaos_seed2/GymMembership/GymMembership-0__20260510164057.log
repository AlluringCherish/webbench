templates/booking.html
```html
'''
PT Booking page template.
Form to schedule personal training sessions.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Personal Training</title>
</head>
<body>
<div id="booking-page">
    <h1>Book Personal Training</h1>
    <form method="post" action="{{ url_for('booking') }}">
        <label for="member_name">Your Name:</label>
        <input type="text" id="member_name" name="member_name" required><br><br>

        <label for="select-trainer">Select Trainer:</label>
        <select id="select-trainer" name="select_trainer" required>
            {% for trainer in trainers %}
            <option value="{{ trainer.trainer_id }}">{{ trainer.name }} - {{ trainer.specialty }}</option>
            {% endfor %}
        </select><br><br>

        <label for="session-date">Session Date:</label>
        <input type="date" id="session-date" name="session_date" required><br><br>

        <label for="session-time">Session Time:</label>
        <select id="session-time" name="session_time" required>
            {% for time in time_slots %}
            <option value="{{ time }}">{{ time }}</option>
            {% endfor %}
        </select><br><br>

        <label for="session-duration">Session Duration (minutes):</label>
        <select id="session-duration" name="session_duration" required>
            {% for dur in durations %}
            <option value="{{ dur }}">{{ dur }}</option>
            {% endfor %}
        </select><br><br>

        <button id="confirm-booking-button" type="submit">Confirm Booking</button>
    </form>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

