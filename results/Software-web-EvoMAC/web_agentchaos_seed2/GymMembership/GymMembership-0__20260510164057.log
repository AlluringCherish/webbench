<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trainer Profiles</title>
</head>
<body>
<div id="trainers-page">
    <h1>Trainer Profiles</h1>
    <input id="trainer-search" type="text" placeholder="Search trainers by name or specialty" value="{{ search_query }}" onkeypress="if(event.key === 'Enter'){searchTrainers();}">
    <select id="specialty-filter" onchange="filterSpecialty()">
        <option value="">All Specialties</option>
        <option value="Strength" {% if filter_specialty == 'Strength' %}selected{% endif %}>Strength</option>
        <option value="Cardio" {% if filter_specialty == 'Cardio' %}selected{% endif %}>Cardio</option>
        <option value="Flexibility" {% if filter_specialty == 'Flexibility' %}selected{% endif %}>Flexibility</option>
        <option value="Weight Loss" {% if filter_specialty == 'Weight Loss' %}selected{% endif %}>Weight Loss</option>
    </select>
    <div id="trainers-grid">
        {% for trainer in trainers %}
        <div class="trainer-card">
            <p><strong>{{ trainer.name }}</strong></p>
            <p>Specialty: {{ trainer.specialty }}</p>
            <button id="view-trainer-button-{{ trainer.trainer_id }}" onclick="location.href='{{ url_for('trainer_detail', trainer_id=trainer.trainer_id) }}'">View Profile</button>
        </div>
        {% endfor %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
<script>
function searchTrainers() {
    var search = document.getElementById('trainer-search').value;
    var filter = document.getElementById('specialty-filter').value;
    var url = '{{ url_for("trainers") }}?search=' + encodeURIComponent(search);
    if(filter) {
        url += '&filter=' + encodeURIComponent(filter);
    }
    window.location.href = url;
}
function filterSpecialty() {
    var filter = document.getElementById('specialty-filter').value;
    var search = document.getElementById('trainer-search').value;
    var url = '{{ url_for("trainers") }}';
    var params = [];
    if(search) params.push('search=' + encodeURIComponent(search));
    if(filter) params.push('filter=' + encodeURIComponent(filter));
    if(params.length > 0) url += '?' + params.join('&');
    window.location.href = url;
}
</script>
</body>
</html>
