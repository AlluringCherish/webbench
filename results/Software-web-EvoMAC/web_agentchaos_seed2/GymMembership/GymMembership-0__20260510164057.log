        <label for="member_name">Your Name:</label>
        <input type="text" id="member_name" name="member_name" required><br><br>

        <label for="workout-type">Workout Type:</label>
        <select id="workout-type" name="workout_type" required>
            {% for wt in workout_types %}
            <option value="{{ wt }}">{{ wt }}</option>
            {% endfor %}
        </select><br><br>

        <label for="workout-duration">Duration (minutes):</label>
        <input id="workout-duration" name="workout_duration" type="number" min="1" required><br><br>

        <label for="calories-burned">Calories Burned:</label>
        <input id="calories-burned" name="calories_burned" type="number" min="0" required><br><br>

        <label for="workout-notes">Notes:</label><br>
        <textarea id="workout-notes" name="workout_notes" rows="4" cols="50"></textarea><br><br>

        <button id="submit-workout-button" type="submit">Submit Workout Record</button>
    </form>
    <button onclick="location.href='{{ url_for('workouts') }}'">Back to Workout Records</button>
</div>
</body>
</html>
