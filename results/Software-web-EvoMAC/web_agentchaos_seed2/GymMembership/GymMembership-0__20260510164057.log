'''
Dashboard page template for GymMembership.
Includes navigation buttons using backend routes.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Gym Membership Dashboard</title>
</head>
<body>
<div id="dashboard-page">
    <div id="member-welcome">
        <h2>{{ member_status }}</h2>
    </div>
    <div>
        <button id="browse-membership-button" onclick="location.href='{{ url_for('memberships') }}'">Browse Memberships</button>
        <button id="view-schedule-button" onclick="location.href='{{ url_for('schedule') }}'">View Class Schedule</button>
        <button id="book-trainer-button" onclick="location.href='{{ url_for('booking') }}'">Book Personal Trainer</button>
        <button id="view-trainers-button" onclick="location.href='{{ url_for('trainers') }}'">View Trainers</button>
        <button id="view-workouts-button" onclick="location.href='{{ url_for('workouts') }}'">My Workout Records</button>
    </div>
    <hr>
    <h3>Featured Class</h3>
    {% if featured_class %}
    <div>
        <strong>{{ featured_class.class_name }}</strong> on {{ featured_class.schedule_day }} at {{ featured_class.schedule_time }}
    </div>
    {% else %}
    <div>No featured class available.</div>
    {% endif %}
    <h3>Featured Trainer</h3>
    {% if featured_trainer %}
    <div>
        <strong>{{ featured_trainer.name }}</strong> - {{ featured_trainer.specialty }}
    </div>
    {% else %}
    <div>No featured trainer available.</div>
    {% endif %}
</div>
</body>
</html>
