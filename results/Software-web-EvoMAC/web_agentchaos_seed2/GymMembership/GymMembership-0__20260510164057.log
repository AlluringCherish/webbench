templates/schedule.html
```html
'''
Class Schedule page template.
Includes search and filter, displays classes with enroll buttons.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Class Schedule</title>
</head>
<body>
<div id="schedule-page">
    <h1>Class Schedule</h1>
    <input id="schedule-search" type="text" placeholder="Search classes or trainers" value="{{ search_query }}" onkeypress="if(event.key === 'Enter'){searchClasses();}">
    <select id="schedule-filter" onchange="filterClasses()">
        <option value="">All Types</option>
        <option value="Yoga" {% if filter_type == 'Yoga' %}selected{% endif %}>Yoga</option>
        <option value="CrossFit" {% if filter_type == 'CrossFit' %}selected{% endif %}>CrossFit</option>
        <option value="Pilates" {% if filter_type == 'Pilates' %}selected{% endif %}>Pilates</option>
        <option value="Boxing" {% if filter_type == 'Boxing' %}selected{% endif %}>Boxing</option>
    </select>
    <div id="classes-grid">
        {% for cls in classes %}
        <div class="class-card">
            <h3>{{ cls.class_name }}</h3>
            <p>Type: {{ cls.class_type }}</p>
            <p>Schedule: {{ cls.schedule_day }} at {{ cls.schedule_time }} ({{ cls.duration }} mins)</p>
            <p>Trainer: {{ cls.trainer_name }}</p>
            <p>Capacity: {{ cls.capacity }}</p>
            <button id="enroll-class-button-{{ cls.class_id }}" onclick="alert('Enrolled in {{ cls.class_name }}!')">Enroll</button>
        </div>
        {% endfor %}
    </div>
    <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
<script>
function searchClasses() {
    var search = document.getElementById('schedule-search').value;
    var filter = document.getElementById('schedule-filter').value;
    var url = '{{ url_for("schedule") }}?search=' + encodeURIComponent(search);
    if(filter) {
        url += '&filter=' + encodeURIComponent(filter);
    }
    window.location.href = url;
}
function filterClasses() {
    var filter = document.getElementById('schedule-filter').value;
    var search = document.getElementById('schedule-search').value;
    var url = '{{ url_for("schedule") }}';
    var params = [];
    if(search) params.push('search=' + encodeURIComponent(search));
    if(filter) params.push('filter=' + encodeURIComponent(filter));
    if(params.length > 0) url += '?' + params.join('&');
    window.location.href = url;
}
</script>
</body>
</html>
```

