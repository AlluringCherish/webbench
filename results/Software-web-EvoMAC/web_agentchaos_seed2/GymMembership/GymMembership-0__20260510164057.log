'''
Membership Plans page template.
Includes filter dropdown and navigation buttons using backend routes.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Membership Plans</title>
</head>
<body>
<div id="membership-page">
    <h1>Membership Plans</h1>
    <label for="plan-filter">Filter by Membership Type:</label>
    <select id="plan-filter" onchange="filterPlans()">
        <option value="">All</option>
        <option value="Basic" {% if filter_type == 'Basic' %}selected{% endif %}>Basic</option>
        <option value="Premium" {% if filter_type == 'Premium' %}selected{% endif %}>Premium</option>
        <option value="Elite" {% if filter_type == 'Elite' %}selected{% endif %}>Elite</option>
    </select>
    <div id="plans-grid">
        {% for plan in memberships %}
        <div class="plan-card">
            <h3>{{ plan.plan_name }}</h3>
            <p>Price: ${{ plan.price }} / {{ plan.billing_cycle }}</p>
            <p>Features: {{ plan.features }}</p>
            <button id="view-details-button-{{ plan.membership_id }}" onclick="location.href='{{ url_for('plan_details', plan_id=plan.membership_id) }}'">View Details</button>
        </div>
        {% endfor %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
<script>
function filterPlans() {
    var filter = document.getElementById('plan-filter').value;
    var url = '{{ url_for("memberships") }}';
    if(filter) {
        url += '?filter=' + filter;
    }
    window.location.href = url;
}
</script>
</body>
</html>
