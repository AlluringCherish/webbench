'''
Dashboard page template for OnlineCourse.
Displays welcome message and enrolled courses.
Includes buttons to navigate to course catalog and my courses.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Learning Dashboard</title>
</head>
<body>
<div id="dashboard-page">
    <h1 id="welcome-message">Welcome, {{ fullname }}!</h1>
    <div id="enrolled-courses">
        <h2>Your Enrolled Courses</h2>
        {% if enrolled_courses %}
            <ul>
                {% for course in enrolled_courses %}
                    <li>
                        {{ course.title }} - Progress: {{ course.progress }}% - Status: {{ course.status }}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>You are not enrolled in any courses yet.</p>
        {% endif %}
    </div>
    <button id="browse-courses-button" onclick="location.href='{{ url_for('course_catalog') }}'">Browse Courses</button>
    <button id="my-courses-button" onclick="location.href='{{ url_for('my_courses') }}'">My Courses</button>
</div>
