        self.assertIn('id="browse-courses-button"', html)
        self.assertIn('/catalog', html)
        # Test if my courses button links to /my-courses
        self.assertIn('id="my-courses-button"', html)
        self.assertIn('/my-courses', html)
if __name__ == '__main__':
    unittest.main()

