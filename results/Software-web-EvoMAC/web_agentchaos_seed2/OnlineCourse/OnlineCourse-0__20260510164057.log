templates/catalog.html
```html
'''
Course Catalog page template for OnlineCourse.
Displays all active courses with search input.
Includes buttons to view course details and back to dashboard.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Available Courses</title>
</head>
<body>
<div id="catalog-page">
    <h1>Available Courses</h1>
    <input type="text" id="search-input" placeholder="Search courses..." onkeyup="filterCourses()">
    <div id="course-grid">
        {% for course_id, course in courses.items() %}
            <div class="course-card">
                <h3>{{ course.title }}</h3>
                <p>{{ course.description }}</p>
                <button id="view-course-button-{{ course_id }}" onclick="location.href='{{ url_for('course_details', course_id=course_id) }}'">View Details</button>
            </div>
        {% endfor %}
    </div>
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
<script>
function filterCourses() {
    let input = document.getElementById('search-input').value.toLowerCase();
    let cards = document.querySelectorAll('.course-card');
    cards.forEach(card => {
        let title = card.querySelector('h3').textContent.toLowerCase();
        if (title.includes(input)) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });
}
</script>
</body>
</html>
```

