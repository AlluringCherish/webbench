import unittest
from main import app
class TestDashboardPage(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()
    def test_dashboard_accessible(self):
        # Test if root URL '/' is accessible (Dashboard page)
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
    def test_dashboard_page_elements(self):
        # Test if Dashboard page contains required elements by IDs
        response = self.client.get('/')
        html = response.get_data(as_text=True)
        # Check container div
        self.assertIn('id="dashboard-page"', html)
        # Check welcome message h1
        self.assertIn('id="welcome-message"', html)
        # Check enrolled courses div
        self.assertIn('id="enrolled-courses"', html)
        # Check browse courses button
        self.assertIn('id="browse-courses-button"', html)
        # Check my courses button
        self.assertIn('id="my-courses-button"', html)
    def test_dashboard_welcome_message_content(self):
        # Test if welcome message contains the user's full name (from example data john -> John Student)
        response = self.client.get('/')
        html = response.get_data(as_text=True)
        self.assertIn('John Student', html)
    def test_dashboard_navigation_buttons_functionality(self):
        # Test if browse courses button links to /catalog
        response = self.client.get('/')
