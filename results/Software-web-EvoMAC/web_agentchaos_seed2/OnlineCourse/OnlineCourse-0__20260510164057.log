templates/course_learning.html
```html
'''
Course Learning page template for OnlineCourse.
Shows lessons list, current lesson content, progress, and mark complete button.
Includes back to my courses button.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Course Learning</title>
</head>
<body>
<div id="learning-page">
    <h1>{{ course.title }}</h1>
    <div id="lessons-list">
        <h2>Lessons</h2>
        <ol>
            {% for idx, lesson in enumerate(lessons) %}
                <li {% if idx == current_lesson_index %}style="font-weight:bold;"{% endif %}>
                    {{ lesson }}
                </li>
            {% endfor %}
        </ol>
    </div>
    <div id="lesson-content">
        <h3>Current Lesson</h3>
        <p>{{ current_lesson }}</p>
    </div>
    {% if progress < 100 %}
        <form method="post" action="{{ url_for('mark_complete', course_id=course_id) }}">
            <button id="mark-complete-button" type="submit">Mark Complete</button>
        </form>
    {% else %}
        <p>Course Completed!</p>
    {% endif %}
    <button id="back-to-my-courses" onclick="location.href='{{ url_for('my_courses') }}'">Back to My Courses</button>
</div>
</body>
</html>
```

templates/assignments.html
```html
'''
My Assignments page template for OnlineCourse.
Displays assignments table with submit buttons for pending assignments.
Includes back to dashboard button.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Assignments</title>
</head>
<body>
<div id="assignments-page">
    <h1>My Assignments</h1>
    {% if assignments %}
        <table id="assignments-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Max Points</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for assignment in assignments %}
                    <tr>
                        <td>{{ assignment.title }}</td>
                        <td>{{ assignment.description }}</td>
                        <td>{{ assignment.due_date }}</td>
                        <td>{{ assignment.max_points }}</td>
                        <td>
                            {% if submissions.get(assignment.assignment_id) %}
                                Submitted
                            {% else %}
                                Pending
                            {% endif %}
                        </td>
                        <td>
                            {% if not submissions.get(assignment.assignment_id) %}
                                <button id="submit-assignment-button-{{ assignment.assignment_id }}" onclick="location.href='{{ url_for('submit_assignment', assignment_id=assignment.assignment_id) }}'">Submit</button>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No assignments available.</p>
    {% endif %}
    <button id="back-to-dashboard" onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
</div>
</body>
</html>
```

