            with self.subTest(url=url):
                response = self.client.get(url)
                self.assertEqual(response.status_code, 200, f"Page {url} should be accessible with status 200")
    def test_04_dashboard_saved_locations_buttons(self):
        # Test that saved locations buttons exist and have correct IDs and link to current weather page
        response = self.client.get('/')
