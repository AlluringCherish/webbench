    def test_02_dashboard_elements(self):
        # Test Task 2 & 3: Check dashboard page elements and content correctness
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')
        # Check container div with id dashboard-page
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container div with id 'dashboard-page' must be present")
        # Check current weather summary div
        current_weather_div = dashboard_div.find('div', id='current-weather-summary')
        self.assertIsNotNone(current_weather_div, "Current weather summary div with id 'current-weather-summary' must be present")
        # Check that at least location name and temperature are displayed if data present
        h2 = current_weather_div.find('h2')
        self.assertIsNotNone(h2, "Current weather summary should display location name in h2")
        temp_p = current_weather_div.find('p', string=lambda text: text and 'Temperature:' in text)
        self.assertIsNotNone(temp_p, "Current weather summary should display temperature")
        # Check quick access saved locations section
        quick_access_div = dashboard_div.find('div', id='quick-access')
        self.assertIsNotNone(quick_access_div, "Quick access div with id 'quick-access' must be present")
        h3 = quick_access_div.find('h3')
        self.assertIsNotNone(h3, "Quick access section should have a heading")
        self.assertIn('Saved Locations', h3.text)
        # Check navigation buttons presence and their IDs
        nav_div = dashboard_div.find('div', id='navigation-buttons')
        self.assertIsNotNone(nav_div, "Navigation buttons div with id 'navigation-buttons' must be present")
        expected_button_ids = [
            'search-location-button',
            'view-forecast-button',
            'view-alerts-button',
            'air-quality-button',
            'saved-locations-button',
            'settings-button'
        ]
        for btn_id in expected_button_ids:
            btn = nav_div.find('button', id=btn_id)
            self.assertIsNotNone(btn, f"Navigation button with id '{btn_id}' must be present")
    def test_03_basic_navigation_links(self):
        # Test that navigation buttons on dashboard redirect to correct pages
        # We test GET requests to those URLs to confirm pages load with status 200
        urls = [
            '/location_search',
            '/weekly_forecast',
            '/weather_alerts',
            '/air_quality',
            '/saved_locations',
            '/settings'
