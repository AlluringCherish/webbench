            color: #f39c12;
            font-weight: bold;
        }
    </style>
</head>
<body>
<div id="reviews-page">
    <h1>My Reviews</h1>
    <div id="reviews-list">
        {% if reviews %}
            {% for review in reviews %}
            <div class="review-item">
                <h3>{{ review.dish_name }}</h3>
                <div class="review-rating">Rating: {{ review.rating }} / 5</div>
                <p>{{ review.review_text }}</p>
                <small>Reviewed on: {{ review.review_date }}</small>
            </div>
            {% endfor %}
        {% else %}
            <p>You have not written any reviews yet.</p>
        {% endif %}
