    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
    <style>
        #reviews-list {
            margin-top: 20px;
        }
        .review-item {
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 5px;
        }
