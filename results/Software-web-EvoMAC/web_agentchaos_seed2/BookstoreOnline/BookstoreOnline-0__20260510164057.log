<body>
<div id="book-details-page">
    <h1 id="book-title">{{ book.title }}</h1>
    <div id="book-author"><strong>Author:</strong> {{ book.author }}</div>
    <div id="book-price"><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</div>
    <div id="book-description"><strong>Description:</strong> {{ book.description }}</div>
    <form method="post" action="{{ url_for('book_details', book_id=book.book_id) }}">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" value="1" min="1" max="{{ book.stock }}">
        <button type="submit" id="add-to-cart-button">Add to Cart</button>
    </form>
    <section id="book-reviews">
        <h2>Customer Reviews</h2>
        {% if reviews %}
            <ul>
                {% for review in reviews %}
                <li>
                    <strong>{{ review.customer_name }}</strong> ({{ review.review_date }}) - Rating: {{ review.rating }} / 5
                    <p>{{ review.review_text }}</p>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No reviews yet for this book.</p>
        {% endif %}
    </section>
    <nav class="book-details-nav">
        <button onclick="location.href='{{ url_for('catalog') }}'">Back to Catalog</button>
        <button onclick="location.href='{{ url_for('cart') }}'">View Cart</button>
        <button onclick="location.href='{{ url_for('write_review') }}'">Write a Review</button>
    </nav>
</div>
</body>
</html>
```

cart.html
```html
'''
Shopping Cart page for BookstoreOnline web application.
Displays items in the cart with quantity management and checkout option.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="cart-page">
    <h1>Shopping Cart</h1>
    {% if cart_items %}
    <form method="post" action="{{ url_for('cart') }}">
        <table id="cart-items-table" border="1" cellpadding="5" cellspacing="0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                    <th>Remove</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart_items %}
                <tr>
                    <td>{{ item.title }}</td>
                    <td>
                        <input type="number" id="update-quantity-{{ item.cart_id }}" name="update-quantity-{{ item.cart_id }}" value="{{ item.quantity }}" min="1" max="{{ item.stock }}">
                    </td>
                    <td>${{ "%.2f"|format(item.price) }}</td>
                    <td>${{ "%.2f"|format(item.subtotal) }}</td>
                    <td>
                        <input type="checkbox" name="remove" value="{{ item.cart_id }}" id="remove-item-button-{{ item.cart_id }}">
                        <label for="remove-item-button-{{ item.cart_id }}">Remove</label>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div id="total-amount">
            <strong>Total Amount:</strong> ${{ "%.2f"|format(total_amount) }}
        </div>
        <div class="cart-actions">
            <button type="submit" name="update-cart">Update Cart</button>
            <button type="submit" name="proceed-checkout" id="proceed-checkout-button">Proceed to Checkout</button>
        </div>
    </form>
    {% else %}
    <p>Your shopping cart is empty.</p>
    {% endif %}
    <nav class="cart-nav">
        <button onclick="location.href='{{ url_for('catalog') }}'">Back to Catalog</button>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </nav>
</div>
</body>
</html>
