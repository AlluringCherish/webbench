'''
Book Catalog page for BookstoreOnline web application.
Displays all available books with search and category filter.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Catalog</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}">
</head>
<body>
<div id="catalog-page">
    <h1>Book Catalog</h1>
    <form method="get" action="{{ url_for('catalog') }}">
        <input type="text" id="search-input" name="search" placeholder="Search by title, author, or ISBN" value="{{ search_query }}">
        <select id="category-filter" name="category">
            <option value="All" {% if category_filter == 'All' or not category_filter %}selected{% endif %}>All Categories</option>
            {% for category in categories %}
            <option value="{{ category.category_name }}" {% if category_filter == category.category_name %}selected{% endif %}>{{ category.category_name }}</option>
            {% endfor %}
        </select>
        <button type="submit">Search</button>
    </form>
    <div id="books-grid" class="books-grid">
        {% if books %}
            {% for book in books %}
            <div class="book-card">
                <h3>{{ book.title }}</h3>
                <p><strong>Author:</strong> {{ book.author }}</p>
                <p><strong>Price:</strong> ${{ "%.2f"|format(book.price) }}</p>
                <a href="{{ url_for('book_details', book_id=book.book_id) }}">
                    <button id="view-book-button-{{ book.book_id }}">View Details</button>
                </a>
            </div>
            {% endfor %}
        {% else %}
            <p>No books found matching your criteria.</p>
        {% endif %}
    </div>
    <nav class="catalog-nav">
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
        <button onclick="location.href='{{ url_for('cart') }}'">View Cart</button>
    </nav>
</div>
</body>
</html>
