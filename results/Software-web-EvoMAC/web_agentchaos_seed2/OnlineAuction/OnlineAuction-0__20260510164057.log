'''
Testing Task 1: Test whether the website can be accessed through local port 5000.
Testing Task 2: Test whether the first page (Dashboard) of the website loads correctly and basic navigation buttons exist and are functional.
Testing Task 3: Test the presence and correctness of all specified elements on the Dashboard page as per the requirements.
'''

import unittest
from threading import Thread
import time
import requests
from bs4 import BeautifulSoup

# Assuming the web app is implemented in a file named app.py with a Flask app named 'app'
# We will import and run it in a separate thread for testing
import app

class TestOnlineAuctionDashboard(unittest.TestCase):
    @classmethod
    def setUpClass(cls):
        # Start the Flask app in a separate thread
        cls.server_thread = Thread(target=app.app.run, kwargs={'port':5000, 'debug':False, 'use_reloader':False})
        cls.server_thread.daemon = True
        cls.server_thread.start()
        # Wait a bit for the server to start
        time.sleep(1)

    @classmethod
    def tearDownClass(cls):
        # Flask does not provide a direct way to stop the server programmatically
        # So we rely on daemon thread exit when tests finish
        pass

    def test_01_access_localhost_5000(self):
        """Test Task 1: Access the website on localhost:5000 and check status code"""
        try:
            response = requests.get('http://127.0.0.1:5000/')
            self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")
        except requests.exceptions.ConnectionError:
            self.fail("Could not connect to the server on port 5000")

    def test_02_dashboard_page_elements(self):
        """Test Task 2 & 3: Check Dashboard page elements and navigation buttons"""
        response = requests.get('http://127.0.0.1:5000/')
        self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")

        soup = BeautifulSoup(response.text, 'html.parser')

        # Check container div with id 'dashboard-page'
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' not found")

        # Check featured auctions div
        featured_div = dashboard_div.find('div', id='featured-auctions')
        self.assertIsNotNone(featured_div, "Featured auctions div with id 'featured-auctions' not found")

        # Check browse auctions button
        browse_button = dashboard_div.find('button', id='browse-auctions-button')
        self.assertIsNotNone(browse_button, "Browse auctions button with id 'browse-auctions-button' not found")

        # Check view bids button
        view_bids_button = dashboard_div.find('button', id='view-bids-button')
        self.assertIsNotNone(view_bids_button, "View bids button with id 'view-bids-button' not found")

        # Check trending auctions button
        trending_button = dashboard_div.find('button', id='trending-auctions-button')
        self.assertIsNotNone(trending_button, "Trending auctions button with id 'trending-auctions-button' not found")

    def test_03_dashboard_navigation_buttons_functionality(self):
        """Test Task 2: Check that navigation buttons link to correct pages"""
        response = requests.get('http://127.0.0.1:5000/')
        self.assertEqual(response.status_code, 200, "Dashboard page did not load successfully")

        soup = BeautifulSoup(response.text, 'html.parser')
        dashboard_div = soup.find('div', id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard container div with id 'dashboard-page' not found")

        # We expect buttons to have onclick or form action or href to navigate
        # Check browse auctions button navigates to /catalog or similar
        browse_button = dashboard_div.find('button', id='browse-auctions-button')
        self.assertIsNotNone(browse_button)
        # Check if button has onclick attribute or form action or is inside a form
        browse_onclick = browse_button.get('onclick')
        self.assertTrue(browse_onclick or browse_button.parent.name == 'a' or browse_button.parent.name == 'form',
                        "Browse auctions button does not have navigation action")

        # Check view bids button navigation
        view_bids_button = dashboard_div.find('button', id='view-bids-button')
        self.assertIsNotNone(view_bids_button)
        view_bids_onclick = view_bids_button.get('onclick')
        self.assertTrue(view_bids_onclick or view_bids_button.parent.name == 'a' or view_bids_button.parent.name == 'form',
                        "View bids button does not have navigation action")

        # Check trending auctions button navigation
        trending_button = dashboard_div.find('button', id='trending-auctions-button')
        self.assertIsNotNone(trending_button)
        trending_onclick = trending_button.get('onclick')
        self.assertTrue(trending_onclick or trending_button.parent.name == 'a' or trending_button.parent.name == 'form',
                        "Trending auctions button does not have navigation action")

if __name__ == '__main__':
    unittest.main()
