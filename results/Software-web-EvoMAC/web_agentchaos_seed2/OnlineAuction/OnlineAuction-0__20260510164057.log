'''
Dashboard page template for OnlineAuction.
Displays featured auctions and trending auctions.
Includes navigation buttons with URLs matching backend routes.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Dashboard</title>
</head>
<body>
    <div id="dashboard-page">
        <h1>Auction Dashboard</h1>
        <div id="featured-auctions">
            <h2>Featured Auctions</h2>
            <ul>
                {% for auction in featured_auctions %}
                <li>
                    <img src="{{ url_for('static', filename=auction.image_url) }}" alt="{{ auction.item_name }}" width="100">
                    <strong>{{ auction.item_name }}</strong> - Current Bid: ${{ '%.2f'|format(auction.current_bid) }}
                    <br>
                    <a href="{{ url_for('auction_details', auction_id=auction.auction_id) }}">View Details</a>
                </li>
                {% else %}
                <li>No featured auctions available.</li>
                {% endfor %}
            </ul>
        </div>
        <div id="trending-auctions">
            <h2>Trending Auctions</h2>
            <ul>
                {% for item in trending_auctions %}
                <li>
                    <strong>{{ item.item_name }}</strong> - Current Bid: ${{ '%.2f'|format(item.current_bid) }} - Bids: {{ item.bid_count }}
                    <br>
                    <a href="{{ url_for('auction_details', auction_id=item.auction_id) }}">View Details</a>
                </li>
                {% else %}
                <li>No trending auctions available.</li>
                {% endfor %}
            </ul>
        </div>
        <button id="browse-auctions-button" onclick="location.href='{{ url_for('catalog') }}'">Browse Auctions</button>
        <button id="view-bids-button" onclick="location.href='{{ url_for('bid_history') }}'">View Bid History</button>
        <button id="trending-auctions-button" onclick="location.href='{{ url_for('trending') }}'">Trending Auctions</button>
    </div>
</body>
</html>
