'''
Auction Catalog page template.
Displays auctions with search and category filter.
Navigation buttons use backend route URLs.
'''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Auction Catalog</title>
</head>
<body>
    <div id="catalog-page">
        <h1>Auction Catalog</h1>
        <form method="get" action="{{ url_for('catalog') }}">
            <input id="search-input" type="text" name="search" placeholder="Search auctions..." value="{{ search_query }}">
            <select id="category-filter" name="category">
                <option value="">All Categories</option>
                {% for category in categories %}
                <option value="{{ category }}" {% if category == selected_category %}selected{% endif %}>{{ category }}</option>
                {% endfor %}
            </select>
            <button type="submit">Search</button>
        </form>
        <div id="auctions-grid">
            {% if auctions %}
            <ul>
                {% for auction in auctions %}
                <li>
                    <img src="{{ url_for('static', filename=auction.image_url) }}" alt="{{ auction.item_name }}" width="100">
                    <h3>{{ auction.item_name }}</h3>
                    <p>Current Bid: ${{ '%.2f'|format(auction.current_bid) }}</p>
                    <p>Time Remaining: {{ auction.end_time }}</p>
                    <button id="view-auction-button-{{ auction.auction_id }}" onclick="location.href='{{ url_for('auction_details', auction_id=auction.auction_id) }}'">View Details</button>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p>No auctions found.</p>
            {% endif %}
        </div>
        <button onclick="location.href='{{ url_for('dashboard') }}'">Back to Dashboard</button>
    </div>
</body>
</html>
