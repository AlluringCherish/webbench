- For admin user: Add Pet, Admin Panel buttons
- Featured pets display correct pet name, species, and age
'''

import unittest
from main import app
from bs4 import BeautifulSoup

class PetAdoptionCenterDashboardTest(unittest.TestCase):
    def setUp(self):
        # Set up test client
        app.config['TESTING'] = True
        self.client = app.test_client()

    def test_dashboard_accessible(self):
        # Test that the dashboard page is accessible at '/'
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)

    def test_dashboard_elements_logged_out(self):
        # Test dashboard page elements when not logged in
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check dashboard-page div exists
        dashboard_div = soup.find(id='dashboard-page')
        self.assertIsNotNone(dashboard_div, "Dashboard page container missing")

        # Check featured-pets div exists
        featured_div = soup.find(id='featured-pets')
        self.assertIsNotNone(featured_div, "Featured pets container missing")

        # Check browse-pets-button and back-to-dashboard buttons exist
        browse_btn = soup.find(id='browse-pets-button')
        self.assertIsNotNone(browse_btn, "Browse Pets button missing")
        back_btn = soup.find(id='back-to-dashboard')
        self.assertIsNotNone(back_btn, "Back to Dashboard button missing")

        # Check Login button present (since logged out)
        login_btn = soup.find('button', string='Login')
        self.assertIsNotNone(login_btn, "Login button missing for logged out user")

        # Check that user-specific buttons are not present
        favorites_btn = soup.find('button', string='My Favorites')
        self.assertIsNone(favorites_btn, "My Favorites button should not be visible when logged out")

    def test_dashboard_elements_logged_in_user(self):
        # Log in as normal user 'john_doe'
        with self.client.session_transaction() as sess:
            sess['username'] = 'john_doe'

        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check user-specific buttons present
        self.assertIsNotNone(soup.find('button', string='My Favorites'), "My Favorites button missing for logged in user")
        self.assertIsNotNone(soup.find('button', string='My Applications'), "My Applications button missing for logged in user")
        self.assertIsNotNone(soup.find('button', string='Messages'), "Messages button missing for logged in user")
        self.assertIsNotNone(soup.find('button', string='My Profile'), "My Profile button missing for logged in user")
        self.assertIsNotNone(soup.find('button', string='Logout'), "Logout button missing for logged in user")

        # Admin buttons should NOT be present for normal user
        self.assertIsNone(soup.find('button', string='Add Pet'), "Add Pet button should not be visible for normal user")
        self.assertIsNone(soup.find('button', string='Admin Panel'), "Admin Panel button should not be visible for normal user")

    def test_dashboard_elements_logged_in_admin(self):
        # Log in as admin user 'admin_user'
        with self.client.session_transaction() as sess:
            sess['username'] = 'admin_user'

        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        # Check admin buttons present
        self.assertIsNotNone(soup.find('button', string='Add Pet'), "Add Pet button missing for admin user")
        self.assertIsNotNone(soup.find('button', string='Admin Panel'), "Admin Panel button missing for admin user")

    def test_featured_pets_limit_and_content(self):
        # Access dashboard and check featured pets count and content
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        soup = BeautifulSoup(response.data, 'html.parser')

        featured_div = soup.find(id='featured-pets')
        self.assertIsNotNone(featured_div, "Featured pets container missing")

        pet_cards = featured_div.find_all(class_='pet-card')
        # Should be at most 5 featured pets
        self.assertLessEqual(len(pet_cards), 5, "More than 5 featured pets displayed")

        for card in pet_cards:
            # Check pet-name, pet-species, pet-age elements inside each card
            pet_name = card.find(class_='pet-name')
            pet_species = card.find(class_='pet-species')
            pet_age = card.find(class_='pet-age')
            self.assertIsNotNone(pet_name, "Pet name missing in pet card")
            self.assertIsNotNone(pet_species, "Pet species missing in pet card")
            self.assertIsNotNone(pet_age, "Pet age missing in pet card")

            # Check that text is not empty
            self.assertTrue(pet_name.text.strip(), "Pet name is empty")
            self.assertTrue(pet_species.text.strip(), "Pet species is empty")
            self.assertTrue(pet_age.text.strip(), "Pet age is empty")

if __name__ == '__main__':
    unittest.main()
