<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Job Listings</title>
</head>
<body>
    <div id="listings-page">
        <h1>Job Listings</h1>
        <input id="search-input" type="text" placeholder="Search jobs by title, company or location">
        <select id="category-filter">
            <option value="">All Categories</option>
            {% for category in categories %}
            <option value="{{ category }}">{{ category }}</option>
            {% endfor %}
        </select>
        <select id="location-filter">
            <option value="">All Locations</option>
            {% for location in locations %}
            <option value="{{ location }}">{{ location }}</option>
            {% endfor %}
        </select>
        <div id="jobs-grid">
            {% for job in jobs %}
            <div class="job-card">
                <h3>{{ job.title }}</h3>
                <p>Company: {{ job.company_name }}</p>
                <p>Location: {{ job.location }}</p>
                <p>Salary: {{ job.salary_min }} - {{ job.salary_max }}</p>
                <p>Category: {{ job.category }}</p>
                <a href="{{ url_for('job_detail', job_id=job.job_id) }}">
                    <button id="view-job-button-{{ job.job_id }}">View Details</button>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
</body>
</html>