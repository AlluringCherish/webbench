<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Submit Application</title>
</head>
<body>
    <div id="application-form-page">
        <h1>Submit Application</h1>
        <form method="GET" enctype="multipart/form-data">
            <label for="applicant-name">Name:</label>
            <input id="applicant-name" name="applicant_name" type="text" required>
            <br>
            <label for="applicant-email">Email:</label>
            <input id="applicant-email" name="applicant_email" type="email" required>
            <br>
            <label for="resume-upload">Upload Resume:</label>
            <input id="resume-upload" name="resume_file" type="file" required>
            <br>
            <label for="cover-letter">Cover Letter:</label>
            <textarea id="cover-letter" name="cover_letter" required></textarea>
            <br>
            <button id="submit-application-button" type="submit">Submit Application</button>
        </form>
    </div>
</body>
</html>