<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Company Directory</title>
</head>
<body>
    <div id="companies-page">
        <h1>Company Directory</h1>
        <input id="search-company-input" type="text" placeholder="Search companies by name or industry">
        <div id="companies-list">
            {% for company in companies %}
            <div class="company-card">
                <h3>{{ company.company_name }}</h3>
                <p>Industry: {{ company.industry }}</p>
                <p>Employees: {{ company.employee_count }}</p>
                <a href="{{ url_for('company_profie', company_id=company.company_id) }}">
                    <button id="view-company-button-{{ company.company_id }}">View Profile</button>
                </a>
            </div>
            {% endfor %}
        </div>
        <a href="{{ url_for('dashboard') }}">
            <button id="back-to-dashboard">Back to Dashboard</button>
        </a>
    </div>
</body>
</html>