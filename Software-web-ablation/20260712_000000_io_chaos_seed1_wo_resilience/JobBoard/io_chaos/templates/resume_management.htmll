<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Resumes</title>
</head>
<body>
    <div id="resume-page">
        <h1>My Resumes</h1>
        <div id="resumes-list">
            {% for resume in resumes %}
            <div class="resume-item">
                <p>Name: {{ resume.applicant_name }}</p>
                <p>Email: {{ resume.applicant_email }}</p>
                <p>File: {{ resume.filename }}</p>
                <p>Uploaded: {{ resume.upload_date }}</p>
                <p>Summary: {{ resume.summary }}</p>
                <form method="POST" action="/resume/delete/{{ resume.resume_id }}">
                    <button id="delete-resume-button-{{ resume.resume_id }}" type="submit">Delete</button>
                </form>
            </div>
            {% endfor %}
        </div>
        <form id="upload-resume-form" method="GET" enctype="multipart/form-data">
            <input id="resume-file-input" name="resume_file" type="file" style="display:none;" onchange="this.form.submit()">
            <button id="upload-resume-button" type="button" onclick="document.getElementById('resume-file-input').click();">Upload Resume</button>
        </form>
        <a href="{{ url_for('dashboard') }}">
            <button id="back-to-dashboard">Back to Dashboard</button>
        </a>
    </div>
</body>
</html>